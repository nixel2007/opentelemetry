// BSLLS:MagicNumber-off
#Использовать ".."
#Использовать asserts

&Тест
Процедура СозданиеРесурса() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();

    // Тогда — дефолтные атрибуты присутствуют
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("unknown_service:oscript");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("telemetry.sdk.name")).Равно("opentelemetry");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("telemetry.sdk.version")).Равно("0.1.0");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("telemetry.sdk.language")).Равно("oscript");

    // Когда — пользователь переопределяет service.name
    Ресурс.Атрибуты().Установить("service.name", "test-service");

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("test-service");

КонецПроцедуры

&Тест
Процедура СозданиеРесурсаБезУмолчаний() Экспорт

    // Дано / Когда
    Ресурс = Новый ОтелРесурс(Истина);

    // Тогда — нет дефолтных атрибутов
    Ожидаем.Что(Ресурс.Атрибуты().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура СлияниеРесурсов() Экспорт

    // Дано
    Ресурс1 = Новый ОтелРесурс();
    Ресурс1.Атрибуты().Установить("service.name", "service-1");
    Ресурс1.Атрибуты().Установить("host.name", "host-1");

    Ресурс2 = Новый ОтелРесурс();
    Ресурс2.Атрибуты().Установить("service.name", "service-2");
    Ресурс2.Атрибуты().Установить("service.version", "2.0");

    // Когда
    Результат = Ресурс1.Слить(Ресурс2);

    // Тогда
    Ожидаем.Что(Результат.Атрибуты().Получить("service.name")).Равно("service-2");
    Ожидаем.Что(Результат.Атрибуты().Получить("host.name")).Равно("host-1");
    Ожидаем.Что(Результат.Атрибуты().Получить("service.version")).Равно("2.0");

КонецПроцедуры

&Тест
Процедура ПреобразованиеРесурсаВOtlp() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "test-service");

    // Когда
    Результат = Ресурс.ВСоответствиеOtlp();

    // Тогда
    Ожидаем.Что(Результат).ИмеетТип("Соответствие");
    Ожидаем.Что(Результат.Получить("attributes")).ИмеетТип("Массив");

КонецПроцедуры
