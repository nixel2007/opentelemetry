// BSLLS:MagicNumber-off
// Интеграционные тесты логирования с LGTM-стеком.
// Запускают контейнер grafana/otel-lgtm через testcontainers.
// Проверяют отправку и чтение логов через OTLP HTTP, верифицируя содержимое через API Loki.
#Использовать "../.."
#Использовать asserts
#Использовать 1connector
#Использовать testcontainers

Перем Контейнер;
Перем ПортOtlpHttp;
Перем ПортTempo;
Перем ПортLoki;
Перем ПортPrometheus;
Перем мКонтейнерЗапущен;
Перем мВсегоТестов;
Перем мВыполненоТестов;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
    мКонтейнерЗапущен = Ложь;
    мВсегоТестов = 3;
    мВыполненоТестов = 0;
КонецПроцедуры

&ПередКаждым
Процедура ПередКаждым() Экспорт
    Если НЕ мКонтейнерЗапущен Тогда
        ЗапуститьКонтейнер();
        мКонтейнерЗапущен = Истина;
    КонецЕсли;
КонецПроцедуры

&ПослеКаждого
Процедура ПослеКаждого() Экспорт
    мВыполненоТестов = мВыполненоТестов + 1;
    Если мВыполненоТестов >= мВсегоТестов Тогда
        Контейнер.Остановить();
    КонецЕсли;
КонецПроцедуры

Процедура ЗапуститьКонтейнер()
    Контейнер = Новый ОбщийКонтейнер("grafana/otel-lgtm")
        .ОткрытьПорт(4318)
        .ОткрытьПорт(3200)
        .ОткрытьПорт(3100)
        .ОткрытьПорт(9090);
    Контейнер.Запустить();

    ПортOtlpHttp = Контейнер.ПолучитьОткрытыйПорт(4318);
    ПортTempo = Контейнер.ПолучитьОткрытыйПорт(3200);
    ПортLoki = Контейнер.ПолучитьОткрытыйПорт(3100);
    ПортPrometheus = Контейнер.ПолучитьОткрытыйПорт(9090);

    ДождатьсяГотовности();
КонецПроцедуры

// ===== ТЕСТЫ =====

&Тест
Процедура ЛогированиеТелоИСерьезность() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "log-body-test");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    Экспортер = Новый ОтелЭкспортерЛогов(Транспорт);
    Процессор = Новый ОтелПростойПроцессорЛогов(Экспортер);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, Процессор);
    Логгер = Провайдер.ПолучитьЛоггер("test-logger", "1.0.0");

    // Когда - отправляем лог с уникальным телом
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("Уникальное тестовое сообщение ABC123")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Warn());
    Логгер.Записать(Запись);

    // Тогда - читаем из Loki и проверяем содержимое
    Результат = ПолучитьЛогиИзLoki("log-body-test");

    Ожидаем.Что(Результат.Количество() > 0).Равно(Истина);

    ПервыйПоток = Результат[0];
    Метки = ПервыйПоток.stream;

    // Проверяем метки потока
    Ожидаем.Что(Метки.service_name).Равно("log-body-test");
    Ожидаем.Что(Метки.severity_text).Равно("WARN");
    Ожидаем.Что(Метки.scope_name).Равно("test-logger");

    // Проверяем тело лога
    Значения = ПервыйПоток.values;
    Ожидаем.Что(Значения.Количество() > 0).Равно(Истина);
    ТелоЛога = Значения[0][1];
    Ожидаем.Что(ТелоЛога).Равно("Уникальное тестовое сообщение ABC123");

КонецПроцедуры

&Тест
Процедура ЛогированиеКорреляцияСТрассировкой() Экспорт

    // Дано - создаём трассировку и лог, связанные через traceId
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "log-trace-corr");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);

    ЭкспортерСпанов = Новый ОтелЭкспортерСпанов(Транспорт);
    ПроцессорСпанов = Новый ОтелПростойПроцессорСпанов(ЭкспортерСпанов);
    ПровайдерТрейсов = Новый ОтелПровайдерТрассировки(Ресурс, ПроцессорСпанов);
    Трассировщик = ПровайдерТрейсов.ПолучитьТрассировщик("test-tracer", "1.0.0");

    ЭкспортерЛогов = Новый ОтелЭкспортерЛогов(Транспорт);
    ПроцессорЛогов = Новый ОтелПростойПроцессорЛогов(ЭкспортерЛогов);
    ПровайдерЛогов = Новый ОтелПровайдерЛогирования(Ресурс, ПроцессорЛогов);
    Логгер = ПровайдерЛогов.ПолучитьЛоггер("test-logger", "1.0.0");

    // Когда - создаём спан и привязываем лог к нему
    Спан = Трассировщик.НачатьСпан("операция-с-логом");
    ИдТрассировки = Спан.КонтекстСпана().ИдТрассировки();

    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("Лог внутри спана")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Info());
    Логгер.Записать(Запись);

    Спан.Завершить();
    ПровайдерТрейсов.Закрыть();

    // Тогда - лог в Loki содержит traceId
    Результат = ПолучитьЛогиИзLoki("log-trace-corr");
    Ожидаем.Что(Результат.Количество() > 0).Равно(Истина);

    // Тело лога соответствует
    ТелоЛога = Результат[0].values[0][1];
    Ожидаем.Что(ТелоЛога).Равно("Лог внутри спана");

    // Спан в Tempo тоже доступен
    ДанныеТрейса = ПолучитьТрассировкуИзTempo(ИдТрассировки);
    СпанДанные = ДанныеТрейса.batches[0].scopeSpans[0].spans[0];
    Ожидаем.Что(СпанДанные.name).Равно("операция-с-логом");

КонецПроцедуры

&Тест
Процедура ЛогированиеАтрибуты() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "log-attrs-test");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    Экспортер = Новый ОтелЭкспортерЛогов(Транспорт);
    Процессор = Новый ОтелПростойПроцессорЛогов(Экспортер);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, Процессор);
    Логгер = Провайдер.ПолучитьЛоггер("test-logger", "1.0.0");

    // Когда - лог с атрибутами
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("лог с атрибутами")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Error())
        .УстановитьАтрибут("user.id", "user-42")
        .УстановитьАтрибут("request.path", "/api/users");
    Логгер.Записать(Запись);

    // Тогда - атрибуты лога попадают в метки потока Loki
    Результат = ПолучитьЛогиИзLoki("log-attrs-test");
    Ожидаем.Что(Результат.Количество() > 0).Равно(Истина);

    Метки = Результат[0].stream;
    Ожидаем.Что(Метки.severity_text).Равно("ERROR");

КонецПроцедуры

// ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====

Функция ПрочитатьОтветJSON(Ответ)
    Тело = Ответ.Текст();
    ЧтениеJSON = Новый ЧтениеJSON();
    ЧтениеJSON.УстановитьСтроку(Тело);
    Возврат ПрочитатьJSON(ЧтениеJSON);
КонецФункции

Функция АтрибутыВСоответствие(МассивАтрибутов)
    Результат = Новый Соответствие();
    Если МассивАтрибутов = Неопределено Тогда
        Возврат Результат;
    КонецЕсли;
    Для Каждого Атр Из МассивАтрибутов Цикл
        Попытка
            Результат.Вставить(Атр.key, Атр.value.stringValue);
        Исключение
            Попытка
                Результат.Вставить(Атр.key, Атр.value.intValue);
            Исключение
                Попытка
                    Результат.Вставить(Атр.key, Атр.value.doubleValue);
                Исключение
                    Попытка
                        Результат.Вставить(Атр.key, Атр.value.boolValue);
                    Исключение
                        Результат.Вставить(Атр.key, "");
                    КонецПопытки;
                КонецПопытки;
            КонецПопытки;
        КонецПопытки;
    КонецЦикла;
    Возврат Результат;
КонецФункции

Функция СобратьВсеСпаны(ДанныеТрассировки)
    ВсеСпаны = Новый Массив();
    Для Каждого Батч Из ДанныеТрассировки.batches Цикл
        Для Каждого СкоупСпан Из Батч.scopeSpans Цикл
            Для Каждого С Из СкоупСпан.spans Цикл
                ВсеСпаны.Добавить(С);
            КонецЦикла;
        КонецЦикла;
    КонецЦикла;
    Возврат ВсеСпаны;
КонецФункции

Функция ПолучитьТрассировкуИзTempo(ИдТрассировки, ОжидаемоеКоличествоСпанов = 1)
    URL = "http://localhost:" + ПортTempo + "/api/traces/" + ИдТрассировки;
    МаксПопыток = 20;
    Для НомерПопытки = 1 По МаксПопыток Цикл
        Попытка
            Ответ = КоннекторHTTP.Get(URL);
            Если Ответ.КодСостояния = 200 Тогда
                Данные = ПрочитатьОтветJSON(Ответ);
                Попытка
                    Если Данные.batches.Количество() > 0 Тогда
                        ВсеСпаны = СобратьВсеСпаны(Данные);
                        Если ВсеСпаны.Количество() >= ОжидаемоеКоличествоСпанов Тогда
                            Возврат Данные;
                        КонецЕсли;
                    КонецЕсли;
                Исключение
                    // Данные ещё не появились
                КонецПопытки;
            КонецЕсли;
        Исключение
            // Сервис ещё не готов
        КонецПопытки;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Трассировка " + ИдТрассировки + " не найдена в Tempo";
КонецФункции

Функция ПолучитьЛогиИзLoki(СервисИмя)
    URL = "http://localhost:" + ПортLoki + "/loki/api/v1/query_range";
    МаксПопыток = 20;
    Для НомерПопытки = 1 По МаксПопыток Цикл
        Попытка
            ПараметрыЗапроса = Новый Структура();
            ПараметрыЗапроса.Вставить("query", "{service_name=""" + СервисИмя + """}");
            ПараметрыЗапроса.Вставить("limit", "100");
            Ответ = КоннекторHTTP.Get(URL, ПараметрыЗапроса);
            Если Ответ.КодСостояния = 200 Тогда
                Данные = ПрочитатьОтветJSON(Ответ);
                Если Данные.data.result.Количество() > 0 Тогда
                    Возврат Данные.data.result;
                КонецЕсли;
            КонецЕсли;
        Исключение
            // Сервис ещё не готов
        КонецПопытки;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Логи для " + СервисИмя + " не найдены в Loki";
КонецФункции

Процедура ДождатьсяГотовности()

    МаксимальноеКоличествоПопыток = 60;
    Для НомерПопытки = 1 По МаксимальноеКоличествоПопыток Цикл
        Попытка
            URLГотовности = "http://localhost:" + ПортOtlpHttp + "/v1/traces";
            Заголовки = Новый Соответствие();
            Заголовки.Вставить("Content-Type", "application/json");
            ДополнительныеПараметры = Новый Структура("Заголовки", Заголовки);
            Ответ = КоннекторHTTP.Post(URLГотовности, "{}", , ДополнительныеПараметры);
            Если Ответ.КодСостояния = 200 Тогда
                Возврат;
            КонецЕсли;
        Исключение
            Приостановить(1000);
        КонецПопытки;
    КонецЦикла;

    ВызватьИсключение "LGTM-стек не готов после " + МаксимальноеКоличествоПопыток + " попыток";

КонецПроцедуры
