// BSLLS:MagicNumber-off
// Интеграционные тесты метрик с LGTM-стеком.
// Запускают контейнер grafana/otel-lgtm через testcontainers.
// Проверяют отправку и чтение метрик через OTLP HTTP и gRPC, верифицируя содержимое через API Prometheus.
#Использовать "../.."
#Использовать asserts
#Использовать 1connector
#Использовать testcontainers

Перем Контейнер;
Перем ПортOtlpHttp;
Перем ПортOtlpGrpc;
Перем ПортTempo;
Перем ПортLoki;
Перем ПортPrometheus;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередВсеми
Процедура ПередВсеми() Экспорт
    ЗапуститьКонтейнер();
КонецПроцедуры

&ПослеВсех
Процедура ПослеВсех() Экспорт
    Контейнер.Остановить();
КонецПроцедуры

Процедура ЗапуститьКонтейнер()
    Контейнер = Новый ОбщийКонтейнер("grafana/otel-lgtm")
        .ОткрытьПорт(4317)
        .ОткрытьПорт(4318)
        .ОткрытьПорт(3200)
        .ОткрытьПорт(3100)
        .ОткрытьПорт(9090);
    Контейнер.Запустить();

    ПортOtlpHttp = Контейнер.ПолучитьОткрытыйПорт(4318);
    ПортOtlpGrpc = Контейнер.ПолучитьОткрытыйПорт(4317);
    ПортTempo = Контейнер.ПолучитьОткрытыйПорт(3200);
    ПортLoki = Контейнер.ПолучитьОткрытыйПорт(3100);
    ПортPrometheus = Контейнер.ПолучитьОткрытыйПорт(9090);

    ДождатьсяГотовности();
КонецПроцедуры

// ===== ТЕСТЫ =====

&ПараметризованныйТест
&ИсточникЗначение("HTTP")
&ИсточникЗначение("gRPC")
Процедура МетрикиСчетчикЗначениеИМетки(ТипТранспорта) Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ИмяСервиса = "metric-counter-svc-" + ТипТранспорта;
    Ресурс.Атрибуты().Установить("service.name", ИмяСервиса);

    Транспорт = СоздатьТранспорт(ТипТранспорта);
    ЭкспортерМетрик = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(ЭкспортерМетрик);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, Читатель);
    Метрика = Провайдер.ПолучитьМетр("test-meter", "1.0.0");

    // Когда - инкрементируем счетчик
    ИмяСчетчика = "integ_http_requests_" + НРег(ТипТранспорта) + "_total";
    Счетчик = Метрика.СоздатьСчетчик(ИмяСчетчика, "HTTP запросы", "1");
    Счетчик.Добавить(10);
    Счетчик.Добавить(5);
    Счетчик.Добавить(3);
    Провайдер.СброситьБуфер();

    // Тогда - в Prometheus значение = 18
    ДанныеМетрики = ПолучитьМетрикуИзPrometheus(ИмяСчетчика);
    Ожидаем.Что(ДанныеМетрики.Количество() > 0).Равно(Истина);

    ПерваяМетрика = ДанныеМетрики[0];
    ЗначениеСтрока = ПерваяМетрика.value[1];
    Ожидаем.Что(Число(ЗначениеСтрока)).Равно(18);

    // Проверяем метки - job/service_name
    Ожидаем.Что(ПерваяМетрика.metric.service_name).Равно(ИмяСервиса);

КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение("HTTP")
&ИсточникЗначение("gRPC")
Процедура МетрикиГистограммаБакеты(ТипТранспорта) Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "metric-histogram-svc-" + ТипТранспорта);

    Транспорт = СоздатьТранспорт(ТипТранспорта);
    ЭкспортерМетрик = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(ЭкспортерМетрик);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, Читатель);
    Метрика = Провайдер.ПолучитьМетр("test-meter", "1.0.0");

    // Когда - записываем значения в гистограмму
    ИмяГистограммы = "integ_request_duration_" + НРег(ТипТранспорта);
    Гистограмма = Метрика.СоздатьГистограмму(ИмяГистограммы, "Длительность", "ms");
    Гистограмма.Записать(50);
    Гистограмма.Записать(150);
    Гистограмма.Записать(300);
    Провайдер.СброситьБуфер();

    // Тогда - в Prometheus есть метрика _count со значением 3
    // OTLP->Prometheus конвертирует unit "ms" в суффикс "_milliseconds"
    ИмяМетрикиCount = ИмяГистограммы + "_milliseconds_count";
    ДанныеМетрики = ПолучитьМетрикуИзPrometheus(ИмяМетрикиCount);
    Ожидаем.Что(ДанныеМетрики.Количество() > 0).Равно(Истина);

    ЗначениеСтрока = ДанныеМетрики[0].value[1];
    Ожидаем.Что(Число(ЗначениеСтрока)).Равно(3);

    // Проверяем _sum
    ИмяМетрикиSum = ИмяГистограммы + "_milliseconds_sum";
    ДанныеСуммы = ПолучитьМетрикуИзPrometheus(ИмяМетрикиSum);
    Ожидаем.Что(ДанныеСуммы.Количество() > 0).Равно(Истина);
    Ожидаем.Что(Число(ДанныеСуммы[0].value[1])).Равно(500);

КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение("HTTP")
&ИсточникЗначение("gRPC")
Процедура МетрикиРеверсивныйСчетчик(ТипТранспорта) Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "metric-updown-svc-" + ТипТранспорта);

    Транспорт = СоздатьТранспорт(ТипТранспорта);
    ЭкспортерМетрик = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(ЭкспортерМетрик);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, Читатель);
    Метрика = Провайдер.ПолучитьМетр("test-meter", "1.0.0");

    // Когда
    ИмяМетрики = "integ_active_connections_" + НРег(ТипТранспорта);
    РевСчетчик = Метрика.СоздатьРеверсивныйСчетчик(ИмяМетрики, "Активные соединения", "1");
    РевСчетчик.Добавить(10);
    РевСчетчик.Добавить(-3);
    Провайдер.СброситьБуфер();

    // Тогда - значение = 7
    ДанныеМетрики = ПолучитьМетрикуИзPrometheus(ИмяМетрики);
    Ожидаем.Что(ДанныеМетрики.Количество() > 0).Равно(Истина);
    Ожидаем.Что(Число(ДанныеМетрики[0].value[1])).Равно(7);

КонецПроцедуры

// ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====

Функция СоздатьТранспорт(ТипТранспорта)
    Если ТипТранспорта = "gRPC" Тогда
        Возврат Новый ОтелGrpcТранспорт("http://localhost:" + ПортOtlpGrpc);
    Иначе
        Возврат Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    КонецЕсли;
КонецФункции

Функция ПрочитатьОтветJSON(Ответ)
    Тело = Ответ.Текст();
    ЧтениеJSON = Новый ЧтениеJSON();
    ЧтениеJSON.УстановитьСтроку(Тело);
    Возврат ПрочитатьJSON(ЧтениеJSON);
КонецФункции

Функция ПолучитьМетрикуИзPrometheus(ИмяМетрики)
    URL = "http://localhost:" + ПортPrometheus + "/api/v1/query";
    МаксПопыток = 20;
    Для НомерПопытки = 1 По МаксПопыток Цикл
        Попытка
            ПараметрыЗапроса = Новый Структура();
            ПараметрыЗапроса.Вставить("query", ИмяМетрики);
            Ответ = КоннекторHTTP.Get(URL, ПараметрыЗапроса);
            Если Ответ.КодСостояния = 200 Тогда
                Данные = ПрочитатьОтветJSON(Ответ);
                Если Данные.data.result.Количество() > 0 Тогда
                    Возврат Данные.data.result;
                КонецЕсли;
            КонецЕсли;
        Исключение
            // Сервис ещё не готов
        КонецПопытки;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Метрика " + ИмяМетрики + " не найдена в Prometheus";
КонецФункции

Процедура ДождатьсяГотовности()

    МаксимальноеКоличествоПопыток = 60;
    Для НомерПопытки = 1 По МаксимальноеКоличествоПопыток Цикл
        Попытка
            URLГотовности = "http://localhost:" + ПортOtlpHttp + "/v1/traces";
            Заголовки = Новый Соответствие();
            Заголовки.Вставить("Content-Type", "application/json");
            ДополнительныеПараметры = Новый Структура("Заголовки", Заголовки);
            Ответ = КоннекторHTTP.Post(URLГотовности, "{}", , ДополнительныеПараметры);
            Если Ответ.КодСостояния = 200 Тогда
                Возврат;
            КонецЕсли;
        Исключение
            Приостановить(1000);
        КонецПопытки;
    КонецЦикла;

    ВызватьИсключение "LGTM-стек не готов после " + МаксимальноеКоличествоПопыток + " попыток";

КонецПроцедуры
