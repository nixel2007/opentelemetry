// BSLLS:MagicNumber-off
// Интеграционные тесты метрик с LGTM-стеком.
// Запускают контейнер grafana/otel-lgtm через testcontainers.
// Проверяют отправку и чтение метрик через OTLP HTTP, верифицируя содержимое через API Prometheus.
#Использовать "../.."
#Использовать asserts
#Использовать 1connector
#Использовать testcontainers

Перем Контейнер;
Перем ПортOtlpHttp;
Перем ПортTempo;
Перем ПортLoki;
Перем ПортPrometheus;
Перем мКонтейнерЗапущен;
Перем мВсегоТестов;
Перем мВыполненоТестов;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
    мКонтейнерЗапущен = Ложь;
    мВсегоТестов = 3;
    мВыполненоТестов = 0;
КонецПроцедуры

&ПередКаждым
Процедура ПередКаждым() Экспорт
    Если НЕ мКонтейнерЗапущен Тогда
        ЗапуститьКонтейнер();
        мКонтейнерЗапущен = Истина;
    КонецЕсли;
КонецПроцедуры

&ПослеКаждого
Процедура ПослеКаждого() Экспорт
    мВыполненоТестов = мВыполненоТестов + 1;
    Если мВыполненоТестов >= мВсегоТестов Тогда
        Контейнер.Остановить();
    КонецЕсли;
КонецПроцедуры

Процедура ЗапуститьКонтейнер()
    Контейнер = Новый ОбщийКонтейнер("grafana/otel-lgtm")
        .ОткрытьПорт(4318)
        .ОткрытьПорт(3200)
        .ОткрытьПорт(3100)
        .ОткрытьПорт(9090);
    Контейнер.Запустить();

    ПортOtlpHttp = Контейнер.ПолучитьОткрытыйПорт(4318);
    ПортTempo = Контейнер.ПолучитьОткрытыйПорт(3200);
    ПортLoki = Контейнер.ПолучитьОткрытыйПорт(3100);
    ПортPrometheus = Контейнер.ПолучитьОткрытыйПорт(9090);

    ДождатьсяГотовности();
КонецПроцедуры

// ===== ТЕСТЫ =====

&Тест
Процедура МетрикиСчетчикЗначениеИМетки() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "metric-counter-svc");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    ЭкспортерМетрик = Новый ОтелЭкспортерМетрик(Транспорт);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, ЭкспортерМетрик);
    Метрика = Провайдер.ПолучитьМетр("test-meter", "1.0.0");

    // Когда — инкрементируем счетчик
    Счетчик = Метрика.СоздатьСчетчик("integ_http_requests_total", "HTTP запросы", "1");
    Счетчик.Добавить(10);
    Счетчик.Добавить(5);
    Счетчик.Добавить(3);
    ЭкспортерМетрик.Экспортировать(Метрика);

    // Тогда — в Prometheus значение = 18
    ДанныеМетрики = ПолучитьМетрикуИзPrometheus("integ_http_requests_total");
    Ожидаем.Что(ДанныеМетрики.Количество() > 0).Равно(Истина);

    ПерваяМетрика = ДанныеМетрики[0];
    ЗначениеСтрока = ПерваяМетрика.value[1];
    Ожидаем.Что(Число(ЗначениеСтрока)).Равно(18);

    // Проверяем метки — job/service_name
    Ожидаем.Что(ПерваяМетрика.metric.service_name).Равно("metric-counter-svc");

КонецПроцедуры

&Тест
Процедура МетрикиГистограммаБакеты() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "metric-histogram-svc");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    ЭкспортерМетрик = Новый ОтелЭкспортерМетрик(Транспорт);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, ЭкспортерМетрик);
    Метрика = Провайдер.ПолучитьМетр("test-meter", "1.0.0");

    // Когда — записываем значения в гистограмму
    Гистограмма = Метрика.СоздатьГистограмму("integ_request_duration", "Длительность", "ms");
    Гистограмма.Записать(50);
    Гистограмма.Записать(150);
    Гистограмма.Записать(300);
    ЭкспортерМетрик.Экспортировать(Метрика);

    // Тогда — в Prometheus есть метрика _count со значением 3
    // OTLP→Prometheus конвертирует unit "ms" в суффикс "_milliseconds"
    ДанныеМетрики = ПолучитьМетрикуИзPrometheus("integ_request_duration_milliseconds_count");
    Ожидаем.Что(ДанныеМетрики.Количество() > 0).Равно(Истина);

    ЗначениеСтрока = ДанныеМетрики[0].value[1];
    Ожидаем.Что(Число(ЗначениеСтрока)).Равно(3);

    // Проверяем _sum
    ДанныеСуммы = ПолучитьМетрикуИзPrometheus("integ_request_duration_milliseconds_sum");
    Ожидаем.Что(ДанныеСуммы.Количество() > 0).Равно(Истина);
    Ожидаем.Что(Число(ДанныеСуммы[0].value[1])).Равно(500);

КонецПроцедуры

&Тест
Процедура МетрикиРеверсивныйСчетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "metric-updown-svc");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    ЭкспортерМетрик = Новый ОтелЭкспортерМетрик(Транспорт);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, ЭкспортерМетрик);
    Метрика = Провайдер.ПолучитьМетр("test-meter", "1.0.0");

    // Когда
    РевСчетчик = Метрика.СоздатьРеверсивныйСчетчик("integ_active_connections", "Активные соединения", "1");
    РевСчетчик.Добавить(10);
    РевСчетчик.Добавить(-3);
    ЭкспортерМетрик.Экспортировать(Метрика);

    // Тогда — значение = 7
    ДанныеМетрики = ПолучитьМетрикуИзPrometheus("integ_active_connections");
    Ожидаем.Что(ДанныеМетрики.Количество() > 0).Равно(Истина);
    Ожидаем.Что(Число(ДанныеМетрики[0].value[1])).Равно(7);

КонецПроцедуры

// ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====

Функция ПрочитатьОтветJSON(Ответ)
    Тело = Ответ.Текст();
    ЧтениеJSON = Новый ЧтениеJSON();
    ЧтениеJSON.УстановитьСтроку(Тело);
    Возврат ПрочитатьJSON(ЧтениеJSON);
КонецФункции

Функция ПолучитьМетрикуИзPrometheus(ИмяМетрики)
    URL = "http://localhost:" + ПортPrometheus + "/api/v1/query";
    МаксПопыток = 20;
    Для НомерПопытки = 1 По МаксПопыток Цикл
        Попытка
            ПараметрыЗапроса = Новый Структура();
            ПараметрыЗапроса.Вставить("query", ИмяМетрики);
            Ответ = КоннекторHTTP.Get(URL, ПараметрыЗапроса);
            Если Ответ.КодСостояния = 200 Тогда
                Данные = ПрочитатьОтветJSON(Ответ);
                Если Данные.data.result.Количество() > 0 Тогда
                    Возврат Данные.data.result;
                КонецЕсли;
            КонецЕсли;
        Исключение
            // Сервис ещё не готов
        КонецПопытки;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Метрика " + ИмяМетрики + " не найдена в Prometheus";
КонецФункции

Процедура ДождатьсяГотовности()

    МаксимальноеКоличествоПопыток = 60;
    Для НомерПопытки = 1 По МаксимальноеКоличествоПопыток Цикл
        Попытка
            URLГотовности = "http://localhost:" + ПортOtlpHttp + "/v1/traces";
            Заголовки = Новый Соответствие();
            Заголовки.Вставить("Content-Type", "application/json");
            ДополнительныеПараметры = Новый Структура("Заголовки", Заголовки);
            Ответ = КоннекторHTTP.Post(URLГотовности, "{}", , ДополнительныеПараметры);
            Если Ответ.КодСостояния = 200 Тогда
                Возврат;
            КонецЕсли;
        Исключение
            Приостановить(1000);
        КонецПопытки;
    КонецЦикла;

    ВызватьИсключение "LGTM-стек не готов после " + МаксимальноеКоличествоПопыток + " попыток";

КонецПроцедуры
