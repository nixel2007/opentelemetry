// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
// BSLLS:DuplicateStringLiteral-off
// Интеграционный тест кросс-сигнальной корреляции с LGTM-стеком.
// Проверяет совместную работу трассировки, логирования и метрик
// с общим ресурсом и корреляцией через traceId.
// Запускается на обоих транспортах: OTLP HTTP и gRPC.
#Использовать "../.."
#Использовать asserts
#Использовать 1connector
#Использовать testcontainers

Перем Контейнер;
Перем ПортOtlpHttp;
Перем ПортOtlpGrpc;
Перем ПортTempo;
Перем ПортLoki;
Перем ПортPrometheus;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередВсеми
Процедура ПередВсеми() Экспорт
    ЗапуститьКонтейнер();
КонецПроцедуры

&ПослеВсех
Процедура ПослеВсех() Экспорт
    Контейнер.Остановить();
КонецПроцедуры

Процедура ЗапуститьКонтейнер()
    Контейнер = Новый ОбщийКонтейнер("grafana/otel-lgtm")
        .ОткрытьПорт(4317)
        .ОткрытьПорт(4318)
        .ОткрытьПорт(3200)
        .ОткрытьПорт(3100)
        .ОткрытьПорт(9090);
    Контейнер.Запустить();

    ПортOtlpHttp = Контейнер.ПолучитьОткрытыйПорт(4318);
    ПортOtlpGrpc = Контейнер.ПолучитьОткрытыйПорт(4317);
    ПортTempo = Контейнер.ПолучитьОткрытыйПорт(3200);
    ПортLoki = Контейнер.ПолучитьОткрытыйПорт(3100);
    ПортPrometheus = Контейнер.ПолучитьОткрытыйПорт(9090);

    ДождатьсяГотовности();
КонецПроцедуры

// ===== ТЕСТЫ =====

&ПараметризованныйТест
&ИсточникЗначение("HTTP")
&ИсточникЗначение("gRPC")
Процедура КроссСигнальнаяКорреляция(ТипТранспорта) Экспорт

    // Дано - общий ресурс для всех трёх сигналов
    Ресурс = Новый ОтелРесурс();
    ИмяСервиса = "cross-signal-svc-" + ТипТранспорта;
    Ресурс.Атрибуты().Установить("service.name", ИмяСервиса);

    Транспорт = СоздатьТранспорт(ТипТранспорта);

    // Трассировка
    ЭкспортерСпанов = Новый ОтелЭкспортерСпанов(Транспорт);
    ПроцессорСпанов = Новый ОтелПростойПроцессорСпанов(ЭкспортерСпанов);
    ПровайдерТрассировки = Новый ОтелПровайдерТрассировки(Ресурс, ПроцессорСпанов);
    Трассировщик = ПровайдерТрассировки.ПолучитьТрассировщик("cross-signal-tracer", "1.0.0");

    // Логирование
    ЭкспортерЛогов = Новый ОтелЭкспортерЛогов(Транспорт);
    ПроцессорЛогов = Новый ОтелПростойПроцессорЛогов(ЭкспортерЛогов);
    ПровайдерЛогов = Новый ОтелПровайдерЛогирования(Ресурс, ПроцессорЛогов);
    Логгер = ПровайдерЛогов.ПолучитьЛоггер("cross-signal-logger", "1.0.0");

    // Метрики
    ЭкспортерМетрик = Новый ОтелЭкспортерМетрик(Транспорт);
    ЧитательМетрик = Новый ОтелПериодическийЧитательМетрик(ЭкспортерМетрик);
    ПровайдерМетрик = Новый ОтелПровайдерМетрик(Ресурс, ЧитательМетрик);
    Метр = ПровайдерМетрик.ПолучитьМетр("cross-signal-meter", "1.0.0");

    Суффикс = НРег(ТипТранспорта);
    ИмяСчетчика = "cross_orders_processed_" + Суффикс + "_total";
    Счетчик = Метр.СоздатьСчетчик(ИмяСчетчика, "Обработанные заказы", "1");
    ИмяГистограммы = "cross_order_processing_duration_" + Суффикс;
    Гистограмма = Метр.СоздатьГистограмму(ИмяГистограммы, "Длительность обработки заказа", "ms");

    // Когда - создаём корневой спан с дочерними, логируем и записываем метрики
    КорневойСпан = Трассировщик.НачатьКорневойСпан("обработка-заказа");
    ИдТрассировки = КорневойСпан.КонтекстСпана().ИдТрассировки();

    // Лог в контексте корневого спана
    ЗаписьКорневая = Логгер.СоздатьЗаписьЛога();
    ЗаписьКорневая.УстановитьТело("Начало обработки заказа")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Info())
        .УстановитьКонтекстТрассировки(
            КорневойСпан.КонтекстСпана().ИдТрассировки(),
            КорневойСпан.КонтекстСпана().ИдСпана());
    Логгер.Записать(ЗаписьКорневая);

    // Дочерний спан - валидация данных
    СпанВалидация = Трассировщик.НачатьДочернийСпан("валидация-данных", КорневойСпан, ОтелВидСпана.Внутренний());
    ЗаписьВалидация = Логгер.СоздатьЗаписьЛога();
    ЗаписьВалидация.УстановитьТело("Валидация данных заказа")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Info())
        .УстановитьКонтекстТрассировки(
            СпанВалидация.КонтекстСпана().ИдТрассировки(),
            СпанВалидация.КонтекстСпана().ИдСпана());
    Логгер.Записать(ЗаписьВалидация);
    СпанВалидация.Завершить();

    // Дочерний спан - сохранение в БД
    СпанСохранение = Трассировщик.НачатьДочернийСпан("сохранение-в-бд", КорневойСпан, ОтелВидСпана.Клиент());
    ЗаписьСохранение = Логгер.СоздатьЗаписьЛога();
    ЗаписьСохранение.УстановитьТело("Сохранение заказа в базу данных")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Info())
        .УстановитьКонтекстТрассировки(
            СпанСохранение.КонтекстСпана().ИдТрассировки(),
            СпанСохранение.КонтекстСпана().ИдСпана());
    Логгер.Записать(ЗаписьСохранение);
    СпанСохранение.Завершить();

    // Метрики
    Счетчик.Добавить(1);
    Гистограмма.Записать(250);

    КорневойСпан.УстановитьСтатус(ОтелКодСтатуса.Ок());
    КорневойСпан.Завершить();

    // Закрываем все провайдеры
    ПровайдерТрассировки.Закрыть();
    ПровайдерМетрик.СброситьБуфер();

    // Тогда - проверяем трассировку в Tempo
    ДанныеТрассировки = ПолучитьТрассировкуИзTempo(ИдТрассировки, 3);
    ВсеСпаны = СобратьВсеСпаны(ДанныеТрассировки);

    // Должно быть 3 спана: корневой + 2 дочерних
    Ожидаем.Что(ВсеСпаны.Количество()).Равно(3);

    // Все спаны имеют общий traceId
    ИменаСпанов = Новый Массив();
    Для Каждого С Из ВсеСпаны Цикл
        ИменаСпанов.Добавить(С.name);
    КонецЦикла;
    Ожидаем.Что(ИменаСпанов).Содержит("обработка-заказа");
    Ожидаем.Что(ИменаСпанов).Содержит("валидация-данных");
    Ожидаем.Что(ИменаСпанов).Содержит("сохранение-в-бд");

    // Проверяем ресурс
    РесурсАтр = АтрибутыВСоответствие(ДанныеТрассировки.batches[0].resource.attributes);
    Ожидаем.Что(РесурсАтр.Получить("service.name")).Равно(ИмяСервиса);

    // Проверяем логи в Loki
    Результат = ПолучитьЛогиИзLoki(ИмяСервиса);
    Ожидаем.Что(Результат.Количество() > 0).Равно(Истина);

    // Собираем все тела логов
    ВсеТелаЛогов = Новый Массив();
    Для Каждого Поток Из Результат Цикл
        Для Каждого Значение Из Поток.values Цикл
            ВсеТелаЛогов.Добавить(Значение[1]);
        КонецЦикла;
    КонецЦикла;

    // Логи должны содержать текст из наших записей
    ПроверитьНаличиеЛога(ВсеТелаЛогов, "Начало обработки заказа");
    ПроверитьНаличиеЛога(ВсеТелаЛогов, "Валидация данных заказа");
    ПроверитьНаличиеЛога(ВсеТелаЛогов, "Сохранение заказа в базу данных");

    // Проверяем кросс-корреляцию: traceId из логов совпадает с traceId спанов
    Для Каждого Поток Из Результат Цикл
        Метки = Поток.stream;
        Попытка
            ЛогTraceId = Метки.trace_id;
            Если ЛогTraceId <> Неопределено И СтрДлина(ЛогTraceId) > 0 Тогда
                Ожидаем.Что(ЛогTraceId).Равно(ИдТрассировки);
            КонецЕсли;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
            // trace_id может отсутствовать в метках
        КонецПопытки;
    КонецЦикла;

    // Проверяем метрики в Prometheus
    ДанныеСчетчика = ПолучитьМетрикуИзPrometheus("cross_orders_processed_" + Суффикс + "_total");
    Ожидаем.Что(ДанныеСчетчика.Количество() > 0).Равно(Истина);
    Ожидаем.Что(Число(ДанныеСчетчика[0].value[1]) >= 1).Равно(Истина);

    // Проверяем метки ресурса в метрике
    Ожидаем.Что(ДанныеСчетчика[0].metric.service_name).Равно(ИмяСервиса);

    // Проверяем гистограмму
    // OTLP->Prometheus конвертирует unit "ms" в суффикс "_milliseconds"
    ИмяМетрики = "cross_order_processing_duration_"
        + Суффикс + "_milliseconds_count";
    ДанныеГистограммы = ПолучитьМетрикуИзPrometheus(ИмяМетрики);
    Ожидаем.Что(ДанныеГистограммы.Количество() > 0).Равно(Истина);
    Ожидаем.Что(Число(ДанныеГистограммы[0].value[1]) >= 1).Равно(Истина);

КонецПроцедуры

// ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====

Функция СоздатьТранспорт(ТипТранспорта)
    Если ТипТранспорта = "gRPC" Тогда
        Возврат Новый ОтелGrpcТранспорт("http://localhost:" + ПортOtlpGrpc);
    Иначе
        Возврат Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    КонецЕсли;
КонецФункции

Функция ПрочитатьОтветJSON(Ответ)
    Тело = Ответ.Текст();
    ЧтениеJSON = Новый ЧтениеJSON();
    ЧтениеJSON.УстановитьСтроку(Тело);
    Возврат ПрочитатьJSON(ЧтениеJSON);
КонецФункции

Функция АтрибутыВСоответствие(МассивАтрибутов)
    Результат = Новый Соответствие();
    Если МассивАтрибутов = Неопределено Тогда
        Возврат Результат;
    КонецЕсли;
    Для Каждого Атр Из МассивАтрибутов Цикл
        Результат.Вставить(Атр.key, ИзвлечьЗначениеАтрибута(Атр.value));
    КонецЦикла;
    Возврат Результат;
КонецФункции

Функция ИзвлечьЗначениеАтрибута(ЗначениеАтр)
    Если ТипЗнч(ЗначениеАтр) = Тип("Соответствие")
        ИЛИ ТипЗнч(ЗначениеАтр) = Тип("Структура") Тогда
        Для Каждого Пара Из ЗначениеАтр Цикл
            Возврат Пара.Значение;
        КонецЦикла;
        Возврат "";
    КонецЕсли;
    Возврат Строка(ЗначениеАтр);
КонецФункции

Процедура ПроверитьНаличиеЛога(ВсеТелаЛогов, ИскомыйТекст)
    Найдено = Ложь;
    Для Каждого Тело Из ВсеТелаЛогов Цикл
        Если СтрНайти(Тело, ИскомыйТекст) > 0 Тогда
            Найдено = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(Найдено).Равно(Истина);
КонецПроцедуры

Функция СобратьВсеСпаны(ДанныеТрассировки)
    ВсеСпаны = Новый Массив();
    Для Каждого Батч Из ДанныеТрассировки.batches Цикл
        Для Каждого СкоупСпан Из Батч.scopeSpans Цикл
            Для Каждого С Из СкоупСпан.spans Цикл
                ВсеСпаны.Добавить(С);
            КонецЦикла;
        КонецЦикла;
    КонецЦикла;
    Возврат ВсеСпаны;
КонецФункции

Функция ПолучитьТрассировкуИзTempo(ИдТрассировки, ОжидаемоеКоличествоСпанов = 1)
    URL = "http://localhost:" + ПортTempo + "/api/traces/" + ИдТрассировки;
    МаксПопыток = 20;
    Для Сч = 1 По МаксПопыток Цикл // BSLLS:UnusedLocalVariable-off
        Результат = ПопробоватьПолучитьТрассировку(URL, ОжидаемоеКоличествоСпанов);
        Если Результат <> Неопределено Тогда
            Возврат Результат;
        КонецЕсли;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Трассировка " + ИдТрассировки + " не найдена в Tempo";
КонецФункции

Функция ПопробоватьПолучитьТрассировку(URL, ОжидаемоеКоличествоСпанов)
    Попытка
        Ответ = КоннекторHTTP.Get(URL);
    Исключение
        Возврат Неопределено;
    КонецПопытки;
    Если Ответ.КодСостояния <> 200 Тогда
        Возврат Неопределено;
    КонецЕсли;
    Данные = ПрочитатьОтветJSON(Ответ);
    Попытка
        Если Данные.batches.Количество() > 0 Тогда
            ВсеСпаны = СобратьВсеСпаны(Данные);
            Если ВсеСпаны.Количество() >= ОжидаемоеКоличествоСпанов Тогда
                Возврат Данные;
            КонецЕсли;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    Возврат Неопределено;
КонецФункции

Функция ПолучитьЛогиИзLoki(СервисИмя)
    URL = "http://localhost:" + ПортLoki + "/loki/api/v1/query_range";
    МаксПопыток = 20;
    Для Сч = 1 По МаксПопыток Цикл // BSLLS:UnusedLocalVariable-off
        Попытка
            ПараметрыЗапроса = Новый Структура();
            ПараметрыЗапроса.Вставить("query", "{service_name=""" + СервисИмя + """}");
            ПараметрыЗапроса.Вставить("limit", "100");
            Ответ = КоннекторHTTP.Get(URL, ПараметрыЗапроса);
            Если Ответ.КодСостояния = 200 Тогда
                Данные = ПрочитатьОтветJSON(Ответ);
                Если Данные.data.result.Количество() > 0 Тогда
                    Возврат Данные.data.result;
                КонецЕсли;
            КонецЕсли;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
            // Сервис ещё не готов
        КонецПопытки;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Логи для " + СервисИмя + " не найдены в Loki";
КонецФункции

Функция ПолучитьМетрикуИзPrometheus(ИмяМетрики)
    URL = "http://localhost:" + ПортPrometheus + "/api/v1/query";
    МаксПопыток = 20;
    Для Сч = 1 По МаксПопыток Цикл // BSLLS:UnusedLocalVariable-off
        Попытка
            ПараметрыЗапроса = Новый Структура();
            ПараметрыЗапроса.Вставить("query", ИмяМетрики);
            Ответ = КоннекторHTTP.Get(URL, ПараметрыЗапроса);
            Если Ответ.КодСостояния = 200 Тогда
                Данные = ПрочитатьОтветJSON(Ответ);
                Если Данные.data.result.Количество() > 0 Тогда
                    Возврат Данные.data.result;
                КонецЕсли;
            КонецЕсли;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
            // Сервис ещё не готов
        КонецПопытки;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Метрика " + ИмяМетрики + " не найдена в Prometheus";
КонецФункции

Процедура ДождатьсяГотовности()

    МаксимальноеКоличествоПопыток = 60;
    Для Сч = 1 По МаксимальноеКоличествоПопыток Цикл // BSLLS:UnusedLocalVariable-off
        Попытка
            URLГотовности = "http://localhost:" + ПортOtlpHttp + "/v1/traces";
            Заголовки = Новый Соответствие();
            Заголовки.Вставить("Content-Type", "application/json");
            ДополнительныеПараметры = Новый Структура("Заголовки", Заголовки);
            Ответ = КоннекторHTTP.Post(URLГотовности, "{}", , ДополнительныеПараметры);
            Если Ответ.КодСостояния = 200 Тогда
                Возврат;
            КонецЕсли;
        Исключение
            Приостановить(1000);
        КонецПопытки;
    КонецЦикла;

    ВызватьИсключение "LGTM-стек не готов после " + МаксимальноеКоличествоПопыток + " попыток";

КонецПроцедуры
