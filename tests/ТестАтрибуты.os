// BSLLS:MagicNumber-off
#Использовать ".."
#Использовать asserts

&Тест
Процедура СозданиеАтрибутов() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();

    // Когда
    Атрибуты.Установить("service.name", "test-service");
    Атрибуты.Установить("service.version", "1.0.0");

    // Тогда
    Ожидаем.Что(Атрибуты.Количество()).Равно(2);
    Ожидаем.Что(Атрибуты.Получить("service.name")).Равно("test-service");
    Ожидаем.Что(Атрибуты.Получить("service.version")).Равно("1.0.0");

КонецПроцедуры

&Тест
Процедура ЦепочкаУстановкиАтрибутов() Экспорт

    // Дано / Когда
    Атрибуты = Новый ОтелАтрибуты();
    Результат = Атрибуты.Установить("key1", "value1").Установить("key2", "value2");

    // Тогда
    Ожидаем.Что(Атрибуты.Количество()).Равно(2);
    Ожидаем.Что(Результат).Равно(Атрибуты);

КонецПроцедуры

&Тест
Процедура УдалениеАтрибутов() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("key1", "value1");
    Атрибуты.Установить("key2", "value2");

    // Когда
    Атрибуты.Удалить("key1");

    // Тогда
    Ожидаем.Что(Атрибуты.Количество()).Равно(1);
    Ожидаем.Что(Атрибуты.Получить("key1")).Равно(Неопределено);
    Ожидаем.Что(Атрибуты.Получить("key2")).Равно("value2");

КонецПроцедуры

&Тест
Процедура ПреобразованиеВСоответствие() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("key", "value");

    // Когда
    Соответствие = Атрибуты.ВСоответствие();

    // Тогда
    Ожидаем.Что(Соответствие).ИмеетТип("Соответствие");
    Ожидаем.Что(Соответствие.Получить("key")).Равно("value");

КонецПроцедуры

&Тест
Процедура ПреобразованиеВМассивOtlp() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("string.key", "string-value");
    Атрибуты.Установить("int.key", 42);
    Атрибуты.Установить("bool.key", Истина);

    // Когда
    Массив = Атрибуты.ВМассивOtlp();

    // Тогда
    Ожидаем.Что(Массив).ИмеетТип("Массив");
    Ожидаем.Что(Массив).ИмеетДлину(3);

КонецПроцедуры
