// BSLLS:MagicNumber-off
#Использовать ".."
#Использовать asserts

&Тест
Процедура СозданиеСчетчика() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Счетчик = Метрика.СоздатьСчетчик("http.requests", "Количество HTTP-запросов", "1");

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("http.requests");
    Ожидаем.Что(Счетчик.Описание()).Равно("Количество HTTP-запросов");
    Ожидаем.Что(Счетчик.ЕдиницаИзмерения()).Равно("1");
    Ожидаем.Что(Счетчик.ТипМетрики()).Равно("sum");
    Ожидаем.Что(Счетчик.Монотонный()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура СчетчикАккумулируетЗначения() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter", "Test counter");

    // Когда — два добавления без атрибутов
    Счетчик.Добавить(1);
    Счетчик.Добавить(5);

    // Тогда — одна точка данных с накопленным значением 6
    Ожидаем.Что(Счетчик.КоличествоСерий()).Равно(1);
    Ожидаем.Что(Счетчик.НакопленноеЗначение()).Равно(6);
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура СчетчикРазделяетПоАтрибутам() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");
    Атр1 = Новый ОтелАтрибуты();
    Атр1.Установить("env", "prod");
    Атр2 = Новый ОтелАтрибуты();
    Атр2.Установить("env", "dev");

    // Когда
    Счетчик.Добавить(3, Атр1);
    Счетчик.Добавить(7, Атр1);
    Счетчик.Добавить(2, Атр2);

    // Тогда — две серии: prod=10, dev=2
    Ожидаем.Что(Счетчик.КоличествоСерий()).Равно(2);
    Ожидаем.Что(Счетчик.НакопленноеЗначение(Атр1)).Равно(10);
    Ожидаем.Что(Счетчик.НакопленноеЗначение(Атр2)).Равно(2);
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура СчетчикОтклоняетОтрицательныеЗначения() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");

    // Когда
    Счетчик.Добавить(-1);

    // Тогда
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура СозданиеГистограммы() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Гистограмма = Метрика.СоздатьГистограмму("http.duration", "Время ответа HTTP", "ms");

    // Тогда
    Ожидаем.Что(Гистограмма.Имя()).Равно("http.duration");
    Ожидаем.Что(Гистограмма.ТипМетрики()).Равно("histogram");
    Ожидаем.Что(Гистограмма.Границы()).ИмеетДлину(14);

КонецПроцедуры

&Тест
Процедура ГистограммаАгрегируетВБакеты() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("test.histogram", "Test histogram", "ms");

    // Когда — записываем три значения (все без атрибутов → одна серия)
    Гистограмма.Записать(100);
    Гистограмма.Записать(200);
    Гистограмма.Записать(150);

    // Тогда — одна агрегированная точка данных
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(1);
    Ожидаем.Что(Гистограмма.ТочкиДанных()).ИмеетДлину(1);

    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(3);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(450);
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(100);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(200);

    // Проверяем наличие бакетов
    Ожидаем.Что(ТочкаДанных.Получить("bucketCounts")).ИмеетДлину(15); // 14 границ + 1 (+Inf)
    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")).ИмеетДлину(14);

КонецПроцедуры

&Тест
Процедура ОчисткаТочекДанных() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");
    Счетчик.Добавить(1);
    Счетчик.Добавить(2);

    // Когда
    Счетчик.ОчиститьТочкиДанных();

    // Тогда
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура МетрикаРегистрируетИнструменты() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Метрика.СоздатьСчетчик("counter1");
    Метрика.СоздатьГистограмму("histogram1");

    // Тогда
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура МетрикаПредоставляетРесурс() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "test-service");
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Тогда
    Ожидаем.Что(Метрика.Ресурс()).Равно(Ресурс);
    Ожидаем.Что(Метрика.Ресурс().Атрибуты().Получить("service.name")).Равно("test-service");

КонецПроцедуры

&Тест
Процедура РеверсивныйСчетчикПринимаетОтрицательные() Экспорт

    // Дано
    Счетчик = Новый ОтелРеверсивныйСчетчик("active.connections", "Активные соединения", "1");

    // Когда
    Счетчик.Добавить(5);
    Счетчик.Добавить(-2);
    Счетчик.Добавить(1);

    // Тогда
    Ожидаем.Что(Счетчик.НакопленноеЗначение()).Равно(4);
    Ожидаем.Что(Счетчик.ТипМетрики()).Равно("sum");
    Ожидаем.Что(Счетчик.Монотонный()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ДатчикЗаписываетПоследнееЗначение() Экспорт

    // Дано
    Датчик = Новый ОтелДатчик("cpu.usage", "Использование CPU", "%");

    // Когда — несколько записей, хранится последнее
    Датчик.Записать(45);
    Датчик.Записать(72);
    Датчик.Записать(63);

    // Тогда — одна точка с последним значением
    Ожидаем.Что(Датчик.КоличествоСерий()).Равно(1);
    Ожидаем.Что(Датчик.ТекущееЗначение()).Равно(63);
    Ожидаем.Что(Датчик.ТипМетрики()).Равно("gauge");

КонецПроцедуры

&Тест
Процедура ДатчикРазделяетПоАтрибутам() Экспорт

    // Дано
    Датчик = Новый ОтелДатчик("memory.usage", "Использование памяти", "bytes");
    АтрГруппа1 = Новый ОтелАтрибуты();
    АтрГруппа1.Установить("host", "server1");
    АтрГруппа2 = Новый ОтелАтрибуты();
    АтрГруппа2.Установить("host", "server2");

    // Когда
    Датчик.Записать(1024, АтрГруппа1);
    Датчик.Записать(2048, АтрГруппа2);
    Датчик.Записать(512, АтрГруппа1); // перезапись

    // Тогда
    Ожидаем.Что(Датчик.КоличествоСерий()).Равно(2);
    Ожидаем.Что(Датчик.ТекущееЗначение(АтрГруппа1)).Равно(512);
    Ожидаем.Что(Датчик.ТекущееЗначение(АтрГруппа2)).Равно(2048);

КонецПроцедуры

&Тест
Процедура МетрикаРегистрируетВсеТипыИнструментов() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Метрика.СоздатьСчетчик("counter1");
    Метрика.СоздатьГистограмму("histogram1");
    Метрика.СоздатьРеверсивныйСчетчик("updown1");
    Метрика.СоздатьДатчик("gauge1");

    // Тогда
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(4);

КонецПроцедуры
