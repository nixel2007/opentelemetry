// BSLLS:MagicNumber-off
#Использовать ".."
#Использовать asserts

&Тест
Процедура СозданиеСчетчика() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетрика("test-library", "1.0.0", Ресурс);

    // Когда
    Счетчик = Метрика.СоздатьСчетчик("http.requests", "Количество HTTP-запросов", "1");

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("http.requests");
    Ожидаем.Что(Счетчик.Описание()).Равно("Количество HTTP-запросов");
    Ожидаем.Что(Счетчик.ЕдиницаИзмерения()).Равно("1");
    Ожидаем.Что(Счетчик.ТипМетрики()).Равно("sum");
    Ожидаем.Что(Счетчик.Монотонный()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ДобавлениеЗначенийВСчетчик() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter", "Test counter");

    // Когда
    Счетчик.Добавить(1);
    Счетчик.Добавить(5);

    // Тогда
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура СчетчикОтклоняетОтрицательныеЗначения() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");

    // Когда
    Счетчик.Добавить(-1);

    // Тогда
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура СозданиеГистограммы() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетрика("test-library", "1.0.0", Ресурс);

    // Когда
    Гистограмма = Метрика.СоздатьГистограмму("http.duration", "Время ответа HTTP", "ms");

    // Тогда
    Ожидаем.Что(Гистограмма.Имя()).Равно("http.duration");
    Ожидаем.Что(Гистограмма.ТипМетрики()).Равно("histogram");

КонецПроцедуры

&Тест
Процедура ЗаписьЗначенийВГистограмму() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("test.histogram", "Test histogram", "ms");

    // Когда
    Гистограмма.Записать(100);
    Гистограмма.Записать(200);
    Гистограмма.Записать(150);

    // Тогда
    Ожидаем.Что(Гистограмма.ТочкиДанных()).ИмеетДлину(3);

КонецПроцедуры

&Тест
Процедура ОчисткаТочекДанных() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");
    Счетчик.Добавить(1);
    Счетчик.Добавить(2);

    // Когда
    Счетчик.ОчиститьТочкиДанных();

    // Тогда
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура МетрикаРегистрируетИнструменты() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетрика("test-library", "1.0.0", Ресурс);

    // Когда
    Метрика.СоздатьСчетчик("counter1");
    Метрика.СоздатьГистограмму("histogram1");

    // Тогда
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(2);

КонецПроцедуры
