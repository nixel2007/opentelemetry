&Тест
Процедура ПровайдерТрассировкиПослеЗакрытияВозвращаетNoOp() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерТрассировки();
    Трассировщик1 = Провайдер.ПолучитьТрассировщик("lib", "1.0");

    // Когда
    Провайдер.Закрыть();

    // Тогда — новый трассировщик не равен старому (no-op)
    Трассировщик2 = Провайдер.ПолучитьТрассировщик("lib", "1.0");
    Ожидаем.Что(Трассировщик2).Не_().Равно(Трассировщик1);

    // Спан от no-op трассировщика всё ещё создаётся, но без процессора
    Спан = Трассировщик2.НачатьСпан("test");
    Ожидаем.Что(Спан).Не_().Равно(Неопределено);
    Ожидаем.Что(Спан.Имя()).Равно("test");

КонецПроцедуры

