// BSLLS:MagicNumber-off
#Использовать ".."
#Использовать asserts

&Тест
Процедура ПровайдерТрассировкиСоздаетТрассировщик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "test-service");
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("my-library", "1.0.0");

    // Тогда
    Спан = Трассировщик.НачатьСпан("test-operation");
    Ожидаем.Что(Спан.Имя()).Равно("test-operation");
    Ожидаем.Что(Спан.ИмяБиблиотеки()).Равно("my-library");

КонецПроцедуры

&Тест
Процедура ПровайдерЛогированияСоздаетЛоггер() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "test-service");
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);

    // Когда
    Логгер = Провайдер.ПолучитьЛоггер("my-library", "1.0.0");

    // Тогда
    Ожидаем.Что(Логгер.ИмяБиблиотеки()).Равно("my-library");
    Ожидаем.Что(Логгер.ВерсияБиблиотеки()).Равно("1.0.0");

КонецПроцедуры

&Тест
Процедура ПровайдерМетрикСоздаетМетрику() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "test-service");
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);

    // Когда
    Метрика = Провайдер.ПолучитьМетр("my-library", "1.0.0");

    // Тогда
    Ожидаем.Что(Метрика.ИмяБиблиотеки()).Равно("my-library");
    Ожидаем.Что(Метрика.ВерсияБиблиотеки()).Равно("1.0.0");

КонецПроцедуры

&Тест
Процедура ПровайдерыСоздаютсяБезПараметров() Экспорт

    // Дано / Когда
    ПровайдерТрассировки = Новый ОтелПровайдерТрассировки();
    ПровайдерЛогирования = Новый ОтелПровайдерЛогирования();
    ПровайдерМетрик = Новый ОтелПровайдерМетрик();

    // Тогда
    Ожидаем.Что(ПровайдерТрассировки.Ресурс()).Не_().Равно(Неопределено);
    Ожидаем.Что(ПровайдерЛогирования.Ресурс()).Не_().Равно(Неопределено);
    Ожидаем.Что(ПровайдерМетрик.Ресурс()).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонтекстСпана() Экспорт

    // Дано
    ИдТрассировки = "0af7651916cd43dd8448eb211c80319c";
    ИдСпана = "b7ad6b7169203331";

    // Когда
    Контекст = Новый ОтелКонтекстСпана(ИдТрассировки, ИдСпана);

    // Тогда
    Ожидаем.Что(Контекст.ИдТрассировки()).Равно(ИдТрассировки);
    Ожидаем.Что(Контекст.ИдСпана()).Равно(ИдСпана);
    Ожидаем.Что(Контекст.ФлагиТрассировки()).Равно(1);
    Ожидаем.Что(Контекст.СостояниеТрассировки()).Равно("");
    Ожидаем.Что(Контекст.Валиден()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КонтекстСпанаСТрейсСтейт() Экспорт

    // Дано
    ИдТрассировки = "0af7651916cd43dd8448eb211c80319c";
    ИдСпана = "b7ad6b7169203331";
    ТрейсСтейт = "vendor1=value1,vendor2=value2";

    // Когда
    Контекст = Новый ОтелКонтекстСпана(ИдТрассировки, ИдСпана, 1, ТрейсСтейт);

    // Тогда
    Ожидаем.Что(Контекст.СостояниеТрассировки()).Равно(ТрейсСтейт);
    Ожидаем.Что(Контекст.Валиден()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КонтекстСпанаНеВалиден() Экспорт

    // Дано / Когда
    Контекст = Новый ОтелКонтекстСпана("", "");

    // Тогда
    Ожидаем.Что(Контекст.Валиден()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ПровайдерыПоддерживаютСброситьБуфер() Экспорт

    // Дано
    ПровайдерТрассировки = Новый ОтелПровайдерТрассировки();
    ПровайдерЛогирования = Новый ОтелПровайдерЛогирования();
    ПровайдерМетрик = Новый ОтелПровайдерМетрик();

    // Когда / Тогда — не должно выбрасывать исключений
    ПровайдерТрассировки.СброситьБуфер();
    ПровайдерЛогирования.СброситьБуфер();
    ПровайдерМетрик.СброситьБуфер();

КонецПроцедуры

&Тест
Процедура ВидыСпанов() Экспорт

    // Дано / Когда / Тогда
    Ожидаем.Что(ОтелВидСпана.Внутренний()).Равно(1);
    Ожидаем.Что(ОтелВидСпана.Сервер()).Равно(2);
    Ожидаем.Что(ОтелВидСпана.Клиент()).Равно(3);
    Ожидаем.Что(ОтелВидСпана.Производитель()).Равно(4);
    Ожидаем.Что(ОтелВидСпана.Потребитель()).Равно(5);

КонецПроцедуры

&Тест
Процедура ПровайдерТрассировкиКешируетТрассировщик() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерТрассировки();

    // Когда
    Трассировщик1 = Провайдер.ПолучитьТрассировщик("my-library", "1.0.0");
    Трассировщик2 = Провайдер.ПолучитьТрассировщик("my-library", "1.0.0");
    Трассировщик3 = Провайдер.ПолучитьТрассировщик("other-library", "2.0.0");

    // Тогда — одинаковые ключи возвращают тот же объект
    Ожидаем.Что(Трассировщик1).Равно(Трассировщик2);
    Ожидаем.Что(Трассировщик1).Не_().Равно(Трассировщик3);

КонецПроцедуры

&Тест
Процедура ПровайдерЛогированияКешируетЛоггер() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерЛогирования();

    // Когда
    Логгер1 = Провайдер.ПолучитьЛоггер("my-library", "1.0.0");
    Логгер2 = Провайдер.ПолучитьЛоггер("my-library", "1.0.0");
    Логгер3 = Провайдер.ПолучитьЛоггер("other-library", "2.0.0");

    // Тогда
    Ожидаем.Что(Логгер1).Равно(Логгер2);
    Ожидаем.Что(Логгер1).Не_().Равно(Логгер3);

КонецПроцедуры

&Тест
Процедура ПровайдерМетрикКешируетМетрику() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерМетрик();

    // Когда
    Метрика1 = Провайдер.ПолучитьМетр("my-library", "1.0.0");
    Метрика2 = Провайдер.ПолучитьМетр("my-library", "1.0.0");
    Метрика3 = Провайдер.ПолучитьМетр("other-library", "2.0.0");

    // Тогда
    Ожидаем.Что(Метрика1).Равно(Метрика2);
    Ожидаем.Что(Метрика1).Не_().Равно(Метрика3);

КонецПроцедуры

&Тест
Процедура КодыСтатуса() Экспорт

    // Дано / Когда / Тогда
    Ожидаем.Что(ОтелКодСтатуса.НеУстановлен()).Равно(0);
    Ожидаем.Что(ОтелКодСтатуса.Ок()).Равно(1);
    Ожидаем.Что(ОтелКодСтатуса.Ошибка()).Равно(2);

КонецПроцедуры
