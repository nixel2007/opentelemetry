&Тест
Процедура ПостроительТрассировщикаКешируетЭкземпляр() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерТрассировки();

    // Когда
    Трассировщик1 = Провайдер.ПостроительТрассировщика("lib").УстановитьВерсию("1.0").Построить();
    Трассировщик2 = Провайдер.ПостроительТрассировщика("lib").УстановитьВерсию("1.0").Построить();
    Трассировщик3 = Провайдер.ПостроительТрассировщика("lib").УстановитьВерсию("2.0").Построить();

    // Тогда — одинаковые параметры → один экземпляр
    Ожидаем.Что(Трассировщик1).Равно(Трассировщик2);
    Ожидаем.Что(Трассировщик1).Не_().Равно(Трассировщик3);

КонецПроцедуры

// --- Тесты InMemory экспортеров ---

&Тест
Процедура ВПамятьЭкспортерСпановСобираетСпаны() Экспорт

    // Дано
    Экспортер = Новый ОтелВПамятьЭкспортерСпанов();
    Процессор = Новый ОтелПростойПроцессорСпанов(Экспортер);
    Провайдер = Новый ОтелПровайдерТрассировки(Неопределено, Процессор);

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("lib", "1.0");
    Спан = Трассировщик.НачатьСпан("test-span");
    Спан.Завершить();

    // Тогда
    Спаны = Экспортер.ПолучитьЭкспортированные();
    Ожидаем.Что(Спаны.Количество()).БольшеИлиРавно(1);

    НайденСпан = Ложь;
    Для Каждого ЭкспортированныйСпан Из Спаны Цикл
        Если ЭкспортированныйСпан.Имя() = "test-span" Тогда
            НайденСпан = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденСпан).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ВПамятьЭкспортерСпановОчищается() Экспорт

    // Дано
    Экспортер = Новый ОтелВПамятьЭкспортерСпанов();
    Процессор = Новый ОтелПростойПроцессорСпанов(Экспортер);
    Провайдер = Новый ОтелПровайдерТрассировки(Неопределено, Процессор);
    Трассировщик = Провайдер.ПолучитьТрассировщик("lib", "1.0");

    Спан = Трассировщик.НачатьСпан("span-to-clear");
    Спан.Завершить();
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).БольшеИлиРавно(1);

    // Когда
    Экспортер.Очистить();

    // Тогда
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ВПамятьЭкспортерЛоговСобираетЗаписи() Экспорт

    // Дано
    Экспортер = Новый ОтелВПамятьЭкспортерЛогов();
    Процессор = Новый ОтелПростойПроцессорЛогов(Экспортер);
    Провайдер = Новый ОтелПровайдерЛогирования(Неопределено, Процессор);

    // Когда
    Логгер = Провайдер.ПолучитьЛоггер("lib", "1.0");
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("test log message");
    Запись.УстановитьСерьезность(ОтелСтепеньСерьезности.Info());
    Логгер.Записать(Запись);

    // Тогда
    Записи = Экспортер.ПолучитьЭкспортированные();
    Ожидаем.Что(Записи.Количество()).БольшеИлиРавно(1);

КонецПроцедуры

// --- Тесты представлений (View) и селектора инструментов ---

&Тест
Процедура СелекторИнструментовФильтруетПоИмени() Экспорт

    // Дано
    Селектор = Новый ОтелСелекторИнструментов("my-counter");

    // Когда / Тогда
    Ожидаем.Что(Селектор.Совпадает("my-counter")).Равно(Истина);
    Ожидаем.Что(Селектор.Совпадает("other-counter")).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура СелекторИнструментовФильтруетПоТипу() Экспорт

    // Дано
    Селектор = Новый ОтелСелекторИнструментов(Неопределено, "histogram");

    // Когда / Тогда
    Ожидаем.Что(Селектор.Совпадает("any-name", "histogram")).Равно(Истина);
    Ожидаем.Что(Селектор.Совпадает("any-name", "sum")).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ПровайдерМетрикРегистрируетПредставление() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерМетрик();
    Селектор = Новый ОтелСелекторИнструментов("my-histogram", "histogram");
    Границы = Новый Массив;
    Границы.Добавить(10);
    Границы.Добавить(50);
    Границы.Добавить(100);
    Представление = Новый ОтелПредставление("renamed-histogram", "Renamed", Неопределено, Границы);

    // Когда
    Провайдер.ЗарегистрироватьПредставление(Селектор, Представление);

    // Тогда
    Представления = Провайдер.ПолучитьПредставления();
    Ожидаем.Что(Представления.Количество()).Равно(1);
    Ожидаем.Что(Представления[0].Получить("Селектор")).Равно(Селектор);
    Ожидаем.Что(Представления[0].Получить("Представление")).Равно(Представление);

КонецПроцедуры

// --- Тест ExemplarFilter на уровне MeterProvider ---

&Тест
Процедура ПровайдерМетрикПринимаетФильтрЭкземпляров() Экспорт

    // Дано / Когда
    Провайдер = Новый ОтелПровайдерМетрик(Неопределено, Неопределено, ОтелФильтрЭкземпляров.ВсегдаВключен());

    // Тогда — провайдер создан без исключений
    Метр = Провайдер.ПолучитьМетр("lib", "1.0");
    Ожидаем.Что(Метр).Не_().Равно(Неопределено);

КонецПроцедуры

// --- Тесты временной агрегации ---

&Тест
Процедура ВременнаяАгрегацияКонстанты() Экспорт

    // Дано / Когда / Тогда
    Ожидаем.Что(ОтелВременнаяАгрегация.НеУказана()).Равно(0);
    Ожидаем.Что(ОтелВременнаяАгрегация.Дельта()).Равно(1);
    Ожидаем.Что(ОтелВременнаяАгрегация.Кумулятивная()).Равно(2);

КонецПроцедуры

&Тест
Процедура СелекторВременнойАгрегацииВсегдаКумулятивная() Экспорт

    // Дано
    Селектор = ОтелСелекторВременнойАгрегации.ВсегдаКумулятивная();

    // Когда / Тогда
    Ожидаем.Что(Селектор.Применить("counter")).Равно(ОтелВременнаяАгрегация.Кумулятивная());
    Ожидаем.Что(Селектор.Применить("histogram")).Равно(ОтелВременнаяАгрегация.Кумулятивная());
    Ожидаем.Что(Селектор.Применить("up_down_counter")).Равно(ОтелВременнаяАгрегация.Кумулятивная());
    Ожидаем.Что(Селектор.Применить("gauge")).Равно(ОтелВременнаяАгрегация.Кумулятивная());

КонецПроцедуры

&Тест
Процедура СелекторВременнойАгрегацииПредпочтительноДельта() Экспорт

    // Дано
    Селектор = ОтелСелекторВременнойАгрегации.ПредпочтительноДельта();

    // Когда / Тогда — DELTA для всех кроме UpDownCounter
    Ожидаем.Что(Селектор.Применить("counter")).Равно(ОтелВременнаяАгрегация.Дельта());
    Ожидаем.Что(Селектор.Применить("histogram")).Равно(ОтелВременнаяАгрегация.Дельта());
    Ожидаем.Что(Селектор.Применить("up_down_counter")).Равно(ОтелВременнаяАгрегация.Кумулятивная());
    Ожидаем.Что(Селектор.Применить("observable_up_down_counter")).Равно(ОтелВременнаяАгрегация.Кумулятивная());

КонецПроцедуры

&Тест
Процедура СелекторВременнойАгрегацииНизкоеПотреблениеПамяти() Экспорт

    // Дано
    Селектор = ОтелСелекторВременнойАгрегации.НизкоеПотреблениеПамяти();

    // Когда / Тогда — DELTA для всех
    Ожидаем.Что(Селектор.Применить("counter")).Равно(ОтелВременнаяАгрегация.Дельта());
    Ожидаем.Что(Селектор.Применить("histogram")).Равно(ОтелВременнаяАгрегация.Дельта());
    Ожидаем.Что(Селектор.Применить("up_down_counter")).Равно(ОтелВременнаяАгрегация.Дельта());

КонецПроцедуры
