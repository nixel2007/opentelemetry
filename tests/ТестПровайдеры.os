&Тест
Процедура РесурсОпределяетСистемнуюИнформацию() Экспорт

    // Дано / Когда
    Ресурс = Новый ОтелРесурс();

    // Тогда — автоматически определённые атрибуты
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("unknown_service:oscript");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("telemetry.sdk.name")).Равно("opentelemetry");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("telemetry.sdk.language")).Равно("oscript");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("host.name")).Не_().Равно(Неопределено);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("os.type")).Не_().Равно(Неопределено);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("process.pid")).Не_().Равно(Неопределено);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("host.arch")).Не_().Равно(Неопределено);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("host.cpu.model.name")).Не_().Равно(Неопределено);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("host.cpu.count")).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура РесурсОпределяетАрхитектуру() Экспорт

    // Дано / Когда
    Ресурс = Новый ОтелРесурс();
    Арх = Ресурс.Атрибуты().Получить("host.arch");

    // Тогда — host.arch должен быть одним из стандартных значений OTel
    ДопустимыеАрхитектуры = Новый Массив();
    ДопустимыеАрхитектуры.Добавить("amd64");
    ДопустимыеАрхитектуры.Добавить("x86");
    ДопустимыеАрхитектуры.Добавить("arm64");
    ДопустимыеАрхитектуры.Добавить("arm32");
    Ожидаем.Что(ДопустимыеАрхитектуры).Содержит(Арх);

КонецПроцедуры

&Тест
Процедура РесурсОпределяетОсТип() Экспорт

    // Дано / Когда
    Ресурс = Новый ОтелРесурс();
    ОсТип = Ресурс.Атрибуты().Получить("os.type");

    // Тогда — os.type должен быть одним из стандартных значений
    ДопустимыеТипы = Новый Массив();
    ДопустимыеТипы.Добавить("linux");
    ДопустимыеТипы.Добавить("windows");
    ДопустимыеТипы.Добавить("darwin");
    Ожидаем.Что(ДопустимыеТипы).Содержит(ОсТип);

КонецПроцедуры

&Тест
Процедура РезультатыЭкспорта() Экспорт

    // Дано / Когда / Тогда
    Ожидаем.Что(ОтелРезультатЭкспорта.Успех()).Равно(0);
    Ожидаем.Что(ОтелРезультатЭкспорта.Ошибка()).Равно(1);

КонецПроцедуры

&Тест
Процедура ПакетныйПроцессорСпановБуферизуетСпаны() Экспорт

    // Дано — пакетный процессор с размером пакета 3
    Процессор = Новый ОтелПакетныйПроцессорСпанов(Неопределено, 100, 3, 60000);
    Ресурс = Новый ОтелРесурс();

    // Когда — добавляем 2 спана (меньше размера пакета)
    Спан1 = Новый ОтелСпан("span-1", Ресурс, "lib", "1.0", Процессор);
    Спан1.Завершить();
    Спан2 = Новый ОтелСпан("span-2", Ресурс, "lib", "1.0", Процессор);
    Спан2.Завершить();

    // Тогда — ничего не упало (без экспортера буфер просто заполняется)
    Процессор.СброситьБуфер();
    Процессор.Закрыть();

КонецПроцедуры

&Тест
Процедура ПакетныйПроцессорЛоговБуферизуетЗаписи() Экспорт

    // Дано
    Процессор = Новый ОтелПакетныйПроцессорЛогов(Неопределено, 100, 3, 60000);
    Ресурс = Новый ОтелРесурс();

    // Когда
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("test log");
    Процессор.Обработать(Запись, Ресурс, "lib", "1.0");

    // Тогда
    Процессор.СброситьБуфер();
    Процессор.Закрыть();

КонецПроцедуры
