// BSLLS:MagicNumber-off
#Использовать ".."
#Использовать asserts

&Тест
Процедура СозданиеЗаписиЛога() Экспорт

    // Дано / Когда
    Запись = Новый ОтелЗаписьЛога();

    // Тогда
    Ожидаем.Что(Запись.НомерСерьезности()).Равно(ОтелСтепеньСерьезности.Info());
    Ожидаем.Что(Запись.ТекстСерьезности()).Равно("INFO");
    Ожидаем.Что(Запись.Тело()).Равно("");

КонецПроцедуры

&Тест
Процедура НастройкаЗаписиЛога() Экспорт

    // Дано
    Запись = Новый ОтелЗаписьЛога();

    // Когда
    Запись.УстановитьТело("Test log message")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Error())
        .УстановитьАтрибут("code.function", "TestMethod");

    // Тогда
    Ожидаем.Что(Запись.Тело()).Равно("Test log message");
    Ожидаем.Что(Запись.НомерСерьезности()).Равно(17);
    Ожидаем.Что(Запись.ТекстСерьезности()).Равно("ERROR");
    Ожидаем.Что(Запись.Атрибуты().Получить("code.function")).Равно("TestMethod");

КонецПроцедуры

&Тест
Процедура КорреляцияЛогаСТрассировкой() Экспорт

    // Дано
    Запись = Новый ОтелЗаписьЛога();

    // Когда
    Запись.УстановитьКонтекстТрассировки("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331");

    // Тогда
    Ожидаем.Что(Запись.ИдТрассировки()).Равно("0af7651916cd43dd8448eb211c80319c");
    Ожидаем.Что(Запись.ИдСпана()).Равно("b7ad6b7169203331");

КонецПроцедуры

&Тест
Процедура АвтоКорреляцияЛогаСТекущимСпаном() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");
    Спан.СделатьТекущим();

    // Когда — создаём запись лога при наличии текущего спана
    Запись = Новый ОтелЗаписьЛога();

    // Тогда — TraceId и SpanId автоматически заполнены из контекста
    Ожидаем.Что(Запись.ИдТрассировки()).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Запись.ИдСпана()).Равно(Спан.КонтекстСпана().ИдСпана());

    Спан.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ЛогБезТекущегоСпанаПустыеИд() Экспорт

    // Дано
    ОтелКонтекст.Очистить();

    // Когда — создаём запись лога без текущего спана
    Запись = Новый ОтелЗаписьЛога();

    // Тогда — TraceId и SpanId пустые
    Ожидаем.Что(Запись.ИдТрассировки()).Равно("");
    Ожидаем.Что(Запись.ИдСпана()).Равно("");

КонецПроцедуры

&Тест
Процедура СтепениСерьезности() Экспорт

    // Дано / Когда / Тогда
    Ожидаем.Что(ОтелСтепеньСерьезности.Trace()).Равно(1);
    Ожидаем.Что(ОтелСтепеньСерьезности.Debug()).Равно(5);
    Ожидаем.Что(ОтелСтепеньСерьезности.Info()).Равно(9);
    Ожидаем.Что(ОтелСтепеньСерьезности.Warn()).Равно(13);
    Ожидаем.Что(ОтелСтепеньСерьезности.Error()).Равно(17);
    Ожидаем.Что(ОтелСтепеньСерьезности.Fatal()).Равно(21);

КонецПроцедуры

&Тест
Процедура ТекстыСерьезности() Экспорт

    // Дано / Когда / Тогда
    Ожидаем.Что(ОтелСтепеньСерьезности.ТекстСерьезности(1)).Равно("TRACE");
    Ожидаем.Что(ОтелСтепеньСерьезности.ТекстСерьезности(5)).Равно("DEBUG");
    Ожидаем.Что(ОтелСтепеньСерьезности.ТекстСерьезности(9)).Равно("INFO");
    Ожидаем.Что(ОтелСтепеньСерьезности.ТекстСерьезности(13)).Равно("WARN");
    Ожидаем.Что(ОтелСтепеньСерьезности.ТекстСерьезности(17)).Равно("ERROR");
    Ожидаем.Что(ОтелСтепеньСерьезности.ТекстСерьезности(21)).Равно("FATAL");

КонецПроцедуры

&Тест
Процедура ТелоЗаписиЛогаПринимаетРазныеТипы() Экспорт

    // Дано / Когда / Тогда — строка
    Запись1 = Новый ОтелЗаписьЛога();
    Запись1.УстановитьТело("текстовое тело");
    Ожидаем.Что(Запись1.Тело()).Равно("текстовое тело");

    // Числовое значение
    Запись2 = Новый ОтелЗаписьЛога();
    Запись2.УстановитьТело(42);
    Ожидаем.Что(Запись2.Тело()).Равно(42);

    // Булево значение
    Запись3 = Новый ОтелЗаписьЛога();
    Запись3.УстановитьТело(Истина);
    Ожидаем.Что(Запись3.Тело()).Равно(Истина);

КонецПроцедуры
