&Тест
Процедура КонвертацияПлоскогоСоответствия() Экспорт

    // Дано
    Данные = Новый Соответствие();
    Данные.Вставить("traceId", "abc123");
    Данные.Вставить("spanId", "def456");
    Данные.Вставить("name", "test-span");
    Данные.Вставить("kind", 1);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат.Получить("trace_id")).Равно("abc123");
    Ожидаем.Что(Результат.Получить("span_id")).Равно("def456");
    Ожидаем.Что(Результат.Получить("name")).Равно("test-span");
    Ожидаем.Что(Результат.Получить("kind")).Равно(1);

КонецПроцедуры

&Тест
Процедура КонвертацияВложенныхСтруктур() Экспорт

    // Дано — спан с атрибутами и статусом
    АтрибутЗначение = Новый Соответствие();
    АтрибутЗначение.Вставить("stringValue", "GET");

    Атрибут = Новый Соответствие();
    Атрибут.Вставить("key", "http.method");
    Атрибут.Вставить("value", АтрибутЗначение);

    Атрибуты = Новый Массив();
    Атрибуты.Добавить(Атрибут);

    Статус = Новый Соответствие();
    Статус.Вставить("code", 1);

    СпанOtlp = Новый Соответствие();
    СпанOtlp.Вставить("traceId", "abc123");
    СпанOtlp.Вставить("startTimeUnixNano", "1234567890000000000");
    СпанOtlp.Вставить("attributes", Атрибуты);
    СпанOtlp.Вставить("status", Статус);

    // Когда
    Результат = Конвертер.Конвертировать(СпанOtlp);

    // Тогда
    Ожидаем.Что(Результат.Получить("trace_id")).Равно("abc123");
    Ожидаем.Что(Результат.Получить("start_time_unix_nano")).Равно("1234567890000000000");

    АтрибутыProto = Результат.Получить("attributes");
    Ожидаем.Что(АтрибутыProto.Количество()).Равно(1);
    Ожидаем.Что(АтрибутыProto[0].Получить("key")).Равно("http.method");
    Ожидаем.Что(АтрибутыProto[0].Получить("value").Получить("string_value")).Равно("GET");

    Ожидаем.Что(Результат.Получить("status").Получить("code")).Равно(1);

КонецПроцедуры

&Тест
Процедура КонвертацияПолнойСтруктурыResourceSpans() Экспорт

    // Дано — полная структура ExportTraceServiceRequest
    Спан = Новый Соответствие();
    Спан.Вставить("traceId", "aabb");
    Спан.Вставить("spanId", "ccdd");

    Скоуп = Новый Соответствие();
    Скоуп.Вставить("name", "lib");
    Скоуп.Вставить("version", "1.0");

    СкоупСпаны = Новый Соответствие();
    СкоупСпаны.Вставить("scope", Скоуп);
    СпаныМассив = Новый Массив();
    СпаныМассив.Добавить(Спан);
    СкоупСпаны.Вставить("spans", СпаныМассив);

    РесурсАтр = Новый Соответствие();
    РесурсАтр.Вставить("key", "service.name");
    Значение = Новый Соответствие();
    Значение.Вставить("stringValue", "test");
    РесурсАтр.Вставить("value", Значение);

    Ресурс = Новый Соответствие();
    МассивАтр = Новый Массив();
    МассивАтр.Добавить(РесурсАтр);
    Ресурс.Вставить("attributes", МассивАтр);

    РесурсСпаны = Новый Соответствие();
    РесурсСпаны.Вставить("resource", Ресурс);
    МассивСкоупов = Новый Массив();
    МассивСкоупов.Добавить(СкоупСпаны);
    РесурсСпаны.Вставить("scopeSpans", МассивСкоупов);

    МассивРС = Новый Массив();
    МассивРС.Добавить(РесурсСпаны);

    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", МассивРС);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    РС = Результат.Получить("resource_spans");
    Ожидаем.Что(РС).ИмеетТип("Массив");
    Ожидаем.Что(РС.Количество()).Равно(1);

    ПервыйРС = РС[0];
    Ожидаем.Что(ПервыйРС.Получить("resource")).ИмеетТип("Соответствие");
    Ожидаем.Что(ПервыйРС.Получить("scope_spans")).ИмеетТип("Массив");

    ПервыйСкоуп = ПервыйРС.Получить("scope_spans")[0];
    Ожидаем.Что(ПервыйСкоуп.Получить("scope").Получить("name")).Равно("lib");

    ПервыйСпан = ПервыйСкоуп.Получить("spans")[0];
    Ожидаем.Что(ПервыйСпан.Получить("trace_id")).Равно("aabb");
    Ожидаем.Что(ПервыйСпан.Получить("span_id")).Равно("ccdd");

    АтрибутРес = ПервыйРС.Получить("resource").Получить("attributes")[0];
    Ожидаем.Что(АтрибутРес.Получить("value").Получить("string_value")).Равно("test");

КонецПроцедуры

&Тест
Процедура КонвертацияСтруктурыВСоответствие() Экспорт

    // Дано — Структура (а не Соответствие) тоже должна конвертироваться
    Данные = Новый Структура();
    Данные.Вставить("scopeMetrics", Новый Массив());

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда — результат всегда Соответствие
    Ожидаем.Что(Результат).ИмеетТип("Соответствие");
    Ожидаем.Что(Результат.Получить("scope_metrics")).ИмеетТип("Массив");

КонецПроцедуры

&Тест
Процедура КонвертацияПримитивовБезИзменений() Экспорт

    Ожидаем.Что(Конвертер.Конвертировать("строка")).Равно("строка");
    Ожидаем.Что(Конвертер.Конвертировать(42)).Равно(42);
    Ожидаем.Что(Конвертер.Конвертировать(3.14)).Равно(3.14);
    Ожидаем.Что(Конвертер.Конвертировать(Истина)).Равно(Истина);
    Ожидаем.Что(Конвертер.Конвертировать(Неопределено)).Равно(Неопределено);

КонецПроцедуры
