// Мок-генератор идентификаторов для тестирования подключаемого IdGenerator.
// Возвращает детерминированные ID.

Перем мСчетчикТрассировок;
Перем мСчетчикСпанов;

Функция СгенерироватьИдТрассировки() Экспорт
    мСчетчикТрассировок = мСчетчикТрассировок + 1;
    Возврат СтрШаблон("%1", Формат(мСчетчикТрассировок, "ЧЦ=32; ЧВН=; ЧГ="));
КонецФункции

Функция СгенерироватьИдСпана() Экспорт
    мСчетчикСпанов = мСчетчикСпанов + 1;
    Возврат СтрШаблон("%1", Формат(мСчетчикСпанов, "ЧЦ=16; ЧВН=; ЧГ="));
КонецФункции

Процедура ПриСозданииОбъекта()
    мСчетчикТрассировок = 0;
    мСчетчикСпанов = 0;
КонецПроцедуры
