// BSLLS:MagicNumber-off
// Интеграционные тесты с LGTM-стеком (Loki, Grafana, Tempo, Mimir/Prometheus).
// Используют testcontainers для запуска контейнера grafana/otel-lgtm.
// Проверяют отправку трассировки, логов и метрик через OTLP HTTP
// и их получение через API Tempo, Loki и Prometheus.
#Использовать ".."
#Использовать asserts
#Использовать testcontainers
#Использовать 1connector
#Использовать 1commands

Перем Контейнер;
Перем ПортOtlp;
Перем ПортTempo;
Перем ПортLoki;
Перем ПортPrometheus;

&ПередВсеми
Процедура ПередВсеми() Экспорт

    // Предварительная загрузка образа, чтобы вывод docker run -d содержал только ID контейнера
    КомандаПулл = Новый Команда;
    КомандаПулл.УстановитьКоманду("docker");
    КомандаПулл.ДобавитьПараметр("pull");
    КомандаПулл.ДобавитьПараметр("grafana/otel-lgtm");
    КомандаПулл.ПоказыватьВыводНемедленно(Истина);
    КомандаПулл.Исполнить();

    Контейнер = Новый ОбщийКонтейнер("grafana/otel-lgtm")
        .ОткрытьПорт(4318)
        .ОткрытьПорт(3200)
        .ОткрытьПорт(3100)
        .ОткрытьПорт(9090);

    Контейнер.Запустить();

    ПортOtlp = Контейнер.ПолучитьОткрытыйПорт(4318);
    ПортTempo = Контейнер.ПолучитьОткрытыйПорт(3200);
    ПортLoki = Контейнер.ПолучитьОткрытыйПорт(3100);
    ПортPrometheus = Контейнер.ПолучитьОткрытыйПорт(9090);

    // Ожидание готовности LGTM-стека
    ДождатьсяГотовности();

КонецПроцедуры

&ПослеВсех
Процедура ПослеВсех() Экспорт

    Контейнер.Остановить();

КонецПроцедуры

&Тест
Процедура ОтправкаТрассировки() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "integration-test");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlp);
    Экспортер = Новый ОтелHttpЭкспортерСпанов(Транспорт);
    Процессор = Новый ОтелПростойПроцессорСпанов(Экспортер);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, Процессор);

    Трассировщик = Провайдер.ПолучитьТрассировщик("test-library", "1.0.0");

    // Когда
    Спан = Трассировщик.НачатьСпан("интеграционный-тест");
    Спан.УстановитьВидСпана(ОтелВидСпана.Сервер());
    Спан.УстановитьАтрибут("test.type", "integration");

    ИдТрассировки = Спан.КонтекстСпана().ИдТрассировки();

    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());
    Спан.Завершить();

    Провайдер.Закрыть();

    // Ждем обработки данных Tempo
    ОтелУтилиты.Пауза(2);

    // Тогда — проверяем через API Tempo
    URLТрассировки = "http://localhost:" + ПортTempo + "/api/traces/" + ИдТрассировки;
    Ответ = КоннекторHTTP.Get(URLТрассировки);

    Ожидаем.Что(Ответ.КодСостояния).Равно(200);

КонецПроцедуры

&Тест
Процедура ОтправкаЛогов() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "integration-test-logs");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlp);
    Экспортер = Новый ОтелHttpЭкспортерЛогов(Транспорт);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, Экспортер);
    Логгер = Провайдер.ПолучитьЛоггер("test-library", "1.0.0");

    // Когда
    ЗаписьЛога = Логгер.СоздатьЗаписьЛога();
    ЗаписьЛога.УстановитьТело("Интеграционное тестовое сообщение")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Info());
    Логгер.Записать(ЗаписьЛога);

    // Ждем обработки данных Loki
    ОтелУтилиты.Пауза(2);

    // Тогда — проверяем через API Loki
    ПараметрыЗапроса = Новый Структура();
    ПараметрыЗапроса.Вставить("query", "{service_name=""integration-test-logs""}");
    URLЛоги = "http://localhost:" + ПортLoki + "/loki/api/v1/query_range";
    Ответ = КоннекторHTTP.Get(URLЛоги, ПараметрыЗапроса);

    Ожидаем.Что(Ответ.КодСостояния).Равно(200);

КонецПроцедуры

&Тест
Процедура ОтправкаМетрик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "integration-test-metrics");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlp);
    ЭкспортерМетрик = Новый ОтелHttpЭкспортерМетрик(Транспорт);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, ЭкспортерМетрик);
    Метрика = Провайдер.ПолучитьМетрику("test-library", "1.0.0");

    Счетчик = Метрика.СоздатьСчетчик("test_requests_total", "Тестовый счетчик", "1");

    // Когда
    Счетчик.Добавить(42);
    ЭкспортерМетрик.Экспортировать(Метрика);

    // Ждем обработки данных Prometheus
    ОтелУтилиты.Пауза(2);

    // Тогда — проверяем через API Prometheus
    ПараметрыЗапроса = Новый Структура();
    ПараметрыЗапроса.Вставить("query", "test_requests_total");
    URLМетрики = "http://localhost:" + ПортPrometheus + "/api/v1/query";
    Ответ = КоннекторHTTP.Get(URLМетрики, ПараметрыЗапроса);

    Ожидаем.Что(Ответ.КодСостояния).Равно(200);

КонецПроцедуры

Процедура ДождатьсяГотовности()

    МаксимальноеКоличествоПопыток = 30;
    Для НомерПопытки = 1 По МаксимальноеКоличествоПопыток Цикл
        Попытка
            URLГотовности = "http://localhost:" + ПортOtlp + "/v1/traces";
            КоннекторHTTP.Post(URLГотовности, "{}");
            Возврат;
        Исключение
            ОтелУтилиты.Пауза(1);
        КонецПопытки;
    КонецЦикла;

    ВызватьИсключение "LGTM-стек не готов после " + МаксимальноеКоличествоПопыток + " попыток";

КонецПроцедуры
