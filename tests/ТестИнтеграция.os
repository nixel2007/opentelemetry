// BSLLS:MagicNumber-off
// Интеграционные тесты с LGTM-стеком (Loki, Grafana, Tempo, Mimir/Prometheus).
// Запускают контейнер grafana/otel-lgtm через testcontainers.
// Проверяют отправку и чтение трассировки, логов и метрик через OTLP HTTP,
// верифицируя содержимое данных через API Tempo, Loki и Prometheus.
#Использовать ".."
#Использовать asserts
#Использовать 1connector
#Использовать lambdas
#Использовать testcontainers

Перем Контейнер;

Перем ПортOtlpHttp;
Перем ПортOtlpGrpc;
Перем ПортTempo;
Перем ПортLoki;
Перем ПортPrometheus;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта() Экспорт
КонецПроцедуры

&ПередВсеми
Процедура ПередВсеми() Экспорт

    Контейнер = Новый ОбщийКонтейнер("grafana/otel-lgtm")
        .ОткрытьПорт(4317)
        .ОткрытьПорт(4318)
        .ОткрытьПорт(3200)
        .ОткрытьПорт(3100)
        .ОткрытьПорт(9090);
    Контейнер.Запустить();

    ПортOtlpHttp = Контейнер.ПолучитьОткрытыйПорт(4318);
    ПортOtlpGrpc = Контейнер.ПолучитьОткрытыйПорт(4317);
    ПортTempo = Контейнер.ПолучитьОткрытыйПорт(3200);
    ПортLoki = Контейнер.ПолучитьОткрытыйПорт(3100);
    ПортPrometheus = Контейнер.ПолучитьОткрытыйПорт(9090);

    ДождатьсяГотовности();

КонецПроцедуры

&ПослеВсех
Процедура ПослеВсех() Экспорт
    Контейнер.Остановить();
КонецПроцедуры

// ===== ТРАССИРОВКА =====

&Тест
Процедура ТрассировкаСпанИмяИАтрибуты() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "trace-test-svc");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    Экспортер = Новый ОтелHttpЭкспортерСпанов(Транспорт);
    Процессор = Новый ОтелПростойПроцессорСпанов(Экспортер);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, Процессор);
    Трассировщик = Провайдер.ПолучитьТрассировщик("test-tracer", "2.0.0");

    // Когда
    Спан = Трассировщик.НачатьСпан("операция-получения-данных", ОтелВидСпана.Сервер());
    Спан.УстановитьАтрибут("http.method", "GET");
    Спан.УстановитьАтрибут("http.url", "/api/data");
    Спан.УстановитьАтрибут("http.status_code", 200);
    ИдТрассировки = Спан.КонтекстСпана().ИдТрассировки();
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());
    Спан.Завершить();
    Провайдер.Закрыть();

    // Тогда — читаем из Tempo и проверяем содержимое
    Данные = ПолучитьТрассировкуИзTempo(ИдТрассировки);
    Батч = Данные.batches[0];
    СпанДанные = Батч.scopeSpans[0].spans[0];

    // Имя спана
    Ожидаем.Что(СпанДанные.name).Равно("операция-получения-данных");

    // Вид спана (SPAN_KIND_SERVER)
    Ожидаем.Что(СпанДанные.kind).Равно("SPAN_KIND_SERVER");

    // Статус OK
    Ожидаем.Что(СпанДанные.status.code).Равно("STATUS_CODE_OK");

    // Атрибуты
    АтрибутыСоответствие = АтрибутыВСоответствие(СпанДанные.attributes);
    Ожидаем.Что(АтрибутыСоответствие.Получить("http.method")).Равно("GET");
    Ожидаем.Что(АтрибутыСоответствие.Получить("http.url")).Равно("/api/data");
    Ожидаем.Что(АтрибутыСоответствие.Получить("http.status_code")).Равно("200");

    // Ресурс — service.name
    РесурсАтр = АтрибутыВСоответствие(Батч.resource.attributes);
    Ожидаем.Что(РесурсАтр.Получить("service.name")).Равно("trace-test-svc");

    // Scope
    Ожидаем.Что(Батч.scopeSpans[0].scope.name).Равно("test-tracer");
    Ожидаем.Что(Батч.scopeSpans[0].scope.version).Равно("2.0.0");

КонецПроцедуры

&Тест
Процедура ТрассировкаРодительскийИДочернийСпан() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "parent-child-svc");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    Экспортер = Новый ОтелHttpЭкспортерСпанов(Транспорт);
    Процессор = Новый ОтелПростойПроцессорСпанов(Экспортер);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, Процессор);
    Трассировщик = Провайдер.ПолучитьТрассировщик("test-tracer", "1.0.0");

    // Когда — создаём родительский и дочерний спан
    Родитель = Трассировщик.НачатьКорневойСпан("родительская-операция");
    Родитель.УстановитьАтрибут("role", "parent");
    ИдТрассировки = Родитель.КонтекстСпана().ИдТрассировки();

    Дочерний = Трассировщик.НачатьДочернийСпан("дочерняя-операция", Родитель, ОтелВидСпана.Клиент());
    Дочерний.УстановитьАтрибут("role", "child");
    Дочерний.Завершить();

    Родитель.Завершить();
    Провайдер.Закрыть();

    // Тогда — в Tempo должны быть оба спана с общим traceId
    Данные = ПолучитьТрассировкуИзTempo(ИдТрассировки, 2);
    ВсеСпаны = СобратьВсеСпаны(Данные);

    Ожидаем.Что(ВсеСпаны.Количество()).Равно(2);

    // Проверяем имена спанов
    ИменаСпанов = Новый Массив();
    Для Каждого С Из ВсеСпаны Цикл
        ИменаСпанов.Добавить(С.name);
    КонецЦикла;
    Ожидаем.Что(ИменаСпанов).Содержит("родительская-операция");
    Ожидаем.Что(ИменаСпанов).Содержит("дочерняя-операция");

    // Дочерний спан должен иметь parentSpanId
    ДочернийСпан = Неопределено;
    Для Каждого С Из ВсеСпаны Цикл
        Если С.name = "дочерняя-операция" Тогда
            ДочернийСпан = С;
        КонецЕсли;
    КонецЦикла;

    Ожидаем.Что(ДочернийСпан).Не_().Равно(Неопределено);
    Ожидаем.Что(ДочернийСпан.kind).Равно("SPAN_KIND_CLIENT");

    // parentSpanId должен быть непустым (base64-encoded)
    Попытка
        Ожидаем.Что(СтрДлина(ДочернийСпан.parentSpanId) > 0).Равно(Истина);
    Исключение
        // parentSpanId может быть в структуре как свойство
    КонецПопытки;

КонецПроцедуры

&Тест
Процедура ТрассировкаСобытияСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "event-test-svc");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    Экспортер = Новый ОтелHttpЭкспортерСпанов(Транспорт);
    Процессор = Новый ОтелПростойПроцессорСпанов(Экспортер);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, Процессор);
    Трассировщик = Провайдер.ПолучитьТрассировщик("test-tracer", "1.0.0");

    // Когда — спан с событиями
    Спан = Трассировщик.НачатьСпан("операция-с-событиями");
    Спан.ДобавитьСобытие("начало-обработки");

    АтрибутыОшибки = Новый ОтелАтрибуты();
    АтрибутыОшибки.Установить("error.code", "ERR_TIMEOUT");
    Спан.ДобавитьСобытие("ошибка-таймаута", АтрибутыОшибки);

    ИдТрассировки = Спан.КонтекстСпана().ИдТрассировки();
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "таймаут соединения");
    Спан.Завершить();
    Провайдер.Закрыть();

    // Тогда — проверяем события в Tempo
    Данные = ПолучитьТрассировкуИзTempo(ИдТрассировки);
    СпанДанные = Данные.batches[0].scopeSpans[0].spans[0];

    // Статус — ошибка
    Ожидаем.Что(СпанДанные.status.code).Равно("STATUS_CODE_ERROR");

    // Должны быть события
    Ожидаем.Что(СпанДанные.events.Количество()).Равно(2);

    ИменаСобытий = Новый Массив();
    Для Каждого Событие Из СпанДанные.events Цикл
        ИменаСобытий.Добавить(Событие.name);
    КонецЦикла;
    Ожидаем.Что(ИменаСобытий).Содержит("начало-обработки");
    Ожидаем.Что(ИменаСобытий).Содержит("ошибка-таймаута");

    // Атрибуты события ошибки
    Для Каждого Событие Из СпанДанные.events Цикл
        Если Событие.name = "ошибка-таймаута" Тогда
            СобытиеАтр = АтрибутыВСоответствие(Событие.attributes);
            Ожидаем.Что(СобытиеАтр.Получить("error.code")).Равно("ERR_TIMEOUT");
        КонецЕсли;
    КонецЦикла;

КонецПроцедуры

// ===== ЛОГИРОВАНИЕ =====

&Тест
Процедура ЛогированиеТелоИСерьезность() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "log-body-test");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    Экспортер = Новый ОтелHttpЭкспортерЛогов(Транспорт);
    Процессор = Новый ОтелПростойПроцессорЛогов(Экспортер);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, Процессор);
    Логгер = Провайдер.ПолучитьЛоггер("test-logger", "1.0.0");

    // Когда — отправляем лог с уникальным телом
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("Уникальное тестовое сообщение ABC123")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Warn());
    Логгер.Записать(Запись);

    // Тогда — читаем из Loki и проверяем содержимое
    Результат = ПолучитьЛогиИзLoki("log-body-test");

    Ожидаем.Что(Результат.Количество() > 0).Равно(Истина);

    ПервыйПоток = Результат[0];
    Метки = ПервыйПоток.stream;

    // Проверяем метки потока
    Ожидаем.Что(Метки.service_name).Равно("log-body-test");
    Ожидаем.Что(Метки.severity_text).Равно("WARN");
    Ожидаем.Что(Метки.scope_name).Равно("test-logger");

    // Проверяем тело лога
    Значения = ПервыйПоток.values;
    Ожидаем.Что(Значения.Количество() > 0).Равно(Истина);
    ТелоЛога = Значения[0][1];
    Ожидаем.Что(ТелоЛога).Равно("Уникальное тестовое сообщение ABC123");

КонецПроцедуры

&Тест
Процедура ЛогированиеКорреляцияСТрассировкой() Экспорт

    // Дано — создаём трассировку и лог, связанные через traceId
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "log-trace-corr");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);

    ЭкспортерСпанов = Новый ОтелHttpЭкспортерСпанов(Транспорт);
    ПроцессорСпанов = Новый ОтелПростойПроцессорСпанов(ЭкспортерСпанов);
    ПровайдерТрейсов = Новый ОтелПровайдерТрассировки(Ресурс, ПроцессорСпанов);
    Трассировщик = ПровайдерТрейсов.ПолучитьТрассировщик("test-tracer", "1.0.0");

    ЭкспортерЛогов = Новый ОтелHttpЭкспортерЛогов(Транспорт);
    ПроцессорЛогов = Новый ОтелПростойПроцессорЛогов(ЭкспортерЛогов);
    ПровайдерЛогов = Новый ОтелПровайдерЛогирования(Ресурс, ПроцессорЛогов);
    Логгер = ПровайдерЛогов.ПолучитьЛоггер("test-logger", "1.0.0");

    // Когда — создаём спан и привязываем лог к нему
    Спан = Трассировщик.НачатьСпан("операция-с-логом");
    ИдТрассировки = Спан.КонтекстСпана().ИдТрассировки();

    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("Лог внутри спана")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Info());
    Логгер.Записать(Запись);

    Спан.Завершить();
    ПровайдерТрейсов.Закрыть();

    // Тогда — лог в Loki содержит traceId
    Результат = ПолучитьЛогиИзLoki("log-trace-corr");
    Ожидаем.Что(Результат.Количество() > 0).Равно(Истина);

    // Тело лога соответствует
    ТелоЛога = Результат[0].values[0][1];
    Ожидаем.Что(ТелоЛога).Равно("Лог внутри спана");

    // Спан в Tempo тоже доступен
    ДанныеТрейса = ПолучитьТрассировкуИзTempo(ИдТрассировки);
    СпанДанные = ДанныеТрейса.batches[0].scopeSpans[0].spans[0];
    Ожидаем.Что(СпанДанные.name).Равно("операция-с-логом");

КонецПроцедуры

&Тест
Процедура ЛогированиеАтрибуты() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "log-attrs-test");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    Экспортер = Новый ОтелHttpЭкспортерЛогов(Транспорт);
    Процессор = Новый ОтелПростойПроцессорЛогов(Экспортер);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, Процессор);
    Логгер = Провайдер.ПолучитьЛоггер("test-logger", "1.0.0");

    // Когда — лог с атрибутами
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("лог с атрибутами")
        .УстановитьСерьезность(ОтелСтепеньСерьезности.Error())
        .УстановитьАтрибут("user.id", "user-42")
        .УстановитьАтрибут("request.path", "/api/users");
    Логгер.Записать(Запись);

    // Тогда — атрибуты лога попадают в метки потока Loki
    Результат = ПолучитьЛогиИзLoki("log-attrs-test");
    Ожидаем.Что(Результат.Количество() > 0).Равно(Истина);

    Метки = Результат[0].stream;
    Ожидаем.Что(Метки.severity_text).Равно("ERROR");

КонецПроцедуры

// ===== МЕТРИКИ =====

&Тест
Процедура МетрикиСчетчикЗначениеИМетки() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "metric-counter-svc");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    ЭкспортерМетрик = Новый ОтелHttpЭкспортерМетрик(Транспорт);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, ЭкспортерМетрик);
    Метрика = Провайдер.ПолучитьМетр("test-meter", "1.0.0");

    // Когда — инкрементируем счетчик
    Счетчик = Метрика.СоздатьСчетчик("integ_http_requests_total", "HTTP запросы", "1");
    Счетчик.Добавить(10);
    Счетчик.Добавить(5);
    Счетчик.Добавить(3);
    ЭкспортерМетрик.Экспортировать(Метрика);

    // Тогда — в Prometheus значение = 18
    ДанныеМетрики = ПолучитьМетрикуИзPrometheus("integ_http_requests_total");
    Ожидаем.Что(ДанныеМетрики.Количество() > 0).Равно(Истина);

    ПерваяМетрика = ДанныеМетрики[0];
    ЗначениеСтрока = ПерваяМетрика.value[1];
    Ожидаем.Что(Число(ЗначениеСтрока)).Равно(18);

    // Проверяем метки — job/service_name
    Ожидаем.Что(ПерваяМетрика.metric.service_name).Равно("metric-counter-svc");

КонецПроцедуры

&Тест
Процедура МетрикиГистограммаБакеты() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "metric-histogram-svc");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    ЭкспортерМетрик = Новый ОтелHttpЭкспортерМетрик(Транспорт);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, ЭкспортерМетрик);
    Метрика = Провайдер.ПолучитьМетр("test-meter", "1.0.0");

    // Когда — записываем значения в гистограмму
    Гистограмма = Метрика.СоздатьГистограмму("integ_request_duration", "Длительность", "ms");
    Гистограмма.Записать(50);
    Гистограмма.Записать(150);
    Гистограмма.Записать(300);
    ЭкспортерМетрик.Экспортировать(Метрика);

    // Тогда — в Prometheus есть метрика _count со значением 3
    // OTLP→Prometheus конвертирует unit "ms" в суффикс "_milliseconds"
    ДанныеМетрики = ПолучитьМетрикуИзPrometheus("integ_request_duration_milliseconds_count");
    Ожидаем.Что(ДанныеМетрики.Количество() > 0).Равно(Истина);

    ЗначениеСтрока = ДанныеМетрики[0].value[1];
    Ожидаем.Что(Число(ЗначениеСтрока)).Равно(3);

    // Проверяем _sum
    ДанныеСуммы = ПолучитьМетрикуИзPrometheus("integ_request_duration_milliseconds_sum");
    Ожидаем.Что(ДанныеСуммы.Количество() > 0).Равно(Истина);
    Ожидаем.Что(Число(ДанныеСуммы[0].value[1])).Равно(500);

КонецПроцедуры

&Тест
Процедура МетрикиРеверсивныйСчетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "metric-updown-svc");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    ЭкспортерМетрик = Новый ОтелHttpЭкспортерМетрик(Транспорт);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, ЭкспортерМетрик);
    Метрика = Провайдер.ПолучитьМетр("test-meter", "1.0.0");

    // Когда
    РевСчетчик = Метрика.СоздатьРеверсивныйСчетчик("integ_active_connections", "Активные соединения", "1");
    РевСчетчик.Добавить(10);
    РевСчетчик.Добавить(-3);
    ЭкспортерМетрик.Экспортировать(Метрика);

    // Тогда — значение = 7
    ДанныеМетрики = ПолучитьМетрикуИзPrometheus("integ_active_connections");
    Ожидаем.Что(ДанныеМетрики.Количество() > 0).Равно(Истина);
    Ожидаем.Что(Число(ДанныеМетрики[0].value[1])).Равно(7);

КонецПроцедуры

// ===== РЕСУРСЫ =====

&Тест
Процедура РесурсАтрибутыВТрассировке() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "resource-attr-svc");
    Ресурс.Атрибуты().Установить("service.version", "3.5.0");
    Ресурс.Атрибуты().Установить("deployment.environment", "staging");

    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + ПортOtlpHttp);
    Экспортер = Новый ОтелHttpЭкспортерСпанов(Транспорт);
    Процессор = Новый ОтелПростойПроцессорСпанов(Экспортер);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, Процессор);
    Трассировщик = Провайдер.ПолучитьТрассировщик("test-tracer", "1.0.0");

    // Когда
    Спан = Трассировщик.НачатьСпан("ресурсный-тест");
    ИдТрассировки = Спан.КонтекстСпана().ИдТрассировки();
    Спан.Завершить();
    Провайдер.Закрыть();

    // Тогда — ресурсные атрибуты доступны в Tempo
    Данные = ПолучитьТрассировкуИзTempo(ИдТрассировки);
    РесурсАтр = АтрибутыВСоответствие(Данные.batches[0].resource.attributes);

    Ожидаем.Что(РесурсАтр.Получить("service.name")).Равно("resource-attr-svc");
    Ожидаем.Что(РесурсАтр.Получить("service.version")).Равно("3.5.0");
    Ожидаем.Что(РесурсАтр.Получить("deployment.environment")).Равно("staging");
    Ожидаем.Что(РесурсАтр.Получить("telemetry.sdk.language")).Равно("oscript");

КонецПроцедуры

// ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====

Функция ПрочитатьОтветJSON(Ответ)
    Тело = Ответ.Текст();
    ЧтениеJSON = Новый ЧтениеJSON();
    ЧтениеJSON.УстановитьСтроку(Тело);
    Возврат ПрочитатьJSON(ЧтениеJSON);
КонецФункции

Функция АтрибутыВСоответствие(МассивАтрибутов)
    Результат = Новый Соответствие();
    Если МассивАтрибутов = Неопределено Тогда
        Возврат Результат;
    КонецЕсли;
    Для Каждого Атр Из МассивАтрибутов Цикл
        Попытка
            Результат.Вставить(Атр.key, Атр.value.stringValue);
        Исключение
            Попытка
                Результат.Вставить(Атр.key, Атр.value.intValue);
            Исключение
                Попытка
                    Результат.Вставить(Атр.key, Атр.value.doubleValue);
                Исключение
                    Попытка
                        Результат.Вставить(Атр.key, Атр.value.boolValue);
                    Исключение
                        Результат.Вставить(Атр.key, "");
                    КонецПопытки;
                КонецПопытки;
            КонецПопытки;
        КонецПопытки;
    КонецЦикла;
    Возврат Результат;
КонецФункции

Функция СобратьВсеСпаны(ДанныеТрассировки)
    ВсеСпаны = Новый Массив();
    Для Каждого Батч Из ДанныеТрассировки.batches Цикл
        Для Каждого СкоупСпан Из Батч.scopeSpans Цикл
            Для Каждого С Из СкоупСпан.spans Цикл
                ВсеСпаны.Добавить(С);
            КонецЦикла;
        КонецЦикла;
    КонецЦикла;
    Возврат ВсеСпаны;
КонецФункции

Функция ПолучитьТрассировкуИзTempo(ИдТрассировки, ОжидаемоеКоличествоСпанов = 1)
    URL = "http://localhost:" + ПортTempo + "/api/traces/" + ИдТрассировки;
    МаксПопыток = 20;
    Для НомерПопытки = 1 По МаксПопыток Цикл
        Попытка
            Ответ = КоннекторHTTP.Get(URL);
            Если Ответ.КодСостояния = 200 Тогда
                Данные = ПрочитатьОтветJSON(Ответ);
                Попытка
                    Если Данные.batches.Количество() > 0 Тогда
                        ВсеСпаны = СобратьВсеСпаны(Данные);
                        Если ВсеСпаны.Количество() >= ОжидаемоеКоличествоСпанов Тогда
                            Возврат Данные;
                        КонецЕсли;
                    КонецЕсли;
                Исключение
                    // Данные ещё не появились
                КонецПопытки;
            КонецЕсли;
        Исключение
            // Сервис ещё не готов
        КонецПопытки;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Трассировка " + ИдТрассировки + " не найдена в Tempo";
КонецФункции

Функция ПолучитьЛогиИзLoki(СервисИмя)
    URL = "http://localhost:" + ПортLoki + "/loki/api/v1/query_range";
    МаксПопыток = 20;
    Для НомерПопытки = 1 По МаксПопыток Цикл
        Попытка
            ПараметрыЗапроса = Новый Структура();
            ПараметрыЗапроса.Вставить("query", "{service_name=""" + СервисИмя + """}");
            ПараметрыЗапроса.Вставить("limit", "100");
            Ответ = КоннекторHTTP.Get(URL, ПараметрыЗапроса);
            Если Ответ.КодСостояния = 200 Тогда
                Данные = ПрочитатьОтветJSON(Ответ);
                Если Данные.data.result.Количество() > 0 Тогда
                    Возврат Данные.data.result;
                КонецЕсли;
            КонецЕсли;
        Исключение
            // Сервис ещё не готов
        КонецПопытки;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Логи для " + СервисИмя + " не найдены в Loki";
КонецФункции

Функция ПолучитьМетрикуИзPrometheus(ИмяМетрики)
    URL = "http://localhost:" + ПортPrometheus + "/api/v1/query";
    МаксПопыток = 20;
    Для НомерПопытки = 1 По МаксПопыток Цикл
        Попытка
            ПараметрыЗапроса = Новый Структура();
            ПараметрыЗапроса.Вставить("query", ИмяМетрики);
            Ответ = КоннекторHTTP.Get(URL, ПараметрыЗапроса);
            Если Ответ.КодСостояния = 200 Тогда
                Данные = ПрочитатьОтветJSON(Ответ);
                Если Данные.data.result.Количество() > 0 Тогда
                    Возврат Данные.data.result;
                КонецЕсли;
            КонецЕсли;
        Исключение
            // Сервис ещё не готов
        КонецПопытки;
        Приостановить(1000);
    КонецЦикла;
    ВызватьИсключение "Метрика " + ИмяМетрики + " не найдена в Prometheus";
КонецФункции

Процедура ДождатьсяГотовности()

    МаксимальноеКоличествоПопыток = 60;
    Для НомерПопытки = 1 По МаксимальноеКоличествоПопыток Цикл
        Попытка
            URLГотовности = "http://localhost:" + ПортOtlpHttp + "/v1/traces";
            Заголовки = Новый Соответствие();
            Заголовки.Вставить("Content-Type", "application/json");
            ДополнительныеПараметры = Новый Структура("Заголовки", Заголовки);
            Ответ = КоннекторHTTP.Post(URLГотовности, "{}", , ДополнительныеПараметры);
            Если Ответ.КодСостояния = 200 Тогда
                Возврат;
            КонецЕсли;
        Исключение
            Приостановить(1000);
        КонецПопытки;
    КонецЦикла;

    ВызватьИсключение "LGTM-стек не готов после " + МаксимальноеКоличествоПопыток + " попыток";

КонецПроцедуры


