// BSLLS:MagicNumber-off
#Использовать ".."
#Использовать asserts

&Тест
Процедура СозданиеСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "test-service");

    // Когда
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Тогда
    Ожидаем.Что(Спан.Имя()).Равно("test-operation");
    Ожидаем.Что(Спан.ИмяБиблиотеки()).Равно("test-library");
    Ожидаем.Что(Спан.ВерсияБиблиотеки()).Равно("1.0.0");
    Ожидаем.Что(Спан.Завершен()).Равно(Ложь);
    Ожидаем.Что(СтрДлина(Спан.КонтекстСпана().ИдТрассировки())).Равно(32);
    Ожидаем.Что(СтрДлина(Спан.КонтекстСпана().ИдСпана())).Равно(16);

КонецПроцедуры

&Тест
Процедура ЗавершениеСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда
    Спан.Завершить();

    // Тогда
    Ожидаем.Что(Спан.Завершен()).Равно(Истина);
    Ожидаем.Что(Спан.ВремяОкончания()).Не_().Равно("");

КонецПроцедуры

&Тест
Процедура УстановкаАтрибутовСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда
    Спан.УстановитьАтрибут("http.method", "GET");
    Спан.УстановитьАтрибут("http.status_code", 200);

    // Тогда
    Ожидаем.Что(Спан.Атрибуты().Получить("http.method")).Равно("GET");
    Ожидаем.Что(Спан.Атрибуты().Получить("http.status_code")).Равно(200);

КонецПроцедуры

&Тест
Процедура НеизменяемостьЗавершенногоСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");
    Спан.Завершить();

    // Когда
    Спан.УстановитьАтрибут("new.attr", "value");

    // Тогда
    Ожидаем.Что(Спан.Атрибуты().Получить("new.attr")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ДобавлениеСобытийКСпану() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда
    Спан.ДобавитьСобытие("event-1");

    АтрибутыСобытия = Новый ОтелАтрибуты();
    АтрибутыСобытия.Установить("exception.type", "RuntimeError");
    Спан.ДобавитьСобытие("exception", АтрибутыСобытия);

    // Тогда
    Ожидаем.Что(Спан.События()).ИмеетДлину(2);
    Ожидаем.Что(Спан.События()[0].Имя()).Равно("event-1");
    Ожидаем.Что(Спан.События()[1].Имя()).Равно("exception");

КонецПроцедуры

&Тест
Процедура УстановкаСтатусаСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "Something went wrong");

    // Тогда
    Ожидаем.Что(Спан.КодСтатуса()).Равно(2);
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("Something went wrong");

КонецПроцедуры

&Тест
Процедура УстановкаВидаСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();

    // Когда — вид спана задаётся при создании (immutable по спецификации)
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0", , , , ОтелВидСпана.Сервер());

    // Тогда
    Ожидаем.Что(Спан.ВидСпана()).Равно(2);

КонецПроцедуры

&Тест
Процедура ВидСпанаПоУмолчаниюВнутренний() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();

    // Когда — без указания вида, используется Внутренний
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Тогда
    Ожидаем.Что(Спан.ВидСпана()).Равно(ОтелВидСпана.Внутренний());

КонецПроцедуры

&Тест
Процедура ИзменениеИмениСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("original-name", Ресурс, "test-library", "1.0.0");

    // Когда
    Спан.ИзменитьИмя("new-name");

    // Тогда
    Ожидаем.Что(Спан.Имя()).Равно("new-name");

    // И после завершения имя нельзя менять
    Спан.Завершить();
    Спан.ИзменитьИмя("should-not-change");
    Ожидаем.Что(Спан.Имя()).Равно("new-name");

КонецПроцедуры

&Тест
Процедура ЗаписьАктивна() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Тогда — до завершения ЗаписьАктивна = Истина
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Истина);

    // Когда
    Спан.Завершить();

    // Тогда — после завершения ЗаписьАктивна = Ложь
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ВидСпанаЧерезТрассировщик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Трассировщик = Новый ОтелТрассировщик("test-library", "1.0.0", Ресурс);

    // Когда
    СпанСервер = Трассировщик.НачатьСпан("server-op", ОтелВидСпана.Сервер());
    СпанКлиент = Трассировщик.НачатьДочернийСпан("client-op", СпанСервер, ОтелВидСпана.Клиент());

    // Тогда
    Ожидаем.Что(СпанСервер.ВидСпана()).Равно(ОтелВидСпана.Сервер());
    Ожидаем.Что(СпанКлиент.ВидСпана()).Равно(ОтелВидСпана.Клиент());

КонецПроцедуры

&Тест
Процедура СтатусОкФинальный() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда — устанавливаем OK, затем пытаемся перейти в ERROR
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "Should be ignored");

    // Тогда — статус остаётся OK
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ок());
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("");

КонецПроцедуры

&Тест
Процедура СтатусОшибкаНельзяВернутьВНеУстановлен() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда — устанавливаем ERROR, затем пытаемся вернуть в UNSET
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "Error occurred");
    Спан.УстановитьСтатус(ОтелКодСтатуса.НеУстановлен());

    // Тогда — статус остаётся ERROR
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ошибка());
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("Error occurred");

КонецПроцедуры

&Тест
Процедура СтатусОшибкаМожноПеревестиВОк() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда — устанавливаем ERROR, затем OK
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "Error occurred");
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());

    // Тогда — статус перешёл в OK
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ок());
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("");

КонецПроцедуры

&Тест
Процедура СозданиеДочернегоСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Трассировщик = Новый ОтелТрассировщик("test-library", "1.0.0", Ресурс);

    РодительскийСпан = Трассировщик.НачатьСпан("parent-operation");

    // Когда
    ДочернийСпан = Трассировщик.НачатьДочернийСпан("child-operation", РодительскийСпан);

    // Тогда
    Ожидаем.Что(ДочернийСпан.Имя()).Равно("child-operation");
    Ожидаем.Что(ДочернийСпан.КонтекстСпана().ИдТрассировки()).Равно(РодительскийСпан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(ДочернийСпан.ИдРодительскогоСпана()).Равно(РодительскийСпан.КонтекстСпана().ИдСпана());

КонецПроцедуры
