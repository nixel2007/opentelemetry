Процедура W3CПропагаторИзвлечениеБезЗаголовка() Экспорт

    // Дано
    Заголовки = Новый Соответствие();

    // Когда
    Результат = ОтелW3CПропагатор.Извлечь(Заголовки);

    // Тогда
    Ожидаем.Что(Результат).Равно(Неопределено);

