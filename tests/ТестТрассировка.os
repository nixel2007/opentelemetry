&Тест
Процедура ЛокальныйКонтекстНеУдалённый() Экспорт

    // Дано — контекст, созданный локально
    Контекст = Новый ОтелКонтекстСпана("abcdef0123456789abcdef0123456789", "0123456789abcdef");

    // Тогда
    Ожидаем.Что(Контекст.Удалённый()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ДочернийСпанОтКонтекстаСпана() Экспорт

    // Дано — имитация распределённой трассировки: контекст получен через W3C propagator
    Ресурс = Новый ОтелРесурс();
    Трассировщик = Новый ОтелТрассировщик("test-library", "1.0.0", Ресурс);
    УдалённыйКонтекст = Новый ОтелКонтекстСпана("abcdef0123456789abcdef0123456789", "0123456789abcdef", 1, "", Истина);

    // Когда — создаём дочерний спан от ОтелКонтекстСпана (не от ОтелСпан)
    Дочерний = Трассировщик.НачатьДочернийСпан("child-op", УдалённыйКонтекст, ОтелВидСпана.Сервер());

    // Тогда — наследует traceId и parentId
    Ожидаем.Что(Дочерний.КонтекстСпана().ИдТрассировки()).Равно("abcdef0123456789abcdef0123456789");
    Ожидаем.Что(Дочерний.ИдРодительскогоСпана()).Равно("0123456789abcdef");
    Ожидаем.Что(Дочерний.ВидСпана()).Равно(ОтелВидСпана.Сервер());

КонецПроцедуры

&Тест
Процедура ЗаписатьИсключение() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда — вызываем ЗаписатьИсключение с ИнформацияОбОшибке
    Попытка
        ВызватьИсключение "Тестовая ошибка";
    Исключение
        Спан.ЗаписатьИсключение(ИнформацияОбОшибке());
    КонецПопытки;

    // Тогда — создано событие "exception" с атрибутом exception.message
    Ожидаем.Что(Спан.События()).ИмеетДлину(1);
    Ожидаем.Что(Спан.События()[0].Имя()).Равно("exception");
    Ожидаем.Что(Спан.События()[0].Атрибуты().Получить("exception.message")).Равно("Тестовая ошибка");

КонецПроцедуры

&Тест
Процедура ЗавершитьСОпциональнымВременем() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");
    ВремяОкончания = "1234567890000000000";

    // Когда
    Спан.Завершить(ВремяОкончания);

    // Тогда — используется заданное время, а не текущее
    Ожидаем.Что(Спан.Завершен()).Равно(Истина);
    Ожидаем.Что(Спан.ВремяОкончания()).Равно("1234567890000000000");

КонецПроцедуры

&Тест
Процедура ДобавитьСобытиеСОпциональнымВременем() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");
    МеткаВремени = "9999999999000000000";

    // Когда
    Спан.ДобавитьСобытие("test-event", , МеткаВремени);

    // Тогда — событие использует заданное время
    Ожидаем.Что(Спан.События()).ИмеетДлину(1);
    Ожидаем.Что(Спан.События()[0].Время()).Равно("9999999999000000000");

КонецПроцедуры

&Тест
Процедура ЛимитыСпана() Экспорт

    // Дано — спан с лимитом 128 (по умолчанию)
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда — добавляем 130 атрибутов
    Для Индекс = 1 По 130 Цикл
        Спан.УстановитьАтрибут("attr." + Индекс, Индекс);
    КонецЦикла;

    // Тогда — только 128
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(128);

    // Перезапись существующего ключа разрешена
    Спан.УстановитьАтрибут("attr.1", 999);
    Ожидаем.Что(Спан.Атрибуты().Получить("attr.1")).Равно(999);
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(128);

КонецПроцедуры

