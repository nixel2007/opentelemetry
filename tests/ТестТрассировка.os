&Тест
Процедура W3CПропагаторИзвлечённыйКонтекстУдалённый() Экспорт

    // Дано
    Заголовки = Новый Соответствие();
    Заголовки.Вставить("traceparent", "00-abcdef0123456789abcdef0123456789-0123456789abcdef-01");

    // Когда
    Контекст = ОтелW3CПропагатор.Извлечь(Заголовки);

    // Тогда — контекст, извлечённый из заголовков, должен быть помечен как удалённый
    Ожидаем.Что(Контекст.Удалённый()).Равно(Истина);

