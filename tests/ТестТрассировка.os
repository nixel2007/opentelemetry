&Тест
Процедура СемплерДетерминированный() Экспорт

    // Дано — один и тот же TraceId при одной доле должен давать одинаковый результат
    ИдТрассировки = "0af7651916cd43dd8448eb211c80319c";

    // Когда
    Решение1 = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 0.5, ИдТрассировки);
    Решение2 = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 0.5, ИдТрассировки);

    // Тогда — результат одинаковый (детерминированный)
    Ожидаем.Что(Решение1).Равно(Решение2);

КонецПроцедуры
