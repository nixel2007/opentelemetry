&Тест
Процедура ВидСпанаЧерезТрассировщик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Трассировщик = Новый ОтелТрассировщик("test-library", "1.0.0", Ресурс);

    // Когда
    СпанСервер = Трассировщик.НачатьСпан("server-op", ОтелВидСпана.Сервер());
    СпанКлиент = Трассировщик.НачатьДочернийСпан("client-op", СпанСервер, ОтелВидСпана.Клиент());

    // Тогда
    Ожидаем.Что(СпанСервер.ВидСпана()).Равно(ОтелВидСпана.Сервер());
    Ожидаем.Что(СпанКлиент.ВидСпана()).Равно(ОтелВидСпана.Клиент());

КонецПроцедуры

&Тест
Процедура СтатусОкФинальный() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда — устанавливаем OK, затем пытаемся перейти в ERROR
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "Should be ignored");

    // Тогда — статус остаётся OK
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ок());
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("");

КонецПроцедуры

&Тест
Процедура СтатусОшибкаНельзяВернутьВНеУстановлен() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда — устанавливаем ERROR, затем пытаемся вернуть в UNSET
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "Error occurred");
    Спан.УстановитьСтатус(ОтелКодСтатуса.НеУстановлен());

    // Тогда — статус остаётся ERROR
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ошибка());
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("Error occurred");

КонецПроцедуры

&Тест
Процедура СтатусОшибкаМожноПеревестиВОк() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");

    // Когда — устанавливаем ERROR, затем OK
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "Error occurred");
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());

    // Тогда — статус перешёл в OK
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ок());
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("");

КонецПроцедуры

&Тест
Процедура СозданиеДочернегоСпана() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Трассировщик = Новый ОтелТрассировщик("test-library", "1.0.0", Ресурс);

    РодительскийСпан = Трассировщик.НачатьСпан("parent-operation");

    // Когда
    ДочернийСпан = Трассировщик.НачатьДочернийСпан("child-operation", РодительскийСпан);

    // Тогда
    Ожидаем.Что(ДочернийСпан.Имя()).Равно("child-operation");
    Ожидаем.Что(ДочернийСпан.КонтекстСпана().ИдТрассировки()).Равно(РодительскийСпан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(ДочернийСпан.ИдРодительскогоСпана()).Равно(РодительскийСпан.КонтекстСпана().ИдСпана());

КонецПроцедуры

&Тест
Процедура КонтекстАвтоматическийРодитель() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс();
    Трассировщик = Новый ОтелТрассировщик("test-library", "1.0.0", Ресурс);

    // Когда — родительский спан делается текущим
    Родитель = Трассировщик.НачатьСпан("parent");
    Родитель.СделатьТекущим();

    // НачатьСпан автоматически берёт родителя из контекста
    Дочерний = Трассировщик.НачатьСпан("child");

    // Тогда — дочерний спан связан с родителем
    Ожидаем.Что(Дочерний.КонтекстСпана().ИдТрассировки()).Равно(Родитель.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Дочерний.ИдРодительскогоСпана()).Равно(Родитель.КонтекстСпана().ИдСпана());

    Родитель.Завершить();
    Дочерний.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура КонтекстВосстанавливаетсяПриЗавершении() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс();
    Трассировщик = Новый ОтелТрассировщик("test-library", "1.0.0", Ресурс);

    Родитель = Трассировщик.НачатьСпан("parent");
    Родитель.СделатьТекущим();

    Дочерний = Трассировщик.НачатьСпан("child");
    Дочерний.СделатьТекущим();

    // Когда — завершаем дочерний
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Дочерний);
    Дочерний.Завершить();

    // Тогда — контекст восстановлен до родителя
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Родитель);

    Родитель.Завершить();
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Неопределено);

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура КорневойСпанИгнорируетКонтекст() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс();
    Трассировщик = Новый ОтелТрассировщик("test-library", "1.0.0", Ресурс);

    Родитель = Трассировщик.НачатьСпан("parent");
    Родитель.СделатьТекущим();

    // Когда — создаём корневой спан, он НЕ берёт родителя из контекста
    Корневой = Трассировщик.НачатьКорневойСпан("root");

    // Тогда — у корневого свой traceId и нет родителя
    Ожидаем.Что(Корневой.ИдРодительскогоСпана()).Равно("");
    Ожидаем.Что(Корневой.КонтекстСпана().ИдТрассировки()).Не_().Равно(Родитель.КонтекстСпана().ИдТрассировки());

    Родитель.Завершить();
    Корневой.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ДобавлениеЛинков() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-operation", Ресурс, "test-library", "1.0.0");
    СвязанныйКонтекст = Новый ОтелКонтекстСпана("abcdef0123456789abcdef0123456789", "0123456789abcdef");

    АтрибутыЛинка = Новый ОтелАтрибуты();
    АтрибутыЛинка.Установить("link.reason", "retry");

    // Когда
    Спан.ДобавитьЛинк(СвязанныйКонтекст, АтрибутыЛинка);

    // Тогда
    Ожидаем.Что(Спан.Линки()).ИмеетДлину(1);
    Ожидаем.Что(Спан.Линки()[0].Получить("КонтекстСпана").ИдТрассировки()).Равно("abcdef0123456789abcdef0123456789");
    Ожидаем.Что(Спан.Линки()[0].Получить("Атрибуты").Получить("link.reason")).Равно("retry");

КонецПроцедуры

&Тест
Процедура W3CПропагаторВнедрениеИИзвлечение() Экспорт

    // Дано
    КонтекстСпана = Новый ОтелКонтекстСпана("abcdef0123456789abcdef0123456789", "0123456789abcdef", 1, "vendor1=value1");
    Заголовки = Новый Соответствие();

    // Когда — внедряем
    ОтелW3CПропагатор.Внедрить(КонтекстСпана, Заголовки);

    // Тогда — заголовки заполнены
    Ожидаем.Что(Заголовки.Получить("traceparent")).Равно("00-abcdef0123456789abcdef0123456789-0123456789abcdef-01");
    Ожидаем.Что(Заголовки.Получить("tracestate")).Равно("vendor1=value1");

    // Когда — извлекаем из тех же заголовков
    Извлечённый = ОтелW3CПропагатор.Извлечь(Заголовки);

    // Тогда — контексты совпадают
    Ожидаем.Что(Извлечённый.ИдТрассировки()).Равно("abcdef0123456789abcdef0123456789");
    Ожидаем.Что(Извлечённый.ИдСпана()).Равно("0123456789abcdef");
    Ожидаем.Что(Извлечённый.ФлагиТрассировки()).Равно(1);
    Ожидаем.Что(Извлечённый.СостояниеТрассировки()).Равно("vendor1=value1");

КонецПроцедуры

