// ============================================================
// Тесты: ОтелАгрегация
// ============================================================

&Тест
Процедура АгрегацияКонстанты() Экспорт
    Ожидаем.Что(ОтелАгрегация.ПоУмолчанию()).Равно("default");
    Ожидаем.Что(ОтелАгрегация.Сумма()).Равно("sum");
    Ожидаем.Что(ОтелАгрегация.ПоследнееЗначение()).Равно("last_value");
    Ожидаем.Что(ОтелАгрегация.Отбросить()).Равно("drop");
КонецПроцедуры

&Тест
Процедура АгрегацияГистограммаСГраницами() Экспорт
    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(50);
    Границы.Добавить(100);

    Результат = ОтелАгрегация.ГистограммаСЯвнымиГраницами(Границы);

    Ожидаем.Что(Результат.Получить("Тип")).Равно("explicit_bucket_histogram");
    ПолученныеГраницы = Результат.Получить("Границы");
    Ожидаем.Что(ПолученныеГраницы.Количество()).Равно(3);
КонецПроцедуры

&Тест
Процедура ПредставлениеСодержитАгрегацию() Экспорт
    // Дано
    Представление = Новый ОтелПредставление("view1", "desc", , , ОтелАгрегация.Сумма());

    // Тогда
    Ожидаем.Что(Представление.Агрегация()).Равно("sum");
КонецПроцедуры

&Тест
Процедура ОбластьЗакрываетсяИВосстанавливаетКонтекст() Экспорт

    // Дано — чистый контекст
    ОтелКонтекст.Очистить();

    // Когда — создаём спан и делаем текущим
    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test-scope", Ресурс, "lib", "1.0");
    Область = Спан.СделатьТекущим();

    // Тогда — спан текущий
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Спан);
    Ожидаем.Что(Область.Закрыта()).Равно(Ложь);

    // Когда — закрываем область
    Область.Закрыть();

    // Тогда — контекст восстановлен
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Неопределено);
    Ожидаем.Что(Область.Закрыта()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОбластьПовторноеЗакрытиеИдемпотентно() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс();
    Спан1 = Новый ОтелСпан("span-1", Ресурс, "lib", "1.0");
    Спан2 = Новый ОтелСпан("span-2", Ресурс, "lib", "1.0");

    Область1 = Спан1.СделатьТекущим();
    Область2 = Спан2.СделатьТекущим();

    // Когда — закрываем вторую область дважды
    Область2.Закрыть();
    Область2.Закрыть();

    // Тогда — контекст восстановлен до Спан1, не до пустого
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Спан1);

    Область1.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ПостроительРесурсаУстановитьИПостроить() Экспорт

    // Дано
    Построитель = Новый ОтелПостроительРесурса();

    // Когда
    Ресурс = Построитель
        .Установить("service.name", "my-service")
        .Установить("service.version", "2.0")
        .Построить();

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("my-service");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.version")).Равно("2.0");

КонецПроцедуры

&Тест
Процедура ПостроительРесурсаУстановитьВсе() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("key1", "val1");
    Атрибуты.Установить("key2", "val2");

    // Когда
    Ресурс = Новый ОтелПостроительРесурса()
        .УстановитьВсе(Атрибуты)
        .Построить();

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("key1")).Равно("val1");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("key2")).Равно("val2");

КонецПроцедуры

&Тест
Процедура ПостроительРесурсаСлитьС() Экспорт

    // Дано — ресурс-источник
    Источник = Новый ОтелРесурс();
    Источник.Атрибуты().Установить("from.source", "yes");

    // Когда
    Ресурс = Новый ОтелПостроительРесурса()
        .Установить("my.attr", "val")
        .СлитьС(Источник)
        .Построить();

    // Тогда — оба атрибута присутствуют
    Ожидаем.Что(Ресурс.Атрибуты().Получить("my.attr")).Равно("val");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("from.source")).Равно("yes");

КонецПроцедуры

&Тест
Процедура BaggageТекущийИСделатьТекущим() Экспорт

    // Дано — чистый контекст
    ОтелКонтекст.Очистить();

    Багаж = Новый ОтелПостроительBaggage()
        .Установить("user-id", "123")
        .Построить();

    // Когда — делаем текущим
    Область = Багаж.СделатьТекущим();

    // Тогда — доступен через Текущий()
    ТекущийБагаж = ОтелКонтекст.ТекущийBaggage();
    Ожидаем.Что(ТекущийБагаж = Неопределено).Равно(Ложь);
    Ожидаем.Что(ТекущийБагаж.Получить("user-id")).Равно("123");

    // Когда — закрываем
    Область.Закрыть();

    // Тогда — не текущий
    Ожидаем.Что(ОтелКонтекст.ТекущийBaggage()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонтекстGenericКлючЗначение() Экспорт

    // Дано — чистый контекст
    ОтелКонтекст.Очистить();

    // Когда — устанавливаем произвольный ключ
    Область = ОтелКонтекст.УстановитьЗначение("my-custom-key", "my-value");

    // Тогда
    Ожидаем.Что(ОтелКонтекст.Получить("my-custom-key")).Равно("my-value");

    // Когда — закрываем
    Область.Закрыть();

    // Тогда — значение удалено
    Ожидаем.Что(ОтелКонтекст.Получить("my-custom-key")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонтекстВложенныеОбласти() Экспорт

    // Дано
    ОтелКонтекст.Очистить();

    // Когда — вложенные значения
    Область1 = ОтелКонтекст.УстановитьЗначение("level", "1");
    Область2 = ОтелКонтекст.УстановитьЗначение("level", "2");

    // Тогда — видим последнее
    Ожидаем.Что(ОтелКонтекст.Получить("level")).Равно("2");

    // Когда — закрываем внутреннюю
    Область2.Закрыть();
    Ожидаем.Что(ОтелКонтекст.Получить("level")).Равно("1");

    // Когда — закрываем внешнюю
    Область1.Закрыть();
    Ожидаем.Что(ОтелКонтекст.Получить("level")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонтекстСпанИBaggageНезависимы() Экспорт

    // Дано
    ОтелКонтекст.Очистить();

    Ресурс = Новый ОтелРесурс();
    Спан = Новый ОтелСпан("test", Ресурс, "lib", "1.0");
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("key", "val")
        .Построить();

    // Когда — оба в контексте
    ОбластьСпана = Спан.СделатьТекущим();
    ОбластьБагажа = Багаж.СделатьТекущим();

    // Тогда — оба доступны
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Спан);
    Ожидаем.Что(ОтелКонтекст.ТекущийBaggage().Получить("key")).Равно("val");

    // Когда — закрываем baggage
    ОбластьБагажа.Закрыть();

    // Тогда — спан остаётся
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Спан);
    Ожидаем.Что(ОтелКонтекст.ТекущийBaggage()).Равно(Неопределено);

    ОбластьСпана.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры
