// BSLLS:MagicNumber-off
#Использовать ".."
#Использовать asserts

// ============================================================
// Тесты: ОтелSdk + ОтелПостроительSdk
// ============================================================

&Тест
Процедура SdkСоздаетсяЧерезПостроитель() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "test");
    ПровайдерТрассировки = Новый ОтелПровайдерТрассировки(Ресурс);
    ПровайдерЛогирования = Новый ОтелПровайдерЛогирования(Ресурс);
    ПровайдерМетрик = Новый ОтелПровайдерМетрик(Ресурс);

    // Когда
    Сдк = Новый ОтелПостроительSdk()
        .УстановитьПровайдерТрассировки(ПровайдерТрассировки)
        .УстановитьПровайдерЛогирования(ПровайдерЛогирования)
        .УстановитьПровайдерМетрик(ПровайдерМетрик)
        .Построить();

    // Тогда
    Ожидаем.Что(Сдк).Не_().Равно(Неопределено);
    Ожидаем.Что(Сдк.ПровайдерТрассировки()).Равно(ПровайдерТрассировки);
    Ожидаем.Что(Сдк.ПровайдерЛогирования()).Равно(ПровайдерЛогирования);
    Ожидаем.Что(Сдк.ПровайдерМетрик()).Равно(ПровайдерМетрик);
КонецПроцедуры

&Тест
Процедура SdkПредоставляетШорткаты() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "test");
    ПровайдерТрассировки = Новый ОтелПровайдерТрассировки(Ресурс);
    ПровайдерЛогирования = Новый ОтелПровайдерЛогирования(Ресурс);
    ПровайдерМетрик = Новый ОтелПровайдерМетрик(Ресурс);

    Сдк = Новый ОтелПостроительSdk()
        .УстановитьПровайдерТрассировки(ПровайдерТрассировки)
        .УстановитьПровайдерЛогирования(ПровайдерЛогирования)
        .УстановитьПровайдерМетрик(ПровайдерМетрик)
        .Построить();

    // Когда
    Трассировщик = Сдк.ПолучитьТрассировщик("lib");
    Логгер = Сдк.ПолучитьЛоггер("lib");
    Метр = Сдк.ПолучитьМетр("lib");

    // Тогда
    Ожидаем.Что(Трассировщик).Не_().Равно(Неопределено);
    Ожидаем.Что(Логгер).Не_().Равно(Неопределено);
    Ожидаем.Что(Метр).Не_().Равно(Неопределено);
КонецПроцедуры

// ============================================================
// Тесты: ОтелГлобальный
// ============================================================

&Тест
Процедура ГлобальныйРеестрУстановкаИПолучение() Экспорт
    // Дано
    ОтелГлобальный.Сброс();
    Ресурс = Новый ОтелРесурс();
    ПровайдерТрассировки = Новый ОтелПровайдерТрассировки(Ресурс);
    Сдк = Новый ОтелПостроительSdk()
        .УстановитьПровайдерТрассировки(ПровайдерТрассировки)
        .Построить();

    // Когда
    ОтелГлобальный.Установить(Сдк);

    // Тогда
    Ожидаем.Что(ОтелГлобальный.Получить()).Равно(Сдк);

    // Cleanup
    ОтелГлобальный.Сброс();
КонецПроцедуры

&Тест
Процедура ГлобальныйРеестрПовторнаяУстановкаВыбрасываетОшибку() Экспорт
    // Дано
    ОтелГлобальный.Сброс();
    Ресурс = Новый ОтелРесурс();
    Сдк1 = Новый ОтелПостроительSdk().Построить();
    Сдк2 = Новый ОтелПостроительSdk().Построить();
    ОтелГлобальный.Установить(Сдк1);

    // Когда / Тогда
    ОшибкаВозникла = Ложь;
    Попытка
        ОтелГлобальный.Установить(Сдк2);
    Исключение
        ОшибкаВозникла = Истина;
    КонецПопытки;
    Ожидаем.Что(ОшибкаВозникла).Равно(Истина);

    // Cleanup
    ОтелГлобальный.Сброс();
КонецПроцедуры

// ============================================================
// Тесты: ОтелПостроительСпана (SpanBuilder)
// ============================================================

&Тест
Процедура ПостроительСпанаСоздаетСпан() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс();
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("lib");

    // Когда
    Спан = Трассировщик.ПостроительСпана("test-builder")
        .УстановитьВидСпана(ОтелВидСпана.Сервер())
        .НачатьСпан();

    // Тогда
    Ожидаем.Что(Спан.Имя()).Равно("test-builder");
    Ожидаем.Что(Спан.ВидСпана()).Равно(ОтелВидСпана.Сервер());
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура ПостроительСпанаУстанавливаетАтрибуты() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс();
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("lib");

    // Когда
    Спан = Трассировщик.ПостроительСпана("with-attrs")
        .УстановитьАтрибут("key1", "value1")
        .УстановитьАтрибут("key2", 42)
        .НачатьСпан();

    // Тогда
    Атрибуты = Спан.Атрибуты().ВСоответствие();
    Ожидаем.Что(Атрибуты.Получить("key1")).Равно("value1");
    Ожидаем.Что(Атрибуты.Получить("key2")).Равно(42);
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура ПостроительСпанаБезРодителяСоздаетКорневой() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс();
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("lib");
    Родитель = Трассировщик.НачатьСпан("parent");

    // Когда
    Ребёнок = Трассировщик.ПостроительСпана("child")
        .БезРодителя()
        .НачатьСпан();

    // Тогда — другой traceId (корневой спан)
    Ожидаем.Что(Ребёнок.КонтекстСпана().ИдТрассировки()).Не_().Равно(Родитель.КонтекстСпана().ИдТрассировки());
    Ребёнок.Завершить();
    Родитель.Завершить();
КонецПроцедуры

// ============================================================
// Тесты: ОтелПостроительПровайдера* (Provider Builders)
// ============================================================

&Тест
Процедура ПостроительПровайдераТрассировкиСоздаетПровайдер() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "builder-test");
    Экспортер = Новый ОтелВПамятьЭкспортерСпанов();
    Процессор = Новый ОтелПростойПроцессорСпанов(Экспортер);

    // Когда
    Провайдер = Новый ОтелПостроительПровайдераТрассировки()
        .УстановитьРесурс(Ресурс)
        .ДобавитьПроцессор(Процессор)
        .УстановитьСемплер(ОтелСемплер.ВсегдаВключен())
        .Построить();

    // Тогда
    Трассировщик = Провайдер.ПолучитьТрассировщик("lib");
    Спан = Трассировщик.НачатьСпан("test");
    Спан.Завершить();
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(1);
КонецПроцедуры

&Тест
Процедура ПостроительПровайдераЛогированияСоздаетПровайдер() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс();
    Экспортер = Новый ОтелВПамятьЭкспортерЛогов();
    Процессор = Новый ОтелПростойПроцессорЛогов(Экспортер);

    // Когда
    Провайдер = Новый ОтелПостроительПровайдераЛогирования()
        .УстановитьРесурс(Ресурс)
        .ДобавитьПроцессор(Процессор)
        .Построить();

    // Тогда
    Логгер = Провайдер.ПолучитьЛоггер("lib");
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("test log");
    Логгер.Записать(Запись);
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(1);
КонецПроцедуры

&Тест
Процедура ПостроительПровайдераМетрикСоздаетПровайдер() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс();
    Экспортер = Новый ОтелВПамятьЭкспортерМетрик();

    // Когда
    Провайдер = Новый ОтелПостроительПровайдераМетрик()
        .УстановитьРесурс(Ресурс)
        .ЗарегистрироватьЧитатель(Экспортер)
        .Построить();

    // Тогда
    Метр = Провайдер.ПолучитьМетр("lib");
    Ожидаем.Что(Метр).Не_().Равно(Неопределено);
КонецПроцедуры

// ============================================================
// Тесты: Immutable Baggage + Builder
// ============================================================

&Тест
Процедура BaggageИммутабельный() Экспорт
    // Дано
    Baggage = Новый ОтелПостроительBaggage()
        .Установить("key1", "value1")
        .Установить("key2", "value2")
        .Построить();

    // Когда
    Baggage2 = Baggage.Установить("key3", "value3");

    // Тогда — оригинал не изменился
    Ожидаем.Что(Baggage.Количество()).Равно(2);
    Ожидаем.Что(Baggage2.Количество()).Равно(3);
    Ожидаем.Что(Baggage.Получить("key3")).Равно(Неопределено);
    Ожидаем.Что(Baggage2.Получить("key3")).Равно("value3");
КонецПроцедуры

&Тест
Процедура BaggageУдалениеВозвращаетНовый() Экспорт
    // Дано
    Baggage = Новый ОтелПостроительBaggage()
        .Установить("key1", "value1")
        .Установить("key2", "value2")
        .Построить();

    // Когда
    Baggage2 = Baggage.Удалить("key1");

    // Тогда — оригинал не изменился
    Ожидаем.Что(Baggage.Количество()).Равно(2);
    Ожидаем.Что(Baggage2.Количество()).Равно(1);
    Ожидаем.Что(Baggage2.Получить("key1")).Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура BaggageТоПостроитель() Экспорт
    // Дано
    Baggage = Новый ОтелПостроительBaggage()
        .Установить("key1", "value1")
        .Построить();

    // Когда — создаём построитель из существующего Baggage
    Baggage2 = Baggage.ТоПостроитель()
        .Установить("key2", "value2")
        .Построить();

    // Тогда
    Ожидаем.Что(Baggage.Количество()).Равно(1);
    Ожидаем.Что(Baggage2.Количество()).Равно(2);
    Ожидаем.Что(Baggage2.Получить("key1")).Равно("value1");
    Ожидаем.Что(Baggage2.Получить("key2")).Равно("value2");
КонецПроцедуры

&Тест
Процедура BaggageПолучитьВсеВозвращаетФиксированноеСоответствие() Экспорт
    // Дано
    Baggage = Новый ОтелПостроительBaggage()
        .Установить("key1", "value1")
        .Построить();

    // Когда
    Все = Baggage.ПолучитьВсе();

    // Тогда — нельзя модифицировать
    ОшибкаВозникла = Ложь;
    Попытка
        Все.Вставить("key2", "value2");
    Исключение
        ОшибкаВозникла = Истина;
    КонецПопытки;
    Ожидаем.Что(ОшибкаВозникла).Равно(Истина);
КонецПроцедуры

