&Тест
Процедура ОбработатьКогдаЗакрыт() Экспорт

    // Дано - закрытый процессор (строки 43-44: ранний выход)
    Процессор = Новый ОтелБазовыйПакетныйПроцессор(Неопределено, "тест", 10, 5);
    Процессор.Закрыть();

    // Когда - обработка элемента на закрытом процессоре
    Процессор.Обработать("элемент");

    // Тогда - элемент не считается отброшенным (ранний выход до проверки буфера)
    Ожидаем.Что(Процессор.КоличествоОтброшенных()).Равно(0);

КонецПроцедуры

&Тест
Процедура ОбработатьПереполнениеБуфера() Экспорт

    // Дано - процессор с буфером размером 1 (строки 51-52: переполнение)
    Процессор = Новый ОтелБазовыйПакетныйПроцессор(Неопределено, "тест", 1, 10);
    Процессор.Обработать("первый");

    // Когда - добавляем второй элемент при полном буфере
    Процессор.Обработать("второй");

    // Тогда - второй элемент отброшен
    Ожидаем.Что(Процессор.КоличествоОтброшенных()).Равно(1);

    Процессор.Закрыть();

КонецПроцедуры

&Тест
Процедура КоличествоОтброшенных() Экспорт

    // Дано (строки 141-142: геттер КоличествоОтброшенных)
    Процессор = Новый ОтелБазовыйПакетныйПроцессор(Неопределено, "тест");

    // Когда / Тогда - начальное значение
    Ожидаем.Что(Процессор.КоличествоОтброшенных()).Равно(0);

    Процессор.Закрыть();

КонецПроцедуры

&Тест
Процедура ЗакрытьКогдаУжеЗакрыт() Экспорт

    // Дано - закрытый процессор (строки 88-89: идемпотентность)
    Процессор = Новый ОтелБазовыйПакетныйПроцессор(Неопределено, "тест");
    Процессор.Закрыть();

    // Когда - повторное закрытие
    Результат = Процессор.Закрыть();

    // Тогда - возвращает ошибку
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЗакрытьСОшибкойЭкспорта() Экспорт

    // Дано - экспортер выбрасывает исключение (строки 104-105)
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    МокЭкспортер.Когда().Экспортировать(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("ошибка экспорта");
    Процессор = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "тест", 2048, 512);
    Процессор.Обработать("элемент");

    // Когда
    Результат = Процессор.Закрыть();

    // Тогда - возвращает ошибку
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЗакрытьСТаймаутомЭкспорта() Экспорт

    // Дано - медленный экспортер (строки 101-102: таймаут при экспорте)
    ПутьКФикстуре = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures", "МедленныйЭкспортер.os");
    МедленныйЭкспортер = ЗагрузитьСценарий(ПутьКФикстуре);
    Процессор = Новый ОтелБазовыйПакетныйПроцессор(МедленныйЭкспортер, "тест", 2048, 512);
    Процессор.Обработать("элемент");

    // Когда - 1мс таймаут, экспортер спит 100мс
    Результат = Процессор.Закрыть(1);

    // Тогда - таймаут
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);

КонецПроцедуры

