&ТестовыйНабор
Процедура ПриСозданииОбъекта()
КонецПроцедуры

// --- Вспомогательные функции ---

Функция ПутьДекодера()
    ПутьHelpersDir = ОбъединитьПути(ТекущийСценарий().Каталог, "..", "..", "helpers");
    Возврат ОбъединитьПути(ПутьHelpersDir, "proto_decoder.py");
КонецФункции

Функция ДекодироватьПротоБайты(Байты)
    ВременныйФайл = ПолучитьИмяВременногоФайла("bin");
    ЗаписьД = Новый ЗаписьДанных(ВременныйФайл);
    ЗаписьД.Записать(Байты);
    ЗаписьД.Закрыть();

    Команда = "python3 " + ПутьДекодера() + " traces " + ВременныйФайл;
    Процесс = СоздатьПроцесс(Команда,, Истина, Истина);
    Процесс.Запустить();
    Пока НЕ Процесс.Завершен Цикл
        Приостановить(50);
    КонецЦикла;

    Вывод = "";
    Пока Процесс.ПотокВывода.ЕстьДанные Цикл
        Вывод = Вывод + Процесс.ПотокВывода.Прочитать();
    КонецЦикла;

    УдалитьФайлы(ВременныйФайл);

    Если Процесс.КодВозврата <> 0 Тогда
        ОшибкаДекодера = "";
        Пока Процесс.ПотокОшибок.ЕстьДанные Цикл
            ОшибкаДекодера = ОшибкаДекодера + Процесс.ПотокОшибок.Прочитать();
        КонецЦикла;
        ВызватьИсключение "proto_decoder.py завершился с кодом " + Процесс.КодВозврата + ": " + ОшибкаДекодера;
    КонецЕсли;

    Разбор = Новый ЧтениеJSON();
    Разбор.УстановитьСтроку(Вывод);
    Возврат ПрочитатьJSON(Разбор);
КонецФункции

Функция СоздатьМинимальныйСпан(ИмяСпана)
    Спан = Новый Соответствие();
    Спан.Вставить("traceId", "aabbccddeeff00112233445566778899");
    Спан.Вставить("spanId", "aabbccddeeff0011");
    Спан.Вставить("name", ИмяСпана);
    Спан.Вставить("kind", 1);
    Спан.Вставить("startTimeUnixNano", 1000000000);
    Спан.Вставить("endTimeUnixNano", 2000000000);
    Спан.Вставить("attributes", Новый Массив());
    Спан.Вставить("droppedAttributesCount", 0);
    Спан.Вставить("events", Новый Массив());
    Спан.Вставить("droppedEventsCount", 0);
    Спан.Вставить("links", Новый Массив());
    Спан.Вставить("droppedLinksCount", 0);
    Спан.Вставить("flags", 1);
    Возврат Спан;
КонецФункции

Функция УпаковатьСпанВДанные(Спан)
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);
    ScopeSpans = Новый Соответствие();
    ScopeSpans.Вставить("scope", Новый Соответствие());
    ScopeSpans.Вставить("spans", МассивСпанов);
    МассивScope = Новый Массив();
    МассивScope.Добавить(ScopeSpans);
    Ресурс = Новый Соответствие();
    Ресурс.Вставить("attributes", Новый Массив());
    ResourceSpans = Новый Соответствие();
    ResourceSpans.Вставить("resource", Ресурс);
    ResourceSpans.Вставить("scopeSpans", МассивScope);
    МассивРесурсов = Новый Массив();
    МассивРесурсов.Добавить(ResourceSpans);
    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", МассивРесурсов);
    Возврат Данные;
КонецФункции

Функция ПолучитьПервыйСпан(ДекодированныеДанные)
    Возврат ДекодированныеДанные["resource_spans"][0]["scope_spans"][0]["spans"][0];
КонецФункции

// --- Тесты полей Span ---

&Тест
Процедура ПоляСпан_Имя() Экспорт
    Спан = СоздатьМинимальныйСпан("my-span-name");
    Данные = УпаковатьСпанВДанные(Спан);

    Результат = ОтелПротоКодировщикTrace.ЗакодироватьTracesData(Данные);
    Декодировано = ДекодироватьПротоБайты(Результат);

    ПервыйСпан = ПолучитьПервыйСпан(Декодировано);
    Ожидаем.Что(ПервыйСпан["name"]).Равно("my-span-name");
КонецПроцедуры

