    Ожидаем.Что(ПерваяСсылка["span_id"] = Неопределено).Равно(Ложь);
КонецПроцедуры

&Тест
Процедура ПоляРесурс_АтрибутСервиса() Экспорт
    // Проверяем, что resource attributes корректно кодируются
    РесурсАтрВаль = Новый Соответствие();
    РесурсАтрВаль.Вставить("stringValue", "my-service");
    РесурсАтр = Новый Соответствие();
    РесурсАтр.Вставить("key", "service.name");
    РесурсАтр.Вставить("value", РесурсАтрВаль);
    МассивРесурсАтр = Новый Массив();
    МассивРесурсАтр.Добавить(РесурсАтр);
    Ресурс = Новый Соответствие();
    Ресурс.Вставить("attributes", МассивРесурсАтр);
    Спан = СоздатьМинимальныйСпан("span");
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);
    ScopeSpans = Новый Соответствие();
    ScopeSpans.Вставить("scope", Новый Соответствие());
    ScopeSpans.Вставить("spans", МассивСпанов);
    МассивScope = Новый Массив();
    МассивScope.Добавить(ScopeSpans);
    ResourceSpans = Новый Соответствие();
    ResourceSpans.Вставить("resource", Ресурс);
    ResourceSpans.Вставить("scopeSpans", МассивScope);
    МассивРесурсов = Новый Массив();
    МассивРесурсов.Добавить(ResourceSpans);
    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", МассивРесурсов);

    Результат = ОтелПротоКодировщикTrace.ЗакодироватьTracesData(Данные);
    Декодировано = ДекодироватьПротоБайты(Результат);

    РесурсДекод = Декодировано["resource_spans"][0]["resource"];
    ПервыйАтр = РесурсДекод["attributes"][0];
    Ожидаем.Что(ПервыйАтр["key"]).Равно("service.name");
    Ожидаем.Что(ПервыйАтр["value"]["string_value"]).Равно("my-service");
КонецПроцедуры

&Тест
Процедура ПоляScope_ИмяВерсия() Экспорт
    // Проверяем scope.name и scope.version в ScopeSpans
    Спан = СоздатьМинимальныйСпан("span");
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);
    Скоп = Новый Соответствие();
    Скоп.Вставить("name", "my-instrumentation");
    Скоп.Вставить("version", "1.2.3");
    ScopeSpans = Новый Соответствие();
    ScopeSpans.Вставить("scope", Скоп);
    ScopeSpans.Вставить("spans", МассивСпанов);
    МассивScope = Новый Массив();
    МассивScope.Добавить(ScopeSpans);
    Ресурс = Новый Соответствие();
    Ресурс.Вставить("attributes", Новый Массив());
    ResourceSpans = Новый Соответствие();
    ResourceSpans.Вставить("resource", Ресурс);
    ResourceSpans.Вставить("scopeSpans", МассивScope);
    МассивРесурсов = Новый Массив();
    МассивРесурсов.Добавить(ResourceSpans);
    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", МассивРесурсов);

    Результат = ОтелПротоКодировщикTrace.ЗакодироватьTracesData(Данные);
    Декодировано = ДекодироватьПротоБайты(Результат);

    Скоп2 = Декодировано["resource_spans"][0]["scope_spans"][0]["scope"];
    Ожидаем.Что(Скоп2["name"]).Равно("my-instrumentation");
    Ожидаем.Что(Скоп2["version"]).Равно("1.2.3");
КонецПроцедуры
