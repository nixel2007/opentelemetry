&Тест
Процедура ПоляСпан_Временные_метки() Экспорт
    Спан = СоздатьМинимальныйСпан("span");
    Спан.Вставить("startTimeUnixNano", 1700000000000000001);
    Спан.Вставить("endTimeUnixNano", 1700000000000000999);
    Данные = УпаковатьСпанВДанные(Спан);

    Результат = ОтелПротоКодировщикTrace.ЗакодироватьTracesData(Данные);
    Декодировано = ДекодироватьПротоБайты(Результат);

    ПервыйСпан = ПолучитьПервыйСпан(Декодировано);
    // proto JSON-формат: uint64 наносекунды кодируются как строки
    Ожидаем.Что(ПервыйСпан["start_time_unix_nano"]).Равно("1700000000000000001");
    Ожидаем.Что(ПервыйСпан["end_time_unix_nano"]).Равно("1700000000000000999");
КонецПроцедуры

&Тест
Процедура ПоляСпан_traceId_spanId_Байты() Экспорт
    // traceId и spanId должны попасть в proto bytes поля
    // в JSON-декодировании они будут base64-encoded строки
    Спан = СоздатьМинимальныйСпан("span");
    Спан.Вставить("traceId", "00000000000000000000000000000001");
    Спан.Вставить("spanId", "0000000000000001");
    Данные = УпаковатьСпанВДанные(Спан);

    Результат = ОтелПротоКодировщикTrace.ЗакодироватьTracesData(Данные);
    Декодировано = ДекодироватьПротоБайты(Результат);

    ПервыйСпан = ПолучитьПервыйСпан(Декодировано);
    // Ненулевые bytes поля есть в decoded JSON
    Ожидаем.Что(ПервыйСпан["trace_id"] = Неопределено).Равно(Ложь);
    Ожидаем.Что(ПервыйСпан["span_id"] = Неопределено).Равно(Ложь);
    // Конкретное значение: base64 для hex 0000000000000000 0000000000000001 (16 байт)
    // 15 байт нулей + 0x01 → "AAAAAAAAAAAAAAAAAAAAAQ=="
    Ожидаем.Что(ПервыйСпан["trace_id"]).Равно("AAAAAAAAAAAAAAAAAAAAAQ==");
    // hex 0000000000000001 (8 байт) → "AAAAAAAAAAE="
    Ожидаем.Что(ПервыйСпан["span_id"]).Равно("AAAAAAAAAAE=");
КонецПроцедуры

