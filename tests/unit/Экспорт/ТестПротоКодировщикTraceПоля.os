КонецПроцедуры

&Тест
Процедура ПоляСпан_СтатусОК() Экспорт
    // Проверяем, что status.code=1 (OK) правильно кодируется в поле №3
    Спан = СоздатьМинимальныйСпан("span");
    Статус = Новый Соответствие();
    Статус.Вставить("code", 1);
    Статус.Вставить("message", "");
    Спан.Вставить("status", Статус);
    Данные = УпаковатьСпанВДанные(Спан);

    Результат = ОтелПротоКодировщикTrace.ЗакодироватьTracesData(Данные);
    Декодировано = ДекодироватьПротоБайты(Результат);

    ПервыйСпан = ПолучитьПервыйСпан(Декодировано);
    // status.code=1 → STATUS_CODE_OK
    Ожидаем.Что(ПервыйСпан["status"]["code"]).Равно("STATUS_CODE_OK");
КонецПроцедуры

&Тест
Процедура ПоляСпан_СтатусОшибка() Экспорт
    // Проверяем, что status.code=2 (Error) правильно кодируется
    Спан = СоздатьМинимальныйСпан("span");
    Статус = Новый Соответствие();
    Статус.Вставить("code", 2);
    Статус.Вставить("message", "something went wrong");
    Спан.Вставить("status", Статус);
    Данные = УпаковатьСпанВДанные(Спан);

    Результат = ОтелПротоКодировщикTrace.ЗакодироватьTracesData(Данные);
    Декодировано = ДекодироватьПротоБайты(Результат);

    ПервыйСпан = ПолучитьПервыйСпан(Декодировано);
    // status.code=2 → STATUS_CODE_ERROR (поле №3 по proto)
    Ожидаем.Что(ПервыйСпан["status"]["code"]).Равно("STATUS_CODE_ERROR");
    // status.message → поле №2 по proto
    Ожидаем.Что(ПервыйСпан["status"]["message"]).Равно("something went wrong");
КонецПроцедуры

