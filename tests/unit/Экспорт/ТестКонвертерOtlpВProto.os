// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts

Перем Конвертер;

&ПередКаждым
Процедура ПередКаждым() Экспорт
    Конвертер = Новый ОтелКонвертерOtlpВProto();
КонецПроцедуры

&Тест
Процедура КонвертацияCamelCase() Экспорт

    // Дано
    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", Новый Массив());

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат.Получить("resource_spans")).ИмеетТип("Массив");
    Ожидаем.Что(Результат.Получить("resourceSpans")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонвертацияВложеннойСтруктуры() Экспорт

    // Дано
    Внутреннее = Новый Соответствие();
    Внутреннее.Вставить("traceId", "abc123");
    Внутреннее.Вставить("spanId", "def456");

    Данные = Новый Соответствие();
    Данные.Вставить("scopeSpans", Внутреннее);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    ВложенныйРезультат = Результат.Получить("scope_spans");
    Ожидаем.Что(ВложенныйРезультат).ИмеетТип("Соответствие");
    Ожидаем.Что(ВложенныйРезультат.Получить("trace_id")).Равно("abc123");
    Ожидаем.Что(ВложенныйРезультат.Получить("span_id")).Равно("def456");

КонецПроцедуры

&Тест
Процедура КонвертацияМассива() Экспорт

    // Дано
    Элемент1 = Новый Соответствие();
    Элемент1.Вставить("stringValue", "test");

    Элемент2 = Новый Соответствие();
    Элемент2.Вставить("intValue", "42");

    Данные = Новый Массив();
    Данные.Добавить(Элемент1);
    Данные.Добавить(Элемент2);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат).ИмеетТип("Массив");
    Ожидаем.Что(Результат.Количество()).Равно(2);
    Ожидаем.Что(Результат[0].Получить("string_value")).Равно("test");
    Ожидаем.Что(Результат[1].Получить("int_value")).Равно("42");

КонецПроцедуры

&Тест
Процедура ПримитивныеТипы() Экспорт

    // Строки, числа, булевы и Неопределено не изменяются
    Ожидаем.Что(Конвертер.Конвертировать("строка")).Равно("строка");
    Ожидаем.Что(Конвертер.Конвертировать(42)).Равно(42);
    Ожидаем.Что(Конвертер.Конвертировать(3.14)).Равно(3.14);
    Ожидаем.Что(Конвертер.Конвертировать(Истина)).Равно(Истина);
    Ожидаем.Что(Конвертер.Конвертировать(Неопределено)).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ПолнаяСтруктура() Экспорт

    // Дано — полная структура ExportTraceServiceRequest
    Спан = Новый Соответствие();
    Спан.Вставить("traceId", "aabb");
    Спан.Вставить("spanId", "ccdd");
    Спан.Вставить("startTimeUnixNano", "1234567890000000000");

    Скоуп = Новый Соответствие();
    Скоуп.Вставить("name", "lib");

    СпаныМассив = Новый Массив();
    СпаныМассив.Добавить(Спан);

    СкоупСпаны = Новый Соответствие();
    СкоупСпаны.Вставить("scope", Скоуп);
    СкоупСпаны.Вставить("spans", СпаныМассив);

    МассивСкоупов = Новый Массив();
    МассивСкоупов.Добавить(СкоупСпаны);

    РесурсСпаны = Новый Соответствие();
    РесурсСпаны.Вставить("scopeSpans", МассивСкоупов);

    МассивРС = Новый Массив();
    МассивРС.Добавить(РесурсСпаны);

    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", МассивРС);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    РС = Результат.Получить("resource_spans");
    Ожидаем.Что(РС).ИмеетТип("Массив");
    Ожидаем.Что(РС.Количество()).Равно(1);

    ПервыйРС = РС[0];
    Ожидаем.Что(ПервыйРС.Получить("scope_spans")).ИмеетТип("Массив");

    ПервыйСкоуп = ПервыйРС.Получить("scope_spans")[0];
    Ожидаем.Что(ПервыйСкоуп.Получить("scope").Получить("name")).Равно("lib");

    ПервыйСпан = ПервыйСкоуп.Получить("spans")[0];
    Ожидаем.Что(ПервыйСпан.Получить("trace_id")).Равно("aabb");
    Ожидаем.Что(ПервыйСпан.Получить("span_id")).Равно("ccdd");
    Ожидаем.Что(ПервыйСпан.Получить("start_time_unix_nano")).Равно("1234567890000000000");

КонецПроцедуры
