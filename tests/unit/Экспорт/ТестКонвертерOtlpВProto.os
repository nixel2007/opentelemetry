КонецПроцедуры

&Тест
Процедура ЧисловыеПоляУжеЧислаНеМеняются() Экспорт

    // Дано - если значение уже число, оно не должно измениться
    Данные = Новый Соответствие();
    Данные.Вставить("count", 42);
    Данные.Вставить("asInt", 100);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат.Получить("count")).Равно(42);
    Ожидаем.Что(Результат.Получить("as_int")).Равно(100);

КонецПроцедуры

&Тест
Процедура BytesПоляКонвертируютсяВBase64АСтроковыеНет() Экспорт

    // Дано - traceId и spanId конвертируются в base64, остальные строки - нет
    Данные = Новый Соответствие();
    Данные.Вставить("traceId", "abc123def456");
    Данные.Вставить("spanId", "1234abcd");
    Данные.Вставить("name", "мой-спан");
    Данные.Вставить("stringValue", "строка");

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат.Получить("trace_id")).Равно("q8Ej3vRW");
    Ожидаем.Что(Результат.Получить("span_id")).Равно("EjSrzQ==");
    Ожидаем.Что(Результат.Получить("name")).Равно("мой-спан");
    Ожидаем.Что(Результат.Получить("string_value")).Равно("строка");

КонецПроцедуры

&Тест
Процедура КонвертацияTraceIdВBase64() Экспорт

    // Дано - trace_id 32 hex символа = 16 байт
    Данные = Новый Соответствие();
    Данные.Вставить("traceId", "550e8400e29b41d4a716446655440000");

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда - должен стать Base64-строкой
    Ожидаем.Что(Результат.Получить("trace_id")).Равно("VQ6EAOKbQdSnFkRmVUQAAA==");

КонецПроцедуры

