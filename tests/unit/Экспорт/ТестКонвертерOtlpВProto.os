&Тест
Процедура ПустойParentSpanIdНеКонвертируется() Экспорт

    // Дано - пустой parentSpanId (корневой спан)
    Данные = Новый Соответствие();
    Данные.Вставить("parentSpanId", "");

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

