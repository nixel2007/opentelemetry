#Использовать "../../.."
#Использовать asserts

Перем Конвертер;

&ПередКаждым
Процедура ПередКаждым() Экспорт
    Конвертер = Новый ОтелКонвертерOtlpВProto();
КонецПроцедуры

&Тест
Процедура КонвертацияCamelCase() Экспорт

    // Дано
    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", Новый Массив());

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат.Получить("resource_spans")).ИмеетТип("Массив");
    Ожидаем.Что(Результат.Получить("resourceSpans")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонвертацияВложеннойСтруктуры() Экспорт

    // Дано
    Внутреннее = Новый Соответствие();
    Внутреннее.Вставить("traceId", "abc123");
    Внутреннее.Вставить("spanId", "def456");

    Данные = Новый Соответствие();
    Данные.Вставить("scopeSpans", Внутреннее);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    ВложенныйРезультат = Результат.Получить("scope_spans");
    Ожидаем.Что(ВложенныйРезультат).ИмеетТип("Соответствие");
    Ожидаем.Что(ВложенныйРезультат.Получить("trace_id")).Равно("q8Ej");
    Ожидаем.Что(ВложенныйРезультат.Получить("span_id")).Равно("3vRW");

КонецПроцедуры

&Тест
Процедура КонвертацияМассива() Экспорт

    // Дано
    Элемент1 = Новый Соответствие();
    Элемент1.Вставить("stringValue", "test");

    Элемент2 = Новый Соответствие();
    Элемент2.Вставить("intValue", "42");

    Данные = Новый Массив();
    Данные.Добавить(Элемент1);
    Данные.Добавить(Элемент2);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат).ИмеетТип("Массив");
    Ожидаем.Что(Результат.Количество()).Равно(2);
    Ожидаем.Что(Результат[0].Получить("string_value")).Равно("test");
    Ожидаем.Что(Результат[1].Получить("int_value")).Равно(42);

КонецПроцедуры

&Тест
Процедура ПримитивныеТипы() Экспорт

    // Строки, числа, булевы и Неопределено не изменяются
    Ожидаем.Что(Конвертер.Конвертировать("строка")).Равно("строка");
    Ожидаем.Что(Конвертер.Конвертировать(42)).Равно(42);
    Ожидаем.Что(Конвертер.Конвертировать(3.14)).Равно(3.14);
    Ожидаем.Что(Конвертер.Конвертировать(Истина)).Равно(Истина);
    Ожидаем.Что(Конвертер.Конвертировать(Неопределено)).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ПолнаяСтруктура() Экспорт

    // Дано - полная структура ExportTraceServiceRequest
    Спан = Новый Соответствие();
    Спан.Вставить("traceId", "aabb");
    Спан.Вставить("spanId", "ccdd");
    Спан.Вставить("startTimeUnixNano", "1234567890000000000");

    ДанныеОбласти = Новый Соответствие();
    ДанныеОбласти.Вставить("name", "lib");

    СпаныМассив = Новый Массив();
    СпаныМассив.Добавить(Спан);

    ОбластьСпаны = Новый Соответствие();
    ОбластьСпаны.Вставить("scope", ДанныеОбласти);
    ОбластьСпаны.Вставить("spans", СпаныМассив);

    МассивОбластей = Новый Массив();
    МассивОбластей.Добавить(ОбластьСпаны);

    РесурсСпаны = Новый Соответствие();
    РесурсСпаны.Вставить("scopeSpans", МассивОбластей);

    МассивРС = Новый Массив();
    МассивРС.Добавить(РесурсСпаны);

    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", МассивРС);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    РС = Результат.Получить("resource_spans");
    Ожидаем.Что(РС).ИмеетТип("Массив");
    Ожидаем.Что(РС.Количество()).Равно(1);

    ПервыйРС = РС[0];
    Ожидаем.Что(ПервыйРС.Получить("scope_spans")).ИмеетТип("Массив");

    ПерваяОбласть = ПервыйРС.Получить("scope_spans")[0];
    Ожидаем.Что(ПерваяОбласть.Получить("scope").Получить("name")).Равно("lib");

    ПервыйСпан = ПерваяОбласть.Получить("spans")[0];
    Ожидаем.Что(ПервыйСпан.Получить("trace_id")).Равно("qrs=");
    Ожидаем.Что(ПервыйСпан.Получить("span_id")).Равно("zN0=");
    Ожидаем.Что(ПервыйСпан.Получить("start_time_unix_nano")).Равно(1234567890000000000);

КонецПроцедуры

&Тест
Процедура КонвертацияTimestampВЧисло() Экспорт

    // Дано - строковые timestamps конвертируются в числа
    Данные = Новый Соответствие();
    Данные.Вставить("startTimeUnixNano", "1710000000000000000");
    Данные.Вставить("endTimeUnixNano", "1710000001000000000");

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат.Получить("start_time_unix_nano")).ИмеетТип("Число");
    Ожидаем.Что(Результат.Получить("start_time_unix_nano")).Равно(1710000000000000000);
    Ожидаем.Что(Результат.Получить("end_time_unix_nano")).ИмеетТип("Число");
    Ожидаем.Что(Результат.Получить("end_time_unix_nano")).Равно(1710000001000000000);

КонецПроцедуры

&Тест
Процедура КонвертацияTimeUnixNano() Экспорт

    // Дано - timeUnixNano для событий и логов
    Данные = Новый Соответствие();
    Данные.Вставить("timeUnixNano", "1710000000500000000");
    Данные.Вставить("observedTimeUnixNano", "1710000000600000000");

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат.Получить("time_unix_nano")).ИмеетТип("Число");
    Ожидаем.Что(Результат.Получить("observed_time_unix_nano")).ИмеетТип("Число");

КонецПроцедуры

&Тест
Процедура КонвертацияМетрикInt64() Экспорт

    // Дано - asInt, count, zeroCount передаются как строки экспортером
    Данные = Новый Соответствие();
    Данные.Вставить("asInt", "100");
    Данные.Вставить("count", "50");
    Данные.Вставить("zeroCount", "3");

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    Ожидаем.Что(Результат.Получить("as_int")).ИмеетТип("Число");
    Ожидаем.Что(Результат.Получить("as_int")).Равно(100);
    Ожидаем.Что(Результат.Получить("count")).ИмеетТип("Число");
    Ожидаем.Что(Результат.Получить("count")).Равно(50);
    Ожидаем.Что(Результат.Получить("zero_count")).ИмеетТип("Число");
    Ожидаем.Что(Результат.Получить("zero_count")).Равно(3);

КонецПроцедуры

&Тест
Процедура КонвертацияBucketCounts() Экспорт

    // Дано - bucketCounts - массив строк
    БакетыСтроки = Новый Массив();
    БакетыСтроки.Добавить("0");
    БакетыСтроки.Добавить("5");
    БакетыСтроки.Добавить("10");
    БакетыСтроки.Добавить("0");

    Данные = Новый Соответствие();
    Данные.Вставить("bucketCounts", БакетыСтроки);

    // Когда
    Результат = Конвертер.Конвертировать(Данные);

    // Тогда
    БакетыЧисла = Результат.Получить("bucket_counts");
    Ожидаем.Что(БакетыЧисла).ИмеетТип("Массив");
    Ожидаем.Что(БакетыЧисла.Количество()).Равно(4);
    Ожидаем.Что(БакетыЧисла[0]).Равно(0);
    Ожидаем.Что(БакетыЧисла[1]).Равно(5);
    Ожидаем.Что(БакетыЧисла[2]).Равно(10);
    Ожидаем.Что(БакетыЧисла[3]).Равно(0);

КонецПроцедуры

&Тест
Процедура КонвертацияIntValue() Экспорт

    // Дано - AnyValue.intValue передается как строка
    Данные = Новый Соответствие();
