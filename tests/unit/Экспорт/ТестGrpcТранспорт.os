#Использовать asserts

&Тест
Процедура КонструкторСНедоступнымАдресом() Экспорт

    // Дано / Когда - адрес недоступен, соединение не устанавливается
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Тогда - объект создан, соединение = Неопределено
    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ОтправитьБезСоединения() Экспорт

    // Дано - соединение не установлено
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Когда
    Результат = Транспорт.Отправить("/v1/traces", Новый Соответствие());

    // Тогда
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ОтправитьНеизвестныйПуть() Экспорт

    // Дано
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Когда - неизвестный путь
    Результат = Транспорт.Отправить("/unknown/path", Новый Соответствие());

    // Тогда
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЗакрытьБезСоединения() Экспорт

    // Дано
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Когда - закрытие без активного соединения
    Транспорт.Закрыть();

    // Тогда - без ошибок
    Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КонструкторСПользовательскимКаталогомProto() Экспорт

    // Дано - указываем каталог proto из проекта
    КаталогПроекта = ОбъединитьПути(ТекущийСценарий().Каталог, "..", "..", "..");
    КаталогProto = ОбъединитьПути(КаталогПроекта, "proto");

    // Когда
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1", , , КаталогProto);

    // Тогда - объект создан
    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонструкторСНесуществующимКаталогомProto() Экспорт

    // Дано - несуществующий каталог proto -> fallback
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1", , , "/nonexistent/proto");

    // Тогда - объект создан (используется путь as-is)
    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры
