// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts

Перем МокСервер;
Перем ПортЗависшегоСервера;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта()
КонецПроцедуры

&ПередВсеми
Процедура ПередВсемиТестами() Экспорт
    ПортЗависшегоСервера = 14317 + Цел(ТекущаяУниверсальнаяДата() - Дата(2025, 1, 1)) % 100;
    КаталогПроекта = ОбъединитьПути(ТекущийСценарий().Каталог, "..", "..", "..");
    ПутьСкрипта = ОбъединитьПути(КаталогПроекта, "tests", "helpers", "mock_hanging_tcp_server.py");
    МокСервер = СоздатьПроцесс("python3 " + ПутьСкрипта + " " + ПортЗависшегоСервера, , Истина);
    МокСервер.Запустить();
    Приостановить(500);
КонецПроцедуры

&ПослеВсех
Процедура ПослеВсехТестов() Экспорт
    Если МокСервер <> Неопределено Тогда
        МокСервер.Завершить();
    КонецЕсли;
КонецПроцедуры

&Тест
Процедура КонструкторСНедоступнымАдресом() Экспорт

    // Дано / Когда - адрес недоступен, соединение не устанавливается
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Тогда - объект создан, соединение = Неопределено
    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ОтправитьБезСоединения() Экспорт

    // Дано - соединение не установлено
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Когда
    Результат = Транспорт.Отправить("/v1/traces", Новый Соответствие());

    // Тогда
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ОтправитьНеизвестныйПуть() Экспорт

    // Дано
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Когда - неизвестный путь
    Результат = Транспорт.Отправить("/unknown/path", Новый Соответствие());

    // Тогда
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЗакрытьБезСоединения() Экспорт

    // Дано
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Когда - закрытие без активного соединения
    Транспорт.Закрыть();

    // Тогда - без ошибок
    Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КонструкторСПользовательскимКаталогомProto() Экспорт

    // Дано - указываем каталог proto из проекта
    КаталогПроекта = ОбъединитьПути(ТекущийСценарий().Каталог, "..", "..", "..");
    КаталогProto = ОбъединитьПути(КаталогПроекта, "proto");

    // Когда
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1", , , КаталогProto);

    // Тогда - объект создан
    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонструкторСНесуществующимКаталогомProto() Экспорт

    // Дано - несуществующий каталог proto -> fallback
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1", , , "/nonexistent/proto");

    // Тогда - объект создан (используется путь as-is)
    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ВыставляетсяМетаданныеUserAgent() Экспорт

    // Дано / Когда
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Тогда - метаданные содержат user-agent в формате OTel-OTLP-Exporter-OneScript/<версия>
    Метаданные = Транспорт.ПолучитьМетаданные();
    Ожидаем.Что(Метаданные).Не_().Равно(Неопределено);
    ЗначениеUserAgent = Метаданные.Получить("user-agent");
    Ожидаем.Что(ЗначениеUserAgent).Не_().Равно(Неопределено);
    Ожидаем.Что(СтрНачинаетсяС(ЗначениеUserAgent, "OTel-OTLP-Exporter-OneScript/")).Равно(Истина);

КонецПроцедуры

&Тест
Процедура UserAgentДополняетКастомныеМетаданные() Экспорт

    // Дано - кастомные метаданные
    КастомныеМетаданные = Новый Соответствие();
    КастомныеМетаданные.Вставить("authorization", "Bearer abc");

    // Когда
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1", , КастомныеМетаданные);

    // Тогда - кастомные метаданные сохранены, user-agent добавлен
    Метаданные = Транспорт.ПолучитьМетаданные();
    Ожидаем.Что(Метаданные.Получить("authorization")).Равно("Bearer abc");
    Ожидаем.Что(СтрНачинаетсяС(Метаданные.Получить("user-agent"), "OTel-OTLP-Exporter-OneScript/")).Равно(Истина);

КонецПроцедуры

// OTLP Exporter (gRPC): https-схема в endpoint поддерживается underlying gRPC-клиентом
// (OPI_GRPC, tonic-based) без отдельной трансформации.
&Тест
Процедура КонструкторПринимаетHttpsURL() Экспорт

    // Дано / Когда - https URL без отдельных настроек TLS
    Транспорт = Новый ОтелGrpcТранспорт("https://localhost:1");

    // Тогда - объект создан, без исключений на этапе конструктора
    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ТаймаутСрабатывает() Экспорт

    // Дано - зависший сервер (принимает соединение, но не отвечает)
    // и транспорт с таймаутом 1 с (1 попытка, без retry)
    ТаймаутМс = 1000;
    МаксПопыток = 1;
    Транспорт = Новый ОтелGrpcТранспорт(
        "http://localhost:" + ПортЗависшегоСервера, , , , ТаймаутМс, МаксПопыток);

    // Когда - отправка на зависший сервер
    Результат = Транспорт.Отправить("/v1/traces", Новый Соответствие());

    // Тогда - таймаут сработал, возврат Ложь (не завис на 10 сек)
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры
