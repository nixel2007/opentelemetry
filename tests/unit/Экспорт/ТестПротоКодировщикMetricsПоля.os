// --- Тесты Histogram ---

&Тест
Процедура ПоляHistogram_ОсновныеПоля() Экспорт
    СчетчикиБакетов = Новый Массив();
    СчетчикиБакетов.Добавить("5");
    СчетчикиБакетов.Добавить("10");
    СчетчикиБакетов.Добавить("3");
    ЯвныеГраницы = Новый Массив();
    ЯвныеГраницы.Добавить(10);
    ЯвныеГраницы.Добавить(100);
    ТочкаДанных = Новый Соответствие();
    ТочкаДанных.Вставить("startTimeUnixNano", "1000000000000000001");
    ТочкаДанных.Вставить("timeUnixNano", "2000000000000000001");
    ТочкаДанных.Вставить("count", "18");
    ТочкаДанных.Вставить("sum", 1234.5);
    ТочкаДанных.Вставить("min", 1.0);
    ТочкаДанных.Вставить("max", 500.0);
    ТочкаДанных.Вставить("bucketCounts", СчетчикиБакетов);
    ТочкаДанных.Вставить("explicitBounds", ЯвныеГраницы);
    ТочкаДанных.Вставить("attributes", Новый Массив());
    МассивТочек = Новый Массив();
    МассивТочек.Добавить(ТочкаДанных);
    Гистограмма = Новый Соответствие();
    Гистограмма.Вставить("dataPoints", МассивТочек);
    Гистограмма.Вставить("aggregationTemporality", 2);
    Метрика = Новый Соответствие();
    Метрика.Вставить("name", "request.duration");
    Метрика.Вставить("unit", "ms");
    Метрика.Вставить("histogram", Гистограмма);

    Результат = ОтелПротоКодировщикMetrics.ЗакодироватьMetricsData(УпаковатьВСтруктуруМетрик(Метрика));
    Декодировано = ДекодироватьПротоБайты(Результат);

    М = ПолучитьПервуюМетрику(Декодировано);
    ТочкаД = М["histogram"]["data_points"][0];

    // count как строка (uint64)
    Ожидаем.Что(ТочкаД["count"]).Равно("18");
    // sum как число
    Ожидаем.Что(ТочкаД["sum"]).Равно(1234.5);
    // min/max
    Ожидаем.Что(ТочкаД["min"]).Равно(1.0);
    Ожидаем.Что(ТочкаД["max"]).Равно(500.0);
    // Временны́е метки
    Ожидаем.Что(ТочкаД["start_time_unix_nano"]).Равно("1000000000000000001");
    Ожидаем.Что(ТочкаД["time_unix_nano"]).Равно("2000000000000000001");
    // bucketCounts как строки
    Ожидаем.Что(ТочкаД["bucket_counts"][0]).Равно("5");
    Ожидаем.Что(ТочкаД["bucket_counts"][1]).Равно("10");
    Ожидаем.Что(ТочкаД["bucket_counts"][2]).Равно("3");
    // explicitBounds
    Ожидаем.Что(ТочкаД["explicit_bounds"][0]).Равно(10.0);
    Ожидаем.Что(ТочкаД["explicit_bounds"][1]).Равно(100.0);
    // BSLLS:CommentedCode-off
    // aggregationTemporality = CUMULATIVE
    // BSLLS:CommentedCode-on
    Ожидаем.Что(М["histogram"]["aggregation_temporality"]).Равно("AGGREGATION_TEMPORALITY_CUMULATIVE");
КонецПроцедуры

