Процедура ПриСозданииОбъекта()
КонецПроцедуры

// --- Вспомогательные функции ---

Функция ПутьДекодера()
    ПутьHelpersDir = ОбъединитьПути(ТекущийСценарий().Каталог, "..", "..", "helpers");
    Возврат ОбъединитьПути(ПутьHelpersDir, "proto_decoder.py");
КонецФункции

Функция ДекодироватьПротоБайты(Байты)
    ВременныйФайл = ПолучитьИмяВременногоФайла("bin");
    ЗаписьД = Новый ЗаписьДанных(ВременныйФайл);
    ЗаписьД.Записать(Байты);
    ЗаписьД.Закрыть();

    Команда = "python3 " + ПутьДекодера() + " metrics " + ВременныйФайл;
    Процесс = СоздатьПроцесс(Команда, , Истина, Истина);
    Процесс.Запустить();
    Пока НЕ Процесс.Завершен Цикл
        Приостановить(50);
    КонецЦикла;

    Вывод = "";
    Пока Процесс.ПотокВывода.ЕстьДанные Цикл
        Вывод = Вывод + Процесс.ПотокВывода.Прочитать();
    КонецЦикла;

    УдалитьФайлы(ВременныйФайл);

    Если Процесс.КодВозврата <> 0 Тогда
        ОшибкаДекодера = "";
        Пока Процесс.ПотокОшибок.ЕстьДанные Цикл
            ОшибкаДекодера = ОшибкаДекодера + Процесс.ПотокОшибок.Прочитать();
        КонецЦикла;
        ВызватьИсключение "proto_decoder.py завершился с кодом " + Процесс.КодВозврата + ": " + ОшибкаДекодера;
    КонецЕсли;

    Разбор = Новый ЧтениеJSON();
    Разбор.УстановитьСтроку(Вывод);
    Возврат ПрочитатьJSON(Разбор);
КонецФункции

Функция УпаковатьВСтруктуруМетрик(Метрика)
    МассивМетрик = Новый Массив();
    МассивМетрик.Добавить(Метрика);
    Скоп = Новый Соответствие();
    Скоп.Вставить("name", "test-scope");
    Скоп.Вставить("version", "1.0.0");
    ОбластьМетрик = Новый Соответствие();
    ОбластьМетрик.Вставить("scope", Скоп);
    ОбластьМетрик.Вставить("metrics", МассивМетрик);
    МассивОбластей = Новый Массив();
    МассивОбластей.Добавить(ОбластьМетрик);
    РесурснаяМетрика = Новый Соответствие();
    РесурснаяМетрика.Вставить("resource", Новый Соответствие());
    РесурснаяМетрика.Вставить("scopeMetrics", МассивОбластей);
    МассивРесурсных = Новый Массив();
    МассивРесурсных.Добавить(РесурснаяМетрика);
    Данные = Новый Соответствие();
    Данные.Вставить("resourceMetrics", МассивРесурсных);
    Возврат Данные;
КонецФункции

Функция ПолучитьПервуюМетрику(ДекодированныеДанные)
    Возврат ДекодированныеДанные["resource_metrics"][0]["scope_metrics"][0]["metrics"][0];
КонецФункции

Функция СоздатьАтрибутСтроку(Ключ, Значение)
    АтрВаль = Новый Соответствие();
    АтрВаль.Вставить("stringValue", Значение);
    Атр = Новый Соответствие();
    Атр.Вставить("key", Ключ);
    Атр.Вставить("value", АтрВаль);
    Возврат Атр;
КонецФункции

// --- Тесты Sum/Counter ---

&Тест
Процедура ПоляSum_ОсновныеПоляМетрики() Экспорт
    // Проверяем name, description, unit на Sum-метрике
    ТочкаДанных = Новый Соответствие();
    ТочкаДанных.Вставить("startTimeUnixNano", 1000000000);
    ТочкаДанных.Вставить("timeUnixNano", 2000000000);
    ТочкаДанных.Вставить("asInt", "42");
    ТочкаДанных.Вставить("attributes", Новый Массив());
    МассивТочек = Новый Массив();
    МассивТочек.Добавить(ТочкаДанных);
    Сумма = Новый Соответствие();
    Сумма.Вставить("dataPoints", МассивТочек);
    Сумма.Вставить("aggregationTemporality", 2);
    Сумма.Вставить("isMonotonic", Истина);
    Метрика = Новый Соответствие();
    Метрика.Вставить("name", "requests.total");
    Метрика.Вставить("description", "Total request count");
    Метрика.Вставить("unit", "{requests}");
    Метрика.Вставить("sum", Сумма);

    Результат = ОтелПротоКодировщикMetrics.ЗакодироватьMetricsData(УпаковатьВСтруктуруМетрик(Метрика));
    Декодировано = ДекодироватьПротоБайты(Результат);

    М = ПолучитьПервуюМетрику(Декодировано);
    Ожидаем.Что(М["name"]).Равно("requests.total");
    Ожидаем.Что(М["description"]).Равно("Total request count");
    Ожидаем.Что(М["unit"]).Равно("{requests}");
КонецПроцедуры

&Тест
Процедура ПоляSum_ТочкаДанных_asInt_КакСтрока() Экспорт
    // asInt передаётся как строка "42" (OTLP JSON int64 convention)
    // - ключевой тест для исправленного бага с приведением типов
    ТочкаДанных = Новый Соответствие();
    ТочкаДанных.Вставить("startTimeUnixNano", "1000000000");
    ТочкаДанных.Вставить("timeUnixNano", "2000000000");
    ТочкаДанных.Вставить("asInt", "12345678");
    ТочкаДанных.Вставить("attributes", Новый Массив());
    МассивТочек = Новый Массив();
    МассивТочек.Добавить(ТочкаДанных);
    Сумма = Новый Соответствие();
    Сумма.Вставить("dataPoints", МассивТочек);
    Сумма.Вставить("aggregationTemporality", 2);
    Сумма.Вставить("isMonotonic", Истина);
    Метрика = Новый Соответствие();
    Метрика.Вставить("name", "counter");
    Метрика.Вставить("sum", Сумма);

    Результат = ОтелПротоКодировщикMetrics.ЗакодироватьMetricsData(УпаковатьВСтруктуруМетрик(Метрика));
    Декодировано = ДекодироватьПротоБайты(Результат);

    М = ПолучитьПервуюМетрику(Декодировано);
    ТочкаД = М["sum"]["data_points"][0];
    // asInt кодируется через sfixed64 → в JSON как строка
    Ожидаем.Что(ТочкаД["as_int"]).Равно("12345678");
    // Временны́е метки как строки
    Ожидаем.Что(ТочкаД["start_time_unix_nano"]).Равно("1000000000");
    Ожидаем.Что(ТочкаД["time_unix_nano"]).Равно("2000000000");
КонецПроцедуры

