#Использовать "../../.."
#Использовать asserts

&Тест
Процедура ОтправитьСохраняетДанные() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Данные = Новый Соответствие();
    Данные.Вставить("key", "value");

    // Когда
    Результат = Транспорт.Отправить("/v1/traces", Данные);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(1);
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()[0].Получить("Путь")).Равно("/v1/traces");
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()[0].Получить("Данные").Получить("key")).Равно("value");

КонецПроцедуры

&Тест
Процедура НесколькоОтправок() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();

    // Когда
    Транспорт.Отправить("/v1/traces", Новый Соответствие());
    Транспорт.Отправить("/v1/logs", Новый Соответствие());
    Транспорт.Отправить("/v1/metrics", Новый Соответствие());

    // Тогда
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(3);
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()[0].Получить("Путь")).Равно("/v1/traces");
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()[1].Получить("Путь")).Равно("/v1/logs");
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()[2].Получить("Путь")).Равно("/v1/metrics");

КонецПроцедуры

&Тест
Процедура ОчиститьУдаляетДанные() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Транспорт.Отправить("/v1/traces", Новый Соответствие());
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(1);

    // Когда
    Транспорт.Очистить();

    // Тогда
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ЗакрытьБлокируетОтправку() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();

    // Когда
    Транспорт.Закрыть();
    Результат = Транспорт.Отправить("/v1/traces", Новый Соответствие());

    // Тогда
    Ожидаем.Что(Результат).Равно(Ложь);
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ПустойТранспортВозвращаетПустойМассив() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();

    // Тогда
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетТип("Массив");
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(0);

КонецПроцедуры
