&Тест
Процедура ЗакодироватьLogsData_ПустаяСтруктура() Экспорт
    Данные = Новый Соответствие();
    Данные.Вставить("resourceLogs", Новый Массив());

    Результат = ОтелПротоКодировщикLogs.ЗакодироватьLogsData(Данные);

    Ожидаем.Что(ТипЗнч(Результат)).Равно(Тип("ДвоичныеДанные"));
    Ожидаем.Что(Результат.Размер()).Равно(0);
КонецПроцедуры

&Тест
Процедура ЗакодироватьLogsData_ОдинЛог() Экспорт
    // Строим LogRecord с основными полями
    АтрВаль = Новый Соответствие();
    АтрВаль.Вставить("stringValue", "production");

    Атрибут = Новый Соответствие();
    Атрибут.Вставить("key", "env");
    Атрибут.Вставить("value", АтрВаль);

    МассивАтр = Новый Массив();
    МассивАтр.Добавить(Атрибут);

    ТелоВаль = Новый Соответствие();
    ТелоВаль.Вставить("stringValue", "Ошибка подключения к базе данных");

    ЗаписьЛога = Новый Соответствие();
    ЗаписьЛога.Вставить("timeUnixNano", 1700000000000000000);
    ЗаписьЛога.Вставить("observedTimeUnixNano", 1700000000100000000);
    ЗаписьЛога.Вставить("severityNumber", 17);
    ЗаписьЛога.Вставить("severityText", "ERROR");
    ЗаписьЛога.Вставить("body", ТелоВаль);
    ЗаписьЛога.Вставить("attributes", МассивАтр);
    ЗаписьЛога.Вставить("droppedAttributesCount", 0);
    ЗаписьЛога.Вставить("traceId", "00000000000000000000000000000001");
    ЗаписьЛога.Вставить("spanId", "0000000000000001");
    ЗаписьЛога.Вставить("flags", 1);

    МассивЗаписей = Новый Массив();
    МассивЗаписей.Добавить(ЗаписьЛога);

    Скоп = Новый Соответствие();
    Скоп.Вставить("name", "test-logger");
    Скоп.Вставить("version", "1.0.0");

    ОбластьЛогов = Новый Соответствие();
    ОбластьЛогов.Вставить("scope", Скоп);
    ОбластьЛогов.Вставить("logRecords", МассивЗаписей);

    МассивОбластей = Новый Массив();
    МассивОбластей.Добавить(ОбластьЛогов);

    РесурсАтр = Новый Соответствие();
    РесурсАтр.Вставить("key", "service.name");
    РесурсАтрВаль = Новый Соответствие();
    РесурсАтрВаль.Вставить("stringValue", "my-service");
    РесурсАтр.Вставить("value", РесурсАтрВаль);

    МассивРесурсАтр = Новый Массив();
    МассивРесурсАтр.Добавить(РесурсАтр);

    Ресурс = Новый Соответствие();
    Ресурс.Вставить("attributes", МассивРесурсАтр);

    РесурсныеЛоги = Новый Соответствие();
    РесурсныеЛоги.Вставить("resource", Ресурс);
    РесурсныеЛоги.Вставить("scopeLogs", МассивОбластей);

    МассивРесурсных = Новый Массив();
    МассивРесурсных.Добавить(РесурсныеЛоги);

    Данные = Новый Соответствие();
    Данные.Вставить("resourceLogs", МассивРесурсных);

    Результат = ОтелПротоКодировщикLogs.ЗакодироватьLogsData(Данные);

    Ожидаем.Что(ТипЗнч(Результат)).Равно(Тип("ДвоичныеДанные"));
    Ожидаем.Что(Результат.Размер()).Больше(0);
КонецПроцедуры

