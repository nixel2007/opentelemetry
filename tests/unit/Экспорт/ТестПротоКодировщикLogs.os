&Тест
Процедура ЗакодироватьLogsData_БезТела() Экспорт
    // Покрывает строку 338: ранний возврат в КодироватьТелоLogRecord когда тело = Неопределено

    ЗаписьЛога = Новый Соответствие();
    ЗаписьЛога.Вставить("timeUnixNano", 1700000000000000000);
    ЗаписьЛога.Вставить("severityNumber", 9);
    ЗаписьЛога.Вставить("severityText", "INFO");
    // Намеренно НЕ устанавливаем "body" - КодироватьТелоLogRecord получит Неопределено

    МассивЗаписей = Новый Массив();
    МассивЗаписей.Добавить(ЗаписьЛога);

    ОбластьЛогов = Новый Соответствие();
    ОбластьЛогов.Вставить("scope", Новый Соответствие());
    ОбластьЛогов.Вставить("logRecords", МассивЗаписей);

    МассивОбластей = Новый Массив();
    МассивОбластей.Добавить(ОбластьЛогов);

    РесурсныеЛоги = Новый Соответствие();
    РесурсныеЛоги.Вставить("resource", Новый Соответствие());
    РесурсныеЛоги.Вставить("scopeLogs", МассивОбластей);

    МассивРесурсных = Новый Массив();
    МассивРесурсных.Добавить(РесурсныеЛоги);

    Данные = Новый Соответствие();
    Данные.Вставить("resourceLogs", МассивРесурсных);

    Результат = ОтелПротоКодировщикLogs.ЗакодироватьLogsData(Данные);

    Ожидаем.Что(ТипЗнч(Результат)).Равно(Тип("ДвоичныеДанные"));
    Ожидаем.Что(Результат.Размер()).Больше(0);
КонецПроцедуры
