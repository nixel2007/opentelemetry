&Тест
Процедура КодированиеAnyValueБулевоЧислоДробное() Экспорт

    // Дано - спан с атрибутами типов boolValue, intValue, doubleValue
    Данные = Новый Соответствие();

    Ресурс = Новый Соответствие();
    Ресурс.Вставить("attributes", Новый Массив());
    Ресурс.Вставить("droppedAttributesCount", 0);

    Спан = Новый Соответствие();
    Спан.Вставить("traceId", "00000000000000000000000000000001");
    Спан.Вставить("spanId", "0000000000000001");
    Спан.Вставить("name", "any-value-span");
    Спан.Вставить("kind", 0);
    Спан.Вставить("startTimeUnixNano", 1000000000);
    Спан.Вставить("endTimeUnixNano", 2000000000);

    КлючАтрибута = "key";
    КлючЗначения = "value";
    МассивАтрибутов = Новый Массив();

    АтрБул = Новый Соответствие();
    АтрБул.Вставить(КлючАтрибута, "flag");
    ЗначБул = Новый Соответствие();
    ЗначБул.Вставить("boolValue", Истина);
    АтрБул.Вставить(КлючЗначения, ЗначБул);
    МассивАтрибутов.Добавить(АтрБул);

    АтрЧисло = Новый Соответствие();
    АтрЧисло.Вставить(КлючАтрибута, "count");
    ЗначЧисло = Новый Соответствие();
    ЗначЧисло.Вставить("intValue", 42);
    АтрЧисло.Вставить(КлючЗначения, ЗначЧисло);
    МассивАтрибутов.Добавить(АтрЧисло);

    АтрДробное = Новый Соответствие();
    АтрДробное.Вставить(КлючАтрибута, "ratio");
    ЗначДробное = Новый Соответствие();
    ЗначДробное.Вставить("doubleValue", 3.14);
    АтрДробное.Вставить(КлючЗначения, ЗначДробное);
    МассивАтрибутов.Добавить(АтрДробное);

    Спан.Вставить("attributes", МассивАтрибутов);
    Спан.Вставить("droppedAttributesCount", 0);
    Спан.Вставить("events", Новый Массив());
    Спан.Вставить("droppedEventsCount", 0);
    Спан.Вставить("links", Новый Массив());
    Спан.Вставить("droppedLinksCount", 0);
    Спан.Вставить("flags", 1);

    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    ScopeSpans = Новый Соответствие();
    ScopeSpans.Вставить("scope", Новый Соответствие());
    ScopeSpans.Вставить("spans", МассивСпанов);
    ScopeSpans.Вставить("droppedSpansCount", 0);

    МассивScopeSpans = Новый Массив();
    МассивScopeSpans.Добавить(ScopeSpans);

    ResourceSpans = Новый Соответствие();
    ResourceSpans.Вставить("resource", Ресурс);
    ResourceSpans.Вставить("scopeSpans", МассивScopeSpans);
    ResourceSpans.Вставить("droppedSpansCount", 0);

    МассивРесурсов = Новый Массив();
    МассивРесурсов.Добавить(ResourceSpans);
    Данные.Вставить("resourceSpans", МассивРесурсов);

    // Когда
    Результат = ОтелПротоКодировщикTrace.ЗакодироватьTracesData(Данные);

    // Тогда - boolValue, intValue, doubleValue закодированы без ошибок
    Ожидаем.Что(ТипЗнч(Результат) = Тип("ДвоичныеДанные")).Равно(Истина);
    Ожидаем.Что(Результат.Размер() > 0).Равно(Истина);

КонецПроцедуры

