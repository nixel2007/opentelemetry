&Тест
Процедура ЗакодироватьInstrumentationScope() Экспорт
    // scope с name, version, droppedAttributesCount > 0 - покрывает ветки 126-133, 140-141
    Данные = Новый Соответствие();

    КлючАтрибутов = "attributes";
    КлючСброшенных = "droppedAttributesCount";
    Ресурс = Новый Соответствие();
    Ресурс.Вставить(КлючАтрибутов, Новый Массив());
    Ресурс.Вставить(КлючСброшенных, 0);

    Спан = Новый Соответствие();
    Спан.Вставить("traceId", "00000000000000000000000000000001");
    Спан.Вставить("spanId", "0000000000000001");
    Спан.Вставить("name", "test");
    Спан.Вставить("kind", 0);
    Спан.Вставить("startTimeUnixNano", 1000000000);
    Спан.Вставить("endTimeUnixNano", 2000000000);
    Спан.Вставить(КлючАтрибутов, Новый Массив());
    Спан.Вставить(КлючСброшенных, 0);
    Спан.Вставить("events", Новый Массив());
    Спан.Вставить("droppedEventsCount", 0);
    Спан.Вставить("links", Новый Массив());
    Спан.Вставить("droppedLinksCount", 0);
    Спан.Вставить("flags", 1);

    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    Скоп = Новый Соответствие();
    Скоп.Вставить("name", "my-instrumentation-library");
    Скоп.Вставить("version", "1.2.3");
    Скоп.Вставить(КлючАтрибутов, Новый Массив());
    Скоп.Вставить(КлючСброшенных, 5);

    ScopeSpans = Новый Соответствие();
    ScopeSpans.Вставить("scope", Скоп);
    ScopeSpans.Вставить("spans", МассивСпанов);
    ScopeSpans.Вставить("droppedSpansCount", 0);

    МассивScopeSpans = Новый Массив();
    МассивScopeSpans.Добавить(ScopeSpans);

    ResourceSpans = Новый Соответствие();
    ResourceSpans.Вставить("resource", Ресурс);
    ResourceSpans.Вставить("scopeSpans", МассивScopeSpans);
    ResourceSpans.Вставить("droppedSpansCount", 0);

