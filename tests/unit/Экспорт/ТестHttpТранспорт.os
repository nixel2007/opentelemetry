// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts

Перем МокСервер;
Перем Порт;

&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта()
КонецПроцедуры

&ПередВсеми
Процедура ПередВсемиТестами() Экспорт
    Порт = 14318 + Цел(ТекущаяУниверсальнаяДата() - Дата(2025, 1, 1)) % 100;
    КаталогПроекта = ОбъединитьПути(ТекущийСценарий().Каталог, "..", "..", "..");
    ПутьСкрипта = ОбъединитьПути(КаталогПроекта, "tests", "helpers", "mock_otlp_server.py");
    МокСервер = СоздатьПроцесс("python3 " + ПутьСкрипта + " " + Порт, , Истина);
    МокСервер.Запустить();
    Приостановить(1000);
КонецПроцедуры

&ПослеВсех
Процедура ПослеВсехТестов() Экспорт
    Если МокСервер <> Неопределено Тогда
        МокСервер.Завершить();
    КонецЕсли;
КонецПроцедуры

&Тест
Процедура ОтправитьУспешно() Экспорт

    // Дано
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + Порт);
    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", Новый Массив());

    // Когда
    Результат = Транспорт.Отправить("/v1/traces", Данные);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОтправитьОшибкаСервера() Экспорт

    // Дано - адрес возвращает 500 (не retryable)
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + Порт, , , 1);
    Данные = Новый Соответствие();

    // Когда
    Результат = Транспорт.Отправить("/error", Данные);

    // Тогда
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ОтправитьСлишкомМногоЗапросовОднаПопытка() Экспорт

    // Дано - 429 с одной попыткой = не retryable (НомерПопытки = МаксПопыток)
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + Порт, , , 1);
    Данные = Новый Соответствие();

    // Когда
    Результат = Транспорт.Отправить("/too-many", Данные);

    // Тогда - не retryable при одной попытке (53-54: лог + Ложь)
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ОтправитьRetryИсчерпаныПопытки() Экспорт

    // Дано - 429 с двумя попытками: первая retry, вторая тоже 429 -> все попытки исчерпаны
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + Порт, , , 2);
    Данные = Новый Соответствие();

    // Когда
    Результат = Транспорт.Отправить("/too-many", Данные);

    // Тогда - исчерпаны попытки (строка 57: Возврат Ложь)
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ОтправитьОшибкаСоединения() Экспорт

    // Дано - несуществующий адрес -> исключение при POST
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:1");
    Данные = Новый Соответствие();

    // Когда
    Результат = Транспорт.Отправить("/v1/traces", Данные);

    // Тогда - обработчик исключения (строки 59-61)
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура КонструкторСПользовательскимиЗаголовками() Экспорт

    // Дано
    Заголовки = Новый Соответствие();
    Заголовки.Вставить("Authorization", "Bearer test-token");
    Заголовки.Вставить("X-Custom", "custom-value");

    // Когда - конструктор с дополнительными заголовками (строки 92-94)
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + Порт, Заголовки);
    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", Новый Массив());

    // Тогда - отправка с кастомными заголовками работает
    Результат = Транспорт.Отправить("/v1/traces", Данные);
    Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КонструкторСТаймаутом() Экспорт

    // Дано / Когда
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + Порт, , 5);

    // Тогда - объект создан без ошибок
    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ОтправитьСGzipСжатием() Экспорт

    // Дано - транспорт с gzip-компрессией
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + Порт, , , , "gzip");
    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", Новый Массив());

    // Когда - отправка на эндпоинт, проверяющий gzip
    Результат = Транспорт.Отправить("/v1/gzip-traces", Данные);

    // Тогда - сервер принял и распаковал gzip
    Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОтправитьБезСжатияНаGzipАдрес() Экспорт

    // Дано - транспорт БЕЗ компрессии
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:" + Порт);
    Данные = Новый Соответствие();
    Данные.Вставить("resourceSpans", Новый Массив());

    // Когда - отправка на gzip-эндпоинт без сжатия
    Результат = Транспорт.Отправить("/v1/gzip-traces", Данные);

    // Тогда - сервер отклонил (нет Content-Encoding: gzip)
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры
