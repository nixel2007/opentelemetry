#Использовать asserts
#Использовать moskito

&Тест
Процедура ЭкспортСпановGrpc() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелGrpcТранспорт"));
    МокТранспорт.Когда().Отправить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелGrpcЭкспортерСпанов(МокТранспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тестовая-операция", Ресурс, "тест-библ", "1.0");
    Спан.Завершить();
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    // Когда
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить("/v1/traces", Матчеры.ЛюбоеЗначение());

КонецПроцедуры

&Тест
Процедура ЭкспортЛоговGrpc() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелGrpcТранспорт"));
    МокТранспорт.Когда().Отправить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелGrpcЭкспортерЛогов(МокТранспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("тестовое сообщение");
    МассивЗаписей = Новый Массив();
    МассивЗаписей.Добавить(Запись);

    // Когда
    Результат = Экспортер.Экспортировать(МассивЗаписей, Ресурс, "тест-библ", "1.0");

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить("/v1/logs", Матчеры.ЛюбоеЗначение());

КонецПроцедуры

&Тест
Процедура ЭкспортМетрикGrpc() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелGrpcТранспорт"));
    МокТранспорт.Когда().Отправить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);

    Ресурс = Новый ОтелРесурс(Истина);
    Ресурс.Атрибуты().Установить("service.name", "тест-сервис");

    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("тест-библ", "1.0");
    Счетчик = Метр.СоздатьСчетчик("test_counter");
    Счетчик.Добавить(1);

    Экспортер = Новый ОтелGrpcЭкспортерМетрик(МокТранспорт);

    // Когда
    Результат = Экспортер.Экспортировать(Метр);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить("/v1/metrics", Матчеры.ЛюбоеЗначение());

КонецПроцедуры
