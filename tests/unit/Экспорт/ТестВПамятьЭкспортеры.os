// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

// Тесты экспортера спанов в память

&Тест
Процедура СозданиеЭкспортераСпанов() Экспорт

    // Дано / Когда
    Экспортер = Новый ОтелВПамятьЭкспортерСпанов();

    // Тогда
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные()).ИмеетТип("Массив");
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ЭкспортСпанов() Экспорт

    // Дано
    Экспортер = Новый ОтелВПамятьЭкспортерСпанов();
    МассивСпанов = Новый Массив();
    МокСпан = Мок.Получить(Тип("Структура"));
    МассивСпанов.Добавить(МокСпан);

    // Когда
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(1);

КонецПроцедуры

&Тест
Процедура ОчисткаСпанов() Экспорт

    // Дано
    Экспортер = Новый ОтелВПамятьЭкспортерСпанов();
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Мок.Получить(Тип("Структура")));
    Экспортер.Экспортировать(МассивСпанов);

    // Когда
    Экспортер.Очистить();

    // Тогда
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ЗакрытиеСпанов() Экспорт

    // Дано
    Экспортер = Новый ОтелВПамятьЭкспортерСпанов();
    Экспортер.Закрыть();

    // Когда
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Мок.Получить(Тип("Структура")));
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

// Тесты экспортера логов в память

&Тест
Процедура СозданиеЭкспортераЛогов() Экспорт

    // Дано / Когда
    Экспортер = Новый ОтелВПамятьЭкспортерЛогов();

    // Тогда
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные()).ИмеетТип("Массив");
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ЭкспортЛогов() Экспорт

    // Дано
    Экспортер = Новый ОтелВПамятьЭкспортерЛогов();
    МассивЗаписей = Новый Массив();
    МокЗапись = Мок.Получить(Тип("Структура"));
    МассивЗаписей.Добавить(МокЗапись);

    МокРесурс = Мок.Получить(Тип("Структура"));

    // Когда
    Результат = Экспортер.Экспортировать(МассивЗаписей, МокРесурс, "test-lib", "1.0");

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(1);

КонецПроцедуры

// Тесты экспортера метрик в память

&Тест
Процедура СозданиеЭкспортераМетрик() Экспорт

    // Дано / Когда
    Экспортер = Новый ОтелВПамятьЭкспортерМетрик();

    // Тогда
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные()).ИмеетТип("Массив");
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ЭкспортМетрик() Экспорт

    // Дано
    Экспортер = Новый ОтелВПамятьЭкспортерМетрик();

    Ресурс = Новый ОтелРесурс(Истина);
    Ресурс.Атрибуты().Установить("service.name", "тест-сервис");
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("test-lib", "1.0");
    Счетчик = Метр.СоздатьСчетчик("test_counter");
    Счетчик.Добавить(1);

    // Когда
    Результат = Экспортер.Экспортировать(Метр);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    Ожидаем.Что(Экспортер.ПолучитьЭкспортированные().Количество()).Равно(1);

КонецПроцедуры
