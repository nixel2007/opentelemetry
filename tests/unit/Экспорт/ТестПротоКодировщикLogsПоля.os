&Тест
Процедура ПоляLogRecord_TraceIdSpanId() Экспорт
    // trace_id и span_id — bytes, в JSON base64
    ЗаписьЛога = Новый Соответствие();
    ЗаписьЛога.Вставить("timeUnixNano", "1000000000000000000");
    ЗаписьЛога.Вставить("traceId", "00000000000000000000000000000001");
    ЗаписьЛога.Вставить("spanId", "0000000000000001");
    ЗаписьЛога.Вставить("body", Новый Соответствие());

    Результат = ОтелПротоКодировщикLogs.ЗакодироватьLogsData(УпаковатьЗаписьЛога(ЗаписьЛога));
    Декодировано = ДекодироватьПротоБайты(Результат);
    Запись = ПолучитьПервуюЗапись(Декодировано);

    Ожидаем.Что(Запись["trace_id"]).Равно("AAAAAAAAAAAAAAAAAAAAAQ==");
    Ожидаем.Что(Запись["span_id"]).Равно("AAAAAAAAAAE=");
КонецПроцедуры

&Тест
Процедура ПоляScope_ИмяВерсия() Экспорт
    // Проверяем передачу scope name/version
    ЗаписьЛога = Новый Соответствие();
    ЗаписьЛога.Вставить("timeUnixNano", "1000000000000000000");
    ЗаписьЛога.Вставить("body", Новый Соответствие());
    МассивЗаписей = Новый Массив();
    МассивЗаписей.Добавить(ЗаписьЛога);
    Скоп = Новый Соответствие();
    Скоп.Вставить("name", "my.logs.lib");
    Скоп.Вставить("version", "2.3.1");
    ОбластьЛогов = Новый Соответствие();
    ОбластьЛогов.Вставить("scope", Скоп);
    ОбластьЛогов.Вставить("logRecords", МассивЗаписей);
    МассивОбластей = Новый Массив();
    МассивОбластей.Добавить(ОбластьЛогов);
    РесурсныеЛоги = Новый Соответствие();
    РесурсныеЛоги.Вставить("resource", Новый Соответствие());
    РесурсныеЛоги.Вставить("scopeLogs", МассивОбластей);
    МассивРесурсных = Новый Массив();
    МассивРесурсных.Добавить(РесурсныеЛоги);
    Данные = Новый Соответствие();
    Данные.Вставить("resourceLogs", МассивРесурсных);

    Результат = ОтелПротоКодировщикLogs.ЗакодироватьLogsData(Данные);
    Декодировано = ДекодироватьПротоБайты(Результат);

    Скоп = Декодировано["resource_logs"][0]["scope_logs"][0]["scope"];
    Ожидаем.Что(Скоп["name"]).Равно("my.logs.lib");
    Ожидаем.Что(Скоп["version"]).Равно("2.3.1");
КонецПроцедуры

&Тест
Процедура ПоляResource_Атрибуты() Экспорт
    // resource.attributes
    АтрВаль = Новый Соответствие();
