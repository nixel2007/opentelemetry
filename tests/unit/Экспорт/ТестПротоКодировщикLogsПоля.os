&ТестовыйНабор
Процедура ПриСозданииОбъекта()
КонецПроцедуры

// --- Вспомогательные функции ---

Функция ПутьДекодера()
    ПутьHelpersDir = ОбъединитьПути(ТекущийСценарий().Каталог, "..", "..", "helpers");
    Возврат ОбъединитьПути(ПутьHelpersDir, "proto_decoder.py");
КонецФункции

Функция ДекодироватьПротоБайты(Байты)
    ВременныйФайл = ПолучитьИмяВременногоФайла("bin");
    ЗаписьД = Новый ЗаписьДанных(ВременныйФайл);
    ЗаписьД.Записать(Байты);
    ЗаписьД.Закрыть();

    Команда = "python3 " + ПутьДекодера() + " logs " + ВременныйФайл;
    Процесс = СоздатьПроцесс(Команда,, Истина, Истина);
    Процесс.Запустить();
    Пока НЕ Процесс.Завершен Цикл
        Приостановить(50);
    КонецЦикла;

    Вывод = "";
    Пока Процесс.ПотокВывода.ЕстьДанные Цикл
        Вывод = Вывод + Процесс.ПотокВывода.Прочитать();
    КонецЦикла;

    УдалитьФайлы(ВременныйФайл);

    Если Процесс.КодВозврата <> 0 Тогда
        ОшибкаДекодера = "";
        Пока Процесс.ПотокОшибок.ЕстьДанные Цикл
            ОшибкаДекодера = ОшибкаДекодера + Процесс.ПотокОшибок.Прочитать();
        КонецЦикла;
        ВызватьИсключение "proto_decoder.py завершился с кодом " + Процесс.КодВозврата + ": " + ОшибкаДекодера;
    КонецЕсли;

    Разбор = Новый ЧтениеJSON();
    Разбор.УстановитьСтроку(Вывод);
    Возврат ПрочитатьJSON(Разбор);
КонецФункции

Функция УпаковатьЗаписьЛога(ЗаписьЛога)
    МассивЗаписей = Новый Массив();
    МассивЗаписей.Добавить(ЗаписьЛога);
    Скоп = Новый Соответствие();
    Скоп.Вставить("name", "test-scope");
    Скоп.Вставить("version", "1.0.0");
    ОбластьЛогов = Новый Соответствие();
    ОбластьЛогов.Вставить("scope", Скоп);
    ОбластьЛогов.Вставить("logRecords", МассивЗаписей);
    МассивОбластей = Новый Массив();
    МассивОбластей.Добавить(ОбластьЛогов);
    РесурсныеЛоги = Новый Соответствие();
    РесурсныеЛоги.Вставить("resource", Новый Соответствие());
    РесурсныеЛоги.Вставить("scopeLogs", МассивОбластей);
    МассивРесурсных = Новый Массив();
    МассивРесурсных.Добавить(РесурсныеЛоги);
    Данные = Новый Соответствие();
    Данные.Вставить("resourceLogs", МассивРесурсных);
    Возврат Данные;
КонецФункции

Функция ПолучитьПервуюЗапись(ДекодированныеДанные)
    Возврат ДекодированныеДанные["resource_logs"][0]["scope_logs"][0]["log_records"][0];
КонецФункции

// --- Тесты ---

&Тест
Процедура ПоляLogRecord_Временные_метки() Экспорт
    // time_unix_nano и observed_time_unix_nano — fixed64
    ЗаписьЛога = Новый Соответствие();
    ЗаписьЛога.Вставить("timeUnixNano", "1000000000000000001");
    ЗаписьЛога.Вставить("observedTimeUnixNano", "2000000000000000001");
    ЗаписьЛога.Вставить("body", Новый Соответствие());

    Результат = ОтелПротоКодировщикLogs.ЗакодироватьLogsData(УпаковатьЗаписьЛога(ЗаписьЛога));
    Декодировано = ДекодироватьПротоБайты(Результат);
    Запись = ПолучитьПервуюЗапись(Декодировано);

    Ожидаем.Что(Запись["time_unix_nano"]).Равно("1000000000000000001");
    Ожидаем.Что(Запись["observed_time_unix_nano"]).Равно("2000000000000000001");
КонецПроцедуры

&Тест
Процедура ПоляLogRecord_СерьезностьЧислоИТекст() Экспорт
    // severity_number (varint) и severity_text (string)
    ЗаписьЛога = Новый Соответствие();
    ЗаписьЛога.Вставить("timeUnixNano", "1000000000000000000");
    ЗаписьЛога.Вставить("severityNumber", 9);
    ЗаписьЛога.Вставить("severityText", "INFO");
    ЗаписьЛога.Вставить("body", Новый Соответствие());

    Результат = ОтелПротоКодировщикLogs.ЗакодироватьLogsData(УпаковатьЗаписьЛога(ЗаписьЛога));
    Декодировано = ДекодироватьПротоБайты(Результат);
    Запись = ПолучитьПервуюЗапись(Декодировано);

    Ожидаем.Что(Запись["severity_number"]).Равно("SEVERITY_NUMBER_INFO");
    Ожидаем.Что(Запись["severity_text"]).Равно("INFO");
КонецПроцедуры

