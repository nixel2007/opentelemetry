&ТестовыйНабор(Характер = "Одиночка")
Процедура ПриСозданииОбъекта()
КонецПроцедуры

// ====== ОтелНастройкиTls ======

&Тест
Процедура НастройкиTlsПоУмолчанию() Экспорт

    // Дано / Когда
    НастройкиTls = Новый ОтелНастройкиTls();

    // Тогда - все поля пустые / false
    Ожидаем.Что(НастройкиTls.ФайлСертификата).Равно("");
    Ожидаем.Что(НастройкиTls.ФайлКлиентскогоКлюча).Равно("");
    Ожидаем.Что(НастройкиTls.ФайлКлиентскогоСертификата).Равно("");
    Ожидаем.Что(НастройкиTls.Insecure).Равно(Ложь);
    Ожидаем.Что(НастройкиTls.Применен()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура НастройкиTlsПримененСФайломСертификата() Экспорт

    // Дано
    НастройкиTls = Новый ОтелНастройкиTls();

    // Когда
    НастройкиTls.ФайлСертификата = "/etc/ssl/certs/ca-certificates.crt";

    // Тогда
    Ожидаем.Что(НастройкиTls.Применен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура НастройкиTlsПримененСInsecure() Экспорт

    // Дано
    НастройкиTls = Новый ОтелНастройкиTls();

    // Когда
    НастройкиTls.Insecure = Истина;

    // Тогда
    Ожидаем.Что(НастройкиTls.Применен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура НастройкиTlsПримененСКлиентскимСертификатом() Экспорт

    // Дано
    НастройкиTls = Новый ОтелНастройкиTls();

    // Когда
    НастройкиTls.ФайлКлиентскогоСертификата = "/tmp/client.crt";
    НастройкиTls.ФайлКлиентскогоКлюча = "/tmp/client.key";

    // Тогда
    Ожидаем.Что(НастройкиTls.Применен()).Равно(Истина);

КонецПроцедуры

// ====== ОтелHttpТранспорт с TLS ======

&Тест
Процедура КонструкторТранспортаСНастройкамиTls() Экспорт

    // Дано - настройки TLS с файлом клиентского сертификата
    НастройкиTls = Новый ОтелНастройкиTls();
    НастройкиTls.ФайлКлиентскогоСертификата = "/tmp/client.crt";
    НастройкиTls.ФайлКлиентскогоКлюча = "/tmp/client.key";

    // Когда - конструктор транспорта принимает настройки TLS (менеджер соединений создан)
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:4318", , , , , НастройкиTls, "http/json");

    // Тогда - транспорт создан и хранит настройки TLS
    Ожидаем.Что(Транспорт.ПолучитьНастройкиTls()).Не_().Равно(Неопределено);
    Ожидаем.Что(Транспорт.ПолучитьНастройкиTls().Применен()).Равно(Истина);
    Ожидаем.Что(Транспорт.ПолучитьНастройкиTls().ФайлКлиентскогоСертификата).Равно("/tmp/client.crt");

КонецПроцедуры

&Тест
Процедура КонструкторТранспортаБезTls() Экспорт

    // Дано / Когда - без TLS настроек
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:4318", , , , , , "http/json");

    // Тогда - нет настроек TLS
    Ожидаем.Что(Транспорт.ПолучитьНастройкиTls()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонструкторТранспортаСInsecure() Экспорт

    // Дано
    НастройкиTls = Новый ОтелНастройкиTls();
    НастройкиTls.Insecure = Истина;

    // Когда
    Транспорт = Новый ОтелHttpТранспорт("http://localhost:4318", , , , , НастройкиTls, "http/json");

    // Тогда
    Ожидаем.Что(Транспорт.ПолучитьНастройкиTls().Insecure).Равно(Истина);

КонецПроцедуры

// ====== ОтелGrpcТранспорт с TLS ======

&Тест
Процедура КонструкторGrpcТранспортаСНастройкамиTls() Экспорт

    // Дано
    НастройкиTls = Новый ОтелНастройкиTls();
    НастройкиTls.ФайлКлиентскогоСертификата = "/tmp/client.crt";
    НастройкиTls.ФайлКлиентскогоКлюча = "/tmp/client.key";

    // Когда
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1", НастройкиTls);

    // Тогда - транспорт хранит настройки TLS
    Ожидаем.Что(Транспорт.ПолучитьНастройкиTls()).Не_().Равно(Неопределено);
    Ожидаем.Что(Транспорт.ПолучитьНастройкиTls().Применен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КонструкторGrpcТранспортаБезTls() Экспорт

    // Дано / Когда
    Транспорт = Новый ОтелGrpcТранспорт("http://localhost:1");

    // Тогда
    Ожидаем.Что(Транспорт.ПолучитьНастройкиTls()).Равно(Неопределено);

КонецПроцедуры
