&Тест
Процедура ЭкспортСпанаСодержитFlags() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерСпанов(Транспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест-flags", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();

    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    // Когда
    Экспортер.Экспортировать(МассивСпанов);

    // Тогда - OTLP JSON содержит поле flags
    Отправленные = Транспорт.ПолучитьОтправленные();
    Данные = Отправленные[0].Получить("Данные");
    РесурсныеСпаны = Данные.Получить("resourceSpans");
    СпанOtlp = РесурсныеСпаны[0].Получить("scopeSpans")[0].Получить("spans")[0];

    // flags ДОЛЖЕН присутствовать (по умолчанию 1 = sampled)
    Ожидаем.Что(СпанOtlp.Получить("flags") <> Неопределено).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ЭкспортЛоговСодержитDroppedAttributesCount() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерЛогов(Транспорт);

    Лимиты = Новый ОтелЛимитыЗаписейЛога().УстановитьМаксАтрибутов(1);
    Запись = Новый ОтелЗаписьЛога(Лимиты);
    Запись.УстановитьТело("тест");
    Запись.УстановитьАтрибут("a", 1);
    Запись.УстановитьАтрибут("b", 2);
    Запись.УстановитьАтрибут("c", 3);
    Запись.УстановитьВремяНаблюдения("1234567890000000000");

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Запись.УстановитьОбластьИнструментирования(ОбластьИнструментирования);
    Запись.УстановитьРесурс(Ресурс);

    МассивЗаписей = Новый Массив();
    МассивЗаписей.Добавить(Запись);

    // Когда
    Экспортер.Экспортировать(МассивЗаписей);

    // Тогда - OTLP JSON содержит droppedAttributesCount
    Отправленные = Транспорт.ПолучитьОтправленные();
    Данные = Отправленные[0].Получить("Данные");
    РесурсныеЛоги = Данные.Получить("resourceLogs");
    ЗаписьOtlp = РесурсныеЛоги[0].Получить("scopeLogs")[0].Получить("logRecords")[0];

    // 2 атрибута отброшены (лимит 1, попытка 3)
    Ожидаем.Что(ЗаписьOtlp.Получить("droppedAttributesCount")).Равно(2);

КонецПроцедуры

