&Тест
Процедура ЭкспортЛоговСАтрибутамиОбластиИАдресСхемы() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерЛогов(МокТранспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("тест");
    МассивЗаписей = Новый Массив();
    МассивЗаписей.Добавить(Запись);

    АтрибутыОбласти = Новый ОтелАтрибуты();
    АтрибутыОбласти.Установить("scope.attr", "value");

    // Когда
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования(
        "библ", "1.0", АтрибутыОбласти, "https://schema.example.com");
    Запись.УстановитьРесурс(Ресурс);
    Запись.УстановитьОбластьИнструментирования(ОбластьИнструментирования);
    Результат = Экспортер.Экспортировать(МассивЗаписей);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить(
        "/v1/logs",
        Матчеры.ЛюбоеЗначение()
    );

