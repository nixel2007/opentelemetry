&Тест
Процедура ЭкспортЛоговСАтрибутамиСкоупаИSchemaUrl() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерЛогов(МокТранспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("тест");
    МассивЗаписей = Новый Массив();
    МассивЗаписей.Добавить(Запись);

    АтрибутыСкоупа = Новый ОтелАтрибуты();
    АтрибутыСкоупа.Установить("scope.attr", "value");

    // Когда
    Результат = Экспортер.Экспортировать(
        МассивЗаписей,
        Ресурс,
        "библ",
        "1.0",
        АтрибутыСкоупа,
        "https://schema.example.com"
    );

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить(
        "/v1/logs",
        Матчеры.ЛюбоеЗначение()
    );

КонецПроцедуры

&Тест
Процедура ЭкспортСпановСАтрибутамиСкоупаИSchemaUrl() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерСпанов(МокТранспорт);

    АтрибутыСкоупа = Новый ОтелАтрибуты();
    АтрибутыСкоупа.Установить("scope.key", "scope.val");

    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    Спан.УстановитьАтрибутыСкоупа(АтрибутыСкоупа);
    Спан.УстановитьSchemaUrl("https://schema.example.com");
    Спан.Завершить();

    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    // Когда
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить(
        "/v1/traces",
        Матчеры.ЛюбоеЗначение()
    );

КонецПроцедуры

