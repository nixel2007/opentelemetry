Функция МедленнаяОтправка(Знач ИнформацияОВызове) Экспорт // BSLLS:UnusedParameters-off
    ОчиньБольшаяПауза = 99999;
    Приостановить(ОчиньБольшаяПауза);
    Возврат Истина;
КонецФункции

&Тест
Процедура ЭкспортСпановСТаймаутомВозвращаетЛожь() Экспорт

    // Дано - мок транспорта с долгой паузой
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    Ответ = Новый Ответ(ЭтотОбъект, "МедленнаяОтправка");
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаОтвечает(Ответ);

    КороткийТаймаутМс = 500;
    Экспортер = Новый ОтелЭкспортерСпанов(МокТранспорт, "/v1/traces", КороткийТаймаутМс);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("тест-библ", "1.0");
    Спан = Новый ОтелСпан("операция", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    // Когда
    НачалоМс = ТекущаяУниверсальнаяДатаВМиллисекундах();
    Результат = Экспортер.Экспортировать(МассивСпанов);
    ЗатраченоМс = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоМс;

    // Тогда - Ложь возвращается в пределах таймаут + допуск
    Ожидаем.Что(Результат).Равно(Ложь);
    ДопускМс = 500;
    Ожидаем.Что(ЗатраченоМс < КороткийТаймаутМс + ДопускМс).Равно(Истина);

КонецПроцедуры

