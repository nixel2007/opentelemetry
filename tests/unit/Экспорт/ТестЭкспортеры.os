    МассивДанных = Новый Массив();
    ДанныеМетрики = Счетчик.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(), Счетчик.Имя(), Счетчик.Описание());
    МассивДанных.Добавить(ДанныеМетрики);

    // Когда
    Результат = Экспортер.Экспортировать(МассивДанных);

    // Тогда
    Ожидаем.Что(Результат).Равно(Ложь);

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ЭкспортСпановУспешенВПределахТаймаута() Экспорт

    // Дано - транспорт отвечает быстро
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    ТаймаутМс = 5000;
    Экспортер = Новый ОтелЭкспортерСпанов(МокТранспорт, "/v1/traces", ТаймаутМс);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("тест-библ", "1.0");
    Спан = Новый ОтелСпан("операция", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    // Когда
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры
