&Тест
Процедура ЭкспортСпанаСЛинками() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерСпанов(МокТранспорт);
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("с-линками", Ресурс, "библ", "1.0");

    КонтекстЛинка = Новый ОтелКонтекстСпана(
        "0af7651916cd43dd8448eb211c80319c",
        "00f067aa0ba902b7",
        "key1=val1"
    );
    АтрибутыЛинка = Новый ОтелАтрибуты();
    АтрибутыЛинка.Установить("link.attr", "value");
    Спан.ДобавитьЛинк(КонтекстЛинка, АтрибутыЛинка);
    Спан.Завершить();

    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    // Когда
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ЭкспортДвухСпановОдногоСкоупа() Экспорт

    // Дано - два спана с одинаковым скоупом должны группироваться
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерСпанов(МокТранспорт);
    Ресурс = Новый ОтелРесурс(Истина);

    Спан1 = Новый ОтелСпан("операция1", Ресурс, "библ", "1.0");
    Спан1.Завершить();
    Спан2 = Новый ОтелСпан("операция2", Ресурс, "библ", "1.0");
    Спан2.Завершить();

    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан1);
    МассивСпанов.Добавить(Спан2);

    // Когда
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры

// --- Экспорт метрик: дополнительные типы ---

&Тест
Процедура ЭкспортМетрикГистограмма() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("библ", "1.0");
    Гистограмма = Метр.СоздатьГистограмму("http.duration", "Время ответа", "ms");
    Гистограмма.Записать(42);

    Экспортер = Новый ОтелЭкспортерМетрик(МокТранспорт);

    // Когда
    Результат = Экспортер.Экспортировать(Метр);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить(
        "/v1/metrics",
        Матчеры.ЛюбоеЗначение()
    );

КонецПроцедуры

