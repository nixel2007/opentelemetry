&Тест
Процедура ЭкспортДвухСпановОднойОбласти() Экспорт

    // Дано - два спана с одинаковым скоупом должны группироваться
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерСпанов(МокТранспорт);
    Ресурс = Новый ОтелРесурс(Истина);

    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан1 = Новый ОтелСпан("операция1", Ресурс, ОбластьИнструментирования);
    Спан1.Завершить();
    Спан2 = Новый ОтелСпан("операция2", Ресурс, ОбластьИнструментирования);
    Спан2.Завершить();

    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан1);
    МассивСпанов.Добавить(Спан2);

    // Когда
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры

