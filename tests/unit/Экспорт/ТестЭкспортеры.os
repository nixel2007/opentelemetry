&Тест
Процедура ЭкспортСпанов() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерСпанов(МокТранспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("тест-библ", "1.0");
    Спан = Новый ОтелСпан("тестовая-операция", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    // Когда
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить("/v1/traces", Матчеры.ЛюбоеЗначение());

КонецПроцедуры

