&Тест
Процедура ЭкспортМетрикСчетчикСExemplars() Экспорт

    // Дано - счетчик с активным спаном для захвата exemplar
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("lib", "1.0");
    Спан = Новый ОтелСпан("test-span", Ресурс, ОбластьИнструментирования);
    Область = Спан.СделатьТекущим();

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("библ", "1.0");
    Счетчик = Метр.СоздатьСчетчик("test_counter");
    Счетчик.Добавить(1);

    // Когда
    МассивДанных = Новый Массив();
    ДанныеМетрики = Счетчик.Собрать(Метр.Ресурс(), Метр.ОбластьИнструментирования(), Счетчик.Имя(), Счетчик.Описание());
    МассивДанных.Добавить(ДанныеМетрики);
    Экспортер.Экспортировать(МассивДанных);

    // Тогда - OTLP payload содержит exemplars с traceId и spanId
    Отправленные = Транспорт.ПолучитьОтправленные();
    Данные = Отправленные[0].Получить("Данные");
    Сумма = Данные
        .Получить("resourceMetrics")[0]
        .Получить("scopeMetrics")[0]
        .Получить("metrics")[0]
        .Получить("sum");
    ТочкаДанных = Сумма.Получить("dataPoints")[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");

    Ожидаем.Что(Экземпляры).Не_().Равно(Неопределено);
    Ожидаем.Что(Экземпляры.Количество()).БольшеИлиРавно(1);

    Экземпляр = Экземпляры[0];
    Ожидаем.Что(Экземпляр.Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляр.Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

    Область.Закрыть();
    Спан.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ЭкспортМетрикГистограммаСExemplars() Экспорт

    // Дано - гистограмма с активным спаном
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("lib", "1.0");
    Спан = Новый ОтелСпан("test-span", Ресурс, ОбластьИнструментирования);
    Область = Спан.СделатьТекущим();

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("библ", "1.0");
    Гистограмма = Метр.СоздатьГистограмму("test_duration", "", "ms");
    Гистограмма.Записать(42);

    // Когда
    МассивДанных = Новый Массив();
    ДанныеМетрики = Гистограмма.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Гистограмма.Имя(), Гистограмма.Описание());
    МассивДанных.Добавить(ДанныеМетрики);
    Экспортер.Экспортировать(МассивДанных);

    // Тогда - OTLP payload содержит exemplars
    Отправленные = Транспорт.ПолучитьОтправленные();
    Данные = Отправленные[0].Получить("Данные");
    ГистограммаOtlp = Данные
        .Получить("resourceMetrics")[0]
        .Получить("scopeMetrics")[0]
        .Получить("metrics")[0]
        .Получить("histogram");
    ТочкаДанных = ГистограммаOtlp.Получить("dataPoints")[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");

    Ожидаем.Что(Экземпляры).Не_().Равно(Неопределено);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());

    Область.Закрыть();
    Спан.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

