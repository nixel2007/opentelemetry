    ).ТогдаВозвращает(Истина);

    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("библ", "1.0");
    Гистограмма = Метр.СоздатьГистограмму("http.duration", "Время ответа", "ms");
    Гистограмма.Записать(42);

    Экспортер = Новый ОтелЭкспортерМетрик(МокТранспорт);

    // Когда
    Результат = Экспортер.Экспортировать(Метр);

    // Тогда
