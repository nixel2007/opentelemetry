&Тест
Процедура ЭкспортМетрикСчетчикСExemplars() Экспорт

    // Дано - счетчик с активным спаном для захвата exemplar
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("lib", "1.0");
    Спан = Новый ОтелСпан("test-span", Ресурс, ОбластьИнструментирования);
    Область = Спан.СделатьТекущим();

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("библ", "1.0");
    Счетчик = Метр.СоздатьСчетчик("test_counter");
    Счетчик.Добавить(1);

    // Когда
    Экспортер.Экспортировать(Метр);

    // Тогда - OTLP payload содержит exemplars с traceId и spanId
    Отправленные = Транспорт.ПолучитьОтправленные();
    Данные = Отправленные[0].Получить("Данные");
    Сумма = Данные
        .Получить("resourceMetrics")[0]
        .Получить("scopeMetrics")[0]
        .Получить("metrics")[0]
        .Получить("sum");
    ТочкаДанных = Сумма.Получить("dataPoints")[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");

    Ожидаем.Что(Экземпляры).Не_().Равно(Неопределено);
    Ожидаем.Что(Экземпляры.Количество()).БольшеИлиРавно(1);

    Экземпляр = Экземпляры[0];
    Ожидаем.Что(Экземпляр.Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляр.Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

    Область.Закрыть();
    Спан.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ЭкспортМетрикГистограммаСExemplars() Экспорт

    // Дано - гистограмма с активным спаном
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("lib", "1.0");
    Спан = Новый ОтелСпан("test-span", Ресурс, ОбластьИнструментирования);
    Область = Спан.СделатьТекущим();

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("библ", "1.0");
    Гистограмма = Метр.СоздатьГистограмму("test_duration", "", "ms");
    Гистограмма.Записать(42);

    // Когда
    Экспортер.Экспортировать(Метр);

    // Тогда - OTLP payload содержит exemplars
    Отправленные = Транспорт.ПолучитьОтправленные();
    Данные = Отправленные[0].Получить("Данные");
    ГистограммаOtlp = Данные
        .Получить("resourceMetrics")[0]
        .Получить("scopeMetrics")[0]
        .Получить("metrics")[0]
        .Получить("histogram");
    ТочкаДанных = ГистограммаOtlp.Получить("dataPoints")[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");

    Ожидаем.Что(Экземпляры).Не_().Равно(Неопределено);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());

    Область.Закрыть();
    Спан.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ЭкспортМетрикДатчикСExemplars() Экспорт

    // Дано - датчик с активным спаном
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("lib", "1.0");
    Спан = Новый ОтелСпан("test-span", Ресурс, ОбластьИнструментирования);
    Область = Спан.СделатьТекущим();

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("библ", "1.0");
    Датчик = Метр.СоздатьДатчик("test_gauge");
    Датчик.Записать(99);

    // Когда
    Экспортер.Экспортировать(Метр);

    // Тогда - OTLP payload содержит exemplars
    Отправленные = Транспорт.ПолучитьОтправленные();
    Данные = Отправленные[0].Получить("Данные");
    ДатчикOtlp = Данные
        .Получить("resourceMetrics")[0]
        .Получить("scopeMetrics")[0]
        .Получить("metrics")[0]
        .Получить("gauge");
    ТочкаДанных = ДатчикOtlp.Получить("dataPoints")[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");

    Ожидаем.Что(Экземпляры).Не_().Равно(Неопределено);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());

    Область.Закрыть();
    Спан.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

// --- Тесты Shutdown/ForceFlush экспортеров (SPEC-V1) ---

&Тест
Процедура ЗакрытиеЭкспортераСпанов() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерСпанов(МокТранспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    // Когда
    Экспортер.Закрыть();
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда - после закрытия экспорт должен возвращать Ложь
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЗакрытиеЭкспортераЛогов() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерЛогов(МокТранспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("тест");
    МассивЗаписей = Новый Массив();
    МассивЗаписей.Добавить(Запись);

    // Когда
    Экспортер.Закрыть();
    Результат = Экспортер.Экспортировать(МассивЗаписей, Ресурс, "библ", "1.0");

    // Тогда
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЗакрытиеЭкспортераМетрик() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерМетрик(МокТранспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("тест.счетчик");
    Счетчик.Добавить(1);

