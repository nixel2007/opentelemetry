        .Получить("resourceMetrics")[0]
        .Получить("scopeMetrics")[0]
        .Получить("metrics")[0]
        .Получить("gauge");
    ТочкаДанных = ДатчикOtlp.Получить("dataPoints")[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");

    Ожидаем.Что(Экземпляры).Не_().Равно(Неопределено);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());

    Область.Закрыть();
    Спан.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

// --- Тесты Shutdown/ForceFlush экспортеров (SPEC-V1) ---

&Тест
Процедура ЗакрытиеЭкспортераСпанов() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);

    Экспортер = Новый ОтелЭкспортерСпанов(МокТранспорт);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    МассивСпанов = Новый Массив();
    МассивСпанов.Добавить(Спан);

    // Когда
    Экспортер.Закрыть();
    Результат = Экспортер.Экспортировать(МассивСпанов);

    // Тогда - после закрытия экспорт должен возвращать Ложь
    Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

