&Тест
Процедура ЭкспортМетрикГистограмма() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("библ", "1.0");
    Гистограмма = Метр.СоздатьГистограмму("http.duration", "Время ответа", "ms");
    Гистограмма.Записать(42);

    Экспортер = Новый ОтелЭкспортерМетрик(МокТранспорт);

    // Когда
    МассивДанных = Новый Массив();
    ДанныеМетрики = Гистограмма.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Гистограмма.Имя(), Гистограмма.Описание());
    МассивДанных.Добавить(ДанныеМетрики);
    Результат = Экспортер.Экспортировать(МассивДанных);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить(
        "/v1/metrics",
        Матчеры.ЛюбоеЗначение()
    );

