&Тест
Процедура ЭкспортМетрик() Экспорт

    // Дано
    МокТранспорт = Мок.Получить(Тип("ОтелHttpТранспорт"));
    МокТранспорт.Когда().Отправить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);

    Ресурс = Новый ОтелРесурс(Истина);
    Ресурс.Атрибуты().Установить("service.name", "тест-сервис");

    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("тест-библ", "1.0");
    Счетчик = Метр.СоздатьСчетчик("test_counter");
    Счетчик.Добавить(1);

    Экспортер = Новый ОтелЭкспортерМетрик(МокТранспорт);

    // Когда
    МассивДанных = Новый Массив();
    ДанныеМетрики = Счетчик.Собрать(Метр.Ресурс(), Метр.ОбластьИнструментирования(), Счетчик.Имя(), Счетчик.Описание());
    МассивДанных.Добавить(ДанныеМетрики);
    Результат = Экспортер.Экспортировать(МассивДанных);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    МокТранспорт.ПроверитьЧтоВызывалсяМетод().Отправить(
        "/v1/metrics", Матчеры.ЛюбоеЗначение());

КонецПроцедуры

