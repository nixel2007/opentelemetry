&Тест
Процедура Chaining() Экспорт
    Писатель = Новый ОтелПротоПисатель();
    Результат = Писатель.ЗаписатьUInt64Varint(10).ЗаписатьUInt64Varint(20);
    Данные = ДвоичныеДанныеВМассивБайт(Результат.ПолучитьДвоичныеДанные());
    Ожидаем.Что(Данные.Количество()).Равно(2);
    Ожидаем.Что(Данные[0]).Равно(10);
    Ожидаем.Что(Данные[1]).Равно(20);
КонецПроцедуры
