&Тест
Процедура Chaining() Экспорт
    Писатель = Новый ОтелПротоПисатель();
    Результат = Писатель.ЗаписатьUInt64Varint(10).ЗаписатьUInt64Varint(20);
    Данные = ДвоичныеДанныеВМассивБайт(Результат.ПолучитьДвоичныеДанные());
    Ожидаем.Что(Данные.Количество()).Равно(2);
    Ожидаем.Что(Данные[0]).Равно(10);
    Ожидаем.Что(Данные[1]).Равно(20);
КонецПроцедуры

&Тест
Процедура ЗаписатьDouble_Ноль() Экспорт
    // 0.0 IEEE754: все байты нулевые
    Писатель = Новый ОтелПротоПисатель();
    Писатель.ЗаписатьDouble(0);
    Данные = ДвоичныеДанныеВМассивБайт(Писатель.ПолучитьДвоичныеДанные());
    Ожидаем.Что(Данные.Количество()).Равно(8);
    Для сч = 0 По 7 Цикл
        Ожидаем.Что(Данные[сч]).Равно(0);
    КонецЦикла;
КонецПроцедуры

&Тест
Процедура ЗаписатьDouble_ОдинЦелый() Экспорт
    // 1.0 IEEE754 LE: 00 00 00 00 00 00 F0 3F
    Писатель = Новый ОтелПротоПисатель();
    Писатель.ЗаписатьDouble(1);
    Данные = ДвоичныеДанныеВМассивБайт(Писатель.ПолучитьДвоичныеДанные());
    Ожидаем.Что(Данные.Количество()).Равно(8);
    Ожидаем.Что(Данные[0]).Равно(0);
    Ожидаем.Что(Данные[1]).Равно(0);
    Ожидаем.Что(Данные[2]).Равно(0);
    Ожидаем.Что(Данные[3]).Равно(0);
    Ожидаем.Что(Данные[4]).Равно(0);
    Ожидаем.Что(Данные[5]).Равно(0);
    Ожидаем.Что(Данные[6]).Равно(240);
    Ожидаем.Что(Данные[7]).Равно(63);
КонецПроцедуры

