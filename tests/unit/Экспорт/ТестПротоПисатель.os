Функция ДвоичныеДанныеВМассивБайт(Данные)
    Буфер = Новый БуферДвоичныхДанных(Данные.Размер());
    Поток = Данные.ОткрытьПотокДляЧтения();
    Поток.Прочитать(Буфер, 0, Данные.Размер());
    Поток.Закрыть();
    
    Массив = Новый Массив();
    Для сч = 0 По Буфер.Размер - 1 Цикл
        Массив.Добавить(Буфер.Получить(сч));
    КонецЦикла;
    Возврат Массив;
КонецФункции

&ТестовыйНабор
Процедура ПриСозданииОбъекта()
КонецПроцедуры

&Тест
Процедура ЗаписатьUInt64Varint_Ноль() Экспорт
    Писатель = Новый ОтелПротоПисатель();
    Писатель.ЗаписатьUInt64Varint(0);
    Данные = ДвоичныеДанныеВМассивБайт(Писатель.ПолучитьДвоичныеДанные());
    Ожидаем.Что(Данные.Количество()).Равно(1);
    Ожидаем.Что(Данные[0]).Равно(0);
КонецПроцедуры

