&Тест
Процедура ЗакодироватьMetricsData_ПустаяСтруктура() Экспорт
    Данные = Новый Соответствие();
    Данные.Вставить("resourceMetrics", Новый Массив());

    Результат = ОтелПротоКодировщикMetrics.ЗакодироватьMetricsData(Данные);

    Ожидаем.Что(ТипЗнч(Результат)).Равно(Тип("ДвоичныеДанные"));
    Ожидаем.Что(Результат.Размер()).Равно(0);
КонецПроцедуры

&Тест
Процедура ЗакодироватьMetricsData_CounterSum() Экспорт
    // Строим структуру с одним Sum/Counter инструментом
    Атрибут = Новый Соответствие();
    Атрибут.Вставить("key", "env");
    АтрВаль = Новый Соответствие();
    АтрВаль.Вставить("stringValue", "prod");
    Атрибут.Вставить("value", АтрВаль);
    МассивАтр = Новый Массив();
    МассивАтр.Добавить(Атрибут);

    ТочкаДанных = Новый Соответствие();
    ТочкаДанных.Вставить("startTimeUnixNano", 1000000000);
    ТочкаДанных.Вставить("timeUnixNano", 2000000000);
    ТочкаДанных.Вставить("asInt", "42");
    ТочкаДанных.Вставить("attributes", МассивАтр);

    МассивТочек = Новый Массив();
    МассивТочек.Добавить(ТочкаДанных);

    Сумма = Новый Соответствие();
    Сумма.Вставить("dataPoints", МассивТочек);
    Сумма.Вставить("aggregationTemporality", 2);
    Сумма.Вставить("isMonotonic", Истина);

    Метрика = Новый Соответствие();
    Метрика.Вставить("name", "requests.count");
    Метрика.Вставить("description", "Total requests");
    Метрика.Вставить("unit", "1");
    Метрика.Вставить("sum", Сумма);

    МассивМетрик = Новый Массив();
    МассивМетрик.Добавить(Метрика);

    Скоп = Новый Соответствие();
    Скоп.Вставить("name", "test-scope");
    Скоп.Вставить("version", "1.0.0");

    ОбластьМетрик = Новый Соответствие();
    ОбластьМетрик.Вставить("scope", Скоп);
    ОбластьМетрик.Вставить("metrics", МассивМетрик);

    МассивОбластей = Новый Массив();
    МассивОбластей.Добавить(ОбластьМетрик);

    РесурснаяМетрика = Новый Соответствие();
    РесурснаяМетрика.Вставить("resource", Новый Соответствие());
    РесурснаяМетрика.Вставить("scopeMetrics", МассивОбластей);

    МассивРесурсных = Новый Массив();
    МассивРесурсных.Добавить(РесурснаяМетрика);

    Данные = Новый Соответствие();
    Данные.Вставить("resourceMetrics", МассивРесурсных);

    Результат = ОтелПротоКодировщикMetrics.ЗакодироватьMetricsData(Данные);

    Ожидаем.Что(ТипЗнч(Результат)).Равно(Тип("ДвоичныеДанные"));
    Ожидаем.Что(Результат.Размер()).Больше(0);
КонецПроцедуры

