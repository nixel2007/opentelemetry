// Внедрение: multi-header

&Тест
Процедура ВнедрениеМультиЗаголовков() Экспорт

    // Дано
    КонтекстСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331", 1);
    Спан = Новый ОтелНоопСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда
    Ожидаем.Что(Носитель.Получить("X-B3-TraceId")).Равно("0af7651916cd43dd8448eb211c80319c");
    Ожидаем.Что(Носитель.Получить("X-B3-SpanId")).Равно("b7ad6b7169203331");
    Ожидаем.Что(Носитель.Получить("X-B3-Sampled")).Равно("1");

КонецПроцедуры

&Тест
Процедура ВнедрениеБезСемплирования() Экспорт

    // Дано - флаг 0 (не семплирован)
    КонтекстСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331", 0);
    Спан = Новый ОтелНоопСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда
    Ожидаем.Что(Носитель.Получить("X-B3-Sampled")).Равно("0");

КонецПроцедуры

&Тест
Процедура ВнедрениеНевалидногоКонтекста() Экспорт

    // Дано - контекст без спана
    Контекст = Новый Соответствие();
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - заголовки не установлены
    Ожидаем.Что(Носитель.Получить("X-B3-TraceId")).Равно(Неопределено);

КонецПроцедуры

// Извлечение: multi-header

&Тест
Процедура ИзвлечениеМультиЗаголовков() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Носитель.Вставить("X-B3-TraceId", "0af7651916cd43dd8448eb211c80319c");
    Носитель.Вставить("X-B3-SpanId", "b7ad6b7169203331");
    Носитель.Вставить("X-B3-Sampled", "1");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда
    Спан = ОтелКонтекст.СпанИзКонтекста(Результат);
    Ожидаем.Что(Спан).Не_().Равно(Неопределено);
    КонтекстСпана = Спан.КонтекстСпана();
    Ожидаем.Что(КонтекстСпана.ИдТрассировки()).Равно("0af7651916cd43dd8448eb211c80319c");
    Ожидаем.Что(КонтекстСпана.ИдСпана()).Равно("b7ad6b7169203331");
    Ожидаем.Что(КонтекстСпана.ФлагиТрассировки()).Равно(1);
    Ожидаем.Что(КонтекстСпана.Удаленный()).Равно(Истина);

КонецПроцедуры

