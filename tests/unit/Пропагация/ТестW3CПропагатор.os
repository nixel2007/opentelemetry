// --- Level 2: random flag (бит 1, маска 0x02) ---

&Тест
Процедура ИзвлечениеSampledИRandomФлагов() Экспорт

    // Дано - traceparent с trace-flags=03 (sampled+random)
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-03");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - оба бита установлены
    Спан = ОтелКонтекст.СпанИзКонтекста(Результат);
    Ожидаем.Что(Спан).Не_().Равно(Неопределено);
    ФлагиТрассировки = Спан.КонтекстСпана().ФлагиТрассировки();
    БитSampled = ФлагиТрассировки % 2;
    БитRandom = Цел(ФлагиТрассировки / 2) % 2;
    Ожидаем.Что(БитSampled).Равно(1);
    Ожидаем.Что(БитRandom).Равно(1);

КонецПроцедуры

&Тест
Процедура ИзвлечениеТолькоRandomФлага() Экспорт

    // Дано - traceparent с trace-flags=02 (только random, не sampled)
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-02");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - random=true, sampled=false
    Спан = ОтелКонтекст.СпанИзКонтекста(Результат);
    Ожидаем.Что(Спан).Не_().Равно(Неопределено);
    ФлагиТрассировки = Спан.КонтекстСпана().ФлагиТрассировки();
    БитSampled = ФлагиТрассировки % 2;
    БитRandom = Цел(ФлагиТрассировки / 2) % 2;
    Ожидаем.Что(БитSampled).Равно(0);
    Ожидаем.Что(БитRandom).Равно(1);

КонецПроцедуры

&Тест
Процедура РаундТрипСохраняетRandomФлаг() Экспорт

    // Дано - SpanContext с trace-flags = 0x03 (sampled+random)
    ФлагиSampledИRandom = 3;
    КонтекстСпана = Новый ОтелКонтекстСпана(
        "4bf92f3577b34da6a3ce929d0e0e4736",
        "00f067aa0ba902b7",
        ФлагиSampledИRandom
    );
    Спан = Новый ОтелНезаписывающийСпан(КонтекстСпана);
    КонтекстВнедрения = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();

    // Когда - внедряем, затем извлекаем
    Пропагатор = Новый ОтелW3CПропагатор();
    Пропагатор.Внедрить(КонтекстВнедрения, Носитель);

    // Тогда - traceparent содержит "-03"
    Ожидаем.Что(Носитель.Получить("traceparent")).Равно(
        "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-03");

    // И при обратном извлечении бит random сохранён
    ВходнойКонтекст = Новый Соответствие();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);
    ВосстановленныйСпан = ОтелКонтекст.СпанИзКонтекста(Результат);
    Ожидаем.Что(ВосстановленныйСпан.КонтекстСпана().ФлагиТрассировки()).Равно(ФлагиSampledИRandom);

КонецПроцедуры

// --- Level 2: расширенный формат traceparent ---

&Тест
Процедура ИзвлечениеРасширеннойВерсии() Экспорт
    // Дано - version "01" с дополнительными полями после 4-го компонента
    // W3C Level 2: при version > 00 неизвестные поля ДОЛЖНЫ игнорироваться
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "01-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01-extra-field");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - расширенный traceparent принят, context span извлечён
    Спан = ОтелКонтекст.СпанИзКонтекста(Результат);
    Ожидаем.Что(Спан).Не_().Равно(Неопределено);
    КонтекстСпана = Спан.КонтекстСпана();
    Ожидаем.Что(КонтекстСпана.ИдТрассировки()).Равно("4bf92f3577b34da6a3ce929d0e0e4736");
    Ожидаем.Что(КонтекстСпана.ИдСпана()).Равно("00f067aa0ba902b7");
    Ожидаем.Что(КонтекстСпана.ФлагиТрассировки()).Равно(1);

КонецПроцедуры

&Тест
Процедура РаундТрипСохраняетRv() Экспорт
    // Дано - span с tracestate содержащим ot=rv:abc123
    КонтекстСпана = Новый ОтелКонтекстСпана(
        "4bf92f3577b34da6a3ce929d0e0e4736",
        "00f067aa0ba902b7",
        1,
        "ot=rv:abc123"
    );
    Спан = Новый ОтелНезаписывающийСпан(КонтекстСпана);
    КонтекстВнедрения = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();

    // Когда - внедряем, затем извлекаем
    Пропагатор = Новый ОтелW3CПропагатор();
    Пропагатор.Внедрить(КонтекстВнедрения, Носитель);
    ВходнойКонтекст = Новый Соответствие();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - rv сохранён при round-trip
    ВосстановленныйСпан = ОтелКонтекст.СпанИзКонтекста(Результат);
    Ожидаем.Что(ВосстановленныйСпан).Не_().Равно(Неопределено);
    СостояниеТрассировки = ВосстановленныйСпан.КонтекстСпана().СостояниеТрассировки();
    Ожидаем.Что(СостояниеТрассировки.ПолучитьОтелПодКлюч("rv")).Равно("abc123");

КонецПроцедуры
