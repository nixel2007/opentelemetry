&Тест
Процедура ИзвлечениеСTracestate() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01");
    Носитель.Вставить("tracestate", "rojo=00f067aa0ba902b7");

    // Когда
    КонтекстСпана = ОтелW3CПропагатор.Извлечь(Носитель);

    // Тогда
    Ожидаем.Что(КонтекстСпана).Не_().Равно(Неопределено);
    Ожидаем.Что(КонтекстСпана.СостояниеТрассировки().ВСтроку()).Равно("rojo=00f067aa0ba902b7");

КонецПроцедуры
