&Тест
Процедура ВнедрениеTraceparent() Экспорт

    // Дано
    КонтекстСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331");
    Спан = Новый ОтелНезаписывающийСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда
    Ожидаем.Что(Носитель.Получить("traceparent")).Равно("00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01");

КонецПроцедуры

&Тест
Процедура ИзвлечениеTraceparent() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда
    Спан = ОтелКонтекст.СпанИзКонтекста(Результат);
    Ожидаем.Что(Спан).Не_().Равно(Неопределено);
    КонтекстСпана = Спан.КонтекстСпана();
    Ожидаем.Что(КонтекстСпана.ИдТрассировки()).Равно("0af7651916cd43dd8448eb211c80319c");
    Ожидаем.Что(КонтекстСпана.ИдСпана()).Равно("b7ad6b7169203331");
    Ожидаем.Что(КонтекстСпана.ФлагиТрассировки()).Равно(1);
    Ожидаем.Что(КонтекстСпана.Удаленный()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ИзвлечениеНевалидного() Экспорт

    // Дано - невалидный заголовок (слишком короткий traceId)
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "00-abc-def-01");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - при ошибке возвращается входной контекст
    Ожидаем.Что(Результат).Равно(ВходнойКонтекст);

КонецПроцедуры

&Тест
Процедура РаундТрип() Экспорт

    // Дано
    ИсходныйТрейсИд = "4bf92f3577b34da6a3ce929d0e0e4736";
    ИсходныйСпанИд = "00f067aa0ba902b7";
    КонтекстСпана = Новый ОтелКонтекстСпана(ИсходныйТрейсИд, ИсходныйСпанИд);
    Спан = Новый ОтелНезаписывающийСпан(КонтекстСпана);
    КонтекстВнедрения = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();

    // Когда - внедряем, затем извлекаем
    Пропагатор = Новый ОтелW3CПропагатор();
    Пропагатор.Внедрить(КонтекстВнедрения, Носитель);
    ВходнойКонтекст = Новый Соответствие();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда
    ВосстановленныйСпан = ОтелКонтекст.СпанИзКонтекста(Результат);
    Ожидаем.Что(ВосстановленныйСпан).Не_().Равно(Неопределено);
    ВосстановленныйКонтекст = ВосстановленныйСпан.КонтекстСпана();
    Ожидаем.Что(ВосстановленныйКонтекст.ИдТрассировки()).Равно(ИсходныйТрейсИд);
    Ожидаем.Что(ВосстановленныйКонтекст.ИдСпана()).Равно(ИсходныйСпанИд);

КонецПроцедуры

