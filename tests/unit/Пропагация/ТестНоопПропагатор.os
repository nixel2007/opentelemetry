&Тест
Процедура ВнедрениеНеМеняетНоситель() Экспорт

    // Дано - носитель с начальными данными
    Носитель = Новый Соответствие();
    Носитель.Вставить("existing", "value");
    КонтекстСпана = Новый ОтелКонтекстСпана(
        "4bf92f3577b34da6a3ce929d0e0e4736",
        "00f067aa0ba902b7");
    Спан = Новый ОтелНезаписывающийСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);

    // Когда - ноп-пропагатор внедряет
    Пропагатор = Новый ОтелНоопПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - носитель не изменён
    Ожидаем.Что(Носитель.Количество()).Равно(1);
    Ожидаем.Что(Носитель.Получить("existing")).Равно("value");
    Ожидаем.Что(Носитель.Получить("traceparent")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ИзвлечениеВозвращаетТотЖеКонтекст() Экспорт

    // Дано - носитель с заголовком traceparent
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01");
    ВходнойКонтекст = Новый Соответствие();

    // Когда - ноп-пропагатор извлекает
    Пропагатор = Новый ОтелНоопПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - возвращается тот же контекст без изменений
    Ожидаем.Что(Результат).Равно(ВходнойКонтекст);

КонецПроцедуры

&Тест
Процедура ПоляПустыеМассив() Экспорт

    // Когда
    Пропагатор = Новый ОтелНоопПропагатор();
    Поля = Пропагатор.Поля();

    // Тогда
    Ожидаем.Что(Поля).Не_().Равно(Неопределено);
    Ожидаем.Что(Поля.Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ВнедрениеСПустымКонтекстом() Экспорт

    // Дано - пустой контекст
    Контекст = Новый Соответствие();
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелНоопПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - носитель пуст
    Ожидаем.Что(Носитель.Количество()).Равно(0);

КонецПроцедуры
