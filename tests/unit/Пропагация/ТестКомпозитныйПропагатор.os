&Тест
Процедура КомпозитноеВнедрение() Экспорт

    // Дано
    МокПропагатор1 = Мок.Получить(Тип("ОтелКомпозитныйПропагатор"));
    МокПропагатор2 = Мок.Получить(Тип("ОтелКомпозитныйПропагатор"));
    Пропагаторы = Новый Массив();
    Пропагаторы.Добавить(МокПропагатор1);
    Пропагаторы.Добавить(МокПропагатор2);

    Композитный = Новый ОтелКомпозитныйПропагатор(Пропагаторы);
    Носитель = Новый Соответствие();
    Контекст = Новый Соответствие();

    // Когда
    Композитный.Внедрить(Контекст, Носитель);

    // Тогда - оба пропагатора вызваны
    МокПропагатор1.ПроверитьЧтоВызывалсяМетод().Внедрить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение());
    МокПропагатор2.ПроверитьЧтоВызывалсяМетод().Внедрить(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение());

КонецПроцедуры

&Тест
Процедура КомпозитноеИзвлечение() Экспорт

    // Дано - реальные пропагаторы (W3C + Baggage) для проверки цепочки
    Пропагаторы = Новый Массив();
    Пропагаторы.Добавить(Новый ОтелW3CПропагатор());
    Пропагаторы.Добавить(Новый ОтелW3CBaggageПропагатор());

    Композитный = Новый ОтелКомпозитныйПропагатор(Пропагаторы);

    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01");
    Носитель.Вставить("baggage", "key1=val1");

    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Результат = Композитный.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - контекст содержит и спан, и baggage (цепочка через пропагаторы)
    Ожидаем.Что(Результат).ИмеетТип("ФиксированноеСоответствие");

    Спан = ОтелКонтекст.СпанИзКонтекста(Результат);
    Ожидаем.Что(Спан).Не_().Равно(Неопределено);
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно("0af7651916cd43dd8448eb211c80319c");

    Багаж = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Багаж).Не_().Равно(Неопределено);
    Ожидаем.Что(Багаж.Получить("key1")).Равно("val1");

КонецПроцедуры
