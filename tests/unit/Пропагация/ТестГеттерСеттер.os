&Тест
Процедура ГеттерПолучитьВозвращаетПервоеЗначение() Экспорт

    // Дано - два заголовка с одинаковым именем в разном регистре
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "первое");
    Носитель.Вставить("Traceparent", "второе");
    Геттер = Новый ОтелГеттерТекстовойКарты();

    // Когда
    Результат = Геттер.Получить(Носитель, "traceparent");

    // Тогда - MUST return first value
    Ожидаем.Что(Результат).Равно("первое");

КонецПроцедуры

&Тест
Процедура ГеттерПолучитьВозвращаетНеопределеноДляОтсутствующего() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Геттер = Новый ОтелГеттерТекстовойКарты();

    // Когда
    Результат = Геттер.Получить(Носитель, "traceparent");

    // Тогда
    Ожидаем.Что(Результат).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ГеттерПолучитьВсеВозвращаетВсеЗначения() Экспорт

    // Дано - два заголовка с одинаковым именем в разном регистре
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "первое");
    Носитель.Вставить("Traceparent", "второе");
    Геттер = Новый ОтелГеттерТекстовойКарты();

    // Когда
    Результат = Геттер.ПолучитьВсе(Носитель, "traceparent");

    // Тогда
    Ожидаем.Что(Результат.Количество()).Равно(2);
    Ожидаем.Что(Результат[0]).Равно("первое");
    Ожидаем.Что(Результат[1]).Равно("второе");

КонецПроцедуры

&Тест
Процедура ГеттерПолучитьВсеВозвращаетПустойМассив() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Геттер = Новый ОтелГеттерТекстовойКарты();

    // Когда
    Результат = Геттер.ПолучитьВсе(Носитель, "traceparent");

    // Тогда
    Ожидаем.Что(Результат.Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ГеттерКлючиВозвращаетСписокКлючей() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "значение1");
    Носитель.Вставить("tracestate", "значение2");
    Носитель.Вставить("baggage", "значение3");
    Геттер = Новый ОтелГеттерТекстовойКарты();

    // Когда
    Результат = Геттер.Ключи(Носитель);

    // Тогда
    Ожидаем.Что(Результат.Количество()).Равно(3);

КонецПроцедуры

// Тесты ОтелСеттерТекстовойКарты

&Тест
Процедура СеттерУстановитьЗаписываетЗначение() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Сеттер = Новый ОтелСеттерТекстовойКарты();

    // Когда
    Сеттер.Установить(Носитель, "traceparent", "00-abc-def-01");

    // Тогда
    Ожидаем.Что(Носитель.Получить("traceparent")).Равно("00-abc-def-01");

КонецПроцедуры

&Тест
Процедура СеттерСохраняетРегистрКлюча() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Сеттер = Новый ОтелСеттерТекстовойКарты();

    // Когда
    Сеттер.Установить(Носитель, "Content-Type", "application/json");

    // Тогда
    Ожидаем.Что(Носитель.Получить("Content-Type")).Равно("application/json");

КонецПроцедуры

// Тесты пропагаторов с Getter/Setter

&Тест
Процедура W3CПропагаторВнедритьССеттером() Экспорт

    // Дано
    КонтекстСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331");
    Спан = Новый ОтелНоопСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();
    Сеттер = Новый ОтелСеттерТекстовойКарты();

    // Когда
    Пропагатор = Новый ОтелW3CПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель, Сеттер);

    // Тогда
    Ожидаем.Что(Носитель.Получить("traceparent")).Равно("00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01");

КонецПроцедуры

&Тест
Процедура W3CПропагаторИзвлечьСГеттером() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "00-0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-01");
    Контекст = Новый Соответствие();
    Геттер = Новый ОтелГеттерТекстовойКарты();

    // Когда
    Пропагатор = Новый ОтелW3CПропагатор();
    НовыйКонтекст = Пропагатор.Извлечь(Контекст, Носитель, Геттер);

    // Тогда
    Спан = ОтелКонтекст.СпанИзКонтекста(НовыйКонтекст);
    Ожидаем.Что(Спан).Заполнено();
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно("0af7651916cd43dd8448eb211c80319c");

КонецПроцедуры

&Тест
Процедура BaggageПропагаторВнедритьССеттером() Экспорт

    // Дано
    Построитель = Новый ОтелПостроительBaggage();
    Построитель.Установить("key1", "value1");
    Контекст = ОтелКонтекст.КонтекстСBaggage(Новый Соответствие(), Построитель.Построить());
    Носитель = Новый Соответствие();
    Сеттер = Новый ОтелСеттерТекстовойКарты();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель, Сеттер);

    // Тогда
    Ожидаем.Что(Носитель.Получить("baggage")).Заполнено();

КонецПроцедуры

&Тест
Процедура BaggageПропагаторИзвлечьСГеттером() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Носитель.Вставить("baggage", "key1=value1");
    Контекст = Новый Соответствие();
    Геттер = Новый ОтелГеттерТекстовойКарты();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    НовыйКонтекст = Пропагатор.Извлечь(Контекст, Носитель, Геттер);

    // Тогда
    ОбъектBaggage = ОтелКонтекст.BaggageИзКонтекста(НовыйКонтекст);
    Ожидаем.Что(ОбъектBaggage).Заполнено();
    Ожидаем.Что(ОбъектBaggage.Получить("key1")).Равно("value1");

КонецПроцедуры
