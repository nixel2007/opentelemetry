// Тесты ОтелГеттерТекстовойКарты

&Тест
Процедура ГеттерПолучитьВозвращаетЗначениеПоКлючу() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Носитель.Вставить("traceparent", "00-abc-def-01");
    Геттер = Новый ОтелГеттерТекстовойКарты();

    // Когда
    Результат = Геттер.Получить(Носитель, "traceparent");

    // Тогда
    Ожидаем.Что(Результат).Равно("00-abc-def-01");

КонецПроцедуры

&Тест
Процедура ГеттерПолучитьРегистроНезависимый() Экспорт

    // Дано
