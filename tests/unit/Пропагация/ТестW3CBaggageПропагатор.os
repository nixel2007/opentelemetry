&Тест
Процедура ИзвлечениеСМетаданными() Экспорт

    // Дано - значение с metadata после ";"
    Носитель = Новый Соответствие();
    Носитель.Вставить("baggage", "key1=val1;property=x");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - metadata отброшены, значение до ";"
    Baggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Baggage.Получить("key1")).Равно("val1");

КонецПроцедуры

&Тест
Процедура ИзвлечениеМетаданныхСохраняется() Экспорт

    // Дано - значение с metadata после ";"
    Носитель = Новый Соответствие();
    Носитель.Вставить("baggage", "key1=val1;property=x;other=y");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - metadata сохранены в Baggage
    Baggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Baggage.Получить("key1")).Равно("val1");
    Ожидаем.Что(Baggage.ПолучитьМетаданные("key1")).Равно("property=x;other=y");

КонецПроцедуры

&Тест
Процедура КруговаяПередачаМетаданных() Экспорт

    // Дано - Baggage с метаданными
    Ключ1 = "key1";
    Ключ2 = "key2";
    Багаж = Новый ОтелПостроительBaggage()
        .Установить(Ключ1, "val1", "someprop=abc")
        .Установить(Ключ2, "val2")
        .Построить();
    Контекст = Новый Соответствие();
    Контекст = ОтелКонтекст.КонтекстСBaggage(Контекст, Багаж);

    // Когда - inject → extract
    Носитель = Новый Соответствие();
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    НовыйКонтекст = Новый Соответствие();
    Результат = Пропагатор.Извлечь(НовыйКонтекст, Носитель);

    // Тогда - metadata сохранились после круговой передачи
    ИзвлеченныйBaggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(ИзвлеченныйBaggage.Получить(Ключ1)).Равно("val1");
    Ожидаем.Что(ИзвлеченныйBaggage.ПолучитьМетаданные(Ключ1)).Равно("someprop=abc");
    Ожидаем.Что(ИзвлеченныйBaggage.Получить(Ключ2)).Равно("val2");
    Ожидаем.Что(ИзвлеченныйBaggage.ПолучитьМетаданные(Ключ2)).Равно("");

КонецПроцедуры

&Тест
Процедура КодированиеЗначенияСоСпецСимволами() Экспорт

    // Дано - значение с запятой, точкой с запятой и пробелом
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("key", "val,ue;wi th")
        .Построить();
    Контекст = ОтелКонтекст.КонтекстСBaggage(Новый Соответствие(), Багаж);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - спецсимволы закодированы
    ЗначениеЗаголовка = Носитель.Получить("baggage");
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "%2C") > 0).Равно(Истина);
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "%3B") > 0).Равно(Истина);
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "%20") > 0).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КруговаяПередачаСоСпецСимволами() Экспорт

    // Дано - значение со спецсимволами
    ЗначениеИсх = "val,ue;with space";
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("k", ЗначениеИсх)
        .Построить();
    Контекст = ОтелКонтекст.КонтекстСBaggage(Новый Соответствие(), Багаж);

    // Когда - inject -> extract
    Носитель = Новый Соответствие();
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);
    Результат = Пропагатор.Извлечь(Новый Соответствие(), Носитель);

    // Тогда - значение восстановлено
    Извлеченный = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Извлеченный.Получить("k")).Равно(ЗначениеИсх);

КонецПроцедуры

&Тест
Процедура ОграничениеДлиныЗаголовка8192Байта() Экспорт

    // Дано - baggage суммарно > 8192 символов
    Построитель = Новый ОтелПостроительBaggage();
    ДлиннаяСтрока = "";
    Пока СтрДлина(ДлиннаяСтрока) < 8200 Цикл
        ДлиннаяСтрока = ДлиннаяСтрока + "xxxxxxxxxx";
    КонецЦикла;
    Построитель.Установить("bigkey", ДлиннаяСтрока);
    Багаж = Построитель.Построить();
    Контекст = ОтелКонтекст.КонтекстСBaggage(Новый Соответствие(), Багаж);
    Носитель = Новый Соответствие();

    // Когда - значение превышает лимит
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - заголовок не устанавливается
    Ожидаем.Что(Носитель.Получить("baggage")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КодированиеНеASCIIЗначения() Экспорт

    // Дано - baggage со значением содержащим non-ASCII символы (строка 217 - КодироватьСтроку)
    Построитель = Новый ОтелПостроительBaggage();
    Построитель.Установить("test-key", "а"); // Кириллическое "а", код 1072 > 127
    Багаж = Построитель.Построить();
    Контекст = ОтелКонтекст.КонтекстСBaggage(Новый Соответствие(), Багаж);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - заголовок содержит percent-encoded значение
    ЗначениеЗаголовка = Носитель.Получить("baggage");
    Ожидаем.Что(ЗначениеЗаголовка).Не_().Равно(Неопределено);
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "%") > 0).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ЗначениеСВосклицательнымЗнаком() Экспорт

    // Дано - символ '!' имеет код 33 (0x21) — допустимый baggage-octet, не должен кодироваться
    Построитель = Новый ОтелПостроительBaggage();
    Построитель.Установить("test-key", "value!with!exclamation");
    Багаж = Построитель.Построить();
    Контекст = ОтелКонтекст.КонтекстСBaggage(Новый Соответствие(), Багаж);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - '!' не закодирован как %21
    ЗначениеЗаголовка = Носитель.Получить("baggage");
    Ожидаем.Что(ЗначениеЗаголовка).Не_().Равно(Неопределено);
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "value!with!exclamation") > 0).Равно(Истина);
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "%21")).Равно(0);

КонецПроцедуры
