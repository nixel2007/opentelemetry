&Тест
Процедура ВнедрениеBaggage() Экспорт

    // Дано
    Baggage = Новый ОтелПостроительBaggage()
        .Установить("key1", "val1")
        .Установить("key2", "val2")
        .Построить();
    Контекст = ОтелКонтекст.КонтекстСBaggage(Новый Соответствие(), Baggage);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда
    ЗначениеЗаголовка = Носитель.Получить("baggage");
    Ожидаем.Что(ЗначениеЗаголовка).Не_().Равно(Неопределено);
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "key1=val1") > 0).Равно(Истина);
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "key2=val2") > 0).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ИзвлечениеBaggage() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Носитель.Вставить("baggage", "key1=val1,key2=val2");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда
    Baggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Baggage).Не_().Равно(Неопределено);
    Ожидаем.Что(Baggage.Получить("key1")).Равно("val1");
    Ожидаем.Что(Baggage.Получить("key2")).Равно("val2");
    Ожидаем.Что(Baggage.Количество()).Равно(2);

КонецПроцедуры

&Тест
Процедура ПустойBaggage() Экспорт

    // Дано
    Baggage = Новый ОтелПостроительBaggage().Построить();
    Контекст = ОтелКонтекст.КонтекстСBaggage(Новый Соответствие(), Baggage);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - пустой Baggage не устанавливает заголовок
    Ожидаем.Что(Носитель.Получить("baggage")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ВнедрениеБезBaggage() Экспорт

    // Дано - контекст без baggage
    Контекст = Новый Соответствие();
    Носитель = Новый Соответствие();

    // Когда - пытаемся внедрить пустой контекст
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - ничего не установлено
    Ожидаем.Что(Носитель.Получить("baggage")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ИзвлечениеБезЗаголовка() Экспорт

    // Дано - пустые заголовки
    Носитель = Новый Соответствие();
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - возвращается входной контекст без изменений
    Ожидаем.Что(Результат).Равно(ВходнойКонтекст);

КонецПроцедуры

&Тест
Процедура ИзвлечениеСПустымиЧастями() Экспорт

    // Дано - заголовок с пустыми частями и без знака "="
    Носитель = Новый Соответствие();
    Носитель.Вставить("baggage", "key1=val1,,noequals, ,key2=val2");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - только валидные пары
    Baggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Baggage.Получить("key1")).Равно("val1");
    Ожидаем.Что(Baggage.Получить("key2")).Равно("val2");

КонецПроцедуры

&Тест
Процедура ИзвлечениеСЗаголовкомВДругомРегистре() Экспорт

    // Дано - HTTP заголовки могут приходить в любом регистре
    Носитель = Новый Соответствие();
    Носитель.Вставить("Baggage", "key1=val1,key2=val2");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда
    Baggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Baggage).Не_().Равно(Неопределено);
    Ожидаем.Что(Baggage.Получить("key1")).Равно("val1");
    Ожидаем.Что(Baggage.Получить("key2")).Равно("val2");

КонецПроцедуры

&Тест
Процедура ИзвлечениеСЗаголовкомВВерхнемРегистре() Экспорт

    // Дано - заголовок полностью в верхнем регистре
    Носитель = Новый Соответствие();
    Носитель.Вставить("BAGGAGE", "key1=val1");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда
    Baggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Baggage).Не_().Равно(Неопределено);
    Ожидаем.Что(Baggage.Получить("key1")).Равно("val1");

КонецПроцедуры

&Тест
Процедура ИзвлечениеСМетаданными() Экспорт

    // Дано - значение с metadata после ";"
    Носитель = Новый Соответствие();
    Носитель.Вставить("baggage", "key1=val1;property=x");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - metadata отброшены, значение до ";"
    Baggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Baggage.Получить("key1")).Равно("val1");

КонецПроцедуры

&Тест
Процедура ИзвлечениеМетаданныхСохраняется() Экспорт

    // Дано - значение с metadata после ";"
    Носитель = Новый Соответствие();
    Носитель.Вставить("baggage", "key1=val1;property=x;other=y");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - metadata сохранены в Baggage
    Baggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(Baggage.Получить("key1")).Равно("val1");
    Ожидаем.Что(Baggage.ПолучитьМетаданные("key1")).Равно("property=x;other=y");

КонецПроцедуры

&Тест
Процедура КруговаяПередачаМетаданных() Экспорт

    // Дано - Baggage с метаданными
    Ключ1 = "key1";
    Ключ2 = "key2";
    Багаж = Новый ОтелПостроительBaggage()
        .Установить(Ключ1, "val1", "someprop=abc")
        .Установить(Ключ2, "val2")
        .Построить();
    Контекст = Новый Соответствие();
    Контекст = ОтелКонтекст.КонтекстСBaggage(Контекст, Багаж);

    // Когда - inject → extract
    Носитель = Новый Соответствие();
    Пропагатор = Новый ОтелW3CBaggageПропагатор();
    Пропагатор.Внедрить(Контекст, Носитель);

    НовыйКонтекст = Новый Соответствие();
    Результат = Пропагатор.Извлечь(НовыйКонтекст, Носитель);

    // Тогда - metadata сохранились после круговой передачи
    ИзвлеченныйBaggage = ОтелКонтекст.BaggageИзКонтекста(Результат);
    Ожидаем.Что(ИзвлеченныйBaggage.Получить(Ключ1)).Равно("val1");
    Ожидаем.Что(ИзвлеченныйBaggage.ПолучитьМетаданные(Ключ1)).Равно("someprop=abc");
    Ожидаем.Что(ИзвлеченныйBaggage.Получить(Ключ2)).Равно("val2");
    Ожидаем.Что(ИзвлеченныйBaggage.ПолучитьМетаданные(Ключ2)).Равно("");

КонецПроцедуры
