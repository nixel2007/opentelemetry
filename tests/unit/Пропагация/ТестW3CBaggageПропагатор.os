// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts

&Тест
Процедура ВнедрениеBaggage() Экспорт

    // Дано
    Baggage = Новый ОтелПостроительBaggage()
        .Установить("key1", "val1")
        .Установить("key2", "val2")
        .Построить();
    Носитель = Новый Соответствие();

    // Когда
    ОтелW3CBaggageПропагатор.Внедрить(Baggage, Носитель);

    // Тогда
    ЗначениеЗаголовка = Носитель.Получить("baggage");
    Ожидаем.Что(ЗначениеЗаголовка).Не_().Равно(Неопределено);
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "key1=val1") > 0).Равно(Истина);
    Ожидаем.Что(СтрНайти(ЗначениеЗаголовка, "key2=val2") > 0).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ИзвлечениеBaggage() Экспорт

    // Дано
    Носитель = Новый Соответствие();
    Носитель.Вставить("baggage", "key1=val1,key2=val2");

    // Когда
    Baggage = ОтелW3CBaggageПропагатор.Извлечь(Носитель);

    // Тогда
    Ожидаем.Что(Baggage).Не_().Равно(Неопределено);
    Ожидаем.Что(Baggage.Получить("key1")).Равно("val1");
    Ожидаем.Что(Baggage.Получить("key2")).Равно("val2");
    Ожидаем.Что(Baggage.Количество()).Равно(2);

КонецПроцедуры

&Тест
Процедура ПустойBaggage() Экспорт

    // Дано
    Baggage = Новый ОтелПостроительBaggage().Построить();
    Носитель = Новый Соответствие();

    // Когда
    ОтелW3CBaggageПропагатор.Внедрить(Baggage, Носитель);

    // Тогда — пустой Baggage не устанавливает заголовок
    Ожидаем.Что(Носитель.Получить("baggage")).Равно(Неопределено);

КонецПроцедуры
