&Тест
Процедура СозданиеСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);

    // Когда
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("моя-библиотека", "1.0.0");
    Спан = Новый ОтелСпан("тестовый-спан", Ресурс, ОбластьИнструментирования);

    // Тогда
    Ожидаем.Что(Спан.Имя()).Равно("тестовый-спан");
    Ожидаем.Что(Спан.ОбластьИнструментирования().Имя()).Равно("моя-библиотека");
    Ожидаем.Что(Спан.ОбластьИнструментирования().Версия()).Равно("1.0.0");
    Ожидаем.Что(Спан.Ресурс()).Равно(Ресурс);
    Ожидаем.Что(Спан.Завершен()).Равно(Ложь);
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Истина);
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.НеУстановлен());
    Ожидаем.Что(Спан.ВидСпана()).Равно(ОтелВидСпана.Внутренний());
КонецПроцедуры

&Тест
Процедура АтрибутыСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда
    Спан.УстановитьАтрибут("http.method", "GET");
    Спан.УстановитьАтрибут("http.status_code", 200);

    // Тогда
    Ожидаем.Что(Спан.Атрибуты().Получить("http.method")).Равно("GET");
    Ожидаем.Что(Спан.Атрибуты().Получить("http.status_code")).Равно(200);
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(2);
КонецПроцедуры

&Тест
Процедура СобытияСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда
    Спан.ДобавитьСобытие("событие-1");
    Спан.ДобавитьСобытие("событие-2");

    // Тогда
    Ожидаем.Что(Спан.События().Количество()).Равно(2);
    Ожидаем.Что(Спан.События()[0].Имя()).Равно("событие-1");
    Ожидаем.Что(Спан.События()[1].Имя()).Равно("событие-2");
КонецПроцедуры

&Тест
Процедура ЛинкиСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    КонтекстЛинка = Новый ОтелКонтекстСпана("01020304050607080910111213141516", "0102030405060708");

    // Когда
    Спан.ДобавитьЛинк(КонтекстЛинка);

    // Тогда
    Ожидаем.Что(Спан.Линки().Количество()).Равно(1);
    Ожидаем.Что(Спан.Линки()[0].Получить("КонтекстСпана")).Равно(КонтекстЛинка);
КонецПроцедуры

&Тест
Процедура УстановкаСтатуса() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда - устанавливаем статус ошибки
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "что-то пошло не так");

    // Тогда
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ошибка());
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("что-то пошло не так");

    // Когда - из ERROR можно перейти в OK
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());

    // Тогда - OK - финальный статус
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ок());
КонецПроцедуры

&Тест
Процедура ЗавершениеСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда
    Спан.Завершить();

    // Тогда
    Ожидаем.Что(Спан.Завершен()).Равно(Истина);
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);
    Ожидаем.Что(Спан.ВремяОкончания() = "").Равно(Ложь);
КонецПроцедуры

&Тест
Процедура НеизменностьПослеЗавершения() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.УстановитьАтрибут("ключ1", "значение1");
    Спан.Завершить();

    // Когда - попытка изменить после завершения
    Спан.УстановитьАтрибут("ключ2", "значение2");
    Спан.ДобавитьСобытие("запоздалое-событие");
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "ошибка");
    Спан.ИзменитьИмя("новое-имя");

    // Тогда - ничего не изменилось
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(1);
    Ожидаем.Что(Спан.Атрибуты().Получить("ключ2")).Равно(Неопределено);
    Ожидаем.Что(Спан.События().Количество()).Равно(0);
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.НеУстановлен());
    Ожидаем.Что(Спан.Имя()).Равно("тест");
КонецПроцедуры

&Тест
Процедура ВызовПроцессораПриЗавершении() Экспорт
    // Дано
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования, МокПроцессор);

    // Когда
    Спан.Завершить();

    // Тогда
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().Обработать(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ВидСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);

    // Когда
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования, , , , ОтелВидСпана.Сервер());

    // Тогда
    Ожидаем.Что(Спан.ВидСпана()).Равно(ОтелВидСпана.Сервер());
КонецПроцедуры

&Тест
Процедура ЗаписьИсключения() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда
    Попытка
        ВызватьИсключение "тестовая ошибка";
    Исключение
        Спан.ЗаписатьИсключение(ИнформацияОбОшибке());
    КонецПопытки;

    // Тогда
    Ожидаем.Что(Спан.События().Количество()).Равно(1);
    Ожидаем.Что(Спан.События()[0].Имя()).Равно("exception");
    Ожидаем.Что(Спан.События()[0].Атрибуты().Получить("exception.message")).Равно("тестовая ошибка");
КонецПроцедуры

&Тест
Процедура СделатьТекущим() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда
    Область = Спан.СделатьТекущим();

    // Тогда
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Спан);

    // Очистка
    Область.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПереименованиеСпана() Экспорт
