#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура СозданиеСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);

    // Когда
    Спан = Новый ОтелСпан("тестовый-спан", Ресурс, "моя-библиотека", "1.0.0");

    // Тогда
    Ожидаем.Что(Спан.Имя()).Равно("тестовый-спан");
    Ожидаем.Что(Спан.ИмяБиблиотеки()).Равно("моя-библиотека");
    Ожидаем.Что(Спан.ВерсияБиблиотеки()).Равно("1.0.0");
    Ожидаем.Что(Спан.Ресурс()).Равно(Ресурс);
    Ожидаем.Что(Спан.Завершен()).Равно(Ложь);
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Истина);
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.НеУстановлен());
    Ожидаем.Что(Спан.ВидСпана()).Равно(ОтелВидСпана.Внутренний());
КонецПроцедуры

&Тест
Процедура АтрибутыСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");

    // Когда
    Спан.УстановитьАтрибут("http.method", "GET");
    Спан.УстановитьАтрибут("http.status_code", 200);

    // Тогда
    Ожидаем.Что(Спан.Атрибуты().Получить("http.method")).Равно("GET");
    Ожидаем.Что(Спан.Атрибуты().Получить("http.status_code")).Равно(200);
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(2);
КонецПроцедуры

&Тест
Процедура СобытияСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");

    // Когда
    Спан.ДобавитьСобытие("событие-1");
    Спан.ДобавитьСобытие("событие-2");

    // Тогда
    Ожидаем.Что(Спан.События().Количество()).Равно(2);
    Ожидаем.Что(Спан.События()[0].Имя()).Равно("событие-1");
    Ожидаем.Что(Спан.События()[1].Имя()).Равно("событие-2");
КонецПроцедуры

&Тест
Процедура ЛинкиСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    КонтекстЛинка = Новый ОтелКонтекстСпана("01020304050607080910111213141516", "0102030405060708");

    // Когда
    Спан.ДобавитьЛинк(КонтекстЛинка);

    // Тогда
    Ожидаем.Что(Спан.Линки().Количество()).Равно(1);
    Ожидаем.Что(Спан.Линки()[0].Получить("КонтекстСпана")).Равно(КонтекстЛинка);
КонецПроцедуры

&Тест
Процедура УстановкаСтатуса() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");

    // Когда - устанавливаем статус ошибки
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "что-то пошло не так");

    // Тогда
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ошибка());
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("что-то пошло не так");

    // Когда - из ERROR можно перейти в OK
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());

    // Тогда - OK - финальный статус
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ок());
КонецПроцедуры

&Тест
Процедура ЗавершениеСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");

    // Когда
    Спан.Завершить();

    // Тогда
    Ожидаем.Что(Спан.Завершен()).Равно(Истина);
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);
    Ожидаем.Что(Спан.ВремяОкончания() = "").Равно(Ложь);
КонецПроцедуры

&Тест
Процедура НеизменностьПослеЗавершения() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    Спан.УстановитьАтрибут("ключ1", "значение1");
    Спан.Завершить();

    // Когда - попытка изменить после завершения
    Спан.УстановитьАтрибут("ключ2", "значение2");
    Спан.ДобавитьСобытие("запоздалое-событие");
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "ошибка");
    Спан.ИзменитьИмя("новое-имя");

    // Тогда - ничего не изменилось
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(1);
    Ожидаем.Что(Спан.Атрибуты().Получить("ключ2")).Равно(Неопределено);
    Ожидаем.Что(Спан.События().Количество()).Равно(0);
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.НеУстановлен());
    Ожидаем.Что(Спан.Имя()).Равно("тест");
КонецПроцедуры

&Тест
Процедура ВызовПроцессораПриЗавершении() Экспорт
    // Дано
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0", МокПроцессор);

    // Когда
    Спан.Завершить();

    // Тогда
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().Обработать(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ВидСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);

    // Когда
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0", , , , ОтелВидСпана.Сервер());

    // Тогда
    Ожидаем.Что(Спан.ВидСпана()).Равно(ОтелВидСпана.Сервер());
КонецПроцедуры

&Тест
Процедура ЗаписьИсключения() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");

    // Когда
    Попытка
        ВызватьИсключение "тестовая ошибка";
    Исключение
        Спан.ЗаписатьИсключение(ИнформацияОбОшибке());
    КонецПопытки;

    // Тогда
    Ожидаем.Что(Спан.События().Количество()).Равно(1);
    Ожидаем.Что(Спан.События()[0].Имя()).Равно("exception");
    Ожидаем.Что(Спан.События()[0].Атрибуты().Получить("exception.message")).Равно("тестовая ошибка");
КонецПроцедуры

&Тест
Процедура СделатьТекущим() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");

    // Когда
    Область = Спан.СделатьТекущим();

    // Тогда
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(Спан);

    // Очистка
    Область.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПереименованиеСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("старое-имя", Ресурс, "библ", "1.0");

    // Когда
    Спан.ИзменитьИмя("новое-имя");

    // Тогда
    Ожидаем.Что(Спан.Имя()).Равно("новое-имя");
КонецПроцедуры

&Тест
Процедура ЛимитыАтрибутов() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксАтрибутов(2);
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0", , , , , Лимиты);

    // Когда
    Спан.УстановитьАтрибут("ключ1", "значение1");
    Спан.УстановитьАтрибут("ключ2", "значение2");
    Спан.УстановитьАтрибут("ключ3", "значение3");

    // Тогда - третий атрибут не добавлен
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(2);
    Ожидаем.Что(Спан.Атрибуты().Получить("ключ1")).Равно("значение1");
    Ожидаем.Что(Спан.Атрибуты().Получить("ключ2")).Равно("значение2");
    Ожидаем.Что(Спан.Атрибуты().Получить("ключ3")).Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура ЛимитыСобытий() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксСобытий(2);
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0", , , , , Лимиты);

    // Когда
    Спан.ДобавитьСобытие("событие-1");
    Спан.ДобавитьСобытие("событие-2");
    Спан.ДобавитьСобытие("событие-3");

    // Тогда - третье событие не добавлено
    Ожидаем.Что(Спан.События().Количество()).Равно(2);
КонецПроцедуры

&Тест
Процедура КонтекстСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);

    // Когда
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");

    // Тогда
    Контекст = Спан.КонтекстСпана();
    Ожидаем.Что(Контекст.Валиден()).Равно(Истина);
    Ожидаем.Что(СтрДлина(Контекст.ИдТрассировки()) > 0).Равно(Истина);
    Ожидаем.Что(СтрДлина(Контекст.ИдСпана()) > 0).Равно(Истина);
КонецПроцедуры

&Тест
Процедура УсечениеДлинногоАтрибута() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана();
    Лимиты.УстановитьМаксДлинаЗначенияАтрибута(5);
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0",, , , , Лимиты);

    // Когда - устанавливаем атрибут с длинным значением
    Спан.УстановитьАтрибут("key", "abcdefghij");

    // Тогда - значение усечено до 5 символов
    Ожидаем.Что(Спан.Атрибуты().Получить("key")).Равно("abcde");
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура ЗаписатьИсключениеНаЗавершенномСпане() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    Спан.Завершить();

    // Когда - пытаемся записать исключение на завершенном спане
    Попытка
        ВызватьИсключение "Тестовая ошибка";
    Исключение
        Спан.ЗаписатьИсключение(ИнформацияОбОшибке());
    КонецПопытки;

    // Тогда - событий нет, спан уже закрыт
    Ожидаем.Что(Спан.События().Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура ЗаписатьИсключениеСДополнительнымиАтрибутами() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    Доп = Новый ОтелАтрибуты();
    Доп.Установить("extra.key", "extra.value");

    // Когда - записываем исключение с доп. атрибутами
    Попытка
        ВызватьИсключение "Тестовая ошибка";
    Исключение
        Спан.ЗаписатьИсключение(ИнформацияОбОшибке(), Доп);
    КонецПопытки;

    // Тогда - событие содержит и стандартные и дополнительные атрибуты
    Ожидаем.Что(Спан.События().Количество()).Равно(1);
    АтрСобытия = Спан.События()[0].Атрибуты();
    Ожидаем.Что(АтрСобытия.Получить("exception.message")).Равно("Тестовая ошибка");
    Ожидаем.Что(АтрСобытия.Получить("extra.key")).Равно("extra.value");
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура ДобавитьЛинкСАтрибутами() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    КонтекстЛинка = Новый ОтелКонтекстСпана("01020304050607080910111213141516", "0102030405060708");
    АтрЛинка = Новый ОтелАтрибуты();
    АтрЛинка.Установить("link.type", "parent");

    // Когда
    Спан.ДобавитьЛинк(КонтекстЛинка, АтрЛинка);

    // Тогда - линк содержит атрибуты
    Ожидаем.Что(Спан.Линки().Количество()).Равно(1);
    Ожидаем.Что(Спан.Линки()[0].Получить("Атрибуты")).Равно(АтрЛинка);
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура СтатусОкНеМеняется() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());

    // Когда - пытаемся перевести в ERROR после OK
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "не должно примениться");

    // Тогда - статус остается OK
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ок());
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура СтатусОшибкаНеСбрасываетсяВНеУстановлен() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "ошибка");

    // Когда - пытаемся сбросить в UNSET
    Спан.УстановитьСтатус(ОтелКодСтатуса.НеУстановлен());

    // Тогда - статус остается ERROR
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ошибка());
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура ЗавершитьСУказаннымВременем() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");

    // Когда - завершаем с явным временем окончания
    Спан.Завершить("9999000000000");

    // Тогда
    Ожидаем.Что(Спан.ВремяОкончания()).Равно("9999000000000");
КонецПроцедуры
