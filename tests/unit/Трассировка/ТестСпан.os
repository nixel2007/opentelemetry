    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования, , , , , Лимиты);

    // Когда
    Спан.ДобавитьСобытие("событие-1");
    Спан.ДобавитьСобытие("событие-2");
    Спан.ДобавитьСобытие("событие-3");

    // Тогда - третье событие не добавлено
    Ожидаем.Что(Спан.События().Количество()).Равно(2);
КонецПроцедуры

&Тест
Процедура КонтекстСпана() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);

    // Когда
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Тогда
    Контекст = Спан.КонтекстСпана();
    Ожидаем.Что(Контекст.Валиден()).Равно(Истина);
    Ожидаем.Что(СтрДлина(Контекст.ИдТрассировки()) > 0).Равно(Истина);
    Ожидаем.Что(СтрДлина(Контекст.ИдСпана()) > 0).Равно(Истина);
КонецПроцедуры

&Тест
Процедура УсечениеДлинногоАтрибута() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана();
    Лимиты.УстановитьМаксДлинаЗначенияАтрибута(5);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан(
        "тест", Ресурс, ОбластьИнструментирования, , , , , Лимиты);

    // Когда - устанавливаем атрибут с длинным значением
    Спан.УстановитьАтрибут("key", "abcdefghij");

    // Тогда - значение усечено до 5 символов
    Ожидаем.Что(Спан.Атрибуты().Получить("key")).Равно("abcde");
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура ЗаписатьИсключениеНаЗавершенномСпане() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();

    // Когда - пытаемся записать исключение на завершенном спане
    Попытка
        ВызватьИсключение "Тестовая ошибка";
    Исключение
        Спан.ЗаписатьИсключение(ИнформацияОбОшибке());
    КонецПопытки;

    // Тогда - событий нет, спан уже закрыт
    Ожидаем.Что(Спан.События().Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура ЗаписатьИсключениеСДополнительнымиАтрибутами() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Доп = Новый ОтелАтрибуты();
    Доп.Установить("extra.key", "extra.value");

    // Когда - записываем исключение с доп. атрибутами
    Попытка
        ВызватьИсключение "Тестовая ошибка";
    Исключение
        Спан.ЗаписатьИсключение(ИнформацияОбОшибке(), Доп);
    КонецПопытки;

    // Тогда - событие содержит и стандартные и дополнительные атрибуты
    Ожидаем.Что(Спан.События().Количество()).Равно(1);
    АтрибутыСобытия = Спан.События()[0].Атрибуты();
    Ожидаем.Что(АтрибутыСобытия.Получить("exception.message")).Равно("Тестовая ошибка");
    Ожидаем.Что(АтрибутыСобытия.Получить("extra.key")).Равно("extra.value");
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура ЗаписатьИсключениеАтрибутыТипИСтек() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда
    Попытка
        ВызватьИсключение "Тестовая ошибка";
    Исключение
        Спан.ЗаписатьИсключение(ИнформацияОбОшибке());
    КонецПопытки;

    // Тогда
    События = Спан.События();
    Ожидаем.Что(События.Количество()).БольшеИлиРавно(1);

    ПоследнееСобытие = События[События.ВГраница()];
    Ожидаем.Что(ПоследнееСобытие.Имя()).Равно("exception");

    Атрибуты = ПоследнееСобытие.Атрибуты();
    Ожидаем.Что(Атрибуты.Получить("exception.message")).Равно("Тестовая ошибка");
    Ожидаем.Что(Атрибуты.Получить("exception.type") <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Атрибуты.Получить("exception.stacktrace") <> Неопределено).ЭтоИстина();
КонецПроцедуры

&Тест
Процедура ДобавитьЛинкСАтрибутами() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    КонтекстЛинка = Новый ОтелКонтекстСпана("01020304050607080910111213141516", "0102030405060708");
    АтрибутыЛинка = Новый ОтелАтрибуты();
    АтрибутыЛинка.Установить("link.type", "parent");

    // Когда
    Спан.ДобавитьЛинк(КонтекстЛинка, АтрибутыЛинка);

    // Тогда - линк содержит атрибуты
    Ожидаем.Что(Спан.Линки().Количество()).Равно(1);
    Ожидаем.Что(Спан.Линки()[0].Получить("Атрибуты")).Равно(АтрибутыЛинка);
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура СтатусОкНеМеняется() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());

    // Когда - пытаемся перевести в ERROR после OK
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "не должно примениться");

    // Тогда - статус остается OK
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ок());
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура СтатусОшибкаНеСбрасываетсяВНеУстановлен() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ошибка(), "ошибка");

    // Когда - пытаемся сбросить в UNSET
    Спан.УстановитьСтатус(ОтелКодСтатуса.НеУстановлен());

    // Тогда - статус остается ERROR
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.Ошибка());
    Спан.Завершить();
КонецПроцедуры

&Тест
Процедура ЗавершитьСУказаннымВременем() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда - завершаем с явным временем окончания
    Спан.Завершить("9999000000000");

    // Тогда
    Ожидаем.Что(Спан.ВремяОкончания()).Равно("9999000000000");
КонецПроцедуры

&Тест
Процедура ЗавершениеНеЗакрываетОбласть() Экспорт
    // Дано - создаем спан и делаем его текущим
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Область = Спан.СделатьТекущим();

    // Когда - завершаем спан
    Спан.Завершить();

    // Тогда - область НЕ закрыта (per OTel spec: Span.end() и Scope.close() независимы)
    Ожидаем.Что(Область.Закрыта()).Равно(Ложь);

    // Очистка
    Область.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ОтброшенныеСчетчикиНулевыеПоУмолчанию() Экспорт
    // Дано / Когда
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Тогда - все счетчики отброшенных равны 0
    Ожидаем.Что(Спан.КоличествоОтброшенныхАтрибутов()).Равно(0);
    Ожидаем.Что(Спан.КоличествоОтброшенныхСобытий()).Равно(0);
    Ожидаем.Что(Спан.КоличествоОтброшенныхЛинков()).Равно(0);
КонецПроцедуры

&Тест
Процедура ОтброшенныеАтрибутыПриПревышенииЛимита() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксАтрибутов(2);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования, , , , , Лимиты);

    // Когда - добавляем 4 атрибута при лимите 2
    Спан.УстановитьАтрибут("ключ1", "значение1");
    Спан.УстановитьАтрибут("ключ2", "значение2");
    Спан.УстановитьАтрибут("ключ3", "значение3");
    Спан.УстановитьАтрибут("ключ4", "значение4");

    // Тогда - 2 атрибута отброшены
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(2);
    Ожидаем.Что(Спан.КоличествоОтброшенныхАтрибутов()).Равно(2);
КонецПроцедуры

