&Тест
Процедура ОтброшенныеЛинкиПриПревышенииЛимита() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксЛинков(2);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования, , , , , Лимиты);
    КонтекстЛинка = Новый ОтелКонтекстСпана("01020304050607080910111213141516", "0102030405060708");

    // Когда - добавляем 4 линка при лимите 2
    Спан.ДобавитьЛинк(КонтекстЛинка);
    Спан.ДобавитьЛинк(КонтекстЛинка);
    Спан.ДобавитьЛинк(КонтекстЛинка);
    Спан.ДобавитьЛинк(КонтекстЛинка);

    // Тогда - 2 линка отброшены
    Ожидаем.Что(Спан.Линки().Количество()).Равно(2);
    Ожидаем.Что(Спан.КоличествоОтброшенныхЛинков()).Равно(2);
