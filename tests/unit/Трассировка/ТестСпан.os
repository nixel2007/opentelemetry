&Тест
Процедура ОтброшенныеАтрибутыСобытияПриПревышенииЛимита() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксАтрибутовНаСобытие(2);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования, , , , , Лимиты);

    АтрибутыСобытия = Новый ОтелАтрибуты();
    АтрибутыСобытия.Установить("a1", "v1");
    АтрибутыСобытия.Установить("a2", "v2");
    АтрибутыСобытия.Установить("a3", "v3");
    АтрибутыСобытия.Установить("a4", "v4");

    // Когда - добавляем событие с 4 атрибутами при лимите 2
    Спан.ДобавитьСобытие("тест-событие", АтрибутыСобытия);

    // Тогда - атрибуты обрезаны до 2, 2 отброшены
    Событие = Спан.События()[0];
    Ожидаем.Что(Событие.Атрибуты().Количество()).Равно(2);
    Ожидаем.Что(Событие.КоличествоОтброшенныхАтрибутов()).Равно(2);
КонецПроцедуры

&Тест
Процедура АтрибутыСобытияВПределахЛимита() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксАтрибутовНаСобытие(5);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования, , , , , Лимиты);

    АтрибутыСобытия = Новый ОтелАтрибуты();
    АтрибутыСобытия.Установить("a1", "v1");
    АтрибутыСобытия.Установить("a2", "v2");

    // Когда - добавляем событие с 2 атрибутами при лимите 5
    Спан.ДобавитьСобытие("тест-событие", АтрибутыСобытия);

    // Тогда - все атрибуты на месте
    Событие = Спан.События()[0];
    Ожидаем.Что(Событие.Атрибуты().Количество()).Равно(2);
    Ожидаем.Что(Событие.КоличествоОтброшенныхАтрибутов()).Равно(0);
КонецПроцедуры

&Тест
Процедура ОтброшенныеАтрибутыЛинкаПриПревышенииЛимита() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксАтрибутовНаЛинк(2);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования, , , , , Лимиты);
    КонтекстЛинка = Новый ОтелКонтекстСпана("01020304050607080910111213141516", "0102030405060708");

    АтрибутыЛинка = Новый ОтелАтрибуты();
    АтрибутыЛинка.Установить("a1", "v1");
    АтрибутыЛинка.Установить("a2", "v2");
    АтрибутыЛинка.Установить("a3", "v3");
    АтрибутыЛинка.Установить("a4", "v4");

    // Когда - добавляем линк с 4 атрибутами при лимите 2
    Спан.ДобавитьЛинк(КонтекстЛинка, АтрибутыЛинка);

    // Тогда - атрибуты обрезаны до 2, 2 отброшены
    Линк = Спан.Линки()[0];
    Ожидаем.Что(Линк.Получить("Атрибуты").Количество()).Равно(2);
    Ожидаем.Что(Линк.Получить("ОтброшеноАтрибутов")).Равно(2);
КонецПроцедуры

