// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

// --- Вспомогательный процессор-шпион ---

Перем ЗавершенПриOnEnding;
Перем ВремяОкончанияПриOnEnding;
Перем АтрибутДобавленВOnEnding;
Перем OnEndingВызван;
Перем OnEndВызван;

&Тест
Процедура ПередЗавершениемВызываетсяДоУстановкиФлагаЗавершен() Экспорт

    // Дано
    Спан = СоздатьСпан();
    ЗавершенПриOnEnding = Неопределено;
    OnEndingВызван = Ложь;

    // Когда
    Спан.Завершить();

    // Тогда - при вызове ПередЗавершением спан ещё не был завершён
    Ожидаем.Что(OnEndingВызван).Равно(Истина);
    Ожидаем.Что(ЗавершенПриOnEnding).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ВремяОкончанияУжеВычисленоПриOnEnding() Экспорт

    // Дано
    Спан = СоздатьСпан();
    ВремяОкончанияПриOnEnding = Неопределено;
    OnEndingВызван = Ложь;

    // Когда
    Спан.Завершить();

    // Тогда - время окончания уже задано при вызове ПередЗавершением
    Ожидаем.Что(OnEndingВызван).Равно(Истина);
    Ожидаем.Что(ВремяОкончанияПриOnEnding).Заполнено();

КонецПроцедуры

&Тест
Процедура СпанМутабеленВоВремяOnEnding() Экспорт

    // Дано
    Спан = СоздатьСпан();
    АтрибутДобавленВOnEnding = Ложь;
    OnEndingВызван = Ложь;

    // Когда
    Спан.Завершить();

    // Тогда - атрибут был успешно добавлен в OnEnding
    Ожидаем.Что(OnEndingВызван).Равно(Истина);
    Ожидаем.Что(АтрибутДобавленВOnEnding).Равно(Истина);
    Ожидаем.Что(Спан.Атрибуты().Получить("onending.attr")).Заполнено();

КонецПроцедуры

&Тест
Процедура OnEndВызываетсяПослеЗавершения() Экспорт

    // Дано
    Спан = СоздатьСпан();
    OnEndВызван = Ложь;

    // Когда
    Спан.Завершить();

    // Тогда
    Ожидаем.Что(OnEndВызван).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КомпозитныйПроцессорДелегируетOnEnding() Экспорт

    // Дано
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));

    Процессоры = Новый Массив;
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);

    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда
    Композитный.ПередЗавершением(Спан);

    // Тогда - оба процессора получили вызов
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().ПередЗавершением(Матчеры.ЛюбоеЗначение());
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().ПередЗавершением(Матчеры.ЛюбоеЗначение());

КонецПроцедуры

&Тест
Процедура ИнтерфейсПроцессораСодержитOnEnding() Экспорт

    // Дано
    Интерфейс = Новый ИнтерфейсПроцессорСпанов();

    // Когда / Тогда - метод существует и вызывается без ошибки
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Интерфейс.ПередЗавершением(Спан);

КонецПроцедуры

// --- Вспомогательные ---

Функция СоздатьСпан()
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования, ЭтотОбъект);
    Возврат Спан;
КонецФункции

// Реализуем интерфейс процессора прямо в тесте

Процедура ПриНачале(Спан, РодительскийКонтекст) Экспорт // BSLLS:UnusedParameters-off
КонецПроцедуры

Процедура ПередЗавершением(Спан) Экспорт
    ЗавершенПриOnEnding = Спан.Завершен();
    ВремяОкончанияПриOnEnding = Спан.ВремяОкончания();
    OnEndingВызван = Истина;

    // Проверяем мутабельность - добавляем атрибут
    Попытка
        Спан.УстановитьАтрибут("onending.attr", "value");
        АтрибутДобавленВOnEnding = Истина;
    Исключение
        АтрибутДобавленВOnEnding = Ложь;
    КонецПопытки;
КонецПроцедуры

Процедура ПриЗавершении(Спан) Экспорт // BSLLS:UnusedParameters-off
    OnEndВызван = Истина;
КонецПроцедуры

Процедура СброситьБуфер() Экспорт
КонецПроцедуры

Процедура Закрыть() Экспорт
КонецПроцедуры
