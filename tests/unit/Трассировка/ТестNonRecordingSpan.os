#Использовать "../../.."
#Использовать asserts

// Тесты алиаса NonRecordingSpan (фабричный модуль ОтелNonRecordingSpan).
// По OTel Trace API §122 спан-заглушка называется NonRecordingSpan;
// в реализации сохранено старое имя ОтелНоопСпан, фабрика приводит API
// к терминологии спецификации.

&Тест
Процедура СоздатьБезКонтекстаДаетНевалидныйСпан() Экспорт
    // Когда
    Спан = ОтелNonRecordingSpan.Создать();

    // Тогда
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Ложь);
КонецПроцедуры

&Тест
Процедура СоздатьСКонтекстомСохраняетКонтекст() Экспорт
    // Дано
    ИдТрассировки = "0af7651916cd43dd8448eb211c80319c";
    ИдСпана = "b7ad6b7169203331";
    Контекст = Новый ОтелКонтекстСпана(ИдТрассировки, ИдСпана, 1);

    // Когда
    Спан = ОтелNonRecordingSpan.Создать(Контекст);

    // Тогда - non-recording, но контекст сохранён (passthrough)
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно(ИдТрассировки);
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Равно(ИдСпана);
КонецПроцедуры
