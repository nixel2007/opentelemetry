&Тест
Процедура ОбработкаСпана() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнстр = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнстр);
    Спан.Завершить();

    // Когда
    Процессор.Обработать(Спан);

    // Тогда
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);

    // Когда / Тогда - закрытие завершается без ошибки
    Процессор.Закрыть();
КонецПроцедуры

&Тест
Процедура ПриНачале() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнстр = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнстр);
    РодительскийКонтекст = Новый Соответствие();

    // Когда / Тогда - ПриНачале принимает спан и родительский контекст (no-op)
    Процессор.ПриНачале(Спан, РодительскийКонтекст);
КонецПроцедуры

&Тест
Процедура СброситьБуфер() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);

    // Когда / Тогда - сброс буфера не вызывает ошибку (нет буферизации)
    Процессор.СброситьБуфер();
КонецПроцедуры
