// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура ОбработкаСпана() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    Спан.Завершить();

    // Когда
    Процессор.Обработать(Спан);

    // Тогда
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);

    // Когда / Тогда — закрытие завершается без ошибки
    Процессор.Закрыть();
КонецПроцедуры

&Тест
Процедура ПриНачале() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");

    // Когда / Тогда — ПриНачале не вызывает ошибку (no-op)
    Процессор.ПриНачале(Спан);
КонецПроцедуры
