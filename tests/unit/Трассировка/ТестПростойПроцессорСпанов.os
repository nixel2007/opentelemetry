#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура ОбработкаСпана() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();

    // Когда
    Процессор.ПриЗавершении(Спан);

    // Тогда
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);

    // Когда
    Процессор.Закрыть();

    // Тогда - per spec: Shutdown MUST call Exporter.Shutdown
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Закрыть();
КонецПроцедуры

&Тест
Процедура ПриНачале() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    РодительскийКонтекст = Новый Соответствие();

    // Когда / Тогда - ПриНачале принимает спан и родительский контекст (no-op)
    Процессор.ПриНачале(Спан, РодительскийКонтекст);
КонецПроцедуры

&Тест
Процедура СброситьБуфер() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);

    // Когда
    Процессор.СброситьБуфер();

    // Тогда - per spec: ForceFlush MUST call Exporter.ForceFlush
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ПриЗавершенииПослеЗакрытия() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    Процессор.Закрыть();

    // Когда - вызов после Shutdown не должен падать
    Процессор.ПриЗавершении(Спан);

    // Тогда - вызов прошел без ошибок, спан проигнорирован
КонецПроцедуры
