#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура ОбработкаСпана() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();

    // Когда
    Процессор.ПриЗавершении(Спан);

    // Тогда
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);

    // Когда
    Процессор.Закрыть();

    // Тогда - per spec: Shutdown MUST call Exporter.Shutdown
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Закрыть();
КонецПроцедуры

&Тест
Процедура ПриНачале() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    РодительскийКонтекст = Новый Соответствие();

    // Когда / Тогда - ПриНачале принимает спан и родительский контекст (no-op)
    Процессор.ПриНачале(Спан, РодительскийКонтекст);
КонецПроцедуры

&Тест
Процедура СброситьБуфер() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);

    // Когда
    Процессор.СброситьБуфер();

    // Тогда - per spec: ForceFlush MUST call Exporter.ForceFlush
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ПриЗавершенииПослеЗакрытия() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    Процессор.Закрыть();

    // Когда - вызов после Shutdown не должен падать
    Процессор.ПриЗавершении(Спан);

    // Тогда - вызов прошел без ошибок, спан проигнорирован
КонецПроцедуры

&Тест
Процедура ПриЗавершенииНеСэмплированногоСпана() Экспорт
    // Дано - span with TraceFlags=0 (not sampled, RECORD_ONLY)
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    МокЭкспортер.Когда().Экспортировать(Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение(
        "ОтелПростойПроцессорСпанов не должен экспортировать несэмплированные спаны");
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    НеСэмплированныйСпан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования,
        Неопределено, "", Неопределено, Неопределено, Неопределено, Неопределено, 0);
    НеСэмплированныйСпан.Завершить();

    // Когда / Тогда - по спецификации SpanProcessor MUST NOT экспортировать non-sampled спаны
    Процессор.ПриЗавершении(НеСэмплированныйСпан);
КонецПроцедуры

&Тест
Процедура ПриЗавершенииБезЭкспортера() Экспорт
    // Дано - процессор без экспортера
    Процессор = Новый ОтелПростойПроцессорСпанов(Неопределено);
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();

    // Когда / Тогда - не бросает исключение
    Процессор.ПриЗавершении(Спан);
КонецПроцедуры

&Тест
Процедура СброситьБуферБезЭкспортера() Экспорт
    // Дано
    Процессор = Новый ОтелПростойПроцессорСпанов(Неопределено);

    // Когда
    Результат = Процессор.СброситьБуфер();

    // Тогда - возвращает успех
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
КонецПроцедуры

&Тест
Процедура ЗакрытьДважды() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);

    // Когда - закрываем дважды
    Результат1 = Процессор.Закрыть();
    Результат2 = Процессор.Закрыть();

    // Тогда - оба вызова возвращают успех, экспортер закрывается один раз
    Ожидаем.Что(Результат1.Успешно()).Равно(Истина);
    Ожидаем.Что(Результат2.Успешно()).Равно(Истина);
КонецПроцедуры

&Тест
Процедура ЗакрытьБезЭкспортера() Экспорт
    // Дано
    Процессор = Новый ОтелПростойПроцессорСпанов(Неопределено);

    // Когда
    Результат = Процессор.Закрыть();

    // Тогда - возвращает успех
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
КонецПроцедуры
