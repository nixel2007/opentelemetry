        Неопределено,
        Ложь,
        Неопределено
    );

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеОтбросить());
КонецПроцедуры

// --- Тесты SamplingResult: атрибуты и TraceState ---

&Тест
Процедура РезультатСодержитПустыеАтрибутыПоУмолчанию() Экспорт
    // Дано / Когда
    Результат = ОтелСэмплер.ДолженСэмплировать(ОтелСэмплер.ВсегдаВключен());

    // Тогда - встроенные семплеры не добавляют атрибутов
    Ожидаем.Что(Результат.Атрибуты()).ИмеетТип("ОтелАтрибуты");
    Ожидаем.Что(Результат.Атрибуты().Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура РезультатСодержитПустоеСостояниеТрассировки() Экспорт
    // Дано / Когда
    Результат = ОтелСэмплер.ДолженСэмплировать(ОтелСэмплер.ВсегдаВключен());

    // Тогда - встроенные семплеры не модифицируют TraceState
    Ожидаем.Что(Результат.СостояниеТрассировки()).ИмеетТип("ОтелСостояниеТрассировки");
    Ожидаем.Что(Результат.СостояниеТрассировки().Пустой()).Равно(Истина);
КонецПроцедуры

&Тест
Процедура РучноеСозданиеРезультатаСАтрибутами() Экспорт
    // Дано - пользовательский семплер может создать результат с атрибутами
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("sampling.priority", 1);

    // Когда
    Результат = Новый ОтелРезультатСэмплирования(
        ОтелСэмплер.РешениеЗаписатьИЭкспортировать(),
        Атрибуты
    );

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеЗаписатьИЭкспортировать());
    Ожидаем.Что(Результат.Атрибуты().Получить("sampling.priority")).Равно(1);
КонецПроцедуры

&Тест
Процедура РучноеСозданиеРезультатаСTraceState() Экспорт
    // Дано - пользовательский семплер может модифицировать TraceState
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();
    СостояниеТрассировки = СостояниеТрассировки.Установить("myvendor", "sampled");

    // Когда
    Результат = Новый ОтелРезультатСэмплирования(
        ОтелСэмплер.РешениеЗаписатьИЭкспортировать(),
        ,
        СостояниеТрассировки
    );

    // Тогда
    Ожидаем.Что(Результат.СостояниеТрассировки().Получить("myvendor")).Равно("sampled");
КонецПроцедуры

// --- Тесты сохранения rv (explicit randomness) в TraceState ---

&Тест
Процедура СэмплерСохраняетРодительскийTraceState() Экспорт
    // Дано - родительский TraceState содержит rv (explicit randomness)
    РодительскийТС = Новый ОтелСостояниеТрассировки();
    РодительскийТС = РодительскийТС.Установить("ot", "rv:abc123");
    РодительскийТС = РодительскийТС.Установить("vendor", "data");

    // Когда - ВсегдаВключен с родительским TraceState
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.ВсегдаВключен(), , , , , , , , РодительскийТС);

    // Тогда - rv и другие записи сохранены
    Ожидаем.Что(Результат.СостояниеТрассировки().Получить("ot")).Равно("rv:abc123");
    Ожидаем.Что(Результат.СостояниеТрассировки().Получить("vendor")).Равно("data");
КонецПроцедуры

&Тест
Процедура СэмплерВсегдаВыключенСохраняетРодительскийTraceState() Экспорт
    // Дано
    РодительскийТС = Новый ОтелСостояниеТрассировки();
    РодительскийТС = РодительскийТС.Установить("ot", "rv:abc123");

    // Когда - ВсегдаВыключен тоже должен сохранять TraceState
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.ВсегдаВыключен(), , , , , , , , РодительскийТС);

    // Тогда
    Ожидаем.Что(Результат.СостояниеТрассировки().Получить("ot")).Равно("rv:abc123");
КонецПроцедуры

&Тест
Процедура СэмплерПоДолеСохраняетRv() Экспорт
    // Дано
    РодительскийТС = Новый ОтелСостояниеТрассировки();
    РодительскийТС = РодительскийТС.Установить("ot", "rv:deadbeef");

    // Когда - ПоДолеТрассировок с долей 1.0 (всегда записывать)
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.ПоДолеТрассировок(), 1.0,
        "0af7651916cd43dd8448eb211c80319c", , , , , , РодительскийТС);

    // Тогда
    Ожидаем.Что(Результат.СостояниеТрассировки().Получить("ot")).Равно("rv:deadbeef");
КонецПроцедуры

&Тест
Процедура СэмплерБезРодительскогоTraceStateВозвращаетПустой() Экспорт
    // Дано / Когда - без родительского TraceState
    Результат = ОтелСэмплер.ДолженСэмплировать(ОтелСэмплер.ВсегдаВключен());

    // Тогда - пустой TraceState (обратная совместимость)
    Ожидаем.Что(Результат.СостояниеТрассировки().Пустой()).Равно(Истина);
КонецПроцедуры
