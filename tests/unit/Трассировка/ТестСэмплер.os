&Тест
Процедура ВсегдаВключен() Экспорт
    // Дано / Когда
    Результат = ОтелСэмплер.ДолженСэмплировать(ОтелСэмплер.ВсегдаВключен());

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеЗаписатьИЭкспортировать());
    Ожидаем.Что(Результат.Атрибуты().Количество()).Равно(0);
    Ожидаем.Что(Результат.СостояниеТрассировки().Пустой()).Равно(Истина);
КонецПроцедуры

