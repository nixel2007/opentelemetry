// --- Тесты СоздатьКонфигурациюНаОсновеРодителя ---

&Тест
Процедура КонфигурацияНаОсновеРодителяУмолчания() Экспорт
    // Дано / Когда - все по умолчанию
    Конфиг = ОтелСэмплер.СоздатьКонфигурациюНаОсновеРодителя();

    // Тогда
    Ожидаем.Что(Конфиг.Получить("УдаленныйРодительСэмплирован")).Равно(ОтелСэмплер.ВсегдаВключен());
    Ожидаем.Что(Конфиг.Получить("УдаленныйРодительНеСэмплирован")).Равно(ОтелСэмплер.ВсегдаВыключен());
    Ожидаем.Что(Конфиг.Получить("ЛокальныйРодительСэмплирован")).Равно(ОтелСэмплер.ВсегдаВключен());
    Ожидаем.Что(Конфиг.Получить("ЛокальныйРодительНеСэмплирован")).Равно(ОтелСэмплер.ВсегдаВыключен());
КонецПроцедуры

&Тест
Процедура КонфигурацияНаОсновеРодителяСПользовательскимиСтратегиями() Экспорт
    // Дано / Когда
    Конфиг = ОтелСэмплер.СоздатьКонфигурациюНаОсновеРодителя(
        ОтелСэмплер.ВсегдаВыключен(),
        ОтелСэмплер.ВсегдаВключен(),
        ОтелСэмплер.ПоДолеТрассировок(),
        ОтелСэмплер.ВсегдаВключен()
    );

    // Тогда
    Ожидаем.Что(Конфиг.Получить("УдаленныйРодительСэмплирован")).Равно(ОтелСэмплер.ВсегдаВыключен());
    Ожидаем.Что(Конфиг.Получить("УдаленныйРодительНеСэмплирован")).Равно(ОтелСэмплер.ВсегдаВключен());
    Ожидаем.Что(Конфиг.Получить("ЛокальныйРодительСэмплирован")).Равно(ОтелСэмплер.ПоДолеТрассировок());
    Ожидаем.Что(Конфиг.Получить("ЛокальныйРодительНеСэмплирован")).Равно(ОтелСэмплер.ВсегдаВключен());
КонецПроцедуры

// --- Тесты ParentBased с конфигурацией remote/local ---

&ПараметризованныйТест
&ИсточникЗначение("УдаленныйСэмплирован")
&ИсточникЗначение("УдаленныйНеСэмплирован")
&ИсточникЗначение("ЛокальныйСэмплирован")
&ИсточникЗначение("ЛокальныйНеСэмплирован")
Процедура НаОсновеРодителяСКонфигурацией(Сценарий) Экспорт
    // Дано
    Конфиг = ОтелСэмплер.СоздатьКонфигурациюНаОсновеРодителя();

    // BSLLS:IfElseIfEndsWithElse-off
    Если Сценарий = "УдаленныйСэмплирован" Тогда
        РодительСэмплирован = Истина;
        РодительУдаленный = Истина;
        ОжидаемоеРешение = ОтелСэмплер.РешениеЗаписатьИЭкспортировать();
    ИначеЕсли Сценарий = "УдаленныйНеСэмплирован" Тогда
        РодительСэмплирован = Ложь;
        РодительУдаленный = Истина;
        ОжидаемоеРешение = ОтелСэмплер.РешениеОтбросить();
    ИначеЕсли Сценарий = "ЛокальныйСэмплирован" Тогда
        РодительСэмплирован = Истина;
        РодительУдаленный = Ложь;
        ОжидаемоеРешение = ОтелСэмплер.РешениеЗаписатьИЭкспортировать();
    ИначеЕсли Сценарий = "ЛокальныйНеСэмплирован" Тогда
        РодительСэмплирован = Ложь;
        РодительУдаленный = Ложь;
        ОжидаемоеРешение = ОтелСэмплер.РешениеОтбросить();
    КонецЕсли;

    // Когда
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.НаОсновеРодителя(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        РодительСэмплирован,
        Истина,
        Неопределено,
        РодительУдаленный,
        Конфиг
    );

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОжидаемоеРешение);
КонецПроцедуры

&Тест
Процедура НаОсновеРодителяКонфигУдаленныйНеСэмплированныйВключен() Экспорт
    // Дано - переопределяем: удаленный не-семплированный -> ВсегдаВключен (вместо ВсегдаВыключен)
    Конфиг = ОтелСэмплер.СоздатьКонфигурациюНаОсновеРодителя(
        Неопределено,
        ОтелСэмплер.ВсегдаВключен(),
        Неопределено,
        Неопределено
    );

    // Когда - удаленный родитель НЕ семплирован
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.НаОсновеРодителя(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Ложь,
        Истина,
        Неопределено,
        Истина,
        Конфиг
    );

    // Тогда - конфигурация переопределила: записываем вместо отбрасывания
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

