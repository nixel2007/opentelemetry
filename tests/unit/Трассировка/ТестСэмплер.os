&Тест
Процедура ПоДолеТрассировокПоловина() Экспорт
    // Дано - доля 0.5
    // Используем traceId с малым хешем (00000001...) - попадет под 50%
    Сэмплер = ОтелСэмплер.ПоДолеТрассировок();
    ИдМалый = "0000000100000000ffffffffffffffff";
    ИдБольшой = "ffffffff00000000ffffffffffffffff";
    РезультатМалый = ОтелСэмплер.ДолженСэмплировать(Сэмплер, 0.5, ИдМалый);
    // Используем traceId с большим хешем (ffffffff...) - не попадет под 50%
    РезультатБольшой = ОтелСэмплер.ДолженСэмплировать(Сэмплер, 0.5, ИдБольшой);

    // Тогда
    Ожидаем.Что(РезультатМалый.Решение()).Равно(ОтелСэмплер.РешениеЗаписатьИЭкспортировать());
    Ожидаем.Что(РезультатБольшой.Решение()).Равно(ОтелСэмплер.РешениеОтбросить());
КонецПроцедуры

&Тест
Процедура ПоДолеТрассировокПустойТрейсИд() Экспорт
    // Дано / Когда - пустой traceId -> записать (fallback)
    Результат = ОтелСэмплер.ДолженСэмплировать(ОтелСэмплер.ПоДолеТрассировок(), 0.5, "");

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

