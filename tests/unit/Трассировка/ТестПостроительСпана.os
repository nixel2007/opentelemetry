&Тест
Процедура НачатьСпан() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Построитель = Трассировщик.ПостроительСпана("операция");

    // Когда
    Спан = Построитель.НачатьСпан();

    // Тогда
    Ожидаем.Что(Спан = Неопределено).Равно(Ложь);
    Ожидаем.Что(Спан.Имя()).Равно("операция");
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Истина);

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура УстановитьВидСпана() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда
    Спан = Трассировщик.ПостроительСпана("операция")
        .УстановитьВидСпана(ОтелВидСпана.Сервер())
        .НачатьСпан();

    // Тогда
    Ожидаем.Что(Спан.ВидСпана()).Равно(ОтелВидСпана.Сервер());

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура УстановитьАтрибут() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда
    Спан = Трассировщик.ПостроительСпана("операция")
        .УстановитьАтрибут("http.method", "POST")
        .НачатьСпан();

    // Тогда
    Ожидаем.Что(Спан.Атрибуты().Получить("http.method")).Равно("POST");

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ДобавитьЛинк() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    КонтекстЛинка = Новый ОтелКонтекстСпана("01020304050607080910111213141516", "0102030405060708");

    // Когда
    Спан = Трассировщик.ПостроительСпана("операция")
        .ДобавитьЛинк(КонтекстЛинка)
        .НачатьСпан();

    // Тогда
    Ожидаем.Что(Спан.Линки().Количество()).Равно(1);
    Ожидаем.Что(Спан.Линки()[0].Получить("КонтекстСпана")).Равно(КонтекстЛинка);

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура FluentAPI() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    КонтекстЛинка = Новый ОтелКонтекстСпана("01020304050607080910111213141516", "0102030405060708");

    // Когда - цепочка вызовов
    Спан = Трассировщик.ПостроительСпана("операция")
        .УстановитьВидСпана(ОтелВидСпана.Клиент())
        .УстановитьАтрибут("http.method", "GET")
        .УстановитьАтрибут("http.url", "https://example.com")
        .ДобавитьЛинк(КонтекстЛинка)
        .НачатьСпан();

    // Тогда - все параметры применены
    Ожидаем.Что(Спан.ВидСпана()).Равно(ОтелВидСпана.Клиент());
    Ожидаем.Что(Спан.Атрибуты().Получить("http.method")).Равно("GET");
    Ожидаем.Что(Спан.Атрибуты().Получить("http.url")).Равно("https://example.com");
    Ожидаем.Что(Спан.Линки().Количество()).Равно(1);

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура УстановитьРодителя() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Родитель = Трассировщик.НачатьСпан("родитель");

    // Когда - создаем спан с явным родителем через построитель
    Спан = Трассировщик.ПостроительСпана("дочерний")
        .УстановитьРодителя(Родитель)
        .НачатьСпан();

    // Тогда - спан наследует trace ID от родителя
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно(Родитель.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Спан.ИдРодительскогоСпана()).Равно(Родитель.КонтекстСпана().ИдСпана());

    // Очистка
    Спан.Завершить();
    Родитель.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура БезРодителя() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Родитель = Трассировщик.НачатьСпан("родитель");
    ОтелКонтекст.СделатьСпанТекущим(Родитель);

    // Когда - создаем корневой спан через БезРодителя
    Спан = Трассировщик.ПостроительСпана("корневой")
        .БезРодителя()
        .НачатьСпан();

    // Тогда - новый trace ID, нет родителя
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки() <> Родитель.КонтекстСпана().ИдТрассировки()).Равно(Истина);
    Ожидаем.Что(Спан.ИдРодительскогоСпана()).Равно("");

    // Очистка
    Спан.Завершить();
    Родитель.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура УстановитьВремяНачала() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда - указываем конкретное время начала
    Спан = Трассировщик.ПостроительСпана("операция")
        .УстановитьВремяНачала("1000000000000")
        .НачатьСпан();

    // Тогда - время начала переопределено
    Ожидаем.Что(Спан.ВремяНачала()).Равно("1000000000000");

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры
