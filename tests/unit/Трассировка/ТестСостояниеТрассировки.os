&Тест
Процедура ТекучийAPIУдаления() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("a=1,b=2");

    // Когда
    Результат = СостояниеТрассировки.Удалить("a");

    // Тогда - immutable: результат - новый объект
    Ожидаем.Что(Результат.Количество()).Равно(1);
    // Оригинал не изменён
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(2);
КонецПроцедуры

// --- #2: error handling через logos ---

Функция СоздатьТестовыйАппендер()
    Текст = "Перем События Экспорт;
    |Процедура ВывестиСобытие(Событие) Экспорт
    |    События.Добавить(Событие);
    |КонецПроцедуры
    |Процедура Закрыть() Экспорт
    |КонецПроцедуры
    |Процедура УстановитьСвойство(Имя, Значение) Экспорт
    |КонецПроцедуры
    |События = Новый Массив();";
    Возврат ЗагрузитьСценарийИзСтроки(Текст);
КонецФункции

Функция ЕстьПредупреждение(Аппендер)
    Для Каждого Событие Из Аппендер.События Цикл
        Если Событие.ПолучитьУровень() = УровниЛога.Предупреждение Тогда
            Возврат Истина;
        КонецЕсли;
    КонецЦикла;
    Возврат Ложь;
КонецФункции

&Тест
Процедура УстановитьНевалидныйКлючЗаписываетПредупреждение() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки();

    // Когда
    Состояние.Установить("ABC", "value");

    // Тогда
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

&Тест
Процедура УстановитьНевалидноеЗначениеЗаписываетПредупреждение() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки();

    // Когда
    Состояние.Установить("key", "val,ue");

    // Тогда
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

&Тест
Процедура УдалитьНевалидныйКлючЗаписываетПредупреждение() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки("valid=ok");

    // Когда - Удалить с невалидным ключом
    Результат = Состояние.Удалить("UPPER");

    // Тогда
    Ожидаем.Что(Результат.Количество()).Равно(1);
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

// --- #7: ot-namespace ПолучитьОтелПодКлюч / УстановитьОтелПодКлюч ---

&Тест
Процедура ПолучитьОтелПодКлючRv() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки("ot=rv:abc123;th:ff");

    // Когда / Тогда
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("rv")).Равно("abc123");
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("th")).Равно("ff");
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("nope")).Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура ПолучитьОтелПодКлючОтсутствуетOt() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки("vendor=x");

    // Когда / Тогда
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("rv")).Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючДобавляетЗначение() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки();

    // Когда
    Новое = Состояние.УстановитьОтелПодКлюч("rv", "abc123");

    // Тогда
    Ожидаем.Что(Новое.ПолучитьОтелПодКлюч("rv")).Равно("abc123");
    Ожидаем.Что(Новое.Получить("ot")).Равно("rv:abc123");
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючRvНеПерезаписываетБезПринудительно() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки("ot=rv:abc123");

    // Когда - попытка перезаписи без Принудительно
    Результат = Состояние.УстановитьОтелПодКлюч("rv", "other");

    // Тогда - rv не изменён + лог
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("rv")).Равно("abc123");
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючRvПринудительноПерезаписывает() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки("ot=rv:abc123");

    // Когда
    Результат = Состояние.УстановитьОтелПодКлюч("rv", "deadbeef", Истина);

    // Тогда
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("rv")).Равно("deadbeef");
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючThОбновляетДругойПодКлюч() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки("ot=rv:abc");

    // Когда
    Результат = Состояние.УстановитьОтелПодКлюч("th", "ff");

    // Тогда
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("rv")).Равно("abc");
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("th")).Равно("ff");
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючНевалидноеИмяОтклоняется() Экспорт
    // Дано - uppercase RV невалиден
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки();

    // Когда
    Результат = Состояние.УстановитьОтелПодКлюч("RV", "abc");

    // Тогда
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("RV")).Равно(Неопределено);
    Ожидаем.Что(Результат.Получить("ot")).Равно(Неопределено);
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

&Тест
Процедура ПарсингЗаписываетОтбросЧлена33() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);

    Части = Новый Массив();
    Для Сч = 1 По 33 Цикл
        Части.Добавить("k" + Сч + "=v" + Сч);
    КонецЦикла;
    Строка = СтрСоединить(Части, ",");

    // Когда
    Состояние = Новый ОтелСостояниеТрассировки(Строка);

    // Тогда
    Ожидаем.Что(Состояние.Количество()).Равно(32);
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

// --- Level 2: tracestate с ot=rv:abc;th:ff (spec example) ---

&Тест
Процедура ПолучитьОтелПодКлючRvИzOtRvAbcThFf() Экспорт
    // Дано - пример из спецификации W3C Level 2: ot=rv:abc;th:ff
    Состояние = Новый ОтелСостояниеТрассировки("ot=rv:abc;th:ff");

    // Когда / Тогда
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("rv")).Равно("abc");
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("th")).Равно("ff");

КонецПроцедуры

// --- Level 2: uppercase sub-key в ot= игнорируется ---

&Тест
Процедура ПолучитьОтелПодКлючИгнорируетUppercaseПодКлюч() Экспорт
    // Дано - ot хранит uppercase sub-key (через прямой конструктор/парсинг строки)
    // tracestate "ot=RV:abc": key=ot (valid), value=RV:abc (valid printable ASCII)
    // но sub-key "RV" является невалидным (uppercase), должен быть проигнорирован
    Состояние = Новый ОтелСостояниеТрассировки("ot=RV:abc");

    // Когда - запрашиваем как uppercase, так и lowercase вариант
    РезультатUppercase = Состояние.ПолучитьОтелПодКлюч("RV");
    РезультатLowercase = Состояние.ПолучитьОтелПодКлюч("rv");

    // Тогда - uppercase sub-key отброшен при парсинге sub-keys
    Ожидаем.Что(РезультатUppercase).Равно(Неопределено);
    // lowercase "rv" тоже Неопределено т.к. сохранён был "RV" (невалидный)
    Ожидаем.Что(РезультатLowercase).Равно(Неопределено);

КонецПроцедуры

// --- Граничные случаи длины ключа ---

Функция ПовторитьСтроку(Строка, Кол)
    Результат = "";
    Для Сч = 1 По Кол Цикл
        Результат = Результат + Строка;
    КонецЦикла;
    Возврат Результат;
КонецФункции

&Тест
Процедура КлючМаксДлина256Принимается() Экспорт
    // Дано - ключ ровно 256 символов (максимально допустимый)
    // Ключ должен начинаться с буквы a-z, остальные a-z0-9_-*/
    КлючМакс = "a" + ПовторитьСтроку("b", 255); // 256 символов

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();
    НовоеСостояние = СостояниеТрассировки.Установить(КлючМакс, "val");

    // Тогда - ключ принят
    Ожидаем.Что(НовоеСостояние.Получить(КлючМакс)).Равно("val");

КонецПроцедуры

&Тест
Процедура КлючДлиннее256Отклоняется() Экспорт
    // Дано - ключ 257 символов (превышает максимум)
    КлючСлишкомДлинный = "a" + ПовторитьСтроку("b", 256); // 257 символов

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();
    НовоеСостояние = СостояниеТрассировки.Установить(КлючСлишкомДлинный, "val");

    // Тогда - ключ отклонён
    Ожидаем.Что(НовоеСостояние.Пустой()).ЕстьИстина();

КонецПроцедуры

// --- Граничные случаи мультитенантных ключей ---

&Тест
Процедура МультитенантныйКлючСДвойнойСобакойОтклоняется() Экспорт
    // Дано - ключ содержит вторую @ (запрещено)
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();

    // Когда
    НовоеСостояние = СостояниеТрассировки.Установить("a@b@c", "val");

    // Тогда - ключ с двойным @ отклонён
    Ожидаем.Что(НовоеСостояние.Пустой()).ЕстьИстина();

КонецПроцедуры

&Тест
Процедура МультитенантныйКлючПустаяСистемнаяЧастьОтклоняется() Экспорт
    // Дано - нет системной части (пустая строка после @)
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();

    // Когда
    НовоеСостояние = СостояниеТрассировки.Установить("tenant@", "val");

    // Тогда - ключ с пустой системной частью отклонён
    Ожидаем.Что(НовоеСостояние.Пустой()).ЕстьИстина();

КонецПроцедуры

&Тест
Процедура МультитенантныйКлючСлишкомДлиннаяСистемнаяЧастьОтклоняется() Экспорт
    // Дано - системная часть > 14 символов
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();
    СистемнаяЧастьДлинная = "a" + ПовторитьСтроку("b", 14); // 15 символов

    // Когда
    НовоеСостояние = СостояниеТрассировки.Установить("tenant@" + СистемнаяЧастьДлинная, "val");

    // Тогда - ключ отклонён
    Ожидаем.Что(НовоеСостояние.Пустой()).ЕстьИстина();

КонецПроцедуры

&Тест
Процедура МультитенантныйКлючПустаяТенантЧастьОтклоняется() Экспорт
    // Дано - нет тенант-части (пустая строка перед @)
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();

    // Когда
    НовоеСостояние = СостояниеТрассировки.Установить("@vendor", "val");

    // Тогда - ключ с пустой тенант-частью отклонён
    Ожидаем.Что(НовоеСостояние.Пустой()).ЕстьИстина();

КонецПроцедуры

&Тест
Процедура МультитенантныйКлючСистемаНачинаетсяСЦифрыОтклоняется() Экспорт
    // Дано - системная часть начинается с цифры (должна начинаться с a-z)
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();

    // Когда
    НовоеСостояние = СостояниеТрассировки.Установить("tenant@1vendor", "val");

    // Тогда - ключ отклонён (система должна начинаться с a-z)
    Ожидаем.Что(НовоеСостояние.Пустой()).ЕстьИстина();

КонецПроцедуры

&Тест
Процедура МультитенантныйКлючТенантСНедопустимымСимволомОтклоняется() Экспорт
    // Дано - тенант содержит недопустимый символ (заглавная буква в середине)
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();

    // Когда
    НовоеСостояние = СостояниеТрассировки.Установить("ten!ant@vendor", "val");

    // Тогда - ключ отклонён
    Ожидаем.Что(НовоеСостояние.Пустой()).ЕстьИстина();

КонецПроцедуры

// --- Граничные случаи парсинга ---

&Тест
Процедура РазборСлишкомДлиннойСтрокиДаётПустоеСостояние() Экспорт
    // Дано - строка > 512 символов (должна быть отброшена полностью)
    ДлиннаяСтрока = ПовторитьСтроку("a=1,", 150); // >512 символов

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки(ДлиннаяСтрока);

    // Тогда - всё состояние пустое
    Ожидаем.Что(СостояниеТрассировки.Пустой()).ЕстьИстина();

КонецПроцедуры

&Тест
Процедура РазборЧленаБезРавноПропускается() Экспорт
    // Дано - один из членов не содержит знака =
    // Тогда он должен быть пропущен, остальные сохранены

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("valid=ok,noequalssign,also=good");

    // Тогда
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(2);
    Ожидаем.Что(СостояниеТрассировки.Получить("valid")).Равно("ok");
    Ожидаем.Что(СостояниеТрассировки.Получить("also")).Равно("good");

КонецПроцедуры

&Тест
Процедура РазборДублирующегосяКлючаОставляетПервый() Экспорт
    // Дано - дублирующийся ключ в tracestate (W3C: дубликаты отбрасываются)

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("vendor=first,vendor=second");

    // Тогда - только первое значение сохранено
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(1);
    Ожидаем.Что(СостояниеТрассировки.Получить("vendor")).Равно("first");

КонецПроцедуры

&Тест
Процедура НесколькоVendorEntriesВСтроку() Экспорт
    // Дано - несколько vendor entries

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("a=1,b=2,c=3,ot=rv:abc");

    // Тогда - все entries сохранены и сериализованы в правильном порядке
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(4);
    Ожидаем.Что(СостояниеТрассировки.ВСтроку()).Равно("a=1,b=2,c=3,ot=rv:abc");

КонецПроцедуры

&Тест
Процедура ПолучитьОтелПодКлючПарБезДвоеточия() Экспорт
    // Дано - пара в ot-значении без двоеточия (невалидная пара, должна быть пропущена)
    // "ot=invalid;rv:abc" - "invalid" не имеет ":", "rv:abc" валидна
    Состояние = Новый ОтелСостояниеТрассировки("ot=invalid;rv:abc");

    // Когда
    Результат = Состояние.ПолучитьОтелПодКлюч("rv");

    // Тогда - rv найден (пара без двоеточия просто пропускается)
    Ожидаем.Что(Результат).Равно("abc");

КонецПроцедуры

&Тест
Процедура УдалениеНесуществующегоКлючаВозвращаетИммутабельнуюКопию() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("rojo=abc,congo=def");

    // Когда - удаление несуществующего ключа
    НовоеСостояние = СостояниеТрассировки.Удалить("unknown");

    // Тогда - возвращена новая копия с теми же данными
    Ожидаем.Что(НовоеСостояние.Количество()).Равно(2);
    Ожидаем.Что(НовоеСостояние.Получить("rojo")).Равно("abc");
    Ожидаем.Что(НовоеСостояние.Получить("congo")).Равно("def");

КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючОбновляетСуществующийПодКлюч() Экспорт
    // Дано - состояние уже содержит ot с подключем th
    Состояние = Новый ОтелСостояниеТрассировки("ot=th:old");

    // Когда - обновляем th
    НовоеСостояние = Состояние.УстановитьОтелПодКлюч("th", "new");

    // Тогда - th обновлён, rv не добавлен
    Ожидаем.Что(НовоеСостояние.ПолучитьОтелПодКлюч("th")).Равно("new");
    Ожидаем.Что(НовоеСостояние.Получить("ot")).Равно("th:new");

КонецПроцедуры
