// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать logos

&Тест
Процедура ПустоеСостояниеТрассировки() Экспорт
    // Дано

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();

    // Тогда
    Ожидаем.Что(СостояниеТрассировки.Пустой()).ЕстьИстина();
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(0);
    Ожидаем.Что(СостояниеТрассировки.ВСтроку()).Равно("");
КонецПроцедуры

&Тест
Процедура ПарсингВалиднойСтроки() Экспорт
    // Дано
    Строка = "rojo=00f067aa0ba902b7,congo=t61rcWkgMzE";

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки(Строка);

    // Тогда
    Ожидаем.Что(СостояниеТрассировки.Пустой()).ЕстьЛожь();
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(2);
    Ожидаем.Что(СостояниеТрассировки.Получить("rojo")).Равно("00f067aa0ba902b7");
    Ожидаем.Что(СостояниеТрассировки.Получить("congo")).Равно("t61rcWkgMzE");
КонецПроцедуры

&Тест
Процедура ПарсингПустойСтроки() Экспорт
    // Дано

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("");

    // Тогда
    Ожидаем.Что(СостояниеТрассировки.Пустой()).ЕстьИстина();
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура ПолучитьОтсутствующийКлюч() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("rojo=abc");

    // Когда
    Результат = СостояниеТрассировки.Получить("unknown");

    // Тогда
    Ожидаем.Что(Результат).Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура УстановитьНовыйКлюч() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("rojo=abc");

    // Когда
    НовоеСостояние = СостояниеТрассировки.Установить("congo", "def");

    // Тогда
    Ожидаем.Что(НовоеСостояние.Количество()).Равно(2);
    Ожидаем.Что(НовоеСостояние.Получить("congo")).Равно("def");
    // Новый ключ добавляется в начало по W3C spec
    Ожидаем.Что(НовоеСостояние.ВСтроку()).Равно("congo=def,rojo=abc");
    // Оригинал не изменён (immutability)
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(1);
КонецПроцедуры

&Тест
Процедура УстановитьСуществующийКлючПеремещаетВНачало() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("rojo=abc,congo=def");

    // Когда
    НовоеСостояние = СостояниеТрассировки.Установить("congo", "xyz");

    // Тогда
    Ожидаем.Что(НовоеСостояние.Количество()).Равно(2);
    Ожидаем.Что(НовоеСостояние.Получить("congo")).Равно("xyz");
    // Обновленный ключ перемещается в начало
    Ожидаем.Что(НовоеСостояние.ВСтроку()).Равно("congo=xyz,rojo=abc");
КонецПроцедуры

&Тест
Процедура УдалениеКлюча() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("rojo=abc,congo=def");

    // Когда
    НовоеСостояние = СостояниеТрассировки.Удалить("rojo");

    // Тогда
    Ожидаем.Что(НовоеСостояние.Количество()).Равно(1);
    Ожидаем.Что(НовоеСостояние.Получить("rojo")).Равно(Неопределено);
    Ожидаем.Что(НовоеСостояние.ВСтроку()).Равно("congo=def");
    // Оригинал не изменён
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(2);
КонецПроцедуры

&Тест
Процедура УдалениеНесуществующегоКлюча() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("rojo=abc");

    // Когда
    СостояниеТрассировки.Удалить("unknown");

    // Тогда
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(1);
    Ожидаем.Что(СостояниеТрассировки.Получить("rojo")).Равно("abc");
КонецПроцедуры

&Тест
Процедура Максимум32Записи() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();
    Для Сч = 1 По 32 Цикл
        СостояниеТрассировки = СостояниеТрассировки.Установить("k" + Сч, "v" + Сч);
    КонецЦикла;

    // Когда - 33-я запись
    НовоеСостояние = СостояниеТрассировки.Установить("overflow", "nope");

    // Тогда - при переполнении возвращается ЭтотОбъект без изменений
    Ожидаем.Что(НовоеСостояние.Количество()).Равно(32);
    Ожидаем.Что(НовоеСостояние.Получить("overflow")).Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура ОбновлениеСуществующегоКлючаПриМаксимуме() Экспорт
    // Дано - заполнено 32 записи
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();
    Для Сч = 1 По 32 Цикл
        СостояниеТрассировки = СостояниеТрассировки.Установить("k" + Сч, "v" + Сч);
    КонецЦикла;

    // Когда - обновление существующего ключа
    НовоеСостояние = СостояниеТрассировки.Установить("k1", "updated");

    // Тогда - обновление работает, количество не изменилось
    Ожидаем.Что(НовоеСостояние.Количество()).Равно(32);
    Ожидаем.Что(НовоеСостояние.Получить("k1")).Равно("updated");
КонецПроцедуры

&Тест
Процедура ВалидныеПростыеКлючи() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();

    // Когда / Тогда - буквы, цифры, допустимые спецсимволы
    СостояниеТрассировки = СостояниеТрассировки.Установить("abc", "val1");
    Ожидаем.Что(СостояниеТрассировки.Получить("abc")).Равно("val1");

    СостояниеТрассировки = СостояниеТрассировки.Установить("a-b_c*d/e", "val2");
    Ожидаем.Что(СостояниеТрассировки.Получить("a-b_c*d/e")).Равно("val2");

    СостояниеТрассировки = СостояниеТрассировки.Установить("a0123456789", "val3");
    Ожидаем.Что(СостояниеТрассировки.Получить("a0123456789")).Равно("val3");
КонецПроцедуры

