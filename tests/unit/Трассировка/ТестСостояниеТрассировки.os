&Тест
Процедура ТекучийAPIУдаления() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("a=1,b=2");

    // Когда
    Результат = СостояниеТрассировки.Удалить("a");

    // Тогда - immutable: результат - новый объект
    Ожидаем.Что(Результат.Количество()).Равно(1);
    // Оригинал не изменён
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(2);
КонецПроцедуры

// --- #2: error handling через logos ---

Функция СоздатьТестовыйАппендер()
    Текст = "Перем События Экспорт;
    |Процедура ВывестиСобытие(Событие) Экспорт
    |    События.Добавить(Событие);
    |КонецПроцедуры
    |Процедура Закрыть() Экспорт
    |КонецПроцедуры
    |Процедура УстановитьСвойство(Имя, Значение) Экспорт
    |КонецПроцедуры
    |События = Новый Массив();";
    Возврат ЗагрузитьСценарийИзСтроки(Текст);
КонецФункции

Функция ЕстьПредупреждение(Аппендер)
    Для Каждого Событие Из Аппендер.События Цикл
        Если Событие.ПолучитьУровень() = УровниЛога.Предупреждение Тогда
            Возврат Истина;
        КонецЕсли;
    КонецЦикла;
    Возврат Ложь;
КонецФункции

&Тест
Процедура УстановитьНевалидныйКлючЛогируетПредупреждение() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки();

    // Когда
    Состояние.Установить("ABC", "value");

    // Тогда
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

&Тест
Процедура УстановитьНевалидноеЗначениеЛогируетПредупреждение() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки();

    // Когда
    Состояние.Установить("key", "val,ue");

    // Тогда
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

&Тест
Процедура УдалитьНевалидныйКлючЛогируетПредупреждение() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки("valid=ok");

    // Когда - Удалить с невалидным ключом
    Результат = Состояние.Удалить("UPPER");

    // Тогда
    Ожидаем.Что(Результат.Количество()).Равно(1);
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

// --- #7: ot-namespace ПолучитьОтелПодКлюч / УстановитьОтелПодКлюч ---

&Тест
Процедура ПолучитьОтелПодКлючRv() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки("ot=rv:abc123;th:ff");

    // Когда / Тогда
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("rv")).Равно("abc123");
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("th")).Равно("ff");
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("nope")).Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура ПолучитьОтелПодКлючОтсутствуетOt() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки("vendor=x");

    // Когда / Тогда
    Ожидаем.Что(Состояние.ПолучитьОтелПодКлюч("rv")).Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючДобавляетЗначение() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки();

    // Когда
    Новое = Состояние.УстановитьОтелПодКлюч("rv", "abc123");

    // Тогда
    Ожидаем.Что(Новое.ПолучитьОтелПодКлюч("rv")).Равно("abc123");
    Ожидаем.Что(Новое.Получить("ot")).Равно("rv:abc123");
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючRvНеПерезаписываетБезПринудительно() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки("ot=rv:abc123");

    // Когда - попытка перезаписи без Принудительно
    Результат = Состояние.УстановитьОтелПодКлюч("rv", "other");

    // Тогда - rv не изменён + лог
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("rv")).Равно("abc123");
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючRvПринудительноПерезаписывает() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки("ot=rv:abc123");

    // Когда
    Результат = Состояние.УстановитьОтелПодКлюч("rv", "deadbeef", Истина);

    // Тогда
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("rv")).Равно("deadbeef");
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючThОбновляетДругойПодКлюч() Экспорт
    // Дано
    Состояние = Новый ОтелСостояниеТрассировки("ot=rv:abc");

    // Когда
    Результат = Состояние.УстановитьОтелПодКлюч("th", "ff");

    // Тогда
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("rv")).Равно("abc");
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("th")).Равно("ff");
КонецПроцедуры

&Тест
Процедура УстановитьОтелПодКлючНевалидноеИмяОтклоняется() Экспорт
    // Дано - uppercase RV невалиден
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);
    Состояние = Новый ОтелСостояниеТрассировки();

    // Когда
    Результат = Состояние.УстановитьОтелПодКлюч("RV", "abc");

    // Тогда
    Ожидаем.Что(Результат.ПолучитьОтелПодКлюч("RV")).Равно(Неопределено);
    Ожидаем.Что(Результат.Получить("ot")).Равно(Неопределено);
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры

&Тест
Процедура ПарсингЛогируетОтбросЧлена33() Экспорт
    // Дано
    Аппендер = СоздатьТестовыйАппендер();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.tracestate");
    Лог.ДобавитьСпособВывода(Аппендер, УровниЛога.Предупреждение);

    Части = Новый Массив();
    Для Сч = 1 По 33 Цикл
        Части.Добавить("k" + Сч + "=v" + Сч);
    КонецЦикла;
    Строка = СтрСоединить(Части, ",");

    // Когда
    Состояние = Новый ОтелСостояниеТрассировки(Строка);

    // Тогда
    Ожидаем.Что(Состояние.Количество()).Равно(32);
    Ожидаем.Что(ЕстьПредупреждение(Аппендер)).ЕстьИстина();

    Лог.УдалитьСпособВывода(Аппендер);
    Логирование.ЗакрытьЛог(Лог);
КонецПроцедуры
