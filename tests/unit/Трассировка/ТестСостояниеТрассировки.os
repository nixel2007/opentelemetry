&Тест
Процедура ПарсингСПробелами() Экспорт
    // Дано - W3C допускает OWS (optional whitespace) вокруг запятой

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("rojo=abc , congo=def");

    // Тогда
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(2);
    Ожидаем.Что(СостояниеТрассировки.Получить("rojo")).Равно("abc");
    Ожидаем.Что(СостояниеТрассировки.Получить("congo")).Равно("def");
КонецПроцедуры

&Тест
Процедура ПарсингНевалидныхЧленовПропускает() Экспорт
    // Дано - невалидные members пропускаются, валидные сохраняются

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("valid=ok,INVALID=bad,also=good");

    // Тогда
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(2);
    Ожидаем.Что(СостояниеТрассировки.Получить("valid")).Равно("ok");
    Ожидаем.Что(СостояниеТрассировки.Получить("also")).Равно("good");
    Ожидаем.Что(СостояниеТрассировки.Получить("INVALID")).Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура ТекучийAPI() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();

    // Когда - immutable chaining: каждый вызов возвращает новый объект
    Результат = СостояниеТрассировки.Установить("a", "1").Установить("b", "2");

    // Тогда - результат - новый объект с обоими значениями
    Ожидаем.Что(Результат.Количество()).Равно(2);
    // Оригинал не изменён
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура СериализацияСохраняетПорядок() Экспорт
    // Дано

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("a=1,b=2,c=3");

    // Тогда
    Ожидаем.Что(СостояниеТрассировки.ВСтроку()).Равно("a=1,b=2,c=3");
КонецПроцедуры

&Тест
Процедура ЗначениеСПробеламиВнутри() Экспорт
    // Дано - пробелы внутри значения допустимы по W3C

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();
    НовоеСостояние = СостояниеТрассировки.Установить("key", "hello world");

    // Тогда
    Ожидаем.Что(НовоеСостояние.Получить("key")).Равно("hello world");
КонецПроцедуры

&Тест
Процедура НевалидноеЗначениеСВедущимПробелом() Экспорт
    // Дано

    // Когда
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки();
    СостояниеТрассировки.Установить("key", " leading");

    // Тогда
    Ожидаем.Что(СостояниеТрассировки.Пустой()).ЕстьИстина();
КонецПроцедуры

&Тест
Процедура ТекучийAPIУдаления() Экспорт
    // Дано
    СостояниеТрассировки = Новый ОтелСостояниеТрассировки("a=1,b=2");

    // Когда
    Результат = СостояниеТрассировки.Удалить("a");

    // Тогда - immutable: результат - новый объект
    Ожидаем.Что(Результат.Количество()).Равно(1);
    // Оригинал не изменён
    Ожидаем.Что(СостояниеТрассировки.Количество()).Равно(2);
КонецПроцедуры
