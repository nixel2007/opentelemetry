&Тест
Процедура СозданиеСобытия() Экспорт
    // Дано / Когда
    Событие = Новый ОтелСобытиеСпана("тестовое-событие");

    // Тогда
    Ожидаем.Что(Событие.Имя()).Равно("тестовое-событие");
    Ожидаем.Что(Событие.Время() = Неопределено).Равно(Ложь);
    Ожидаем.Что(СтрДлина(Событие.Время()) > 0).Равно(Истина);
КонецПроцедуры

&Тест
Процедура СобытиеСАтрибутами() Экспорт
    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("ключ1", "значение1");
    Атрибуты.Установить("ключ2", 42);

    // Когда
    Событие = Новый ОтелСобытиеСпана("событие", Атрибуты);

    // Тогда
    Ожидаем.Что(Событие.Атрибуты().Получить("ключ1")).Равно("значение1");
    Ожидаем.Что(Событие.Атрибуты().Получить("ключ2")).Равно(42);
    Ожидаем.Что(Событие.Атрибуты().Количество()).Равно(2);
КонецПроцедуры

&Тест
Процедура СобытиеБезАтрибутов() Экспорт
    // Дано / Когда
    Событие = Новый ОтелСобытиеСпана("простое-событие");

    // Тогда - атрибуты создаются пустыми автоматически
    Ожидаем.Что(Событие.Атрибуты() = Неопределено).Равно(Ложь);
    Ожидаем.Что(Событие.Атрибуты().Количество()).Равно(0);
КонецПроцедуры
