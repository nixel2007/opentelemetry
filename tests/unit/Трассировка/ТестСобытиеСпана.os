&Тест
Процедура СозданиеСобытия() Экспорт
    // Дано / Когда
    Событие = Новый ОтелСобытиеСпана("тестовое-событие");

    // Тогда
    Ожидаем.Что(Событие.Имя()).Равно("тестовое-событие");
    Ожидаем.Что(Событие.Время() = Неопределено).Равно(Ложь);
    Ожидаем.Что(СтрДлина(Событие.Время()) > 0).Равно(Истина);
КонецПроцедуры

&Тест
Процедура СобытиеСАтрибутами() Экспорт
    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("ключ1", "значение1");
    Атрибуты.Установить("ключ2", 42);

    // Когда
    Событие = Новый ОтелСобытиеСпана("событие", Атрибуты);

    // Тогда
    Ожидаем.Что(Событие.Атрибуты().Получить("ключ1")).Равно("значение1");
    Ожидаем.Что(Событие.Атрибуты().Получить("ключ2")).Равно(42);
    Ожидаем.Что(Событие.Атрибуты().Количество()).Равно(2);
КонецПроцедуры

&Тест
Процедура СобытиеБезАтрибутов() Экспорт
    // Дано / Когда
    Событие = Новый ОтелСобытиеСпана("простое-событие");

    // Тогда - атрибуты создаются пустыми автоматически
    Ожидаем.Что(Событие.Атрибуты() = Неопределено).Равно(Ложь);
    Ожидаем.Что(Событие.Атрибуты().Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура СобытиеСАтрибутамиВПределахЛимита() Экспорт
    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("ключ1", "значение1");
    Атрибуты.Установить("ключ2", "значение2");

    // Когда - лимит 5, атрибутов 2
    Событие = Новый ОтелСобытиеСпана("событие", Атрибуты, , 5);

    // Тогда - все атрибуты на месте, ничего не отброшено
    Ожидаем.Что(Событие.Атрибуты().Количество()).Равно(2);
    Ожидаем.Что(Событие.КоличествоОтброшенныхАтрибутов()).Равно(0);
КонецПроцедуры

&Тест
Процедура СобытиеСАтрибутамиПревышающимиЛимит() Экспорт
    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("ключ1", "значение1");
    Атрибуты.Установить("ключ2", "значение2");
    Атрибуты.Установить("ключ3", "значение3");
    Атрибуты.Установить("ключ4", "значение4");
    Атрибуты.Установить("ключ5", "значение5");

    // Когда - лимит 2, атрибутов 5
    Событие = Новый ОтелСобытиеСпана("событие", Атрибуты, , 2);

    // Тогда - атрибуты обрезаны до 2, 3 отброшены
    Ожидаем.Что(Событие.Атрибуты().Количество()).Равно(2);
    Ожидаем.Что(Событие.КоличествоОтброшенныхАтрибутов()).Равно(3);
КонецПроцедуры

&Тест
Процедура СобытиеБезЛимитаАтрибутов() Экспорт
    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("ключ1", "значение1");
    Атрибуты.Установить("ключ2", "значение2");
    Атрибуты.Установить("ключ3", "значение3");

    // Когда - лимит 0 (без ограничения)
    Событие = Новый ОтелСобытиеСпана("событие", Атрибуты, , 0);

    // Тогда - все атрибуты на месте
    Ожидаем.Что(Событие.Атрибуты().Количество()).Равно(3);
    Ожидаем.Что(Событие.КоличествоОтброшенныхАтрибутов()).Равно(0);
КонецПроцедуры

&Тест
Процедура СобытиеOtlpСодержитDroppedAttributesCount() Экспорт
    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("ключ1", "значение1");
    Атрибуты.Установить("ключ2", "значение2");
    Атрибуты.Установить("ключ3", "значение3");

    // Когда - лимит 1
    Событие = Новый ОтелСобытиеСпана("событие", Атрибуты, , 1);
    Otlp = Событие.ВСоответствиеOtlp();

    // Тогда
    Ожидаем.Что(Otlp.Получить("droppedAttributesCount")).Равно(2);
    Ожидаем.Что(Otlp.Получить("attributes").Количество()).Равно(1);
КонецПроцедуры
