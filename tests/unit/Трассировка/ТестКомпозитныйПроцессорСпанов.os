&Тест
Процедура ДелегацияПриНачале() Экспорт
    // Дано
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда
    РодительскийКонтекст = Новый Соответствие();
    Композитный.ПриНачале(Спан, РодительскийКонтекст);

    // Тогда - оба процессора вызваны с контекстом
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().ПриНачале(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение());
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().ПриНачале(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ДелегацияОбработки() Экспорт
    // Дано
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();

    // Когда
    Композитный.ПриЗавершении(Спан);

    // Тогда - оба процессора вызваны
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().ПриЗавершении(Матчеры.ЛюбоеЗначение());
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().ПриЗавершении(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ДелегацияЗакрытия() Экспорт
    // Дано
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    // Когда
    Композитный.Закрыть();

    // Тогда - оба процессора закрыты
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().Закрыть(Матчеры.ЛюбоеЗначение());
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().Закрыть(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ДелегацияСбросаБуфера() Экспорт
    // Дано
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    // Когда
    Композитный.СброситьБуфер();

    // Тогда - оба процессора сбросили буфер
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ОшибкаПервогоПроцессораНеПрерываетВторой() Экспорт

    // Дано - первый процессор бросает исключение
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор1.Когда().ПриЗавершении(Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("тестовая ошибка");
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Спан = Новый ОтелСпан("test-span", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();

    // Когда - обрабатываем спан (первый процессор бросит ошибку)
    Композитный.ПриЗавершении(Спан);

    // Тогда - второй процессор всё равно получил вызов
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().ПриЗавершении(Матчеры.ЛюбоеЗначение());

КонецПроцедуры

