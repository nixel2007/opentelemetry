    // Тогда - оба процессора получили вызов ПередЗавершением
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().ПередЗавершением(Матчеры.ЛюбоеЗначение());
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().ПередЗавершением(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура СброситьБуферОшибкаПроцессора() Экспорт
    // Дано - процессор возвращает Ошибка()
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(ОтелРезультатыЭкспорта.Ошибка());
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор);
    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    // Когда
    Результат = Композитный.СброситьБуфер();

    // Тогда - итоговый результат Ошибка
    Ожидаем.Что(Результат.Успешно()).ЭтоЛожь();
КонецПроцедуры

&Тест
Процедура СброситьБуферИсключениеПроцессора() Экспорт
    // Дано - процессор бросает исключение в СброситьБуфер
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("тест: ошибка сброса буфера");
