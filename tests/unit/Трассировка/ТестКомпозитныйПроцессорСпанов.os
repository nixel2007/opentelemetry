    Ожидаем.Что(Результат.Успешно()).ЭтоЛожь();
КонецПроцедуры

&Тест
Процедура ЗакрытьТаймаут() Экспорт
    // Дано - первый процессор медленный (больше таймаута)
    ПутьКФикстуре = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures", "МедленныйПроцессорСпанов.os");
    МедленныйПроцессор = ЗагрузитьСценарий(ПутьКФикстуре);
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МедленныйПроцессор);
    Процессоры.Добавить(МокПроцессор2);
    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    // Когда - закрываем с таймаутом 1мс
    Результат = Композитный.Закрыть(1);

    // Тогда - превышен таймаут
    Ожидаем.Что(Результат.Успешно()).ЭтоЛожь();
КонецПроцедуры

&Тест
Процедура ЗакрытьИсключениеПроцессора() Экспорт
    // Дано - процессор бросает исключение в Закрыть
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор.Когда().Закрыть(Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("тест: ошибка закрытия");
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор);
    Процессоры.Добавить(МокПроцессор2);
    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    // Когда - не должно выбрасывать исключение
    Результат = Композитный.Закрыть();

    // Тогда - успешно (исключение поглощено), второй процессор тоже вызван
    Ожидаем.Что(Результат.Успешно()).ЭтоИстина();
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().Закрыть(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура СброситьБуферТаймаут() Экспорт
    // Дано - первый процессор медленный при СброситьБуфер (200мс), таймаут 1мс
    ПутьКФикстуре = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures", "МедленныйПроцессорСпановСброс.os");
    МедленныйПроцессор = ЗагрузитьСценарий(ПутьКФикстуре);
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МедленныйПроцессор);
    Процессоры.Добавить(МокПроцессор2);
    Композитный = Новый ОтелКомпозитныйПроцессорСпанов(Процессоры);

    // Когда - сбрасываем буфер с таймаутом 1мс (медленный процессор занимает 200мс)
    Результат = Композитный.СброситьБуфер(1);

    // Тогда - превышен таймаут
    Ожидаем.Что(Результат.Успешно()).ЭтоЛожь();
КонецПроцедуры
