// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts

// Тесты модуля ОтелСпаны - публичных операций над интерфейсом Span.
// По OTel Trace API §«Wrapping a SpanContext in a Span» рекомендуется
// предоставлять функцию, возвращающую Span, а не публичный класс.
// Аналог Java io.opentelemetry.api.trace.Span.wrap()/getInvalid().

&Тест
Процедура ОбернутьБезКонтекстаДаетНевалидныйСпан() Экспорт
    // Когда
    Спан = ОтелСпаны.Обернуть();

    // Тогда
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНезаписывающийСпан"));
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Ложь);
КонецПроцедуры

&Тест
Процедура ОбернутьСКонтекстомСохраняетКонтекст() Экспорт
    // Дано
    ИдТрассировки = "0af7651916cd43dd8448eb211c80319c";
    ИдСпана = "b7ad6b7169203331";
    Контекст = Новый ОтелКонтекстСпана(ИдТрассировки, ИдСпана, 1);

    // Когда
    Спан = ОтелСпаны.Обернуть(Контекст);

    // Тогда - non-recording, но контекст сохранён (passthrough)
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНезаписывающийСпан"));
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно(ИдТрассировки);
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Равно(ИдСпана);
КонецПроцедуры

&Тест
Процедура ОбернутьСНевалиднымКонтекстомДаетНевалидныйСпан() Экспорт
    // Дано
    НевалидныйКонтекст = Новый ОтелКонтекстСпана(
        "00000000000000000000000000000000", "0000000000000000", 0);

    // Когда
    Спан = ОтелСпаны.Обернуть(НевалидныйКонтекст);

    // Тогда - возвращается синглтон Невалидный()
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Ложь);
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);
КонецПроцедуры

&Тест
Процедура НевалидныйВозвращаетСинглтон() Экспорт
    // Когда
    Спан1 = ОтелСпаны.Невалидный();
    Спан2 = ОтелСпаны.Невалидный();

    // Тогда
    Ожидаем.Что(Спан1).Равно(Спан2);
    Ожидаем.Что(Спан1.КонтекстСпана().Валиден()).Равно(Ложь);
    Ожидаем.Что(Спан1.ЗаписьАктивна()).Равно(Ложь);
КонецПроцедуры
