// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура НачатьСпан() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Трассировщик = Новый ОтелТрассировщик("библ", "1.0", Ресурс);

    // Когда
    Спан = Трассировщик.НачатьСпан("операция");

    // Тогда
    Ожидаем.Что(Спан = Неопределено).Равно(Ложь);
    Ожидаем.Что(Спан.Имя()).Равно("операция");
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Истина);

    // Очистка
    Спан.Завершить();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НачатьКорневойСпан() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Трассировщик = Новый ОтелТрассировщик("библ", "1.0", Ресурс);

    // Когда
    Спан = Трассировщик.НачатьКорневойСпан("корневая-операция");

    // Тогда
    Ожидаем.Что(Спан = Неопределено).Равно(Ложь);
    Ожидаем.Что(Спан.ИдРодительскогоСпана()).Равно("");

    // Очистка
    Спан.Завершить();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НачатьДочернийСпан() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Трассировщик = Новый ОтелТрассировщик("библ", "1.0", Ресурс);
    Родитель = Трассировщик.НачатьКорневойСпан("родитель");

    // Когда
    Дочерний = Трассировщик.НачатьДочернийСпан("дочерний", Родитель);

    // Тогда
    Ожидаем.Что(Дочерний = Неопределено).Равно(Ложь);
    Ожидаем.Что(Дочерний.КонтекстСпана().ИдТрассировки()).Равно(Родитель.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Дочерний.ИдРодительскогоСпана()).Равно(Родитель.КонтекстСпана().ИдСпана());
    Ожидаем.Что(Дочерний.КонтекстСпана().ИдСпана() = Родитель.КонтекстСпана().ИдСпана()).Равно(Ложь);

    // Очистка
    Дочерний.Завершить();
    Родитель.Завершить();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура СемплированиеВсегдаВыключено() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Трассировщик = Новый ОтелТрассировщик("библ", "1.0", Ресурс, , ОтелСемплер.ВсегдаВыключен());

    // Когда
    Спан = Трассировщик.НачатьСпан("отброшенный");

    // Тогда - семплер возвращает NoOp-спан вместо Неопределено
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);

    // Все методы вызываются без ошибок
    Спан.УстановитьАтрибут("ключ", "значение");
    Спан.Завершить();

    // Очистка
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПостроительСпана() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Трассировщик = Новый ОтелТрассировщик("библ", "1.0", Ресурс);

    // Когда
    Построитель = Трассировщик.ПостроительСпана("операция");

    // Тогда
    Ожидаем.Что(Построитель = Неопределено).Равно(Ложь);

    // Дополнительно - построитель создаёт спан
    Спан = Построитель.НачатьСпан();
    Ожидаем.Что(Спан = Неопределено).Равно(Ложь);
    Ожидаем.Что(Спан.Имя()).Равно("операция");

    // Очистка
    Спан.Завершить();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПередачаЛимитов() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксАтрибутов(2);
    Ресурс = Новый ОтелРесурс(Истина);
    Трассировщик = Новый ОтелТрассировщик("библ", "1.0", Ресурс, , , , , , , Лимиты);

    // Когда
    Спан = Трассировщик.НачатьКорневойСпан("операция");
    Спан.УстановитьАтрибут("к1", "з1");
    Спан.УстановитьАтрибут("к2", "з2");
    Спан.УстановитьАтрибут("к3", "з3");

    // Тогда - лимиты действуют
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(2);

    // Очистка
    Спан.Завершить();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ИмяИВерсияБиблиотеки() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Трассировщик = Новый ОтелТрассировщик("моя-библиотека", "2.5.0", Ресурс);

    // Когда
    Спан = Трассировщик.НачатьКорневойСпан("операция");

    // Тогда
    Ожидаем.Что(Спан.ИмяБиблиотеки()).Равно("моя-библиотека");
    Ожидаем.Что(Спан.ВерсияБиблиотеки()).Равно("2.5.0");

    // Очистка
    Спан.Завершить();
    ОтелКонтекст.Очистить();
КонецПроцедуры
