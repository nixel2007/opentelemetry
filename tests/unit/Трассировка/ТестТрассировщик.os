#Использовать moskito

&Тест
Процедура НачатьСпан() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда
    Спан = Трассировщик.НачатьСпан("операция");

    // Тогда
    Ожидаем.Что(Спан = Неопределено).Равно(Ложь);
    Ожидаем.Что(Спан.Имя()).Равно("операция");
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Истина);

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НачатьКорневойСпан() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда
    Спан = Трассировщик.НачатьКорневойСпан("корневая-операция");

    // Тогда
    Ожидаем.Что(Спан = Неопределено).Равно(Ложь);
    Ожидаем.Что(Спан.ИдРодительскогоСпана()).Равно("");

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НачатьДочернийСпан() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Родитель = Трассировщик.НачатьКорневойСпан("родитель");

    // Когда
    Дочерний = Трассировщик.НачатьДочернийСпан("дочерний", Родитель);

    // Тогда
    Ожидаем.Что(Дочерний = Неопределено).Равно(Ложь);
    Ожидаем.Что(Дочерний.КонтекстСпана().ИдТрассировки()).Равно(Родитель.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Дочерний.ИдРодительскогоСпана()).Равно(Родитель.КонтекстСпана().ИдСпана());
    Ожидаем.Что(Дочерний.КонтекстСпана().ИдСпана() = Родитель.КонтекстСпана().ИдСпана()).Равно(Ложь);

    // Очистка
    Дочерний.Завершить();
    Родитель.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура СэмплированиеВсегдаВыключено() Экспорт
    // Дано - сэмплер настраивается через Provider
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, , ОтелСэмплер.ВсегдаВыключен());
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда
    Спан = Трассировщик.НачатьСпан("отброшенный");

    // Тогда - семплер возвращает NoOp-спан
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);

    // Все методы вызываются без ошибок
    Спан.УстановитьАтрибут("ключ", "значение");
    Спан.Завершить();

    // Очистка
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПостроительСпана() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда
    Построитель = Трассировщик.ПостроительСпана("операция");

    // Тогда
    Ожидаем.Что(Построитель = Неопределено).Равно(Ложь);

    // Дополнительно - построитель создаёт спан
    Спан = Построитель.НачатьСпан();
    Ожидаем.Что(Спан = Неопределено).Равно(Ложь);
    Ожидаем.Что(Спан.Имя()).Равно("операция");

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПередачаЛимитов() Экспорт
    // Дано - лимиты настраиваются через Provider
    ОтелКонтекст.Очистить();
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксАтрибутов(2);
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, , , , , Лимиты);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда
    Спан = Трассировщик.НачатьКорневойСпан("операция");
    Спан.УстановитьАтрибут("к1", "з1");
    Спан.УстановитьАтрибут("к2", "з2");
    Спан.УстановитьАтрибут("к3", "з3");

    // Тогда - лимиты действуют
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(2);

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ИмяИВерсияБиблиотеки() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("моя-библиотека", "2.5.0");

    // Когда
    Спан = Трассировщик.НачатьКорневойСпан("операция");

    // Тогда
    Ожидаем.Что(Спан.ОбластьИнструментирования().Имя()).Равно("моя-библиотека");
    Ожидаем.Что(Спан.ОбластьИнструментирования().Версия()).Равно("2.5.0");

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура СпанНаследуетTraceIdОтТекущегоКонтекста() Экспорт
    // Дано - есть активный спан в контексте
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Родитель = Трассировщик.НачатьСпан("родитель");
    ОтелКонтекст.СделатьСпанТекущим(Родитель);

    // Когда - НачатьСпан находит родителя из контекста
    Дочерний = Трассировщик.НачатьСпан("дочерний");

    // Тогда - наследует trace ID, parent ID установлен
    Ожидаем.Что(Дочерний.КонтекстСпана().ИдТрассировки()).Равно(Родитель.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Дочерний.ИдРодительскогоСпана()).Равно(Родитель.КонтекстСпана().ИдСпана());

    // Очистка
    Дочерний.Завершить();
    Родитель.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ТрассировщикСАтрибутамиОбластиИАдресСхемы() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    АтрибутыОбласти = Новый ОтелАтрибуты();
    АтрибутыОбласти.Установить("scope.attr", "val");
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0", АтрибутыОбласти, "https://schema.test");

    // Когда - создаем все типы спанов
    Обычный = Трассировщик.НачатьСпан("обычный");
    Корневой = Трассировщик.НачатьКорневойСпан("корневой");
    Дочерний = Трассировщик.НачатьДочернийСпан("дочерний", Обычный);

    // Тогда - scope данные доступны через спаны
    Ожидаем.Что(Обычный.ОбластьИнструментирования().Атрибуты()).Равно(АтрибутыОбласти);
    Ожидаем.Что(Обычный.ОбластьИнструментирования().АдресСхемы()).Равно("https://schema.test");

    // Очистка
    Дочерний.Завершить();
    Корневой.Завершить();
    Обычный.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НачатьСпанСRemoteParentSampled() Экспорт
    // Дано - remote parent пришел через W3C propagator (NoopSpan с sampled флагом)
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Имитируем то, что делает W3C propagator: создает NoopSpan с trace flags = 1 (sampled)
    ФлагСэмплирован = 1;
    РодительскийИдТрассировки = "0af7651916cd43dd8448eb211c80319c";
    РодительскийИдСпана = "b7ad6b7169203331";
    КонтекстУдаленногоСпана = Новый ОтелКонтекстСпана(РодительскийИдТрассировки, РодительскийИдСпана, ФлагСэмплирован);
    УдаленныйСпан = Новый ОтелНоопСпан(КонтекстУдаленногоСпана);
    ОтелКонтекст.СделатьСпанТекущим(УдаленныйСпан);

    // Когда - создаем спан при наличии remote parent
    Спан = Трассировщик.НачатьСпан("серверная-операция", ОтелВидСпана.Сервер());

    // Тогда - должен быть реальный спан (не NoopSpan), т.к. remote parent sampled
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелСпан"));
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Истина);
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно(РодительскийИдТрассировки);
    Ожидаем.Что(Спан.ИдРодительскогоСпана()).Равно(РодительскийИдСпана);

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НачатьДочернийСпанОтNoopСпанаСSampledФлагом() Экспорт
    // Дано - remote parent (NoopSpan с sampled флагом)
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    ФлагСэмплирован = 1;
    РодительскийИдТрассировки = "0af7651916cd43dd8448eb211c80319c";
    РодительскийИдСпана = "b7ad6b7169203331";
    КонтекстУдаленногоСпана = Новый ОтелКонтекстСпана(РодительскийИдТрассировки, РодительскийИдСпана, ФлагСэмплирован);
    УдаленныйСпан = Новый ОтелНоопСпан(КонтекстУдаленногоСпана);

    // Когда - НачатьДочернийСпан с NoopSpan как родителем
    Спан = Трассировщик.НачатьДочернийСпан("серверная-операция", УдаленныйСпан);

    // Тогда - должен быть реальный спан
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелСпан"));
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно(РодительскийИдТрассировки);
    Ожидаем.Что(Спан.ИдРодительскогоСпана()).Равно(РодительскийИдСпана);

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НачатьДочернийСпанОтКонтекстаСпана() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Родитель = Трассировщик.НачатьСпан("родитель");

    // Когда - передаем ОтелКонтекстСпана вместо ОтелСпан
    КонтекстРодителя = Родитель.КонтекстСпана();
    Дочерний = Трассировщик.НачатьДочернийСпан("дочерний", КонтекстРодителя);

    // Тогда
    Ожидаем.Что(Дочерний.КонтекстСпана().ИдТрассировки()).Равно(КонтекстРодителя.ИдТрассировки());

    // Очистка
    Дочерний.Завершить();
    Родитель.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НоопСпанБезРодителяИмеетНевалидныйКонтекст() Экспорт
    // Дано - сэмплер всегда выключен, родителя в контексте нет
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, , ОтелСэмплер.ВсегдаВыключен());
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда - нет родителя в контексте
    Спан = Трассировщик.НачатьСпан("отброшенный");

    // Тогда - per spec #6: SpanID и TraceID генерируются ДО сэмплирования,
    // независимо от decision; при DROP возвращается NoOp-спан с валидными IDs,
    // но unsampled TraceFlags.
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Истина);
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Не_().Равно("00000000000000000000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Не_().Равно("0000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().ФлагиТрассировки()).Равно(0);

    // Очистка
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НоопСпанСРодителемИмеетКонтекстРодителя() Экспорт
    // Дано - сэмплер всегда выключен, но есть родитель в контексте
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ПровайдерОсновной = Новый ОтелПровайдерТрассировки(Ресурс);
    ТрассировщикОсновной = ПровайдерОсновной.ПолучитьТрассировщик("библ", "1.0");
    Родитель = ТрассировщикОсновной.НачатьКорневойСпан("родитель");
    ОтелКонтекст.СделатьСпанТекущим(Родитель);

    ПровайдерВыкл = Новый ОтелПровайдерТрассировки(Ресурс, , ОтелСэмплер.ВсегдаВыключен());
    ТрассировщикВыкл = ПровайдерВыкл.ПолучитьТрассировщик("библ", "1.0");

    // Когда - семплер отбрасывает, но родитель есть
    Спан = ТрассировщикВыкл.НачатьСпан("отброшенный");

    // Тогда - per spec #6: TraceID наследуется от родителя, SpanID генерируется новый
    // независимо от sampling decision; TraceFlags unsampled.
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно(Родитель.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Не_().Равно(Родитель.КонтекстСпана().ИдСпана());
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Не_().Равно("0000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().ФлагиТрассировки()).Равно(0);

    // Очистка
    Родитель.Завершить();
    ПровайдерОсновной.Закрыть();
    ПровайдерВыкл.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НоопКорневойСпанИмеетНевалидныйКонтекст() Экспорт
    // Дано - корневой спан всегда без родителя
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
