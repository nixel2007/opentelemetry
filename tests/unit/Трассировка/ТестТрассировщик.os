    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Когда
    Спан = Трассировщик.НачатьКорневойСпан("корневой");

    // Тогда - per spec #6: TraceID и SpanID генерируются ДО сэмплирования
    // независимо от sampling decision; TraceFlags unsampled.
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Истина);
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Не_().Равно("00000000000000000000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Не_().Равно("0000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().ФлагиТрассировки()).Равно(0);

    // Очистка
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НоопДочернийСпанИмеетКонтекстРодителя() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ПровайдерОсновной = Новый ОтелПровайдерТрассировки(Ресурс);
    ТрассировщикОсновной = ПровайдерОсновной.ПолучитьТрассировщик("библ", "1.0");
    Родитель = ТрассировщикОсновной.НачатьКорневойСпан("родитель");

    ПровайдерВыкл = Новый ОтелПровайдерТрассировки(Ресурс, , ОтелСэмплер.ВсегдаВыключен());
    ТрассировщикВыкл = ПровайдерВыкл.ПолучитьТрассировщик("библ", "1.0");

    // Когда - НачатьДочернийСпан с DROP семплером
    Спан = ТрассировщикВыкл.НачатьДочернийСпан("дочерний", Родитель);

    // Тогда - per spec #6: TraceID от родителя, SpanID новый независимо от sampling.
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно(Родитель.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Не_().Равно(Родитель.КонтекстСпана().ИдСпана());
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Не_().Равно("0000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().ФлагиТрассировки()).Равно(0);

    // Очистка
    Родитель.Завершить();
    ПровайдерОсновной.Закрыть();
    ПровайдерВыкл.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ВключенВозвращаетИстинуЕслиКонфигурацияВключена() Экспорт

    // Дано - провайдер без процессоров, конфигурация enabled=true
    Конфигурация = Новый ОтелКонфигурацияТрассировщика(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест");
    Провайдер = Новый ОтелПровайдерТрассировки();

    // Когда
    Трассировщик = Новый ОтелТрассировщик(Область, Провайдер, Конфигурация);
    Результат = Трассировщик.Включен();

    // Тогда - по спеке: enabled=true - Включен() возвращает Истина
    Ожидаем.Что(Результат).Равно(Истина);

КонецПроцедуры

// Сценарий 1 матрицы: API-режим без родителя -> all-zero контекст,
// IdGenerator не вызывается. Trace API §122.
&Тест
Процедура APIРежимБезРодителяВозвращаетAllZeroКонтекст() Экспорт
    ОтелКонтекст.Очистить();
    ОтелГлобальный.Сбросить();

    Трассировщик = ОтелГлобальный.ПолучитьТрассировщик("библ", "1.0");
    Спан = Трассировщик.НачатьСпан("op");

    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно("00000000000000000000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Равно("0000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Ложь);
    Ожидаем.Что(Спан.КонтекстСпана().ФлагиТрассировки()).Равно(0);

    ОтелКонтекст.Очистить();
КонецПроцедуры

// Сценарий 2 матрицы: API-режим с родителем -> non-recording с контекстом
// родителя as-is. Trace API §120.
&Тест
Процедура APIРежимСРодителемНаследуетКонтекстРодителя() Экспорт
    ОтелКонтекст.Очистить();
    ОтелГлобальный.Сбросить();

    РодКонтекст = Новый ОтелКонтекстСпана(
        "11111111111111111111111111111111", "2222222222222222", 1, , Истина);
    РодСпан = Новый ОтелНоопСпан(РодКонтекст);
    ОтелКонтекст.СделатьСпанТекущим(РодСпан);

    Трассировщик = ОтелГлобальный.ПолучитьТрассировщик("библ", "1.0");
    Спан = Трассировщик.НачатьСпан("child");

    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНоопСпан"));
    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно("11111111111111111111111111111111");
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Равно("2222222222222222");
    Ожидаем.Что(Спан.КонтекстСпана().ФлагиТрассировки()).Равно(1);
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Истина);

    ОтелКонтекст.Очистить();
КонецПроцедуры

// Сценарий 3 матрицы: Disabled Tracer без родителя -> all-zero.
&Тест
Процедура DisabledTracerБезРодителяВозвращаетAllZero() Экспорт
    ОтелКонтекст.Очистить();
    Провайдер = Новый ОтелПровайдерТрассировки();
    Конфигурация = Новый ОтелКонфигурацияТрассировщика(Ложь);
    Область = Новый ОтелОбластьИнструментирования("тест");
    Трассировщик = Новый ОтелТрассировщик(Область, Провайдер, Конфигурация);

    Спан = Трассировщик.НачатьСпан("op");

    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно("00000000000000000000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Равно("0000000000000000");
    Ожидаем.Что(Спан.КонтекстСпана().Валиден()).Равно(Ложь);

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

// Сценарий 4 матрицы: Disabled Tracer с родителем -> контекст родителя.
&Тест
Процедура DisabledTracerСРодителемНаследуетКонтекстРодителя() Экспорт
    ОтелКонтекст.Очистить();
    Провайдер = Новый ОтелПровайдерТрассировки();
    Конфигурация = Новый ОтелКонфигурацияТрассировщика(Ложь);
    Область = Новый ОтелОбластьИнструментирования("тест");
    Трассировщик = Новый ОтелТрассировщик(Область, Провайдер, Конфигурация);

    РодКонтекст = Новый ОтелКонтекстСпана(
        "33333333333333333333333333333333", "4444444444444444", 1, , Истина);
    РодСпан = Новый ОтелНоопСпан(РодКонтекст);
    ОтелКонтекст.СделатьСпанТекущим(РодСпан);

    Спан = Трассировщик.НачатьСпан("child");

    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно("33333333333333333333333333333333");
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Равно("4444444444444444");

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

// Сценарий 4b матрицы: Disabled Tracer + явно переданный родительский контекст
// в НачатьДочернийСпан -> контекст наследуется.
&Тест
Процедура DisabledTracerНачатьДочернийСпанНаследуетКонтекстРодителя() Экспорт
    ОтелКонтекст.Очистить();
    Провайдер = Новый ОтелПровайдерТрассировки();
    Конфигурация = Новый ОтелКонфигурацияТрассировщика(Ложь);
    Область = Новый ОтелОбластьИнструментирования("тест");
    Трассировщик = Новый ОтелТрассировщик(Область, Провайдер, Конфигурация);

    РодКонтекст = Новый ОтелКонтекстСпана(
        "77777777777777777777777777777777", "8888888888888888", 1, , Истина);

    Спан = Трассировщик.НачатьДочернийСпан("child", РодКонтекст);

    Ожидаем.Что(Спан.КонтекстСпана().ИдТрассировки()).Равно("77777777777777777777777777777777");
    Ожидаем.Что(Спан.КонтекстСпана().ИдСпана()).Равно("8888888888888888");

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

// Сценарий 3b матрицы: Disabled Tracer + НачатьКорневойСпан без родителя -> all-zero.
&Тест
Процедура DisabledTracerНачатьКорневойСпанВозвращаетAllZero() Экспорт
    ОтелКонтекст.Очистить();
