// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts

&Тест
Процедура ГеттерыВозвращаютДефолты() Экспорт

    // Дано
    Спан = Новый ОтелНоопСпан();

    // Тогда
    Ожидаем.Что(Спан.Имя()).Равно("");
    Ожидаем.Что(Спан.ИдРодительскогоСпана()).Равно("");
    Ожидаем.Что(Спан.ВидСпана()).Равно(ОтелВидСпана.Внутренний());
    Ожидаем.Что(Спан.ВремяНачала()).Равно("0");
    Ожидаем.Что(Спан.ВремяОкончания()).Равно("0");
    Ожидаем.Что(Спан.ИмяБиблиотеки()).Равно("");
    Ожидаем.Что(Спан.ВерсияБиблиотеки()).Равно("");
    Ожидаем.Что(Спан.SchemaUrl()).Равно("");
    Ожидаем.Что(Спан.КодСтатуса()).Равно(ОтелКодСтатуса.НеУстановлен());
    Ожидаем.Что(Спан.СообщениеСтатуса()).Равно("");
    Ожидаем.Что(Спан.Завершен()).Равно(Истина);
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);
    Ожидаем.Что(Спан.Ресурс()).Равно(Неопределено);
    Ожидаем.Что(Спан.АтрибутыСкоупа()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура КонтекстСпанаНевалидный() Экспорт

    // Дано
    Спан = Новый ОтелНоопСпан();

    // Когда
    Контекст = Спан.КонтекстСпана();

    // Тогда
    Ожидаем.Что(Контекст.ИдТрассировки()).Равно("00000000000000000000000000000000");
    Ожидаем.Что(Контекст.ИдСпана()).Равно("0000000000000000");

КонецПроцедуры

&Тест
Процедура КоллекцииПустые() Экспорт

    // Дано
    Спан = Новый ОтелНоопСпан();

    // Тогда
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(0);
    Ожидаем.Что(Спан.События().Количество()).Равно(0);
    Ожидаем.Что(Спан.Линки().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура МутаторыНеПадают() Экспорт

    // Дано
    Спан = Новый ОтелНоопСпан();

    // Когда - все мутаторы вызываются без ошибок
    Спан.ИзменитьИмя("новое-имя");
    Спан.УстановитьАтрибут("ключ", "значение");
    Спан.ДобавитьСобытие("событие");
    Спан.ДобавитьЛинк(Спан.КонтекстСпана());
    Спан.СделатьТекущим();
    Спан.УстановитьАтрибутыСкоупа(Новый ОтелАтрибуты());
    Спан.УстановитьSchemaUrl("http://example.com");
    Спан.УстановитьСтатус(ОтелКодСтатуса.Ок());
    Спан.ПереопределитьВремяНачала("12345");
    Спан.Завершить();

    // Тогда - ничего не изменилось
    Ожидаем.Что(Спан.Имя()).Равно("");
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура МутаторыВозвращаютЭтотОбъект() Экспорт

    // Дано
    Спан = Новый ОтелНоопСпан();

    // Когда / Тогда - fluent API работает
    Результат = Спан
        .ИзменитьИмя("имя")
        .УстановитьАтрибут("к", "з")
        .ДобавитьСобытие("событие")
        .ДобавитьЛинк(Спан.КонтекстСпана())
        .УстановитьСтатус(ОтелКодСтатуса.Ок());

    Ожидаем.Что(Результат).Равно(Спан);

КонецПроцедуры
