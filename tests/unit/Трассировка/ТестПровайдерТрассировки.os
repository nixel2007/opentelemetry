&Тест
Процедура КонфигураторВыбрасываетИсключение() Экспорт

    // Дано - провайдер с уже зарегистрированным трассировщиком
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("тест");

    // Когда - устанавливаем конфигуратор, бросающий исключение
    Конфигуратор = Новый Действие(ЭтотОбъект, "КонфигураторВыбрасывающийИсключение");
    Провайдер.ОбновитьКонфигуратор(Конфигуратор);

    // Тогда - исключение поглощено, трассировщик по-прежнему включён (конфигурация = Неопределено)
    Ожидаем.Что(Трассировщик.Включен()).Равно(Истина);
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура НекорректныйИдТрассировки() Экспорт

    // Дано - генератор, возвращающий IdТрассировки неправильной длины
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    НекорректныйГенератор = ЗагрузитьСценарий(
        ОбъединитьПути(КаталогФикстур, "НекорректныйГенераторИд.os"));
    Построитель = Новый ОтелПостроительПровайдераТрассировки();
    Построитель.УстановитьГенераторИд(НекорректныйГенератор);
    Провайдер = Построитель.Построить();
    Трассировщик = Провайдер.ПолучитьТрассировщик("тест");

    // Когда / Тогда - НачатьСпан выбрасывает исключение из-за некорректного IdТрассировки
    ВыброшеноИсключение = Ложь;
    Попытка
        Трассировщик.НачатьСпан("тест-спан");
    Исключение
        ВыброшеноИсключение = Истина;
    КонецПопытки;
    Ожидаем.Что(ВыброшеноИсключение).ЭтоИстина();
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура НекорректныйИдСпана() Экспорт

    // Дано - генератор возвращает правильный ID трассировки, но некорректный ID спана
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    НекорректныйГенератор = ЗагрузитьСценарий(
