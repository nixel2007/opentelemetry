&Тест
Процедура ЗакрытьСОшибкойПроцессора() Экспорт
    // Дано - процессор бросает при Закрыть()
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор.Когда().Закрыть(Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("ошибка процессора");
    Провайдер = Новый ОтелПровайдерТрассировки(Новый ОтелРесурс(Истина), МокПроцессор);

    // Когда
    Результат = Провайдер.Закрыть();

    // Тогда - возвращает ошибку
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
КонецПроцедуры

