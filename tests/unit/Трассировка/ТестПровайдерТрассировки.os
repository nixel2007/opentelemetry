&Тест
Процедура СгенерироватьИдПользовательскимГенератором() Экспорт
    // Дано - пользовательский генератор
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    Генератор = ЗагрузитьСценарий(ОбъединитьПути(КаталогФикстур, "ПользовательскийГенераторИд.os"));
    Построитель = Новый ОтелПостроительПровайдераТрассировки();
    Построитель.УстановитьГенераторИд(Генератор);
    Провайдер = Построитель.Построить();
    Трассировщик = Провайдер.ПолучитьТрассировщик("тест");

    // Когда - создаем спан, который вызывает генератор
    Спан = Трассировщик.НачатьСпан("тест-операция");

    // Тогда - ID трассировки сгенерирован пользовательским генератором (32 hex символа)
    Ожидаем.Что(СтрДлина(Спан.КонтекстСпана().ИдТрассировки())).Равно(32);

    Спан.Завершить();
    Провайдер.Закрыть();
КонецПроцедуры

