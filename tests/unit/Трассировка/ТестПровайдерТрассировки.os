&Тест
Процедура ПолучитьТрассировщик() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("моя-библиотека", "1.0");

    // Тогда - трассировщик создаёт спаны
    Спан = Трассировщик.НачатьКорневойСпан("операция");
    Ожидаем.Что(Спан = Неопределено).Равно(Ложь);
    Ожидаем.Что(Спан.Имя()).Равно("операция");

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура КэшированиеТрассировщиков() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);

    // Когда
    Трассировщик1 = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Трассировщик2 = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Тогда - один и тот же объект
    Ожидаем.Что(Трассировщик1).Равно(Трассировщик2);

    // Очистка
    Провайдер.Закрыть();
КонецПроцедуры

&Тест
Процедура ПередачаРесурса() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Ресурс.Атрибуты().Установить("service.name", "тест-сервис");
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Спан = Трассировщик.НачатьКорневойСпан("операция");

    // Тогда - ресурс передан спану
    Ожидаем.Что(Спан.Ресурс()).Равно(Ресурс);
    Ожидаем.Что(Спан.Ресурс().Атрибуты().Получить("service.name")).Равно("тест-сервис");

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПередачаЛимитов() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксАтрибутов(2);
    Построитель = Новый ОтелПостроительПровайдераТрассировки();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Построитель
        .УстановитьРесурс(Ресурс)
        .УстановитьЛимитыСпана(Лимиты)
        .Построить();

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Спан = Трассировщик.НачатьКорневойСпан("операция");
    Спан.УстановитьАтрибут("к1", "з1");
    Спан.УстановитьАтрибут("к2", "з2");
    Спан.УстановитьАтрибут("к3", "з3");

    // Тогда - лимиты применены
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(2);

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт
    // Дано
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, МокПроцессор);

    // Когда
    Провайдер.Закрыть();

    // Тогда - процессор закрыт
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().Закрыть(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ПостроительТрассировщика() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);

    // Когда
    Построитель = Провайдер.ПостроительТрассировщика("моя-библ");

    // Тогда
    Ожидаем.Что(Построитель <> Неопределено).Равно(Истина);
    Провайдер.Закрыть();
КонецПроцедуры

&Тест
Процедура ПолучитьТрассировщикПослеЗакрытия() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, МокПроцессор);
    Провайдер.Закрыть();

    // Когда - запрашиваем трассировщик после закрытия
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Тогда - трассировщик non-recording (Включен()=Ложь),
    // создаваемые спаны - ОтелНезаписывающийСпан с ЗаписьАктивна()=Ложь.
    Ожидаем.Что(Трассировщик <> Неопределено).Равно(Истина);
    Ожидаем.Что(Трассировщик.Включен()).Равно(Ложь);
    Спан = Трассировщик.НачатьСпан("после-закрытия");
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);
    Спан.Завершить();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ДобавитьПроцессорИСброситьБуфер() Экспорт
    // Дано
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Провайдер.ДобавитьПроцессор(МокПроцессор1);
    Провайдер.ДобавитьПроцессор(МокПроцессор2);

    // Когда
    Провайдер.СброситьБуфер();

    // Тогда - оба процессора сбросили буфер
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());
    Провайдер.Закрыть();
КонецПроцедуры

&Тест
Процедура СброситьБуферАсинхронно() Экспорт
    // Дано
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, МокПроцессор);

    // Когда
    Обещание = Провайдер.СброситьБуферАсинхронно();
    Обещание.Получить(5000);

    // Тогда
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());
    Провайдер.Закрыть();
КонецПроцедуры

&Тест
Процедура ЗакрытьАсинхронно() Экспорт
    // Дано
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, МокПроцессор);

    // Когда
    Обещание = Провайдер.ЗакрытьАсинхронно();
    Обещание.Получить(5000);

    // Тогда
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().Закрыть(Матчеры.ЛюбоеЗначение());
КонецПроцедуры

&Тест
Процедура ПостроительСПроцессорамиИСэмплером() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));

    // Когда
    Провайдер = Новый ОтелПостроительПровайдераТрассировки()
        .УстановитьРесурс(Ресурс)
        .ДобавитьПроцессор(МокПроцессор1)
        .ДобавитьПроцессор(МокПроцессор2)
        .УстановитьСэмплер(ОтелСэмплер.ПоДолеТрассировок(), 0.5)
        .Построить();

    // Тогда - провайдер построен и СброситьБуфер делегирует обоим
    Провайдер.СброситьБуфер();
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПостроительТрассировщикаFluentChain() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    АтрибутыОбласти = Новый ОтелАтрибуты();
    АтрибутыОбласти.Установить("scope.key", "scope.value");

    // Когда - используем полный fluent chain построителя
    Трассировщик = Провайдер.ПостроительТрассировщика("моя-библ")
        .УстановитьВерсию("2.0.0")
        .УстановитьАдресСхемы("https://schema.example.com")
        .УстановитьАтрибутыОбласти(АтрибутыОбласти)
        .Построить();

    // Тогда
    Ожидаем.Что(Трассировщик <> Неопределено).Равно(Истина);
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

