&Тест
Процедура Ресурс() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Ресурс.Атрибуты().Установить("service.name", "my-service");
    Провайдер = Новый ОтелПостроительПровайдераТрассировки()
        .УстановитьРесурс(Ресурс)
        .Построить();

    // Когда
    РезультатРесурс = Провайдер.Ресурс();

    // Тогда
    Ожидаем.Что(РезультатРесурс.Атрибуты().Получить("service.name")).Равно("my-service");
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ТрассировщикВидитПроцессорДобавленныйПослеСоздания() Экспорт
    // Дано - Provider без процессоров, получаем Tracer (SDK-режим по умолчанию)
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Включён по умолчанию (наличие процессоров не определяет SDK-режим)
    Ожидаем.Что(Трассировщик.Включен()).Равно(Истина);

    // Когда - добавляем процессор ПОСЛЕ получения Tracer
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Провайдер.ДобавитьПроцессор(МокПроцессор);

    // Тогда - КомпозитныйПроцессор видит новый процессор (per spec: late binding)
    Ожидаем.Что(Провайдер.Процессор().ЕстьПроцессоры()).Равно(Истина);
    Ожидаем.Что(Трассировщик.Включен()).Равно(Истина);

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ОдинПроцессорБезКомпозита() Экспорт

    // Дано - один процессор не должен оборачиваться в композит
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Процессор = Новый ОтелПростойПроцессорСпанов(МокЭкспортер);

    Провайдер = Новый ОтелПостроительПровайдераТрассировки()
        .ДобавитьПроцессор(Процессор)
        .Построить();

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("test", "1.0");

    // Тогда - работает без ошибок
    Ожидаем.Что(Трассировщик).Не_().Равно(Неопределено);
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПолучитьТрассировщикСПустымИменем() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);

    // Когда - пустое имя
    Трассировщик = Провайдер.ПолучитьТрассировщик("");

    // Тогда - возвращает рабочий трассировщик (MUST NOT return null)
    Ожидаем.Что(Трассировщик).Не_().Равно(Неопределено);

    // Спан создается нормально
    Спан = Трассировщик.НачатьКорневойСпан("тест");
    Ожидаем.Что(Спан).Не_().Равно(Неопределено);
    Спан.Завершить();

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПолучитьТрассировщикСНеопределеноИменем() Экспорт
