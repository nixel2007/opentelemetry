&Тест
Процедура ЗакрытьСТаймаутом() Экспорт

    // Дано - медленный процессор (200мс) и быстрый мок; таймаут 1мс
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    МедленныйПроцессор = ЗагрузитьСценарий(ОбъединитьПути(КаталогФикстур, "МедленныйПроцессорСпанов.os"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    Провайдер = Новый ОтелПровайдерТрассировки(Новый ОтелРесурс(Истина), МедленныйПроцессор);
    Провайдер.ДобавитьПроцессор(МокПроцессор2);

    // Когда - закрываем с таймаутом 1мс
    Результат = Провайдер.Закрыть(1);

    // Тогда - превышен таймаут
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьСТаймаутом() Экспорт

    // Дано - процессор возвращает таймаут при СброситьБуфер
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорСпанов"));
    МокПроцессор.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(
        ОтелРезультатыЭкспорта.Таймаут());
    Провайдер = Новый ОтелПровайдерТрассировки(Новый ОтелРесурс(Истина), МокПроцессор);

    // Когда
    Результат = Провайдер.ПринудительноВыгрузитьСРезультатом();

    // Тогда - таймаут
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Провайдер.Закрыть();

КонецПроцедуры

