    Построитель.УстановитьГенераторИд(Генератор);
    Провайдер = Построитель.Построить();

    // Когда / Тогда - флаг Random возвращается от генератора (Истина)
    Ожидаем.Что(Провайдер.ФлагRandomДляНовыхИд()).Равно(Истина);

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ОбновитьКонфигураторТрассировкиОтключаетТрассировщик() Экспорт

    // Дано - провайдер с уже полученным трассировщиком
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("test-lib", "1.0");
    Ожидаем.Что(Трассировщик.Включен()).Равно(Истина);

    // Когда - устанавливаем конфигуратор, отключающий трассировщик
    Конфигуратор = Новый Действие(ЭтотОбъект, "КонфигураторТрассировщикаОтключающий");
    Провайдер.ОбновитьКонфигуратор(Конфигуратор);

    // Тогда - существующий трассировщик отключен
    Ожидаем.Что(Трассировщик.Включен()).Равно(Ложь);

    Провайдер.Закрыть();

КонецПроцедуры

// Callback-конфигуратор: отключает трассировщик
Функция КонфигураторТрассировщикаОтключающий(ОбластьИнструментирования) Экспорт // BSLLS:UnusedParameters-off
    Возврат Новый ОтелКонфигурацияТрассировщика(Ложь);
КонецФункции

// Callback-конфигуратор: выбрасывает исключение
Процедура КонфигураторВыбрасывающийИсключение(ОбластьИнструментирования) Экспорт // BSLLS:UnusedParameters-off
    ВызватьИсключение "тестовая ошибка конфигуратора";
КонецПроцедуры

