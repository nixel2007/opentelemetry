// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура ПолучитьТрассировщик() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("моя-библиотека", "1.0");

    // Тогда — трассировщик создаёт спаны
    Спан = Трассировщик.НачатьКорневойСпан("операция");
    Ожидаем.Что(Спан = Неопределено).Равно(Ложь);
    Ожидаем.Что(Спан.Имя()).Равно("операция");

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура КэшированиеТрассировщиков() Экспорт
    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);

    // Когда
    Трассировщик1 = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Трассировщик2 = Провайдер.ПолучитьТрассировщик("библ", "1.0");

    // Тогда — один и тот же объект
    Ожидаем.Что(Трассировщик1).Равно(Трассировщик2);

    // Очистка
    Провайдер.Закрыть();
КонецПроцедуры

&Тест
Процедура ПередачаРесурса() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Ресурс.Атрибуты().Установить("service.name", "тест-сервис");
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Спан = Трассировщик.НачатьКорневойСпан("операция");

    // Тогда — ресурс передан спану
    Ожидаем.Что(Спан.Ресурс()).Равно(Ресурс);
    Ожидаем.Что(Спан.Ресурс().Атрибуты().Получить("service.name")).Равно("тест-сервис");

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПередачаЛимитов() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Лимиты = Новый ОтелЛимитыСпана().УстановитьМаксАтрибутов(2);
    Построитель = Новый ОтелПостроительПровайдераТрассировки();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Построитель
        .УстановитьРесурс(Ресурс)
        .УстановитьЛимитыСпана(Лимиты)
        .Построить();

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Спан = Трассировщик.НачатьКорневойСпан("операция");
    Спан.УстановитьАтрибут("к1", "з1");
    Спан.УстановитьАтрибут("к2", "з2");
    Спан.УстановитьАтрибут("к3", "з3");

    // Тогда — лимиты применены
    Ожидаем.Что(Спан.Атрибуты().Количество()).Равно(2);

    // Очистка
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт
    // Дано
    МокПроцессор = Мок.Получить(Новый ОтелПростойПроцессорСпанов(Новый ОтелВПамятьЭкспортерСпанов()));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс, МокПроцессор);

    // Когда
    Провайдер.Закрыть();

    // Тогда — процессор закрыт
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().Закрыть();
КонецПроцедуры
