// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off

#Использовать "../../.."
#Использовать asserts
#Использовать moskito

// Вспомогательные переменные
Перем ОбластьИзКонфигуратора;

Функция СоздатьПроцессор()
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Возврат Новый ОтелПростойПроцессорСпанов(МокЭкспортер);
КонецФункции

&Тест
Процедура КонфигурацияПоУмолчаниюВключена() Экспорт

    // Дано

    // Когда
    Конфигурация = Новый ОтелКонфигурацияТрассировщика();

    // Тогда
    Ожидаем.Что(Конфигурация.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КонфигурацияМожетБытьОтключена() Экспорт

    // Дано

    // Когда
    Конфигурация = Новый ОтелКонфигурацияТрассировщика(Ложь);

    // Тогда
    Ожидаем.Что(Конфигурация.Включен()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ТрассировщикОтключенПриКонфигурации() Экспорт

    // Дано
    Конфигурация = Новый ОтелКонфигурацияТрассировщика(Ложь);
    Область = Новый ОтелОбластьИнструментирования("тест");
    Провайдер = Новый ОтелПровайдерТрассировки();
    Провайдер.ДобавитьПроцессор(СоздатьПроцессор());

    // Когда
    Трассировщик = Новый ОтелТрассировщик(Область, Провайдер, Конфигурация);

    // Тогда
    Ожидаем.Что(Трассировщик.Включен()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ТрассировщикВключенПриКонфигурации() Экспорт

    // Дано
    Конфигурация = Новый ОтелКонфигурацияТрассировщика(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест");
    Провайдер = Новый ОтелПровайдерТрассировки();
    Провайдер.ДобавитьПроцессор(СоздатьПроцессор());

    // Когда
    Трассировщик = Новый ОтелТрассировщик(Область, Провайдер, Конфигурация);

    // Тогда
    Ожидаем.Что(Трассировщик.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ТрассировщикОтключенБезПроцессоровИКонфигурации() Экспорт

    // Дано
    Конфигурация = Новый ОтелКонфигурацияТрассировщика(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест");
    Провайдер = Новый ОтелПровайдерТрассировки();

    // Когда
    Трассировщик = Новый ОтелТрассировщик(Область, Провайдер, Конфигурация);

    // Тогда - включен по конфигурации, но нет процессоров
    Ожидаем.Что(Трассировщик.Включен()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура КонфигураторВызываетсяПриСозданииТрассировщика() Экспорт

    // Дано
    ОбластьИзКонфигуратора = Неопределено;
    Конфигуратор = Новый Действие(ЭтотОбъект, "КонфигураторТрассировщика");
    Провайдер = Новый ОтелПровайдерТрассировки(, , , , , , Конфигуратор);
    Провайдер.ДобавитьПроцессор(СоздатьПроцессор());

    // Когда
    Провайдер.ПолучитьТрассировщик("моя-библиотека", "1.0.0");

    // Тогда
    Ожидаем.Что(ОбластьИзКонфигуратора).Не_().Равно(Неопределено);
    Ожидаем.Что(ОбластьИзКонфигуратора.Имя()).Равно("моя-библиотека");
    Ожидаем.Что(ОбластьИзКонфигуратора.Версия()).Равно("1.0.0");

КонецПроцедуры

&Тест
Процедура КонфигураторОтключаетТрассировщик() Экспорт

    // Дано
    Конфигуратор = Новый Действие(ЭтотОбъект, "КонфигураторОтключающий");
    Провайдер = Новый ОтелПровайдерТрассировки(, , , , , , Конфигуратор);
    Провайдер.ДобавитьПроцессор(СоздатьПроцессор());

    // Когда
    Трассировщик = Провайдер.ПолучитьТрассировщик("отключаемая");

    // Тогда
    Ожидаем.Что(Трассировщик.Включен()).Равно(Ложь);

КонецПроцедуры

// Callback-конфигуратор: запоминает область и возвращает конфигурацию по умолчанию
Функция КонфигураторТрассировщика(ОбластьИнструментирования) Экспорт
    ОбластьИзКонфигуратора = ОбластьИнструментирования;
    Возврат Новый ОтелКонфигурацияТрассировщика();
КонецФункции

// Callback-конфигуратор: отключает трассировщик
Функция КонфигураторОтключающий(ОбластьИнструментирования) Экспорт // BSLLS:UnusedParameters-off
    Возврат Новый ОтелКонфигурацияТрассировщика(Ложь);
КонецФункции
