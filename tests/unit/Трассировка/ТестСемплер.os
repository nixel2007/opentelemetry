&Тест
Процедура ВсегдаВключен() Экспорт
    // Дано / Когда
    Результат = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ВсегдаВключен());

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
    Ожидаем.Что(Результат.Атрибуты().Количество()).Равно(0);
    Ожидаем.Что(Результат.СостояниеТрассировки().Пустой()).Равно(Истина);
КонецПроцедуры

