&Тест
Процедура ПоДолеТрассировокНоль() Экспорт
    // Дано / Когда - доля 0.0 означает отбрасывать все
    Результат = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 0.0, "0af7651916cd43dd8448eb211c80319c");

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСемплер.РешениеОтбросить());
КонецПроцедуры

&Тест
Процедура ПоДолеТрассировокЕдиница() Экспорт
    // Дано / Когда - доля 1.0 означает записывать все
    Результат = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 1.0, "0af7651916cd43dd8448eb211c80319c");

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура ПоДолеТрассировокПоловина() Экспорт
    // Дано - доля 0.5
    // Используем traceId с малым хешем (00000001...) - попадет под 50%
    Семплер = ОтелСемплер.ПоДолеТрассировок();
    ИдМалый = "0000000100000000ffffffffffffffff";
    ИдБольшой = "ffffffff00000000ffffffffffffffff";
    РезультатМалый = ОтелСемплер.ДолженСемплировать(Семплер, 0.5, ИдМалый);
    // Используем traceId с большим хешем (ffffffff...) - не попадет под 50%
    РезультатБольшой = ОтелСемплер.ДолженСемплировать(Семплер, 0.5, ИдБольшой);

    // Тогда
    Ожидаем.Что(РезультатМалый.Решение()).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
    Ожидаем.Что(РезультатБольшой.Решение()).Равно(ОтелСемплер.РешениеОтбросить());
КонецПроцедуры

&Тест
Процедура ПоДолеТрассировокПустойТрейсИд() Экспорт
    // Дано / Когда - пустой traceId -> записать (fallback)
    Результат = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 0.5, "");

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура НеизвестнаяСтратегия() Экспорт
    // Дано / Когда - неизвестная стратегия -> fallback на РешениеЗаписатьИЭкспортировать
    Результат = ОтелСемплер.ДолженСемплировать(999);

    // Тогда
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

