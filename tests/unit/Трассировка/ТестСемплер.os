&Тест
Процедура ПоДолеТрассировокНоль() Экспорт
    // Дано / Когда - доля 0.0 означает отбрасывать все
    Решение = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 0.0, "0af7651916cd43dd8448eb211c80319c");

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеОтбросить());
КонецПроцедуры

&Тест
Процедура ПоДолеТрассировокЕдиница() Экспорт
    // Дано / Когда - доля 1.0 означает записывать все
    Решение = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 1.0, "0af7651916cd43dd8448eb211c80319c");

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура ПоДолеТрассировокПоловина() Экспорт
    // Дано - доля 0.5
    // Используем traceId с малым хешем (00000001...) - попадет под 50%
    РешениеМалый = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 0.5, "0000000100000000ffffffffffffffff");
    // Используем traceId с большим хешем (ffffffff...) - не попадет под 50%
    РешениеБольшой = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 0.5, "ffffffff00000000ffffffffffffffff");

    // Тогда
    Ожидаем.Что(РешениеМалый).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
    Ожидаем.Что(РешениеБольшой).Равно(ОтелСемплер.РешениеОтбросить());
КонецПроцедуры

&Тест
Процедура ПоДолеТрассировокПустойТрейсИд() Экспорт
    // Дано / Когда - пустой traceId -> записать (fallback)
    Решение = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 0.5, "");

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура НеизвестнаяСтратегия() Экспорт
    // Дано / Когда - неизвестная стратегия -> fallback на РешениеЗаписатьИЭкспортировать
    Решение = ОтелСемплер.ДолженСемплировать(999);

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура НаОсновеРодителяСемплированный() Экспорт
    // Дано / Когда - родитель семплирован -> ребенок тоже
    Решение = ОтелСемплер.ДолженСемплировать(
        ОтелСемплер.НаОсновеРодителя(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Истина,
        Истина
    );

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

