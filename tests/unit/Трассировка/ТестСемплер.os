// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура ВсегдаВключен() Экспорт
    // Дано / Когда
    Решение = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ВсегдаВключен());

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура ВсегдаВыключен() Экспорт
    // Дано / Когда
    Решение = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ВсегдаВыключен());

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеОтбросить());
КонецПроцедуры

&Тест
Процедура ПоДолеТрассировокНоль() Экспорт
    // Дано / Когда - доля 0.0 означает отбрасывать всё
    Решение = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 0.0, "0af7651916cd43dd8448eb211c80319c");

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеОтбросить());
КонецПроцедуры

&Тест
Процедура ПоДолеТрассировокЕдиница() Экспорт
    // Дано / Когда - доля 1.0 означает записывать всё
    Решение = ОтелСемплер.ДолженСемплировать(ОтелСемплер.ПоДолеТрассировок(), 1.0, "0af7651916cd43dd8448eb211c80319c");

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура НаОсновеРодителяСемплированный() Экспорт
    // Дано / Когда - родитель семплирован -> ребёнок тоже
    Решение = ОтелСемплер.ДолженСемплировать(
        ОтелСемплер.НаОсновеРодителя(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Истина,
        Истина
    );

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура НаОсновеРодителяНеСемплированный() Экспорт
    // Дано / Когда - родитель не семплирован -> ребёнок тоже
    Решение = ОтелСемплер.ДолженСемплировать(
        ОтелСемплер.НаОсновеРодителя(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Ложь,
        Истина
    );

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеОтбросить());
КонецПроцедуры

&Тест
Процедура НаОсновеРодителяБезРодителя() Экспорт
    // Дано / Когда - нет родителя, используется корневая стратегия (ВсегдаВключен по умолчанию)
    Решение = ОтелСемплер.ДолженСемплировать(
        ОтелСемплер.НаОсновеРодителя(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Истина,
        Ложь
    );

    // Тогда - корневая стратегия по умолчанию ВсегдаВключен
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры
