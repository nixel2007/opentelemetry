// --- Тесты СоздатьКонфигурациюНаОсновеРодителя ---

&Тест
Процедура КонфигурацияНаОсновеРодителяУмолчания() Экспорт
    // Дано / Когда - все по умолчанию
    Конфиг = ОтелСемплер.СоздатьКонфигурациюНаОсновеРодителя();

    // Тогда
    Ожидаем.Что(Конфиг.Получить("УдаленныйРодительСемплирован")).Равно(ОтелСемплер.ВсегдаВключен());
    Ожидаем.Что(Конфиг.Получить("УдаленныйРодительНеСемплирован")).Равно(ОтелСемплер.ВсегдаВыключен());
    Ожидаем.Что(Конфиг.Получить("ЛокальныйРодительСемплирован")).Равно(ОтелСемплер.ВсегдаВключен());
    Ожидаем.Что(Конфиг.Получить("ЛокальныйРодительНеСемплирован")).Равно(ОтелСемплер.ВсегдаВыключен());
КонецПроцедуры

&Тест
Процедура КонфигурацияНаОсновеРодителяСПользовательскимиСтратегиями() Экспорт
    // Дано / Когда
    Конфиг = ОтелСемплер.СоздатьКонфигурациюНаОсновеРодителя(
        ОтелСемплер.ВсегдаВыключен(),
        ОтелСемплер.ВсегдаВключен(),
        ОтелСемплер.ПоДолеТрассировок(),
        ОтелСемплер.ВсегдаВключен()
    );

    // Тогда
    Ожидаем.Что(Конфиг.Получить("УдаленныйРодительСемплирован")).Равно(ОтелСемплер.ВсегдаВыключен());
    Ожидаем.Что(Конфиг.Получить("УдаленныйРодительНеСемплирован")).Равно(ОтелСемплер.ВсегдаВключен());
    Ожидаем.Что(Конфиг.Получить("ЛокальныйРодительСемплирован")).Равно(ОтелСемплер.ПоДолеТрассировок());
    Ожидаем.Что(Конфиг.Получить("ЛокальныйРодительНеСемплирован")).Равно(ОтелСемплер.ВсегдаВключен());
КонецПроцедуры

// --- Тесты ParentBased с конфигурацией remote/local ---

&ПараметризованныйТест
&ИсточникЗначение("УдаленныйСемплирован")
&ИсточникЗначение("УдаленныйНеСемплирован")
&ИсточникЗначение("ЛокальныйСемплирован")
&ИсточникЗначение("ЛокальныйНеСемплирован")
Процедура НаОсновеРодителяСКонфигурацией(Сценарий) Экспорт
    // Дано
    Конфиг = ОтелСемплер.СоздатьКонфигурациюНаОсновеРодителя();

    Если Сценарий = "УдаленныйСемплирован" Тогда
        РодительСемплирован = Истина;
        РодительУдаленный = Истина;
        ОжидаемоеРешение = ОтелСемплер.РешениеЗаписатьИЭкспортировать();
    ИначеЕсли Сценарий = "УдаленныйНеСемплирован" Тогда
        РодительСемплирован = Ложь;
        РодительУдаленный = Истина;
        ОжидаемоеРешение = ОтелСемплер.РешениеОтбросить();
    ИначеЕсли Сценарий = "ЛокальныйСемплирован" Тогда
        РодительСемплирован = Истина;
        РодительУдаленный = Ложь;
        ОжидаемоеРешение = ОтелСемплер.РешениеЗаписатьИЭкспортировать();
    ИначеЕсли Сценарий = "ЛокальныйНеСемплирован" Тогда
        РодительСемплирован = Ложь;
        РодительУдаленный = Ложь;
        ОжидаемоеРешение = ОтелСемплер.РешениеОтбросить();
    КонецЕсли;

    // Когда
    Решение = ОтелСемплер.ДолженСемплировать(
        ОтелСемплер.НаОсновеРодителя(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        РодительСемплирован,
        Истина,
        Неопределено,
        РодительУдаленный,
        Конфиг
    );

    // Тогда
    Ожидаем.Что(Решение).Равно(ОжидаемоеРешение);
КонецПроцедуры

&Тест
Процедура НаОсновеРодителяКонфигУдаленныйНеСемплированныйВключен() Экспорт
    // Дано - переопределяем: удаленный не-семплированный -> ВсегдаВключен (вместо ВсегдаВыключен)
    Конфиг = ОтелСемплер.СоздатьКонфигурациюНаОсновеРодителя(
        Неопределено,
        ОтелСемплер.ВсегдаВключен(),
        Неопределено,
        Неопределено
    );

    // Когда - удаленный родитель НЕ семплирован
    Решение = ОтелСемплер.ДолженСемплировать(
        ОтелСемплер.НаОсновеРодителя(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Ложь,
        Истина,
        Неопределено,
        Истина,
        Конфиг
    );

    // Тогда - конфигурация переопределила: записываем вместо отбрасывания
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура НаОсновеРодителяБезКонфигурацииРодительНеСемплирован() Экспорт
    // Дано / Когда - есть родитель, но без конфигурации -> простой fallback
    Решение = ОтелСемплер.ДолженСемплировать(
        ОтелСемплер.НаОсновеРодителя(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Ложь,
        Истина,
        Неопределено,
        Ложь,
        Неопределено
    );

    // Тогда
    Ожидаем.Что(Решение).Равно(ОтелСемплер.РешениеОтбросить());
КонецПроцедуры
