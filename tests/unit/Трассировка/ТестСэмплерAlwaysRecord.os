&Тест
Процедура AlwaysRecordПоднимаетDropДоRecordOnly() Экспорт
    // Дано / Когда - делегат ВсегдаВыключен (DROP)
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.ВсегдаЗаписывать(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Истина,
        Ложь,
        ОтелСэмплер.ВсегдаВыключен()
    );

    // Тогда - решение поднято до RECORD_ONLY (1)
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеЗаписать());
КонецПроцедуры

&Тест
Процедура AlwaysRecordСохраняетRecordAndSample() Экспорт
    // Дано / Когда - делегат ВсегдаВключен (RECORD_AND_SAMPLE)
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.ВсегдаЗаписывать(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Истина,
        Ложь,
        ОтелСэмплер.ВсегдаВключен()
    );

    // Тогда - решение делегата сохранено
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура AlwaysRecordПоднимаетDropОтДелегатаПоДоле() Экспорт
    // Дано / Когда - делегат ПоДолеТрассировок 0.0 (всегда DROP)
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.ВсегдаЗаписывать(),
        0.0,
        "ffffffff00000000ffffffffffffffff",
        Истина,
        Ложь,
        ОтелСэмплер.ПоДолеТрассировок()
    );

    // Тогда - DROP поднят до RECORD_ONLY
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеЗаписать());
КонецПроцедуры

&Тест
Процедура AlwaysRecordПоУмолчаниюИспользуетВсегдаВключен() Экспорт
    // Дано / Когда - делегат не указан (Неопределено) -> ВсегдаВключен
    Результат = ОтелСэмплер.ДолженСэмплировать(ОтелСэмплер.ВсегдаЗаписывать());

    // Тогда - RECORD_AND_SAMPLE
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеЗаписатьИЭкспортировать());
КонецПроцедуры

&Тест
Процедура AlwaysRecordСохраняетРодительскийTraceState() Экспорт
    // Дано - родительский TraceState с rv
    РодительскийТС = Новый ОтелСостояниеТрассировки();
    РодительскийТС = РодительскийТС.Установить("ot", "rv:abc123");

    // Когда - AlwaysRecord(ВсегдаВыключен) с родительским TraceState
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.ВсегдаЗаписывать(),
        1.0,
        "",
        Истина,
        Ложь,
        ОтелСэмплер.ВсегдаВыключен(),
        Ложь,
        Неопределено,
        РодительскийТС
    );

    // Тогда - решение поднято, TraceState сохранен
    Ожидаем.Что(Результат.Решение()).Равно(ОтелСэмплер.РешениеЗаписать());
    Ожидаем.Что(Результат.СостояниеТрассировки().Получить("ot")).Равно("rv:abc123");
КонецПроцедуры

&Тест
Процедура AlwaysRecordВозвращаетПустыеАтрибуты() Экспорт
    // Дано / Когда - встроенные делегаты не добавляют атрибутов
    Результат = ОтелСэмплер.ДолженСэмплировать(
        ОтелСэмплер.ВсегдаЗаписывать(),
        1.0,
        "0af7651916cd43dd8448eb211c80319c",
        Истина,
        Ложь,
        ОтелСэмплер.ВсегдаВыключен()
    );

    // Тогда - атрибуты делегата (пустые) сохранены
    Ожидаем.Что(Результат.Атрибуты()).ИмеетТип("ОтелАтрибуты");
    Ожидаем.Что(Результат.Атрибуты().Количество()).Равно(0);
КонецПроцедуры

&Тест
Процедура AlwaysRecordОписаниеСодержитДелегата() Экспорт
    // Дано / Когда
    Описание = ОтелСэмплер.Описание(
        ОтелСэмплер.ВсегдаЗаписывать(),
        1.0,
        ОтелСэмплер.ВсегдаВыключен()
    );

    // Тогда
    Ожидаем.Что(Описание).Равно("AlwaysRecord{AlwaysOffSampler}");
КонецПроцедуры

&Тест
Процедура AlwaysRecordОписаниеПоУмолчанию() Экспорт
    // Дано / Когда - без указания делегата
    Описание = ОтелСэмплер.Описание(ОтелСэмплер.ВсегдаЗаписывать());

    // Тогда - по умолчанию делегат ВсегдаВключен
    Ожидаем.Что(Описание).Равно("AlwaysRecord{AlwaysOnSampler}");
КонецПроцедуры

&Тест
Процедура AlwaysRecordОборачиваетДелегатаПоДолеВОписании() Экспорт
    // Дано / Когда
    Описание = ОтелСэмплер.Описание(
        ОтелСэмплер.ВсегдаЗаписывать(),
        0.5,
        ОтелСэмплер.ПоДолеТрассировок()
    );

    // Тогда
    Ожидаем.Что(Описание).Равно("AlwaysRecord{TraceIdRatioBased{0.500000}}");
КонецПроцедуры
