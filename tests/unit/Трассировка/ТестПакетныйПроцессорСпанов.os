// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito
#Использовать extends

// Поля для concurrency-теста (shared между main-потоком и фоновыми заданиями)
Перем КонкурПроцессор;
Перем КонкурРесурс;
Перем КонкурОбласть;

// Вызывается фоновым заданием в тесте КонкурентноеДобавлениеСпановВОчередь
Процедура ДобавитьДесятьСпановВФоне() Экспорт
    Для Сч = 1 По 10 Цикл
        Спан = Новый ОтелСпан("спан", КонкурРесурс, КонкурОбласть);
        Спан.Завершить();
        КонкурПроцессор.ПриЗавершении(Спан);
    КонецЦикла;
КонецПроцедуры

&Тест
Процедура БуферизацияСпанов() Экспорт
    // Дано - большой размер пакета, спаны копятся в буфере
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);

    // Когда - добавляем спаны (не достигая размера пакета)
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Для Сч = 1 По 3 Цикл
        Спан = Новый ОтелСпан("спан-" + Сч, Ресурс, ОбластьИнструментирования);
        Спан.Завершить();
        Процессор.ПриЗавершении(Спан);
    КонецЦикла;

    // Тогда - после СброситьБуфер экспортер вызывается
    Процессор.СброситьБуфер();
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(Матчеры.ЛюбоеЗначение());

    // Очистка
    Процессор.Закрыть();
КонецПроцедуры

&Тест
Процедура СброситьБуфер() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    Процессор.ПриЗавершении(Спан);

    // Когда
    Процессор.СброситьБуфер();

    // Тогда
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(Матчеры.ЛюбоеЗначение());

    // Очистка
    Процессор.Закрыть();
КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт
    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    Процессор.ПриЗавершении(Спан);

    // Когда - закрытие сбрасывает оставшиеся спаны
    Процессор.Закрыть();

    // Тогда
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    );
КонецПроцедуры

&Тест
Процедура ЭкспортПриДостиженииРазмераПакета() Экспорт

    // Дано - маленький размер пакета (2), чтобы автоматически запустить экспорт
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    МокЭкспортер.Когда().Экспортировать(Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 2, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);

    // Когда - добавляем 2 спана (равно размеру пакета)
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Для Сч = 1 По 2 Цикл
        Спан = Новый ОтелСпан("спан-" + Сч, Ресурс, ОбластьИнструментирования);
        Спан.Завершить();
        Процессор.ПриЗавершении(Спан);
    КонецЦикла;

    // Тогда - экспорт вызван автоматически
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(Матчеры.ЛюбоеЗначение());

    Процессор.Закрыть();

КонецПроцедуры

&Тест
Процедура ЧастичныйЭкспортБольшогоБуфера() Экспорт

    // Дано - размер пакета 2, но в буфере будет 3 спана
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    МокЭкспортер.Когда().Экспортировать(Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 2, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);

    // Добавляем 3 спана - при 2-м вызовется авто-экспорт
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Для Сч = 1 По 3 Цикл
        Спан = Новый ОтелСпан("спан-" + Сч, Ресурс, ОбластьИнструментирования);
        Спан.Завершить();
        Процессор.ПриЗавершении(Спан);
    КонецЦикла;

    // Когда - сбрасываем оставшийся 1 спан
    Процессор.СброситьБуфер();

    // Тогда - экспорт вызывался минимум 2 раза
    Процессор.Закрыть();

КонецПроцедуры

&Тест
Процедура ОбработкаПослеЗакрытия() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);

    Процессор.Закрыть();

    // Когда - обработка спана после закрытия
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    Процессор.ПриЗавершении(Спан);

    // Тогда - ничего не падает, спан просто игнорируется
    Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ПовторныйЗапускФоновогоЭкспорта() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();

    // Когда - двойной запуск
    Процессор.ЗапуститьФоновыйЭкспорт();
    Процессор.ЗапуститьФоновыйЭкспорт(); // повторный вызов - должен быть безопасен

    // Тогда - без ошибок
    Ожидаем.Что(Истина).Равно(Истина);

    Процессор.Закрыть();

КонецПроцедуры

&Тест
Процедура ОшибкаЭкспортера() Экспорт

    // Дано - экспортер бросает исключение при вызове
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    МокЭкспортер.Когда().Экспортировать(
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВыбрасываетИсключение("тест: ошибка экспорта спанов");
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);

    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    Процессор.ПриЗавершении(Спан);

    // Когда - сброс вызывает экспорт, который падает
    Процессор.СброситьБуфер();

    // Тогда - ошибка обработана, процессор не сломался
    Процессор.Закрыть();
    Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ФоновыйПериодическийЭкспорт() Экспорт

    // Дано - короткий интервал для быстрого срабатывания
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);

    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест-фон", Ресурс, ОбластьИнструментирования);
    Спан.Завершить();
    Процессор.ПриЗавершении(Спан);

    // Когда - запускаем фоновый экспорт и ждем его срабатывания
    Процессор.ЗапуститьФоновыйЭкспорт();
    Приостановить(300);

    // Тогда - закрываем, фоновый экспорт должен остановиться
    Процессор.Закрыть();
    Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура СчетчикОтброшенныхСпанов() Экспорт

    // Дано - буфер на 3 спана
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 3, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");

    // Когда - добавляем 5 спанов (буфер вместит только 3)
    Для Сч = 1 По 5 Цикл
        Спан = Новый ОтелСпан("спан-" + Сч, Ресурс, ОбластьИнструментирования);
        Спан.Завершить();
        Процессор.ПриЗавершении(Спан);
    КонецЦикла;

    // Тогда - 2 спана отброшены
    Ожидаем.Что(Процессор.КоличествоОтброшенных()).Равно(2);

    Процессор.Закрыть();

КонецПроцедуры

&Тест
Процедура ПриНачалеНеВыполняетДействий() Экспорт

    // Дано - пакетный процессор и спан
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);

    // Когда - вызываем ПриНачале (ничего не должно произойти - пустая процедура)
    Процессор.ПриНачале(Спан);

    // Тогда - без ошибок
    Ожидаем.Что(Истина).Равно(Истина);

    Процессор.Закрыть();

КонецПроцедуры

