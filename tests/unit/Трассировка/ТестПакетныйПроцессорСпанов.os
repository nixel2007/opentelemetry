КонецПроцедуры

&Тест
Процедура НесэмплированныйСпанОтброшенПриЗавершении() Экспорт

    // Дано - спан с ФлагиТрассировки=0 (не сэмплирован)
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    // BSLLS:MagicNumber-off
    НесэмплированныйСпан = Новый ОтелСпан(
        "не-сэмпл", Ресурс, ОбластьИнструментирования,
        Неопределено, "", Неопределено, Неопределено, Неопределено, Неопределено, 0);
    // BSLLS:MagicNumber-on

    // Когда - передаём несэмплированный завершённый спан
    НесэмплированныйСпан.Завершить();
    Процессор.ПриЗавершении(НесэмплированныйСпан);

    // Тогда - никаких отброшенных (спан просто проигнорирован без записи в буфер)
    Ожидаем.Что(Процессор.КоличествоОтброшенных()).Равно(0);

    Процессор.Закрыть();

КонецПроцедуры

&Тест
Процедура СпанСКонтекстомНеопределеноОтброшен() Экспорт

    // Дано - мок-спан с КонтекстСпана() = Неопределено
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 2048, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    МокСпан = Мок.Получить(Тип("ОтелСпан"));
    МокСпан.Когда().КонтекстСпана().ТогдаВозвращает(Неопределено);

    // Когда - передаём спан с неопределённым контекстом
    Процессор.ПриЗавершении(МокСпан);

    // Тогда - никаких отброшенных (спан просто проигнорирован - контекст Неопределено)
    Ожидаем.Что(Процессор.КоличествоОтброшенных()).Равно(0);

    Процессор.Закрыть();

КонецПроцедуры

&Тест
Процедура КонкурентноеДобавлениеСпановВОчередь() Экспорт

    // Дано - BSP с большой очередью и длинным интервалом (auto-flush не срабатывает)
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    МокЭкспортер.Когда().Экспортировать(Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(Истина);
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "traces", 1000, 500, 60000);
    КонкурПроцессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    КонкурРесурс = Новый ОтелРесурс(Истина);
    КонкурОбласть = Новый ОтелОбластьИнструментирования("библ", "1.0");

    // Когда - 10 фоновых заданий, каждое добавляет 10 спанов (итого 100)
    Задания = Новый Массив();
    Для Сч = 1 По 10 Цикл
        Задания.Добавить(ФоновыеЗадания.Выполнить(ЭтотОбъект, "ДобавитьДесятьСпановВФоне"));
    КонецЦикла;
    Для Каждого Задание Из Задания Цикл
        Задание.ОжидатьЗавершения(10000);
    КонецЦикла;

    // Тогда - все 100 спанов добавлены без потерь и без повреждения данных
    Ожидаем.Что(КонкурПроцессор.КоличествоОтброшенных()).Равно(0);

    КонкурПроцессор.Закрыть();

КонецПроцедуры
