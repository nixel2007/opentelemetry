&Тест
Процедура ДефолтныеЛимиты() Экспорт
    // Дано / Когда
    Лимиты = Новый ОтелЛимитыСпана();

    // Тогда
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(128);
    Ожидаем.Что(Лимиты.МаксСобытий()).Равно(128);
    Ожидаем.Что(Лимиты.МаксЛинков()).Равно(128);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(0);
    Ожидаем.Что(Лимиты.МаксАтрибутовНаСобытие()).Равно(128);
    Ожидаем.Что(Лимиты.МаксАтрибутовНаЛинк()).Равно(128);
КонецПроцедуры

&Тест
Процедура УстановкаЛимитов() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана();

    // Когда
    Лимиты.УстановитьМаксАтрибутов(256);
    Лимиты.УстановитьМаксСобытий(64);
    Лимиты.УстановитьМаксЛинков(32);
    Лимиты.УстановитьМаксДлинаЗначенияАтрибута(1024);

    // Тогда
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(256);
    Ожидаем.Что(Лимиты.МаксСобытий()).Равно(64);
    Ожидаем.Что(Лимиты.МаксЛинков()).Равно(32);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(1024);
КонецПроцедуры

&Тест
Процедура FluentAPI() Экспорт
    // Дано / Когда - цепочка вызовов
    Лимиты = Новый ОтелЛимитыСпана()
        .УстановитьМаксАтрибутов(10)
        .УстановитьМаксСобытий(20)
        .УстановитьМаксЛинков(30)
        .УстановитьМаксДлинаЗначенияАтрибута(100)
        .УстановитьМаксАтрибутовНаСобытие(5)
        .УстановитьМаксАтрибутовНаЛинк(3);

    // Тогда
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(10);
    Ожидаем.Что(Лимиты.МаксСобытий()).Равно(20);
    Ожидаем.Что(Лимиты.МаксЛинков()).Равно(30);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(100);
    Ожидаем.Что(Лимиты.МаксАтрибутовНаСобытие()).Равно(5);
    Ожидаем.Что(Лимиты.МаксАтрибутовНаЛинк()).Равно(3);
КонецПроцедуры

&Тест
Процедура ВсеШестьЛимитов() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана()
        .УстановитьМаксАтрибутов(1)
        .УстановитьМаксСобытий(2)
        .УстановитьМаксЛинков(3)
        .УстановитьМаксАтрибутовНаСобытие(4)
        .УстановитьМаксАтрибутовНаЛинк(5)
        .УстановитьМаксДлинаЗначенияАтрибута(6);

    // Тогда - все шесть лимитов установлены
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(1);
    Ожидаем.Что(Лимиты.МаксСобытий()).Равно(2);
    Ожидаем.Что(Лимиты.МаксЛинков()).Равно(3);
    Ожидаем.Что(Лимиты.МаксАтрибутовНаСобытие()).Равно(4);
    Ожидаем.Что(Лимиты.МаксАтрибутовНаЛинк()).Равно(5);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(6);
КонецПроцедуры

&Тест
Процедура ПсевдонимыВСтилеOTelВозвращаютТеЖеЗначения() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана()
        .УстановитьМаксАтрибутов(11)
        .УстановитьМаксСобытий(22)
        .УстановитьМаксЛинков(33);

    // Тогда - псевдонимы возвращают значения из старых геттеров
    Ожидаем.Что(Лимиты.КоличествоАтрибутовЛимит()).Равно(Лимиты.МаксАтрибутов());
    Ожидаем.Что(Лимиты.КоличествоСобытийЛимит()).Равно(Лимиты.МаксСобытий());
    Ожидаем.Что(Лимиты.КоличествоСсылокЛимит()).Равно(Лимиты.МаксЛинков());
КонецПроцедуры

&Тест
Процедура УстановкаЧерезПсевдонимыВидныЧерезСтарыеИмена() Экспорт
    // Дано
    Лимиты = Новый ОтелЛимитыСпана();

    // Когда
    Лимиты.УстановитьКоличествоАтрибутовЛимит(7)
        .УстановитьКоличествоСобытийЛимит(8)
        .УстановитьКоличествоСсылокЛимит(9);

    // Тогда - значения видны и через старые геттеры
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(7);
    Ожидаем.Что(Лимиты.МаксСобытий()).Равно(8);
    Ожидаем.Что(Лимиты.МаксЛинков()).Равно(9);
    Ожидаем.Что(Лимиты.КоличествоАтрибутовЛимит()).Равно(7);
    Ожидаем.Что(Лимиты.КоличествоСобытийЛимит()).Равно(8);
    Ожидаем.Что(Лимиты.КоличествоСсылокЛимит()).Равно(9);
КонецПроцедуры
