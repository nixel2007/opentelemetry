&Тест
Процедура СозданиеКонтекста() Экспорт
    // Дано
    ИдТрассировки = "0af7651916cd43dd8448eb211c80319c";
    ИдСпана = "b7ad6b7169203331";

    // Когда
    Контекст = Новый ОтелКонтекстСпана(ИдТрассировки, ИдСпана);

    // Тогда
    Ожидаем.Что(Контекст.ИдТрассировки()).Равно(ИдТрассировки);
    Ожидаем.Что(Контекст.ИдСпана()).Равно(ИдСпана);
    Ожидаем.Что(Контекст.ФлагиТрассировки()).Равно(1);
    Ожидаем.Что(Контекст.СостояниеТрассировки().ВСтроку()).Равно("");
КонецПроцедуры

&Тест
Процедура ЛокальныйКонтекст() Экспорт
    // Дано / Когда
    Контекст = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331");

    // Тогда - по умолчанию контекст локальный
    Ожидаем.Что(Контекст.Удаленный()).Равно(Ложь);
КонецПроцедуры

&Тест
Процедура УдаленныйКонтекст() Экспорт
    // Дано / Когда
    Контекст = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331", 1, "", Истина);

    // Тогда
    Ожидаем.Что(Контекст.Удаленный()).Равно(Истина);
КонецПроцедуры

&Тест
Процедура Валидность() Экспорт
    // Дано / Когда
    ВалидныйКонтекст = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331");
    ПустойТрассировки = Новый ОтелКонтекстСпана("", "b7ad6b7169203331");
    ПустойСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "");
    ОбаПустых = Новый ОтелКонтекстСпана("", "");

    // Тогда
    Ожидаем.Что(ВалидныйКонтекст.Валиден()).Равно(Истина);
    Ожидаем.Что(ПустойТрассировки.Валиден()).Равно(Ложь);
    Ожидаем.Что(ПустойСпана.Валиден()).Равно(Ложь);
    Ожидаем.Что(ОбаПустых.Валиден()).Равно(Ложь);
КонецПроцедуры

&Тест
Процедура ТестВалиденКорректныйКонтекст() Экспорт
    Контекст = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331");
    Ожидаем.Что(Контекст.Валиден()).ЭтоИстина();
КонецПроцедуры

