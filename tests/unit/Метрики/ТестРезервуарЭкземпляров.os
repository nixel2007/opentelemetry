    Ожидаем.Что(Резервуар.Собрать("несуществующий")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура РезервуарноеСэмплированиеСтатистически() Экспорт

    // Дано - резервуар на 1 элемент, добавляем 1000
    Резервуар = Новый ОтелРезервуарЭкземпляров(1);

    КоличествоПоследних = 0;
    Для Итерация = 1 По 100 Цикл
        Резервуар.Очистить();
        Для Сч = 1 По 20 Цикл
            Резервуар.Предложить("key1", Сч);
        КонецЦикла;

        Результат = Резервуар.Собрать("key1");
        Если Результат[0].Получить("asDouble") = 20 Тогда
            КоличествоПоследних = КоличествоПоследних + 1;
        КонецЕсли;
    КонецЦикла;

    // При FIFO последний ВСЕГДА побеждает (100%).
    // При reservoir sampling вероятность 1/20 = 5%, за 100 попыток ~5 раз.
    Ожидаем.Что(КоличествоПоследних < 50).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ЭкземплярСодержитВременнуюМеткуИЗначение() Экспорт

    // Дано
    Резервуар = Новый ОтелРезервуарЭкземпляров(1);

    // Когда
    Резервуар.Предложить("key1", 3.14);

    // Тогда
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(1);
    Ожидаем.Что(Результат[0].Получить("asDouble")).Равно(3.14);
    Ожидаем.Что(Результат[0].Получить("timeUnixNano") <> Неопределено).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ФильтрованныеАтрибуты() Экспорт

    // Дано
    Резервуар = Новый ОтелРезервуарЭкземпляров(1);
    АтрибутыИзмерения = Новый ОтелАтрибуты();
    АтрибутыИзмерения.Установить("method", "GET");
    АтрибутыИзмерения.Установить("status", "200");
    АтрибутыИзмерения.Установить("path", "/api");

    АтрибутыСерии = Новый ОтелАтрибуты();
    АтрибутыСерии.Установить("method", "GET");

    // Когда
    Резервуар.Предложить("key1", 1.0, АтрибутыИзмерения, АтрибутыСерии);

    // Тогда
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(1);
    Отфильтрованные = Результат[0].Получить("filteredAttributes");
    Ожидаем.Что(Отфильтрованные).ИмеетДлину(2);
    Ожидаем.Что(Отфильтрованные[0].Получить("key")).Равно("status");
    Ожидаем.Что(Отфильтрованные[1].Получить("key")).Равно("path");

КонецПроцедуры

&Тест
Процедура БезАтрибутовНетФильтрованных() Экспорт

    // Дано
    Резервуар = Новый ОтелРезервуарЭкземпляров(1);

    // Когда
    Резервуар.Предложить("key1", 1.0);

    // Тогда
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат[0].Получить("filteredAttributes")).Равно(Неопределено);

КонецПроцедуры
