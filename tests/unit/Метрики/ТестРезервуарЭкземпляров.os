&Тест
Процедура СозданиеРезервуара() Экспорт

    // Дано / Когда
    Резервуар = Новый ОтелРезервуарЭкземпляров(5);

    // Тогда
    Ожидаем.Что(Резервуар.МаксРазмер()).Равно(5);

КонецПроцедуры

&Тест
Процедура ЗахватДоЗаполнения() Экспорт

    // Дано
    Резервуар = Новый ОтелРезервуарЭкземпляров(3);
    Экземпляр1 = Новый Соответствие();
    Экземпляр1.Вставить("asDouble", 1);
    Экземпляр2 = Новый Соответствие();
    Экземпляр2.Вставить("asDouble", 2);

    // Когда
    Резервуар.Предложить("key1", Экземпляр1);
    Резервуар.Предложить("key1", Экземпляр2);

    // Тогда
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(2);
    Ожидаем.Что(Результат[0].Получить("asDouble")).Равно(1);
    Ожидаем.Что(Результат[1].Получить("asDouble")).Равно(2);

КонецПроцедуры

&Тест
Процедура РезервуарНеПревышаетМакс() Экспорт

    // Дано
    Резервуар = Новый ОтелРезервуарЭкземпляров(2);

    // Когда - добавляем 100 экземпляров
    Для Сч = 1 По 100 Цикл
        Экземпляр = Новый Соответствие();
        Экземпляр.Вставить("asDouble", Сч);
        Резервуар.Предложить("key1", Экземпляр);
    КонецЦикла;

    // Тогда - не более 2
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат.Количество() <= 2).Равно(Истина);

КонецПроцедуры

&Тест
Процедура РазныеКлючиНезависимы() Экспорт

    // Дано
    Резервуар = Новый ОтелРезервуарЭкземпляров(1);
    Экз1 = Новый Соответствие();
    Экз1.Вставить("asDouble", 1);
    Экз2 = Новый Соответствие();
    Экз2.Вставить("asDouble", 2);

    // Когда
    Резервуар.Предложить("key1", Экз1);
    Резервуар.Предложить("key2", Экз2);

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("key1")).ИмеетДлину(1);
    Ожидаем.Что(Резервуар.Собрать("key2")).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ОчисткаСбрасываетВсе() Экспорт

    // Дано
    Резервуар = Новый ОтелРезервуарЭкземпляров(5);
    Экз = Новый Соответствие();
    Экз.Вставить("asDouble", 42);
    Резервуар.Предложить("key1", Экз);
    Ожидаем.Что(Резервуар.Собрать("key1")).ИмеетДлину(1);

    // Когда
    Резервуар.Очистить();

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("key1")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура СобратьБезКлючаВозвращаетПустойМассив() Экспорт

    // Дано
    Резервуар = Новый ОтелРезервуарЭкземпляров(5);

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("несуществующий")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура РезервуарноеСемплированиеСтатистически() Экспорт

    // Дано - резервуар на 1 элемент, добавляем 1000
    // При reservoir sampling последний элемент НЕ всегда побеждает
    // В отличие от FIFO, где последний всегда остается
    Резервуар = Новый ОтелРезервуарЭкземпляров(1);

    КоличествоПоследних = 0;
    Для Итерация = 1 По 100 Цикл
        Резервуар.Очистить();
        Для Сч = 1 По 20 Цикл
            Экз = Новый Соответствие();
            Экз.Вставить("asDouble", Сч);
            Резервуар.Предложить("key1", Экз);
        КонецЦикла;

        Результат = Резервуар.Собрать("key1");
        Если Результат[0].Получить("asDouble") = 20 Тогда
            КоличествоПоследних = КоличествоПоследних + 1;
        КонецЕсли;
    КонецЦикла;

    // При FIFO последний ВСЕГДА побеждает (100%).
    // При reservoir sampling вероятность 1/20 = 5%, за 100 попыток ~5 раз.
    // Допустим < 50 - это точно не FIFO.
    Ожидаем.Что(КоличествоПоследних < 50).Равно(Истина);

КонецПроцедуры
