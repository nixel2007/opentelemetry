// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off

#Использовать "../../.."
#Использовать asserts

// Вспомогательные переменные
Перем ОбластьИзКонфигуратора;

&Тест
Процедура КонфигурацияПоУмолчаниюВключена() Экспорт

    // Дано

    // Когда
    Конфигурация = Новый ОтелКонфигурацияМетра();

    // Тогда
    Ожидаем.Что(Конфигурация.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КонфигурацияМожетБытьОтключена() Экспорт

    // Дано

    // Когда
    Конфигурация = Новый ОтелКонфигурацияМетра(Ложь);

    // Тогда
    Ожидаем.Что(Конфигурация.Включен()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура КонфигураторВызываетсяПриСозданииМетра() Экспорт

    // Дано
    ОбластьИзКонфигуратора = Неопределено;
    Конфигуратор = Новый Действие(ЭтотОбъект, "КонфигураторМетра");
    Провайдер = Новый ОтелПровайдерМетрик(, , , Конфигуратор);

    // Когда
    Провайдер.ПолучитьМетр("моя-библиотека", "2.0.0");

    // Тогда
    Ожидаем.Что(ОбластьИзКонфигуратора).Не_().Равно(Неопределено);
    Ожидаем.Что(ОбластьИзКонфигуратора.Имя()).Равно("моя-библиотека");
    Ожидаем.Что(ОбластьИзКонфигуратора.Версия()).Равно("2.0.0");

КонецПроцедуры

&Тест
Процедура КонфигураторОтключаетИнструментыМетра() Экспорт

    // Дано
    Конфигуратор = Новый Действие(ЭтотОбъект, "КонфигураторОтключающий");
    Провайдер = Новый ОтелПровайдерМетрик(, , , Конфигуратор);

    // Когда
    Метр = Провайдер.ПолучитьМетр("отключаемая");
    Счетчик = Метр.СоздатьСчетчик("тест");

    // Тогда
    Ожидаем.Что(Счетчик.Включен()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ИнструментыВключеныПоУмолчаниюБезКонфигуратора() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерМетрик();

    // Когда
    Метр = Провайдер.ПолучитьМетр("библиотека");
    Счетчик = Метр.СоздатьСчетчик("тест");

    // Тогда
    Ожидаем.Что(Счетчик.Включен()).Равно(Истина);

КонецПроцедуры

// Callback-конфигуратор: запоминает область и возвращает конфигурацию по умолчанию
Функция КонфигураторМетра(ОбластьИнструментирования) Экспорт
    ОбластьИзКонфигуратора = ОбластьИнструментирования;
    Возврат Новый ОтелКонфигурацияМетра();
КонецФункции

// Callback-конфигуратор: отключает метр
Функция КонфигураторОтключающий(ОбластьИнструментирования) Экспорт // BSLLS:UnusedParameters-off
    Возврат Новый ОтелКонфигурацияМетра(Ложь);
КонецФункции
