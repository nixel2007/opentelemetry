#Использовать asserts
#Использовать moskito

&Тест
Процедура СозданиеПредставления() Экспорт

    // Дано
    КлючиАтрибутов = Новый Массив();
    КлючиАтрибутов.Добавить("method");
    КлючиАтрибутов.Добавить("status");

    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(50);
    Границы.Добавить(100);

    // Когда
    Представление = Новый ОтелПредставление("new.name", "Новое описание", КлючиАтрибутов, Границы, "sum");

    // Тогда
    Ожидаем.Что(Представление.НовоеИмя()).Равно("new.name");
    Ожидаем.Что(Представление.НовоеОписание()).Равно("Новое описание");
    Ожидаем.Что(Представление.РазрешенныеКлючиАтрибутов()).ИмеетДлину(2);
    Ожидаем.Что(Представление.ГраницыГистограммы()).ИмеетДлину(3);
    Ожидаем.Что(Представление.Агрегация()).Равно("sum");

КонецПроцедуры

&Тест
Процедура ДефолтныеЗначения() Экспорт

    // Дано / Когда
    Представление = Новый ОтелПредставление();

    // Тогда - все значения по умолчанию Неопределено
    Ожидаем.Что(Представление.НовоеИмя()).Равно(Неопределено);
    Ожидаем.Что(Представление.НовоеОписание()).Равно(Неопределено);
    Ожидаем.Что(Представление.РазрешенныеКлючиАтрибутов()).Равно(Неопределено);
    Ожидаем.Что(Представление.ГраницыГистограммы()).Равно(Неопределено);
    Ожидаем.Что(Представление.Агрегация()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ЧастичноеЗаполнение() Экспорт

    // Дано / Когда - только имя и описание, остальное по умолчанию
    Представление = Новый ОтелПредставление("renamed.metric", "Переименованная метрика");

    // Тогда
    Ожидаем.Что(Представление.НовоеИмя()).Равно("renamed.metric");
    Ожидаем.Что(Представление.НовоеОписание()).Равно("Переименованная метрика");
    Ожидаем.Что(Представление.РазрешенныеКлючиАтрибутов()).Равно(Неопределено);
    Ожидаем.Что(Представление.ГраницыГистограммы()).Равно(Неопределено);

КонецПроцедуры
