&Тест
Процедура СозданиеПредставления() Экспорт

    // Дано
    КлючиАтрибутов = Новый Массив();
    КлючиАтрибутов.Добавить("method");
    КлючиАтрибутов.Добавить("status");

    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(50);
    Границы.Добавить(100);

    // Когда
    Представление = Новый ОтелПредставление("new.name", "Новое описание", КлючиАтрибутов, Границы, "sum");

    // Тогда
    Ожидаем.Что(Представление.НовоеИмя()).Равно("new.name");
    Ожидаем.Что(Представление.НовоеОписание()).Равно("Новое описание");
    Ожидаем.Что(Представление.РазрешенныеКлючиАтрибутов()).ИмеетДлину(2);
    Ожидаем.Что(Представление.ГраницыГистограммы()).ИмеетДлину(3);
    Ожидаем.Что(Представление.Агрегация()).Равно("sum");

КонецПроцедуры

&Тест
Процедура ДефолтныеЗначения() Экспорт

    // Дано / Когда
    Представление = Новый ОтелПредставление();

    // Тогда - все значения по умолчанию Неопределено
    Ожидаем.Что(Представление.НовоеИмя()).Равно(Неопределено);
    Ожидаем.Что(Представление.НовоеОписание()).Равно(Неопределено);
    Ожидаем.Что(Представление.РазрешенныеКлючиАтрибутов()).Равно(Неопределено);
    Ожидаем.Что(Представление.ГраницыГистограммы()).Равно(Неопределено);
    Ожидаем.Что(Представление.Агрегация()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ЧастичноеЗаполнение() Экспорт

    // Дано / Когда - только имя и описание, остальное по умолчанию
    Представление = Новый ОтелПредставление("renamed.metric", "Переименованная метрика");

    // Тогда
    Ожидаем.Что(Представление.НовоеИмя()).Равно("renamed.metric");
    Ожидаем.Что(Представление.НовоеОписание()).Равно("Переименованная метрика");
    Ожидаем.Что(Представление.РазрешенныеКлючиАтрибутов()).Равно(Неопределено);
    Ожидаем.Что(Представление.ГраницыГистограммы()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ПредставлениеФильтруетАтрибутыСчетчика() Экспорт

    // Дано - View с фильтром атрибутов
    РазрешенныеКлючи = Новый Массив();
    РазрешенныеКлючи.Добавить("method");
    РазрешенныеКлючи.Добавить("status");

    Селектор = Новый ОтелСелекторИнструментов("http.requests");
    Представление = Новый ОтелПредставление(, , РазрешенныеКлючи);

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Провайдер = Новый ОтелПостроительПровайдераМетрик()
        .ЗарегистрироватьЧитатель(Читатель)
        .ЗарегистрироватьПредставление(Селектор, Представление)
        .Построить();

    // Когда - записываем данные с лишними атрибутами
    Метр = Провайдер.ПолучитьМетр("test-lib");
    Счетчик = Метр.СоздатьСчетчик("http.requests");

    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("method", "GET");
    Атрибуты.Установить("status", "200");
    Атрибуты.Установить("host", "example.com");
    Атрибуты.Установить("path", "/api");

    Счетчик.Добавить(1, Атрибуты);
    Провайдер.СброситьБуфер();

    // Тогда - экспортированные данные содержат только разрешенные атрибуты
    Отправленные = Транспорт.ПолучитьОтправленные();
    Ожидаем.Что(Отправленные.Количество()).БольшеИлиРавно(1);

    ДанныеОтлп = Отправленные[0].Получить("Данные");
    РесурсныеМетрики = ДанныеОтлп.Получить("resourceMetrics");
    СкоупМетрики = РесурсныеМетрики[0].Получить("scopeMetrics");
    Метрики = СкоупМетрики[0].Получить("metrics");
    ТочкиДанных = Метрики[0].Получить("sum").Получить("dataPoints");

    ЭкспортированныеАтрибуты = ТочкиДанных[0].Получить("attributes");

    // Должно быть только 2 атрибута (method, status), не 4
    Ожидаем.Что(ЭкспортированныеАтрибуты.Количество()).Равно(2);

    // Проверяем что есть именно method и status
    ИмеетMethod = Ложь;
    ИмеетStatus = Ложь;
    Для Каждого Атрибут Из ЭкспортированныеАтрибуты Цикл
        Если Атрибут.Получить("key") = "method" Тогда
            ИмеетMethod = Истина;
        ИначеЕсли Атрибут.Получить("key") = "status" Тогда
            ИмеетStatus = Истина;
        КонецЕсли;
    КонецЦикла;

    Ожидаем.Что(ИмеетMethod).Равно(Истина);
    Ожидаем.Что(ИмеетStatus).Равно(Истина);

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПредставлениеПереименовываетМетрику() Экспорт

    // Дано - View с переименованием
    Селектор = Новый ОтелСелекторИнструментов("old.metric.name");
    Представление = Новый ОтелПредставление("new.metric.name", "New description");

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Провайдер = Новый ОтелПостроительПровайдераМетрик()
        .ЗарегистрироватьЧитатель(Читатель)
        .ЗарегистрироватьПредставление(Селектор, Представление)
        .Построить();

    // Когда
    Метр = Провайдер.ПолучитьМетр("test-lib");
    Счетчик = Метр.СоздатьСчетчик("old.metric.name", "Old description");
    Счетчик.Добавить(42);
    Провайдер.СброситьБуфер();

    // Тогда - имя и описание в OTLP переопределены
    Отправленные = Транспорт.ПолучитьОтправленные();
    ДанныеОтлп = Отправленные[0].Получить("Данные");
    РесурсныеМетрики = ДанныеОтлп.Получить("resourceMetrics");
    СкоупМетрики = РесурсныеМетрики[0].Получить("scopeMetrics");
    Метрики = СкоупМетрики[0].Получить("metrics");

    Ожидаем.Что(Метрики[0].Получить("name")).Равно("new.metric.name");
    Ожидаем.Что(Метрики[0].Получить("description")).Равно("New description");

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПредставлениеОбъединяетТочкиПослеФильтрации() Экспорт

    // Дано - View с фильтром: только method
    РазрешенныеКлючи = Новый Массив();
    РазрешенныеКлючи.Добавить("method");

    Селектор = Новый ОтелСелекторИнструментов("req.count");
    Представление = Новый ОтелПредставление(, , РазрешенныеКлючи);

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Провайдер = Новый ОтелПостроительПровайдераМетрик()
        .ЗарегистрироватьЧитатель(Читатель)
        .ЗарегистрироватьПредставление(Селектор, Представление)
        .Построить();

    // Когда - записываем с разными host, но одинаковым method
    Метр = Провайдер.ПолучитьМетр("test-lib");
    Счетчик = Метр.СоздатьСчетчик("req.count");

    Атрибуты1 = Новый ОтелАтрибуты();
    Атрибуты1.Установить("method", "GET");
    Атрибуты1.Установить("host", "example.com");

    Атрибуты2 = Новый ОтелАтрибуты();
    Атрибуты2.Установить("method", "GET");
    Атрибуты2.Установить("host", "other.com");

    Счетчик.Добавить(10, Атрибуты1);
    Счетчик.Добавить(20, Атрибуты2);

    Провайдер.СброситьБуфер();

    // Тогда - одна точка данных с суммой 30
    Отправленные = Транспорт.ПолучитьОтправленные();
    ДанныеОтлп = Отправленные[0].Получить("Данные");
    РесурсныеМетрики = ДанныеОтлп.Получить("resourceMetrics");
    СкоупМетрики = РесурсныеМетрики[0].Получить("scopeMetrics");
    Метрики = СкоупМетрики[0].Получить("metrics");
    ТочкиДанных = Метрики[0].Получить("sum").Получить("dataPoints");

    // Должна быть одна объединенная точка данных
    Ожидаем.Что(ТочкиДанных.Количество()).Равно(1);

    // Значение = 10 + 20 = 30 (asInt - строка)
    Ожидаем.Что(ТочкиДанных[0].Получить("asInt")).Равно("30");

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПредставлениеБезСовпаденияНеМеняетДанные() Экспорт

    // Дано - View для другого инструмента
    РазрешенныеКлючи = Новый Массив();
    РазрешенныеКлючи.Добавить("method");

    Селектор = Новый ОтелСелекторИнструментов("other.metric");
    Представление = Новый ОтелПредставление("renamed", , РазрешенныеКлючи);

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Провайдер = Новый ОтелПостроительПровайдераМетрик()
        .ЗарегистрироватьЧитатель(Читатель)
        .ЗарегистрироватьПредставление(Селектор, Представление)
        .Построить();

    // Когда - записываем в другой инструмент
    Метр = Провайдер.ПолучитьМетр("test-lib");
    Счетчик = Метр.СоздатьСчетчик("my.counter", "My counter");

    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("method", "GET");
    Атрибуты.Установить("host", "example.com");

    Счетчик.Добавить(5, Атрибуты);
    Провайдер.СброситьБуфер();

    // Тогда - данные не изменены: имя и атрибуты оригинальные
    Отправленные = Транспорт.ПолучитьОтправленные();
    ДанныеОтлп = Отправленные[0].Получить("Данные");
    РесурсныеМетрики = ДанныеОтлп.Получить("resourceMetrics");
    СкоупМетрики = РесурсныеМетрики[0].Получить("scopeMetrics");
    Метрики = СкоупМетрики[0].Получить("metrics");

    Ожидаем.Что(Метрики[0].Получить("name")).Равно("my.counter");
    Ожидаем.Что(Метрики[0].Получить("description")).Равно("My counter");

    ТочкиДанных = Метрики[0].Получить("sum").Получить("dataPoints");
    ЭкспортированныеАтрибуты = ТочкиДанных[0].Получить("attributes");
    Ожидаем.Что(ЭкспортированныеАтрибуты.Количество()).Равно(2);

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПредставлениеТолькоОписание() Экспорт

    // Дано - View только с новым описанием
    Селектор = Новый ОтелСелекторИнструментов("test.counter");
    Представление = Новый ОтелПредставление(, "Overridden description");

    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Провайдер = Новый ОтелПостроительПровайдераМетрик()
        .ЗарегистрироватьЧитатель(Читатель)
        .ЗарегистрироватьПредставление(Селектор, Представление)
        .Построить();

    // Когда
    Метр = Провайдер.ПолучитьМетр("test-lib");
    Счетчик = Метр.СоздатьСчетчик("test.counter", "Original description");
    Счетчик.Добавить(1);
    Провайдер.СброситьБуфер();

    // Тогда - имя оригинальное, описание переопределено
    Отправленные = Транспорт.ПолучитьОтправленные();
    ДанныеОтлп = Отправленные[0].Получить("Данные");
    РесурсныеМетрики = ДанныеОтлп.Получить("resourceMetrics");
    СкоупМетрики = РесурсныеМетрики[0].Получить("scopeMetrics");
    Метрики = СкоупМетрики[0].Получить("metrics");

    Ожидаем.Что(Метрики[0].Получить("name")).Равно("test.counter");
    Ожидаем.Что(Метрики[0].Получить("description")).Равно("Overridden description");

    Провайдер.Закрыть();

КонецПроцедуры
