&Тест
Процедура ИсключениеАтрибутовПоКлючам() Экспорт

    // Дано - инструмент с исключением ключей атрибутов (View exclude-list)
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    ИсключенныеКлючи = Новый Массив;
    ИсключенныеКлючи.Добавить("path");
    Инструмент.УстановитьИсключенныеКлючиАтрибутов(ИсключенныеКлючи);

    Атрибут = Новый ОтелАтрибуты();
    Атрибут.Установить("method", "GET");
    Атрибут.Установить("path", "/api");
    Атрибут.Установить("status", "200");

    // Когда
    Инструмент.Записать(1, Атрибут);
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда - "path" исключен, остаются "method" и "status"
    ТочкаДанных = Данные.ТочкиДанных()[0];
    ЭкспАтрибуты = ТочкаДанных.Получить("attributes");
    Ожидаем.Что(ЭкспАтрибуты).ИмеетДлину(2);

    КлючиОставшихся = Новый Массив;
    Для Каждого Атр Из ЭкспАтрибуты Цикл
        КлючиОставшихся.Добавить(Атр.Получить("key"));
    КонецЦикла;
    Ожидаем.Что(КлючиОставшихся.Найти("path") = Неопределено).ЭтоИстина();
    Ожидаем.Что(КлючиОставшихся.Найти("method") <> Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура УстановитьРезервуарЭкземпляровЛегаси() Экспорт

    // Дано - устаревший API: передача резервуара напрямую (не через фабрику)
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Резервуар = Новый ОтелРезервуарЭкземпляров(5);

    // Когда - устанавливаем устаревший резервуар
    Инструмент.УстановитьРезервуарЭкземпляров(Резервуар);
    Инструмент.Записать(42);
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда - данные собраны через РезервуарЭкземпляров путь
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);

    // Когда - очищаем (попадает в ветку РезервуарЭкземпляров.Очистить())
    Инструмент.ОчиститьТочкиДанных();
    ДанныеПослеОчистки = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда
    Ожидаем.Что(ДанныеПослеОчистки = Неопределено).ЭтоИстина();

КонецПроцедуры
