КонецПроцедуры

&Тест
Процедура СобратьПередаетИмяОписаниеВМетаданные() Экспорт

    // Дано - View может изменить имя и описание
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "original.name", "original desc", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Инструмент.Записать(1);

    // Когда - передаем изменённые имя и описание (как делает View)
    Данные = Инструмент.Собрать(Ресурс, Область, "view.name", "view desc");

    // Тогда
    Ожидаем.Что(Данные.Имя()).Равно("view.name");
    Ожидаем.Что(Данные.Описание()).Равно("view desc");

КонецПроцедуры

&Тест
Процедура ФильтрацияАтрибутовПоКлючам() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Ключи = Новый Массив;
    Ключи.Добавить("method");
    Инструмент.УстановитьРазрешенныеКлючиАтрибутов(Ключи);

    Атрибут = Новый ОтелАтрибуты();
    Атрибут.Установить("method", "GET");
    Атрибут.Установить("path", "/api");

    // Когда
    Инструмент.Записать(1, Атрибут);
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда - path отфильтрован, только method остался
    ТочкаДанных = Данные.ТочкиДанных()[0];
    ЭкспАтрибуты = ТочкаДанных.Получить("attributes");
    Ожидаем.Что(ЭкспАтрибуты).ИмеетДлину(1);
    Ожидаем.Что(ЭкспАтрибуты[0].Получить("key")).Равно("method");

КонецПроцедуры

