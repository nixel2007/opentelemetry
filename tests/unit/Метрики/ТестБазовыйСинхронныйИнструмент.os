&Тест
Процедура ГистограммаЧерезБазовый() Экспорт

    // Дано - базовый инструмент с агрегатором гистограммы
    Границы = Новый Массив;
    Границы.Добавить(10);
    Границы.Добавить(100);
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Гистограмма(), Ложь, "double");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторГистограммы(Границы), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.hist", "", "ms", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    // Когда
    Инструмент.Записать(5);
    Инструмент.Записать(50);
    Инструмент.Записать(200);
    Данные = Инструмент.Собрать(Ресурс, Область, "test.hist", "");

    // Тогда
    Ожидаем.Что(Данные.ТипМетрики()).Равно(ОтелТипМетрики.Гистограмма());
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);

    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(3);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(255);

КонецПроцедуры

&Тест
Процедура ИгнорироватьНечисловоеЗначение() Экспорт

    // Дано - счетчик
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "long");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
