&Тест
Процедура СозданиеБазовогоСинхронного() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();

    // Когда
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "описание", "1", Агрегатор);

    // Тогда
    Ожидаем.Что(Инструмент.Имя()).Равно("test.counter");
    Ожидаем.Что(Инструмент.Описание()).Равно("описание");
    Ожидаем.Что(Инструмент.ЕдиницаИзмерения()).Равно("1");

КонецПроцедуры

&Тест
Процедура ЗаписатьИСобрать() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "описание", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    // Когда
    Инструмент.Записать(10);
    Инструмент.Записать(32);
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "описание");

    // Тогда
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Данные.ТипМетрики()).Равно(ОтелТипМетрики.Сумма());
    Ожидаем.Что(Данные.Монотонный()).Равно(Истина);
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(42);

КонецПроцедуры

&Тест
Процедура СобратьБезДанныхВозвращаетНеопределено() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "описание", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    // Когда - не записываем значения
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "описание");

    // Тогда
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ЗаписьСАтрибутамиГруппировка() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Атрибут1 = Новый ОтелАтрибуты();
    Атрибут1.Установить("method", "GET");
    Атрибут2 = Новый ОтелАтрибуты();
    Атрибут2.Установить("method", "POST");

    // Когда
    Инструмент.Записать(10, Атрибут1);
    Инструмент.Записать(20, Атрибут1);
    Инструмент.Записать(5, Атрибут2);
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда - 2 серии
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ОчиститьТочкиДанных() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Инструмент.Записать(42);

    // Когда
    Инструмент.ОчиститьТочкиДанных();
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

// BSLLS:Typo-off
&Тест
Процедура КардинальностьЛимитОграничиваетСерии() Экспорт
// BSLLS:Typo-on

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", "1", Агрегатор);
    ЛимитМощности = 3;
    Инструмент.УстановитьЛимитМощности(ЛимитМощности);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    // Когда - записываем 5 разных наборов атрибутов
    Для Сч = 1 По 5 Цикл
        Атрибут = Новый ОтелАтрибуты();
        Атрибут.Установить("key", "val" + Сч);
        Инструмент.Записать(1, Атрибут);
    КонецЦикла;

    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда - не больше лимита + overflow
    Ожидаем.Что(Данные.ТочкиДанных().Количество() <= ЛимитМощности + 1).ЭтоИстина();

КонецПроцедуры

