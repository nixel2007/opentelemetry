&Тест
Процедура УправляющиеСимволыВЕдиницеИзмеренияСохраняются() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "long");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();

    // Когда - TAB (0x09) (без валидации согласно спеке)
    ИнструментТаб = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", Символ(9), Агрегатор);
    // Когда - NUL (0x00)
    ИнструментНуль = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", Символ(0), Агрегатор);

    // Тогда
    Ожидаем.Что(ИнструментТаб.ЕдиницаИзмерения()).Равно(Символ(9));
    Ожидаем.Что(ИнструментНуль.ЕдиницаИзмерения()).Равно(Символ(0));

