// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts

Функция СоздатьМетр()
    Ресурс = Новый ОтелРесурс(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Возврат Новый ОтелМетр(Область, Ресурс);
КонецФункции

&Тест
Процедура ФильтрБезДелегатовПринимаетВсе() Экспорт

    // Дано
    Фильтр = Новый ОтелФильтрМетрик();
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");

    // Когда
    Результат = Фильтр.ТестМетрики(Область, "my.metric", "sum", "1");

    // Тогда
    Ожидаем.Что(Результат).Равно(ОтелРезультатФильтраМетрик.Принять());

КонецПроцедуры

&Тест
Процедура ФильтрБезДелегатаАтрибутовПринимаетВсе() Экспорт

    // Дано
    Фильтр = Новый ОтелФильтрМетрик();
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Атрибуты = Новый Соответствие;
    Атрибуты.Вставить("key", "value");

    // Когда
    Результат = Фильтр.ТестАтрибутов(Область, "my.metric", "sum", "1", Атрибуты);

    // Тогда
    Ожидаем.Что(Результат).Равно(ОтелРезультатФильтраАтрибутов.Принять());

КонецПроцедуры

&Тест
Процедура ФильтрОтбрасываетМетрикуЧерезДелегат() Экспорт

    // Дано - фильтр, который всегда отбрасывает
    ДелегатОтбросить = Новый Действие(ЭтотОбъект, "ФильтрВсегдаОтбрасывает");
    Фильтр = Новый ОтелФильтрМетрик(ДелегатОтбросить);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");

    // Когда / Тогда
    Ожидаем.Что(Фильтр.ТестМетрики(Область, "any.metric", "sum", "1"))
        .Равно(ОтелРезультатФильтраМетрик.Отбросить());

КонецПроцедуры

&Тест
Процедура ФильтрЧастичноеПринятие() Экспорт

    // Дано - фильтр, который возвращает частичное принятие
    ДелегатЧастичный = Новый Действие(ЭтотОбъект, "ФильтрВсегдаЧастичный");
    Фильтр = Новый ОтелФильтрМетрик(ДелегатЧастичный);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");

    // Когда / Тогда
    Ожидаем.Что(Фильтр.ТестМетрики(Область, "http.requests", "sum", "1"))
        .Равно(ОтелРезультатФильтраМетрик.ЧастичноеПринятие());

КонецПроцедуры

&Тест
Процедура ФильтрОтбрасываетАтрибуты() Экспорт

    // Дано - фильтр атрибутов, который всегда отбрасывает
    ДелегатАтр = Новый Действие(ЭтотОбъект, "ФильтрАтрибутовОтбрасывает");
    Фильтр = Новый ОтелФильтрМетрик(Неопределено, ДелегатАтр);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Атрибуты = Новый Соответствие;
    Атрибуты.Вставить("key", "value");

    // Когда / Тогда
    Ожидаем.Что(Фильтр.ТестАтрибутов(Область, "m", "sum", "1", Атрибуты))
        .Равно(ОтелРезультатФильтраАтрибутов.Отбросить());

КонецПроцедуры

&Тест
Процедура ЧитательФильтруетМетрикиПриСборе() Экспорт

    // Дано - создаем метр с двумя счетчиками
    Метр = СоздатьМетр();
    Счетчик1 = Метр.СоздатьСчетчик("public.counter", "Публичный", "1");
    Счетчик2 = Метр.СоздатьСчетчик("secret.counter", "Секретный", "1");
    Счетчик1.Добавить(10);
    Счетчик2.Добавить(20);

    // Создаем фильтр, который отбрасывает все
    ДелегатОтбросить = Новый Действие(ЭтотОбъект, "ФильтрВсегдаОтбрасывает");
    Фильтр = Новый ОтелФильтрМетрик(ДелегатОтбросить);

    // Создаем читатель с фильтром
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);
    Читатель.УстановитьФильтрМетрик(Фильтр);
    Читатель.ДобавитьМетр(Метр);

    // Когда - собираем данные
    Читатель.СброситьБуфер();

    // Тогда - транспорт не получил данных (все отброшено)
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ЧитательБезФильтраСобираетВсе() Экспорт

    // Дано - создаем метр с двумя счетчиками
    Метр = СоздатьМетр();
    Счетчик1 = Метр.СоздатьСчетчик("counter.one", "Первый", "1");
    Счетчик2 = Метр.СоздатьСчетчик("counter.two", "Второй", "1");
    Счетчик1.Добавить(10);
    Счетчик2.Добавить(20);

    // Создаем читатель без фильтра
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Читатель.СброситьБуфер();

    // Тогда - транспорт получил данные
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(1);

КонецПроцедуры

// Вспомогательные методы для делегатов

Функция ФильтрВсегдаОтбрасывает(ОбластьИнструментирования, Имя, Вид, ЕдиницаИзмерения) Экспорт
    Возврат ОтелРезультатФильтраМетрик.Отбросить();
КонецФункции

Функция ФильтрВсегдаЧастичный(ОбластьИнструментирования, Имя, Вид, ЕдиницаИзмерения) Экспорт
    Возврат ОтелРезультатФильтраМетрик.ЧастичноеПринятие();
КонецФункции

Функция ФильтрАтрибутовОтбрасывает(ОбластьИнструментирования, Имя, Вид, ЕдиницаИзмерения, Атрибуты) Экспорт // BSLLS:NumberOfParams-off
    Возврат ОтелРезультатФильтраАтрибутов.Отбросить();
КонецФункции
