// ============================================================
// Тесты временной агрегации (Temporality)
// ============================================================

// --- Дельта-очистка: аккумуляторы сбрасываются ---

&Тест
Процедура ДельтаОчисткаСбрасываетАккумуляторы() Экспорт

    // Дано
    Инструмент = СоздатьСчетчик();
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test", "1.0");
    Инструмент.Записать(10);

    // Когда - очистка в режиме дельта
    Инструмент.ОчиститьТочкиДанных(ОтелВременнаяАгрегация.Дельта());
    Данные = Инструмент.Собрать(Ресурс, Область, "c", "");

    // Тогда - данных нет (аккумуляторы сброшены)
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ДельтаОчисткаСбрасываетВремяСтарта() Экспорт

    // Дано - мок-часы с детерминированным инкрементом (1 секунда = 1_000_000_000 нс на каждый вызов).
    // Нужен потому что реальные часы имеют точность лишь в миллисекунды, а тест выполняется
    // быстрее 1мс, что делает оба вызова ТекущееВремяВНаносекундах() неотличимыми.
    ТекстЧасов =
        "Перем Счетчик;" + Символы.ПС +
        "Функция ТекущееВремяВНаносекундах() Экспорт" + Символы.ПС +
        "    Счетчик = Счетчик + 1000000000;" + Символы.ПС +
        "    Возврат Формат(Счетчик, ""ЧГ="");" + Символы.ПС +
        "КонецФункции" + Символы.ПС +
        "Счетчик = 0;";
    МокЧасы = ЗагрузитьСценарийИзСтроки(ТекстЧасов);
    ОтелУтилиты.УстановитьЧасы(МокЧасы);

    Попытка
        Инструмент = СоздатьСчетчик();
        Ресурс = Новый ОтелРесурс();
        Область = Новый ОтелОбластьИнструментирования("test", "1.0");
        Инструмент.Записать(10);
        Данные1 = Инструмент.Собрать(Ресурс, Область, "c", "");
        ВремяСтарта1 = Данные1.ТочкиДанных()[0].Получить("startTimeUnixNano");

        // Когда - очистка дельта и новая запись
        Инструмент.ОчиститьТочкиДанных(ОтелВременнаяАгрегация.Дельта());
        Инструмент.Записать(5);
        Данные2 = Инструмент.Собрать(Ресурс, Область, "c", "");
        ВремяСтарта2 = Данные2.ТочкиДанных()[0].Получить("startTimeUnixNano");
    Исключение
        ОтелУтилиты.СброситьЧасы();
        ВызватьИсключение;
    КонецПопытки;

    ОтелУтилиты.СброситьЧасы();

    // Тогда - время старта после delta reset строго больше предыдущего
    Ожидаем.Что(ВремяСтарта2 > ВремяСтарта1).ЭтоИстина();

КонецПроцедуры

// --- Кумулятивная очистка: аккумуляторы сохраняются ---

&Тест
Процедура КумулятивнаяОчисткаСохраняетАккумуляторы() Экспорт

    // Дано
    Инструмент = СоздатьСчетчик();
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test", "1.0");
    Инструмент.Записать(10);

    // Когда - очистка в режиме кумулятивная
    Инструмент.ОчиститьТочкиДанных(ОтелВременнаяАгрегация.Кумулятивная());
    Данные = Инструмент.Собрать(Ресурс, Область, "c", "");

    // Тогда - данные сохранились
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(10);

КонецПроцедуры

&Тест
Процедура КумулятивнаяОчисткаСохраняетВремяСтарта() Экспорт

    // Дано
    Инструмент = СоздатьСчетчик();
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test", "1.0");
    Инструмент.Записать(10);
    Данные1 = Инструмент.Собрать(Ресурс, Область, "c", "");
    ВремяСтарта1 = Данные1.ТочкиДанных()[0].Получить("startTimeUnixNano");

    // Когда - очистка кумулятивная и новая запись
    Инструмент.ОчиститьТочкиДанных(ОтелВременнаяАгрегация.Кумулятивная());
    Инструмент.Записать(5);
    Данные2 = Инструмент.Собрать(Ресурс, Область, "c", "");
    ВремяСтарта2 = Данные2.ТочкиДанных()[0].Получить("startTimeUnixNano");

    // Тогда - время старта НЕ изменилось (кумулятивная)
    Ожидаем.Что(ВремяСтарта2).Равно(ВремяСтарта1);

КонецПроцедуры

&Тест
Процедура КумулятивнаяНакапливаетЗначения() Экспорт

    // Дано
    Инструмент = СоздатьСчетчик();
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test", "1.0");
    Инструмент.Записать(10);

    // Когда - экспорт кумулятивный, затем новая запись
    Инструмент.ОчиститьТочкиДанных(ОтелВременнаяАгрегация.Кумулятивная());
    Инструмент.Записать(5);
    Данные = Инструмент.Собрать(Ресурс, Область, "c", "");

    // Тогда - значение кумулятивное (10 + 5 = 15)
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(15);

КонецПроцедуры

&Тест
Процедура КумулятивнаяОчисткаОчищаетЭкземпляры() Экспорт

    // Дано
    Инструмент = СоздатьСчетчик();
    Инструмент.Записать(10);

    // Когда - кумулятивная очистка
    Инструмент.ОчиститьТочкиДанных(ОтелВременнаяАгрегация.Кумулятивная());

    // Тогда - экземпляры очищены, но аккумуляторы сохранены
    Ожидаем.Что(Инструмент.КоличествоСерий()).Равно(1);

КонецПроцедуры

// --- Обратная совместимость: без параметра = дельта ---

&Тест
Процедура ОчисткаБезПараметраРаботаетКакДельта() Экспорт

    // Дано
    Инструмент = СоздатьСчетчик();
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test", "1.0");
    Инструмент.Записать(10);

    // Когда - вызов без параметра (обратная совместимость)
    Инструмент.ОчиститьТочкиДанных();
    Данные = Инструмент.Собрать(Ресурс, Область, "c", "");

    // Тогда - данных нет (дельта-поведение)
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

// --- MetricReader передает временность при очистке ---

&Тест
Процедура ЧитательПередаетВременностьПриОчистке() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter", "1");
    Счетчик.Добавить(100);

    ТранспортВПамять = Новый ОтелВПамятьТранспорт();
    СелекторДельта = ОтелСелекторВременнойАгрегации.НизкоеПотреблениеПамяти();
    Экспортер = Новый ОтелЭкспортерМетрик(ТранспортВПамять, СелекторДельта);

    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);
    Читатель.ДобавитьМетр(Метр);

    // Когда - первый сбор
    Читатель.СброситьБуфер();

    // Записываем ещё
    Счетчик.Добавить(50);

    // Второй сбор
    Читатель.СброситьБуфер();

    // Тогда - при дельта: второй экспорт содержит только 50 (не 150)
    Отправки = ТранспортВПамять.ПолучитьОтправленные();
    Ожидаем.Что(Отправки.Количество()).Равно(2);

КонецПроцедуры

&Тест
Процедура ЧитательКумулятивныйСохраняетАккумуляторы() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter", "1");
    Счетчик.Добавить(100);

    ТранспортВПамять = Новый ОтелВПамятьТранспорт();
    СелекторКумулятивный = ОтелСелекторВременнойАгрегации.ВсегдаКумулятивная();
    Экспортер = Новый ОтелЭкспортерМетрик(ТранспортВПамять, СелекторКумулятивный);

    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);
    Читатель.ДобавитьМетр(Метр);

    // Когда - первый сбор
    Читатель.СброситьБуфер();

    // Записываем ещё
    Счетчик.Добавить(50);

    // Второй сбор
    Читатель.СброситьБуфер();

    // Тогда - при кумулятивной: оба экспорта отправлены
    Отправки = ТранспортВПамять.ПолучитьОтправленные();
    Ожидаем.Что(Отправки.Количество()).Равно(2);

КонецПроцедуры

// --- Экспортер предоставляет селектор ---

&Тест
Процедура ЭкспортерПредоставляетВременнуюАгрегацию() Экспорт

    // Дано
    ТранспортВПамять = Новый ОтелВПамятьТранспорт();
    СелекторДельта = ОтелСелекторВременнойАгрегации.НизкоеПотреблениеПамяти();
    Экспортер = Новый ОтелЭкспортерМетрик(ТранспортВПамять, СелекторДельта);

    // Когда
    Временность = Экспортер.ПолучитьВременнуюАгрегацию("counter");

    // Тогда
    Ожидаем.Что(Временность).Равно(ОтелВременнаяАгрегация.Дельта());

КонецПроцедуры

&Тест
Процедура ЭкспортерПоУмолчаниюКумулятивный() Экспорт

    // Дано
    ТранспортВПамять = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(ТранспортВПамять);

    // Когда
    Временность = Экспортер.ПолучитьВременнуюАгрегацию("counter");

    // Тогда - по умолчанию кумулятивная
    Ожидаем.Что(Временность).Равно(ОтелВременнаяАгрегация.Кумулятивная());

КонецПроцедуры

// ============================================================
// Вспомогательные методы
// ============================================================

Функция СоздатьСчетчик()
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Возврат Новый ОтелБазовыйСинхронныйИнструмент("test.counter", "", "1", Агрегатор);
КонецФункции

Функция СоздатьМетр()
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test", "1.0");
    Возврат Новый ОтелМетр(Область, Ресурс);
КонецФункции
