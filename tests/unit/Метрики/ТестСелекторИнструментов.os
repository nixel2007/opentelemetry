#Использовать asserts
#Использовать moskito

&Тест
Процедура УстановкаИмени() Экспорт

    // Дано / Когда
    Селектор = Новый ОтелСелекторИнструментов("http.requests");

    // Тогда
    Ожидаем.Что(Селектор.Имя()).Равно("http.requests");
    Ожидаем.Что(Селектор.ТипИнструмента()).Равно(Неопределено);
    Ожидаем.Что(Селектор.ИмяМетра()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура УстановкаТипа() Экспорт

    // Дано / Когда
    Селектор = Новый ОтелСелекторИнструментов(Неопределено, "histogram");

    // Тогда
    Ожидаем.Что(Селектор.Имя()).Равно(Неопределено);
    Ожидаем.Что(Селектор.ТипИнструмента()).Равно("histogram");

КонецПроцедуры

&Тест
Процедура СовпадениеПоИмени() Экспорт

    // Дано
    Селектор = Новый ОтелСелекторИнструментов("http.requests");

    // Тогда — совпадающий инструмент
    Ожидаем.Что(Селектор.Совпадает("http.requests", "sum")).Равно(Истина);

    // Тогда — несовпадающий инструмент
    Ожидаем.Что(Селектор.Совпадает("http.duration", "histogram")).Равно(Ложь);

    // Тогда — подстановочный знак "*" пропускает всё
    СелекторВсе = Новый ОтелСелекторИнструментов("*");
    Ожидаем.Что(СелекторВсе.Совпадает("any.name")).Равно(Истина);

    // Тогда — пустой селектор пропускает всё
    СелекторПустой = Новый ОтелСелекторИнструментов();
    Ожидаем.Что(СелекторПустой.Совпадает("any.name", "sum", "lib")).Равно(Истина);

КонецПроцедуры
