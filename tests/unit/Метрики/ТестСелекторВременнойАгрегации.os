&Тест
Процедура ОпределитьТипИнструмента_Счетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("библ", "1.0");
    Счетчик = Метр.СоздатьСчетчик("test.counter");

    // Когда
    Тип = ОтелСелекторВременнойАгрегации.ОпределитьТипИнструмента(Счетчик);

    // Тогда
    Ожидаем.Что(Тип).Равно("counter");

КонецПроцедуры

