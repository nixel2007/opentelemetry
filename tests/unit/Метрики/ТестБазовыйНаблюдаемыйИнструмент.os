// ============================================================

&Тест
Процедура СозданиеБазовогоНаблюдаемого() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Действие = Лямбда.Выражение("н -> н.Записать(42)").ВДействие();

    // Когда
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Действие, "", "1", Агрегатор);

    // Тогда
    Ожидаем.Что(Инструмент.Имя()).Равно("obs.counter");
    Ожидаем.Что(Инструмент.ЕдиницаИзмерения()).Равно("1");

КонецПроцедуры

&Тест
Процедура СобратьВызываетCallbackИВозвращаетДанные() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Действие = Лямбда.Выражение("н -> н.Записать(42)").ВДействие();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Действие, "описание", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    // Когда
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "описание");

    // Тогда
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Данные.ТипМетрики()).Равно(ОтелТипМетрики.Сумма());
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(42);

КонецПроцедуры

&Тест
Процедура СобратьБезCallbackВозвращаетНеопределено() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Неопределено, "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    // Когда
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");

    // Тогда
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ВнешниеНаблюденияИзМультиCallback() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Неопределено, "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Наблюдение = Новый ОтелНаблюдениеМетрики();
    Наблюдение.Записать(100);

    // Когда
    Инструмент.ДобавитьВнешниеНаблюдения(Наблюдение);
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");

    // Тогда
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(100);

КонецПроцедуры

&Тест
Процедура ОчиститьТочкиДанныхНаблюдаемого() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Неопределено, "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Наблюдение = Новый ОтелНаблюдениеМетрики();
    Наблюдение.Записать(100);
    Инструмент.ДобавитьВнешниеНаблюдения(Наблюдение);

    // Когда
    Инструмент.ОчиститьТочкиДанных();
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");

    // Тогда
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ДатчикЧерезБазовыйНаблюдаемый() Экспорт

    // Дано - Gauge aggregator
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Датчик(), Ложь, "double");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторПоследнегоЗначения(), АгрегаторБаза).Построить();
    Действие = Лямбда.Выражение("н -> н.Записать(99.5)").ВДействие();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.gauge", Действие, "Температура", "C", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    // Когда
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.gauge", "Температура");

    // Тогда
    Ожидаем.Что(Данные.ТипМетрики()).Равно(ОтелТипМетрики.Датчик());
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(99.5);

КонецПроцедуры
