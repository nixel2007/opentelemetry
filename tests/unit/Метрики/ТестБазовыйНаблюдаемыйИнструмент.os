&Тест
Процедура УправляющиеСимволыВЕдиницеИзмеренияСохраняются() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "long");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Действие = Лямбда.Выражение("н -> н.Записать(1)").ВДействие();

    // Когда - TAB
    ИнструментТаб = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Действие, "", Символ(9), Агрегатор);
    // Когда - NUL
    ИнструментНуль = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Действие, "", Символ(0), Агрегатор);

    // Тогда
    Ожидаем.Что(ИнструментТаб.ЕдиницаИзмерения()).Равно(Символ(9));
    Ожидаем.Что(ИнструментНуль.ЕдиницаИзмерения()).Равно(Символ(0));

КонецПроцедуры

&Тест
Процедура ДобавитьCallbackДубликатИгнорируется() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "long");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Действие = Лямбда.Выражение("н -> н.Записать(1)").ВДействие();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Неопределено, "", "1", Агрегатор);

    // Когда - добавляем один и тот же callback дважды
    Инструмент.ДобавитьCallback(Действие);
    Инструмент.ДобавитьCallback(Действие);

    // Тогда - данные собираются один раз (дубликат проигнорирован)
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура УдалитьCallbackВозвращаетПустыеДанные() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "long");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Действие = Лямбда.Выражение("н -> н.Записать(42)").ВДействие();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Действие, "", "1", Агрегатор);

    // Когда - удаляем callback
    Инструмент.УдалитьCallback(Действие);

    // Тогда - данные пустые (Собрать возвращает Неопределено без callbacks)
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");
    Ожидаем.Что(Данные).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ВыполнитьОдинCallbackССостоянием() Экспорт

    // Дано - callback с двумя параметрами: (Наблюдение, Состояние)
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "long");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    // Callback принимает (Наблюдение, Состояние) и записывает состояние как значение
    Действие = Лямбда.Выражение("(н, с) -> н.Записать(с)").ВДействие();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Неопределено, "", "1", Агрегатор);
    Инструмент.ДобавитьCallback(Действие, 99);

    // Когда - собираем данные
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");

    // Тогда - callback вызван с состоянием
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(99);

КонецПроцедуры

&Тест
Процедура МассивCallbacksВКонструкторе() Экспорт

    // Дано - массив из двух callbacks
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "long");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Действие1 = Лямбда.Выражение("н -> н.Записать(10)").ВДействие();
    Действие2 = Лямбда.Выражение("н -> н.Записать(20)").ВДействие();
    МассивCallbacks = Новый Массив();
    МассивCallbacks.Добавить(Действие1);
    МассивCallbacks.Добавить(Действие2);

    // Когда - передаем массив в конструктор
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", МассивCallbacks, "", "1", Агрегатор);

    // Тогда - оба callback вызваны
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");
    ОбщаяСумма = 0;
    Для Каждого Точка Из Данные.ТочкиДанных() Цикл
        ОбщаяСумма = ОбщаяСумма + Точка.Получить("value");
    КонецЦикла;
    Ожидаем.Что(ОбщаяСумма).Равно(30);

КонецПроцедуры

&Тест
Процедура ДобавитьCallbackНеопределенноПропускается() Экспорт

    // Дано - инструмент без callbacks
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "long");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Неопределено, "", "1", Агрегатор);

    // Когда - добавляем Неопределено (→ line 113: ранний выход)
    Инструмент.ДобавитьCallback(Неопределено);

    // Тогда - никаких callbacks не добавлено, Собрать возвращает Неопределено
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");
    Ожидаем.Что(Данные).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура CallbackБросаетИсключениеЛогируетПредупреждение() Экспорт

    // Дано - callback, бросающий исключение (→ lines 376-378)
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "long");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();

    ТекстНаблюдателя = "
    |Процедура Наблюдать(Наблюдение) Экспорт
    |    ВызватьИсключение ""тест: ошибка callback"";
    |КонецПроцедуры";
    Наблюдатель = ЗагрузитьСценарийИзСтроки(ТекстНаблюдателя);
    Действие = Новый Действие(Наблюдатель, "Наблюдать");

    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.throwing", Действие, "", "1", Агрегатор);

    // Когда - callback бросает, ВыполнитьCallbackСУчетомТаймаута (inline) перехватывает
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.throwing", "");

    // Тогда - callback упал, записей нет, Данные=Неопределено (нет точек)
    Ожидаем.Что(Данные).Равно(Неопределено);

КонецПроцедуры
