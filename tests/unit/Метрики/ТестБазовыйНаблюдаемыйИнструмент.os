&Тест
Процедура ВнешниеНаблюденияИзМультиCallback() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Неопределено, "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Наблюдение = Новый ОтелНаблюдениеМетрики();
    Наблюдение.Записать(100);

    // Когда - имитируем callback-контекст (мульти-callback dispatch SDK).
    Инструмент.УстановитьВыполняетсяCallback(Истина);
    Инструмент.ДобавитьВнешниеНаблюдения(Наблюдение);
    Инструмент.УстановитьВыполняетсяCallback(Ложь);
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");

    // Тогда
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(100);

КонецПроцедуры

&Тест
Процедура ВнешниеНаблюденияВнеCallbackИгнорируются() Экспорт

    // Дано - спека: SDK SHOULD disregard async instrument APIs outside callbacks
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Неопределено, "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Наблюдение = Новый ОтелНаблюдениеМетрики();
    Наблюдение.Записать(100);

    // Когда - вызов вне callback-контекста (флаг по умолчанию Ложь)
    Инструмент.ДобавитьВнешниеНаблюдения(Наблюдение);
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");

    // Тогда - наблюдения отброшены, точек данных нет
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ОчиститьТочкиДанныхНаблюдаемого() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйНаблюдаемыйИнструмент(
        "obs.counter", Неопределено, "", "1", Агрегатор);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Наблюдение = Новый ОтелНаблюдениеМетрики();
    Наблюдение.Записать(100);
    Инструмент.УстановитьВыполняетсяCallback(Истина);
    Инструмент.ДобавитьВнешниеНаблюдения(Наблюдение);
    Инструмент.УстановитьВыполняетсяCallback(Ложь);

    // Когда
    Инструмент.ОчиститьТочкиДанных();
    Данные = Инструмент.Собрать(Ресурс, Область, "obs.counter", "");

    // Тогда
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

