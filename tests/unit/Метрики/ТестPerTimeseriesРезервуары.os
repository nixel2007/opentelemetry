// ========================
// Фабрика простых резервуаров
// ========================

&Тест
Процедура ФабрикаПростыхРезервуаровСоздаетНовыйЭкземпляр() Экспорт

    // Дано
    Фабрика = Новый ОтелФабрикаПростыхРезервуаров(5);

    // Когда
    Р1 = Фабрика.СоздатьРезервуар();
    Р2 = Фабрика.СоздатьРезервуар();

    // Тогда - два независимых экземпляра
    Ожидаем.Что(Р1 <> Р2).ЭтоИстина();
    Ожидаем.Что(Р1.МаксРазмер()).Равно(5);
    Ожидаем.Что(Р2.МаксРазмер()).Равно(5);

КонецПроцедуры

&Тест
Процедура ФабрикаПростыхРезервуаровВозвращаетРазмер() Экспорт

    // Дано / Когда
    Фабрика = Новый ОтелФабрикаПростыхРезервуаров(3);

    // Тогда
    Ожидаем.Что(Фабрика.Размер()).Равно(3);

КонецПроцедуры

// ========================
// Фабрика выровненных резервуаров гистограммы
// ========================

&Тест
Процедура ФабрикаВыровненныхСоздаетНовыйЭкземпляр() Экспорт

    // Дано
    Границы = Новый Массив;
    Границы.Добавить(10);
    Границы.Добавить(100);
    Фабрика = Новый ОтелФабрикаВыровненныхРезервуаровГистограммы(Границы);

    // Когда
    Р1 = Фабрика.СоздатьРезервуар();
    Р2 = Фабрика.СоздатьРезервуар();

    // Тогда - два независимых экземпляра с правильным размером
    Ожидаем.Что(Р1 <> Р2).ЭтоИстина();
    Ожидаем.Что(Р1.МаксРазмер()).Равно(3); // 2 границы + 1 overflow

КонецПроцедуры

// ========================
// Noop-резервуар
// ========================

&Тест
Процедура НоопРезервуарИгнорируетПредложить() Экспорт

    // Дано
    Резервуар = Новый ОтелНоопРезервуарЭкземпляров();

    // Когда
    Резервуар.Предложить("key", 42.0);

    // Тогда - пустой результат
    Ожидаем.Что(Резервуар.Собрать("key")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ФабрикаНоопСоздаетНоопРезервуар() Экспорт

    // Дано
    Фабрика = Новый ОтелФабрикаNoopРезервуаров();

    // Когда
    Резервуар = Фабрика.СоздатьРезервуар();
    Резервуар.Предложить("key", 1.0);

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("key")).ИмеетДлину(0);

КонецПроцедуры

// ========================
// ОтелБазовыйСинхронныйИнструмент - per-timeseries exemplars
// ========================

// Вспомогательная функция для создания инструмента-счетчика с фабрикой
Функция СоздатьИнструментСФабрикой(Фабрика)
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "описание", "1", Агрегатор);
    Инструмент.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());
    Инструмент.УстановитьФабрикуРезервуаров(Фабрика);
    Возврат Инструмент;
КонецФункции

&Тест
Процедура УстановитьФабрикуРезервуаровРаботает() Экспорт

    // Дано
    Фабрика = Новый ОтелФабрикаПростыхРезервуаров(1);
    Инструмент = СоздатьИнструментСФабрикой(Фабрика);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    // Когда
    Инструмент.Записать(10);
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда - данные собраны корректно
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ДвеСерииАтрибутовНезависимыеExemplars() Экспорт

    // Дано - две серии атрибутов должны иметь независимые резервуары exemplars
    Фабрика = Новый ОтелФабрикаПростыхРезервуаров(1);
    Инструмент = СоздатьИнструментСФабрикой(Фабрика);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Атрибут1 = Новый ОтелАтрибуты();
    Атрибут1.Установить("method", "GET");
    Атрибут2 = Новый ОтелАтрибуты();
    Атрибут2.Установить("method", "POST");

    // Когда - записываем в обе серии
    Инструмент.Записать(10, Атрибут1);
    Инструмент.Записать(20, Атрибут2);
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда - 2 серии с независимыми точками данных (exemplars не перемешаны)
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(2);

    // Проверяем что каждая точка данных корректна
    ТочкиДанных = Данные.ТочкиДанных();
    Для Каждого ТочкаДанных Из ТочкиДанных Цикл
        Атрибуты = ТочкаДанных.Получить("attributes");
        // Каждая точка данных должна иметь ровно 1 атрибут (method=GET или method=POST)
        Ожидаем.Что(Атрибуты).ИмеетДлину(1);
        Ожидаем.Что(Атрибуты[0].Получить("key")).Равно("method");
    КонецЦикла;

КонецПроцедуры

&Тест
Процедура МокФабрикаВызываетсяТочноДвеРазаДляДвухСерий() Экспорт

    // Дано - счетчик вызовов СоздатьРезервуар
    СчетчикВызовов = Новый АтомарноеЧисло(0);

    ТекстМокФабрики = "
    |#Использовать atomic
    |Перем СчетчикВнешний;
    |Функция СоздатьРезервуар() Экспорт
    |    СчетчикВнешний.ПолучитьИДобавить(1);
    |    Возврат Новый ОтелРезервуарЭкземпляров(1);
    |КонецФункции
    |Процедура УстановитьСчетчик(С) Экспорт
    |    СчетчикВнешний = С;
    |КонецПроцедуры";
    МокФабрика = ЗагрузитьСценарийИзСтроки(ТекстМокФабрики);
    МокФабрика.УстановитьСчетчик(СчетчикВызовов);

    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", "1", Агрегатор);
    Инструмент.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());
    Инструмент.УстановитьФабрикуРезервуаров(МокФабрика);

    Атрибут1 = Новый ОтелАтрибуты();
    Атрибут1.Установить("method", "GET");
    Атрибут2 = Новый ОтелАтрибуты();
    Атрибут2.Установить("method", "POST");

    // Когда - 10 записей в 2 набора атрибутов (5 + 5)
    Для Сч = 1 По 5 Цикл
        Инструмент.Записать(Сч, Атрибут1);
        Инструмент.Записать(Сч, Атрибут2);
    КонецЦикла;

    // Тогда - СоздатьРезервуар() вызван ровно 2 раза (по одному на каждую серию)
    Ожидаем.Что(СчетчикВызовов.Получить()).Равно(2);

КонецПроцедуры

&Тест
Процедура ОдинКлючАтрибутовСоздаетОдинРезервуар() Экспорт

    // Дано
    СчетчикВызовов = Новый АтомарноеЧисло(0);

    ТекстМокФабрики = "
    |#Использовать atomic
    |Перем СчетчикВнешний;
    |Функция СоздатьРезервуар() Экспорт
    |    СчетчикВнешний.ПолучитьИДобавить(1);
    |    Возврат Новый ОтелРезервуарЭкземпляров(1);
    |КонецФункции
    |Процедура УстановитьСчетчик(С) Экспорт
    |    СчетчикВнешний = С;
    |КонецПроцедуры";
    МокФабрика = ЗагрузитьСценарийИзСтроки(ТекстМокФабрики);
    МокФабрика.УстановитьСчетчик(СчетчикВызовов);

    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Инструмент = Новый ОтелБазовыйСинхронныйИнструмент(
        "test.counter", "", "1", Агрегатор);
    Инструмент.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());
    Инструмент.УстановитьФабрикуРезервуаров(МокФабрика);

    Атрибут = Новый ОтелАтрибуты();
    Атрибут.Установить("method", "GET");

    // Когда - 10 записей в одну серию
    Для Сч = 1 По 10 Цикл
        Инструмент.Записать(Сч, Атрибут);
    КонецЦикла;

    // Тогда - СоздатьРезервуар() вызван ровно 1 раз
    Ожидаем.Что(СчетчикВызовов.Получить()).Равно(1);

КонецПроцедуры

&Тест
Процедура ОчиститьТочкиДанныхСбрасываетРезервуары() Экспорт

    // Дано
    Фабрика = Новый ОтелФабрикаПростыхРезервуаров(5);
    Инструмент = СоздатьИнструментСФабрикой(Фабрика);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    Атрибут = Новый ОтелАтрибуты();
    Атрибут.Установить("key", "val");
    Инструмент.Записать(42, Атрибут);

    // Когда - очищаем
    Инструмент.ОчиститьТочкиДанных();
    // Снова записываем в ту же серию
    Инструмент.Записать(100, Атрибут);
    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда - данные есть (инструмент не сломан после очистки)
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура МножественныеЗаписиБезИсключений() Экспорт

    // Дано - симулируем "конкурентную" запись: множество серий без ошибок
    Фабрика = Новый ОтелФабрикаПростыхРезервуаров(1);
    Инструмент = СоздатьИнструментСФабрикой(Фабрика);
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");

    // Когда - записываем в 10 разных серий по 10 измерений
    Для Серия = 1 По 10 Цикл
        Атрибут = Новый ОтелАтрибуты();
        Атрибут.Установить("серия", Серия);
        Для Изм = 1 По 10 Цикл
            Инструмент.Записать(Изм, Атрибут);
        КонецЦикла;
    КонецЦикла;

    Данные = Инструмент.Собрать(Ресурс, Область, "test.counter", "");

    // Тогда - данные собраны без исключений
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(10);

КонецПроцедуры

&Тест
Процедура ГистограммаИспользуетФабрикуВыровненныхРезервуаров() Экспорт

    // Дано - гистограмма через ОтелМетр должна использовать per-timeseries резервуары
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(Область, Ресурс);

    Гистограмма = Метр.СоздатьГистограмму("test.hist");

    Атрибут1 = Новый ОтелАтрибуты();
    Атрибут1.Установить("route", "/api");
    Атрибут2 = Новый ОтелАтрибуты();
    Атрибут2.Установить("route", "/health");

    // Когда - записываем в 2 серии
    Гистограмма.Записать(50, Атрибут1);
    Гистограмма.Записать(5, Атрибут2);

    Данные = Гистограмма.Собрать(Ресурс, Область, "test.hist", "");

    // Тогда - 2 независимых точки данных
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры
