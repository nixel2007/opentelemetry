    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("obs.inline", Действие, "Inline", "1");
    Ожидаем.Что(Счетчик.ТаймаутCallbackМс()).Равно(0);

    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(7);

КонецПроцедуры

Процедура ОбратныйВызовССостоянием(Наблюдение, Состояние) Экспорт // BSLLS:UnusedParameters-off
    ЗахваченноеСостояниеОбратногоВызова = Состояние;
КонецПроцедуры

&Тест
Процедура CallbackПолучаетСостояниеПриВызове() Экспорт

    // Дано - наблюдаемый счетчик с callback, ожидающим состояние
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("test.obs.counter");

    МоеСостояние = "my-state";
    Счетчик.ДобавитьCallback(Новый Действие(ЭтотОбъект, "ОбратныйВызовССостоянием"), МоеСостояние);

    // Когда - собираем данные (внутри вызывается callback)
    СобратьДанные(Счетчик, Метр);

    // Тогда - callback получил переданное состояние
    Ожидаем.Что(ЗахваченноеСостояниеОбратногоВызова).Равно(МоеСостояние);

КонецПроцедуры
