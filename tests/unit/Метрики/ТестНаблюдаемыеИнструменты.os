// Callback для теста мульти-записи
Процедура МультиЗаписьCallback(Наблюдение) Экспорт
    Атрибуты1 = Новый ОтелАтрибуты();
    Атрибуты1.Установить("cpu", "0");
    Наблюдение.Записать(42, Атрибуты1);

    Атрибуты2 = Новый ОтелАтрибуты();
    Атрибуты2.Установить("cpu", "1");
    Наблюдение.Записать(41, Атрибуты2);
КонецПроцедуры

&Тест
Процедура НесколькоНаблюденийСАтрибутами() Экспорт

    // Дано - callback записывает два значения с разными атрибутами
    Метр = СоздатьМетр();
    Действие = Новый Действие(ЭтотОбъект, "МультиЗаписьCallback");

    // Когда
    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("multi.obs", Действие, "Multi value", "1");
    Данные = СобратьДанные(Счетчик, Метр);
    ТочкиДанных = Данные.ТочкиДанных();

    // Тогда
    Ожидаем.Что(ТочкиДанных).ИмеетДлину(2);
    Ожидаем.Что(ТочкиДанных[0].Получить("value")).Равно(42);
    Ожидаем.Что(ТочкиДанных[1].Получить("value")).Равно(41);

    // Атрибуты сериализованы в OTLP формат
    Атрибуты0 = ТочкиДанных[0].Получить("attributes");
    Ожидаем.Что(Атрибуты0).ИмеетДлину(1);

    Атрибуты1 = ТочкиДанных[1].Получить("attributes");
    Ожидаем.Что(Атрибуты1).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура НаблюдениеБезАтрибутов() Экспорт

    // Дано - callback записывает значение без атрибутов
    Метр = СоздатьМетр();
    Действие = Лямбда.Выражение("н -> н.Записать(100)").ВДействие();

    // Когда
    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("no.attrs", Действие);
    Данные = СобратьДанные(Счетчик, Метр);
    ТочкиДанных = Данные.ТочкиДанных();

    // Тогда - атрибуты должны быть пустым массивом
    Ожидаем.Что(ТочкиДанных).ИмеетДлину(1);
    Ожидаем.Что(ТочкиДанных[0].Получить("value")).Равно(100);
    Ожидаем.Что(ТочкиДанных[0].Получить("attributes")).ИмеетДлину(0);

КонецПроцедуры

// Callback для тестов множественных callback
Процедура ВторойCallback(Наблюдение) Экспорт
    Наблюдение.Записать(200);
КонецПроцедуры

&Тест
Процедура МножественныеCallbackНаблюдаемогоСчетчика() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Действие1 = Лямбда.Выражение("н -> н.Записать(10)").ВДействие();
    Действие2 = Новый Действие(ЭтотОбъект, "ВторойCallback");
    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("multi.cb", Действие1, "Мульти callback", "1");

    // Когда
    Счетчик.ДобавитьCallback(Действие2);
    Данные = СобратьДанные(Счетчик, Метр);

    // Тогда
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(2);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(10);
    Ожидаем.Что(Данные.ТочкиДанных()[1].Получить("value")).Равно(200);

КонецПроцедуры

&Тест
Процедура ДерегистрацияCallbackНаблюдаемогоСчетчика() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Действие1 = Лямбда.Выражение("н -> н.Записать(10)").ВДействие();
    Действие2 = Новый Действие(ЭтотОбъект, "ВторойCallback");
    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("dereg.cb", Действие1, "С дерегистрацией", "1");
    Счетчик.ДобавитьCallback(Действие2);

    // Когда - создаем регистрацию и закрываем
    Регистрация = Новый ОтелРегистрацияНаблюдателя(Счетчик, Действие2);
    Регистрация.Закрыть();

    Данные = СобратьДанные(Счетчик, Метр);

    // Тогда - остался только первый callback
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(10);

КонецПроцедуры

&Тест
Процедура СоздатьИнструментБезCallback() Экспорт

    // Дано
    Метр = СоздатьМетр();

    // Когда - создаем без callback, потом добавляем
    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("late.cb");
    Счетчик.ДобавитьCallback(Лямбда.Выражение("н -> н.Записать(55)").ВДействие());

    Данные = СобратьДанные(Счетчик, Метр);

    // Тогда
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(55);

КонецПроцедуры

&Тест
Процедура НаблюдаемыйСчетчикМассивCallback() Экспорт

    // Дано - два callback в массиве
    Метр = СоздатьМетр();
    Атрибуты1 = Новый ОтелАтрибуты();
    Атрибуты1.Установить("k", "a");
    Атрибуты2 = Новый ОтелАтрибуты();
    Атрибуты2.Установить("k", "b");

    // Лямбды не поддерживают захват переменных - используем именованные атрибуты через модуль
    Callback1 = Лямбда.Выражение("н -> н.Записать(10)").ВДействие();
    Callback2 = Лямбда.Выражение("н -> н.Записать(20)").ВДействие();

    Массив = Новый Массив;
    Массив.Добавить(Callback1);
    Массив.Добавить(Callback2);

    // Когда
    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("multi.callbacks", Массив);

    // Тогда - оба callback вызываются при сборе
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры

