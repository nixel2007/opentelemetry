&Тест
Процедура НаблюдаемыйИнструментПереполнениеМощности() Экспорт

    // Дано - метр с лимитом мощности 2
    Метр = СоздатьМетр();
    Метр.УстановитьЛимитМощности(2);

    Действие = Лямбда.Выражение("н ->
        |    А1 = Новый ОтелАтрибуты(); А1.Установить(""k"", ""a""); н.Записать(1, А1);
        |    А2 = Новый ОтелАтрибуты(); А2.Установить(""k"", ""b""); н.Записать(1, А2);
        |    А3 = Новый ОтелАтрибуты(); А3.Установить(""k"", ""c""); н.Записать(1, А3);
        |    А4 = Новый ОтелАтрибуты(); А4.Установить(""k"", ""d""); н.Записать(1, А4);").ВДействие();

    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("over.flow", Действие);

    // Когда
    Данные = СобратьДанные(Счетчик, Метр);

    // Тогда - 2 уникальные комбинации + overflow
    ИмеетOverflow = Ложь;
    Для Каждого Точка Из Данные.ТочкиДанных() Цикл
        Атрибуты = Точка.Получить("attributes");
        Для Каждого А Из Атрибуты Цикл
            Если А.Получить("key") = "otel.metric.overflow" Тогда
                ИмеетOverflow = Истина;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    Ожидаем.Что(ИмеетOverflow).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура SoftTimeoutCallbackОтбрасываетИзмерения() Экспорт

    Метр = СоздатьМетр();
    МедленноеДействие = Лямбда.Выражение("н -> Приостановить(1)").ВДействие();

    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("obs.slow", МедленноеДействие, "Slow", "1");
    Счетчик.УстановитьТаймаутCallbackМс(50);

    Данные = СобратьДанные(Счетчик, Метр);

    Ожидаем.Что(Данные).ЭтоНеопределено();

КонецПроцедуры

&Тест
Процедура БезТаймаутаCallbackВыполняетсяInline() Экспорт

    Метр = СоздатьМетр();
