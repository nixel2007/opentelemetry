// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts
#Использовать lambdas

Перем ЗахваченноеСостояниеОбратногоВызова;

Функция СоздатьМетр()
    Ресурс = Новый ОтелРесурс(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Возврат Новый ОтелМетр(Область, Ресурс);
КонецФункции

Функция СобратьДанные(Инструмент, Метр)
    Возврат Инструмент.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Инструмент.Имя(), Инструмент.Описание());
КонецФункции

&Тест
Процедура НаблюдаемыйСчетчик() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Действие = Лямбда.Выражение("н -> н.Записать(42)").ВДействие();

    // Когда
    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("obs.counter", Действие, "Наблюдаемый счетчик", "1");

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("obs.counter");
    Ожидаем.Что(Счетчик.Описание()).Равно("Наблюдаемый счетчик");
    Ожидаем.Что(Счетчик.ЕдиницаИзмерения()).Равно("1");

    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(42);

КонецПроцедуры

