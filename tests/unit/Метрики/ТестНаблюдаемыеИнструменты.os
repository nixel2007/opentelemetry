&Тест
Процедура НаблюдаемыйСчетчик() Экспорт

    // Дано
    Действие = Лямбда.Выражение("-> Возврат 42").ВДействие();

    // Когда
    Счетчик = Новый ОтелНаблюдаемыйСчетчик("obs.counter", Действие, "Наблюдаемый счетчик", "1");

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("obs.counter");
    Ожидаем.Что(Счетчик.Описание()).Равно("Наблюдаемый счетчик");
    Ожидаем.Что(Счетчик.ЕдиницаИзмерения()).Равно("1");

    ТочкиДанных = Счетчик.ТочкиДанных();
    Ожидаем.Что(ТочкиДанных).ИмеетДлину(1);
    Ожидаем.Что(ТочкиДанных[0].Получить("value")).Равно(42);

КонецПроцедуры

&Тест
Процедура НаблюдаемыйРеверсивныйСчетчик() Экспорт

    // Дано
    Действие = Лямбда.Выражение("-> Возврат -5").ВДействие();

    // Когда
    Счетчик = Новый ОтелНаблюдаемыйРеверсивныйСчетчик("obs.updown", Действие, "UpDown", "1");

    // Тогда
    ТочкиДанных = Счетчик.ТочкиДанных();
    Ожидаем.Что(ТочкиДанных).ИмеетДлину(1);
    Ожидаем.Что(ТочкиДанных[0].Получить("value")).Равно(-5);

КонецПроцедуры

&Тест
Процедура НаблюдаемыйДатчик() Экспорт

    // Дано
    Действие = Лямбда.Выражение("-> Возврат 99.5").ВДействие();

    // Когда
    Датчик = Новый ОтелНаблюдаемыйДатчик("obs.gauge", Действие, "Температура", "°C");

    // Тогда
    ТочкиДанных = Датчик.ТочкиДанных();
    Ожидаем.Что(ТочкиДанных).ИмеетДлину(1);
    Ожидаем.Что(ТочкиДанных[0].Получить("value")).Равно(99.5);

КонецПроцедуры

&Тест
Процедура ТипыИнструментов() Экспорт

    // Дано
    Действие = Лямбда.Выражение("-> Возврат 1").ВДействие();

    // Когда
    Счетчик = Новый ОтелНаблюдаемыйСчетчик("c", Действие);
    РевСчетчик = Новый ОтелНаблюдаемыйРеверсивныйСчетчик("u", Действие);
    Датчик = Новый ОтелНаблюдаемыйДатчик("g", Действие);

    // Тогда
    Ожидаем.Что(Счетчик.ТипМетрики()).Равно("sum");
    Ожидаем.Что(Счетчик.Монотонный()).Равно(Истина);
    Ожидаем.Что(Счетчик.ТипЗначения()).Равно("int");

    Ожидаем.Что(РевСчетчик.ТипМетрики()).Равно("sum");
    Ожидаем.Что(РевСчетчик.Монотонный()).Равно(Ложь);
    Ожидаем.Что(РевСчетчик.ТипЗначения()).Равно("int");

    Ожидаем.Что(Датчик.ТипМетрики()).Равно("gauge");
    Ожидаем.Что(Датчик.ТипЗначения()).Равно("double");

КонецПроцедуры
