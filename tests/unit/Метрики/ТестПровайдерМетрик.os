&Тест
Процедура СброситьБуферАсинхронно() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);
    Провайдер = Новый ОтелПровайдерМетрик(, Читатель);
    Метр = Провайдер.ПолучитьМетр("lib", "1.0");
    Счетчик = Метр.СоздатьСчетчик("async.counter");
    Счетчик.Добавить(7);

    // Когда
    Обещание = Провайдер.СброситьБуферАсинхронно();
    Обещание.Получить(5000);

    // Тогда
    Ожидаем.Что(Транспорт.ПолучитьОтправленные().Количество()).БольшеИлиРавно(1);
    Провайдер.Закрыть();

