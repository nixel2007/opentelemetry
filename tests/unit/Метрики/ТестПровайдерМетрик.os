&Тест
Процедура ПостроительМетраFluentChain() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерМетрик();
    АтрибутыСкоупа = Новый ОтелАтрибуты();
    АтрибутыСкоупа.Установить("scope.key", "scope.value");

    // Когда - используем полный fluent chain построителя
    Метр = Провайдер.ПостроительМетра("моя-библ")
        .УстановитьВерсию("2.0.0")
        .УстановитьSchemaUrl("https://schema.example.com")
        .УстановитьАтрибутыСкоупа(АтрибутыСкоупа)
        .Построить();

    // Тогда
    Ожидаем.Что(Метр <> Неопределено).Равно(Истина);
    Ожидаем.Что(Метр.ИмяБиблиотеки()).Равно("моя-библ");
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ВременнаяАгрегацияДельта() Экспорт

    // Тогда - проверяем константы временной агрегации
    Ожидаем.Что(ОтелВременнаяАгрегация.Дельта()).Равно(1);
    Ожидаем.Что(ОтелВременнаяАгрегация.НеУказана()).Равно(0);
    Ожидаем.Что(ОтелВременнаяАгрегация.Кумулятивная()).Равно(2);

КонецПроцедуры

&Тест
Процедура ЗакрытиеПровайдераОтключаетИнструменты() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерМетрик();
    Метр = Провайдер.ПолучитьМетр("test-lib");
    Счетчик = Метр.СоздатьСчетчик("test.counter");
    Ожидаем.Что(Счетчик.Включен()).Равно(Истина);

    // Когда
