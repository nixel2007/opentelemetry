&Тест
Процедура НесколькоЧитателейВПровайдере() Экспорт

    // Дано - два читателя метрик с разными транспортами
    Транспорт1 = Новый ОтелВПамятьТранспорт();
    Транспорт2 = Новый ОтелВПамятьТранспорт();
    Экспортер1 = Новый ОтелЭкспортерМетрик(Транспорт1);
    Экспортер2 = Новый ОтелЭкспортерМетрик(Транспорт2);
    Читатель1 = Новый ОтелПериодическийЧитательМетрик(Экспортер1);
    Читатель2 = Новый ОтелПериодическийЧитательМетрик(Экспортер2);

    // Когда - регистрируем оба в одном провайдере
    Провайдер = Новый ОтелПостроительПровайдераМетрик()
        .ЗарегистрироватьЧитатель(Читатель1)
        .ЗарегистрироватьЧитатель(Читатель2)
        .Построить();

    Метр = Провайдер.ПолучитьМетр("test-lib");
    Счетчик = Метр.СоздатьСчетчик("multi.reader.counter");
    Счетчик.Добавить(42);

    Провайдер.СброситьБуфер();

    // Тогда - оба транспорта получили данные
    Ожидаем.Что(Транспорт1.ПолучитьОтправленные().Количество()).БольшеИлиРавно(1);
    Ожидаем.Что(Транспорт2.ПолучитьОтправленные().Количество()).БольшеИлиРавно(1);

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ЧитателиМетрикВозвращаетМассив() Экспорт

    // Дано - два читателя
    Транспорт1 = Новый ОтелВПамятьТранспорт();
    Транспорт2 = Новый ОтелВПамятьТранспорт();
    Экспортер1 = Новый ОтелЭкспортерМетрик(Транспорт1);
    Экспортер2 = Новый ОтелЭкспортерМетрик(Транспорт2);
    Читатель1 = Новый ОтелПериодическийЧитательМетрик(Экспортер1);
    Читатель2 = Новый ОтелПериодическийЧитательМетрик(Экспортер2);

    Провайдер = Новый ОтелПостроительПровайдераМетрик()
        .ЗарегистрироватьЧитатель(Читатель1)
        .ЗарегистрироватьЧитатель(Читатель2)
        .Построить();

    // Когда
    Читатели = Провайдер.ЧитателиМетрик();

    // Тогда - массив из двух читателей
    Ожидаем.Что(Читатели.Количество()).Равно(2);

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ЗакрытьВызываетсяТолькоОдинРазПриПовторныхВызовах() Экспорт

    // Дано - провайдер со spy-читателем, подсчитывающим вызовы Закрыть
    ПутьКФикстуре = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures", "ПодсчетЗакрытийЧитатель.os");
    СпайЧитатель = ЗагрузитьСценарий(ПутьКФикстуре);

    Провайдер = Новый ОтелПровайдерМетрик(, СпайЧитатель);

    // Когда - закрываем провайдер несколько раз
    Провайдер.Закрыть();
    Провайдер.Закрыть();
    Провайдер.Закрыть();

    // Тогда - читатель получил Закрыть ровно один раз
    // (Shutdown MUST be called only once per MeterProvider — спека Metrics SDK)
    Ожидаем.Что(СпайЧитатель.КоличествоЗакрытий()).Равно(1);

КонецПроцедуры

