&Тест
Процедура ПринудительноВыгрузитьПослеЗакрытияОшибка() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерМетрик();
    Провайдер.Закрыть();

    // Когда
    Результат = Провайдер.ПринудительноВыгрузитьСРезультатом();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ФильтрЭкземпляровИзОкруженияAlwaysOn() Экспорт
    // Дано
    УстановитьПеременнуюСреды("OTEL_METRICS_EXEMPLAR_FILTER", "always_on");
    Попытка
        // Когда
        Провайдер = Новый ОтелПостроительПровайдераМетрик().Построить();

        // Тогда - провайдер создан без ошибок
        Ожидаем.Что(Провайдер <> Неопределено).Равно(Истина);
        Провайдер.Закрыть();
    Исключение
        УстановитьПеременнуюСреды("OTEL_METRICS_EXEMPLAR_FILTER", "");
        ВызватьИсключение;
    КонецПопытки;
    УстановитьПеременнуюСреды("OTEL_METRICS_EXEMPLAR_FILTER", "");
КонецПроцедуры

