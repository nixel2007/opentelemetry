&Тест
Процедура ПостроительМетраFluentChain() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерМетрик();
    АтрибутыОбласти = Новый ОтелАтрибуты();
    АтрибутыОбласти.Установить("scope.key", "scope.value");

    // Когда - используем полный fluent chain построителя
    Метр = Провайдер.ПостроительМетра("моя-библ")
        .УстановитьВерсию("2.0.0")
        .УстановитьАдресСхемы("https://schema.example.com")
        .УстановитьАтрибутыОбласти(АтрибутыОбласти)
        .Построить();

    // Тогда
    Ожидаем.Что(Метр <> Неопределено).Равно(Истина);
    Ожидаем.Что(Метр.ОбластьИнструментирования().Имя()).Равно("моя-библ");
    Провайдер.Закрыть();

КонецПроцедуры

