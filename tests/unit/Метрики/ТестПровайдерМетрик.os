&Тест
Процедура ПолучитьМетр() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);

    // Когда
    Метрика = Провайдер.ПолучитьМетр("test-library", "1.0.0");

    // Тогда - метр может создавать инструменты
    Счетчик = Метрика.СоздатьСчетчик("test.counter");
    Ожидаем.Что(Счетчик.Имя()).Равно("test.counter");
    Ожидаем.Что(Метрика.ОбластьИнструментирования().Имя()).Равно("test-library");

КонецПроцедуры

&Тест
Процедура КэшированиеМетров() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерМетрик();

    // Когда - запрашиваем одного и того же метра дважды
    Метр1 = Провайдер.ПолучитьМетр("lib", "1.0");
    Метр2 = Провайдер.ПолучитьМетр("lib", "1.0");

    // Тогда - возвращается тот же объект
    Ожидаем.Что(Метр1).Равно(Метр2);

КонецПроцедуры

&Тест
Процедура ПостроительFluent() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Ресурс.Атрибуты().Установить("service.name", "test-service");
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    // Когда - используем построитель с читателем (как в Java SDK)
    Провайдер = Новый ОтелПостроительПровайдераМетрик()
        .УстановитьРесурс(Ресурс)
        .ЗарегистрироватьЧитатель(Читатель)
        .Построить();

    // Тогда
    Ожидаем.Что(Провайдер.Ресурс()).Равно(Ресурс);
    Ожидаем.Что(Провайдер.ЧитательМетрик()).Равно(Читатель);

КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт

    // Дано
    Провайдер = Новый ОтелПровайдерМетрик();
    Метр1 = Провайдер.ПолучитьМетр("lib", "1.0");

    // Когда
    Провайдер.Закрыть();

    // Тогда - после закрытия возвращается новый (no-op) метр
    Метр2 = Провайдер.ПолучитьМетр("lib", "1.0");
    Ожидаем.Что(Метр1).Не_().Равно(Метр2);

КонецПроцедуры

&Тест
Процедура ПровайдерРегистрируетМетрВЧитателе() Экспорт

    // Дано - провайдер с читателем метрик
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Провайдер = Новый ОтелПровайдерМетрик(, Читатель);

    // Когда - создаем метр, счетчик и добавляем значение
    Метр = Провайдер.ПолучитьМетр("test-lib", "1.0");
    Счетчик = Метр.СоздатьСчетчик("test.counter");
    Счетчик.Добавить(42);

    Провайдер.СброситьБуфер();

    // Тогда - метрики экспортированы через читатель
    Ожидаем.Что(Транспорт.ПолучитьОтправленные().Количество()).БольшеИлиРавно(1);

КонецПроцедуры

&Тест
Процедура СброситьБуферДелегируетЧитателю() Экспорт

    // Дано - провайдер с читателем
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Провайдер = Новый ОтелПровайдерМетрик(, Читатель);

    Метр = Провайдер.ПолучитьМетр("lib", "1.0");
    Счетчик = Метр.СоздатьСчетчик("flush.counter");
    Счетчик.Добавить(10);

    // Когда - вызываем сброс буфера дважды, добавляя данные между вызовами
    Провайдер.СброситьБуфер();
    КоличествоПослеПервогоСброса = Транспорт.ПолучитьОтправленные().Количество();

    Счетчик.Добавить(20);
    Провайдер.СброситьБуфер();

    // Тогда - оба сброса отправили данные
    Ожидаем.Что(КоличествоПослеПервогоСброса).БольшеИлиРавно(1);
    Ожидаем.Что(Транспорт.ПолучитьОтправленные().Количество()).Больше(КоличествоПослеПервогоСброса);

КонецПроцедуры

&Тест
Процедура ЗакрытьЗакрываетЧитатель() Экспорт

    // Дано - провайдер с читателем
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Провайдер = Новый ОтелПровайдерМетрик(, Читатель);

    Метр = Провайдер.ПолучитьМетр("lib", "1.0");
    Счетчик = Метр.СоздатьСчетчик("close.counter");
    Счетчик.Добавить(99);

    // Когда - закрываем провайдер
    Провайдер.Закрыть();

    // Тогда - финальный экспорт произведен
    Ожидаем.Что(Транспорт.ПолучитьОтправленные().Количество()).БольшеИлиРавно(1);

КонецПроцедуры

&Тест
Процедура ПровайдерБезЧитателяРаботает() Экспорт

    // Дано - провайдер без читателя (no-op режим для метрик)
    Провайдер = Новый ОтелПровайдерМетрик();

    // Когда - создаем метр и счетчик
    Метр = Провайдер.ПолучитьМетр("lib", "1.0");
    Счетчик = Метр.СоздатьСчетчик("noop.counter");
    Счетчик.Добавить(5);

    // Тогда - сброс и закрытие не падают
    Провайдер.СброситьБуфер();
    Провайдер.Закрыть();

