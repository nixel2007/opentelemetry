&Тест
Процедура ФильтрЭкземпляровИзОкруженияНеизвестноеЗначение() Экспорт
    // Дано
    УстановитьПеременнуюСреды("OTEL_METRICS_EXEMPLAR_FILTER", "unknown_value");
    Попытка
        // Когда - неизвестное значение должно быть проигнорировано (предупреждение)
        Провайдер = Новый ОтелПостроительПровайдераМетрик().Построить();

        // Тогда - провайдер создан без ошибок
        Ожидаем.Что(Провайдер <> Неопределено).Равно(Истина);
        Провайдер.Закрыть();
    Исключение
        УстановитьПеременнуюСреды("OTEL_METRICS_EXEMPLAR_FILTER", "");
        ВызватьИсключение;
    КонецПопытки;
    УстановитьПеременнуюСреды("OTEL_METRICS_EXEMPLAR_FILTER", "");
КонецПроцедуры

&Тест
Процедура ОбновитьКонфигураторМетрикОтключаетМетр() Экспорт

    // Дано - провайдер уже создан с метром
    Ресурс = Новый ОтелРесурс();
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс);
    Метр = Провайдер.ПолучитьМетр("test-lib", "1.0");
    Ожидаем.Что(Метр.Включен()).Равно(Истина);

    // Когда - обновляем конфигуратор, возвращающий отключенную конфигурацию
    КонфигураторСпай = Новый Действие(ЭтотОбъект, "ОтключеннаяКонфигурацияМетра");
    Провайдер.ОбновитьКонфигуратор(КонфигураторСпай);

    // Тогда - существующий метр отключен
    Ожидаем.Что(Метр.Включен()).Равно(Ложь);

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура КонфигурацияПрименяетсяПриСозданииМетра() Экспорт

    // Дано - провайдер с конфигуратором, отключающим метр
    Ресурс = Новый ОтелРесурс();
    КонфигураторСпай = Новый Действие(ЭтотОбъект, "ОтключеннаяКонфигурацияМетра");
    Провайдер = Новый ОтелПровайдерМетрик(Ресурс, Неопределено, Неопределено, КонфигураторСпай);

    // Когда - запрашиваем метр
    Метр = Провайдер.ПолучитьМетр("disabled-lib", "1.0");

    // Тогда - метр отключен согласно конфигурации
    Ожидаем.Что(Метр).Не_().Равно(Неопределено);
    Ожидаем.Что(Метр.Включен()).Равно(Ложь);

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПолучитьМетрПослеЗакрытия() Экспорт
    // Дано - провайдер закрыт
    Провайдер = Новый ОтелПостроительПровайдераМетрик().Построить();
    Провайдер.Закрыть();

    // Когда - запрашиваем метр
    Метр = Провайдер.ПолучитьМетр("test-lib");

    // Тогда - возвращается NoOp метр без читателей
    Ожидаем.Что(Метр).Не_().Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура ПолучитьМетрПустоеИмя() Экспорт
    // Дано - провайдер и пустое имя библиотеки
    Провайдер = Новый ОтелПровайдерМетрик();

    // Когда - запрашиваем метр с пустым именем
    Метр = Провайдер.ПолучитьМетр("");

    // Тогда - метр всё равно создается (предупреждение в лог)
    Ожидаем.Что(Метр).Не_().Равно(Неопределено);
    Провайдер.Закрыть();
КонецПроцедуры

&Тест
Процедура СоздатьПровайдерСМассивомЧитателей() Экспорт
    // Дано - массив из двух читателей
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер1 = Новый ОтелЭкспортерМетрик(Транспорт);
    Экспортер2 = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель1 = Новый ОтелПериодическийЧитательМетрик(Экспортер1);
    Читатель2 = Новый ОтелПериодическийЧитательМетрик(Экспортер2);
    МассивЧитателей = Новый Массив;
    МассивЧитателей.Добавить(Читатель1);
    МассивЧитателей.Добавить(Читатель2);

    // Когда
    Провайдер = Новый ОтелПровайдерМетрик(Новый ОтелРесурс(), МассивЧитателей);
    Метр = Провайдер.ПолучитьМетр("test");

    // Тогда - метр создан, оба читателя зарегистрированы
    Ожидаем.Что(Метр).Не_().Равно(Неопределено);
    Провайдер.Закрыть();
КонецПроцедуры

&Тест
Процедура СоздатьПровайдерСПользовательскимФильтром() Экспорт
    // Дано - явный фильтр экземпляров
    Провайдер = Новый ОтелПровайдерМетрик(
        Новый ОтелРесурс(),
        Неопределено,
        ОтелФильтрЭкземпляров.ВсегдаВключен());

    // Когда
    Метр = Провайдер.ПолучитьМетр("test");

    // Тогда
    Ожидаем.Что(Метр).Не_().Равно(Неопределено);
    Провайдер.Закрыть();
КонецПроцедуры

&Тест
Процедура ЗакрытьСОшибкойЧитателя() Экспорт
    // Дано - читатель бросает при закрытии
    МокЧитатель = Мок.Получить(Тип("ОтелПериодическийЧитательМетрик"));
    МокЧитатель.Когда().ЗарегистрироватьУПровайдера().ТогдаВозвращает(Истина);
    МокЧитатель.Когда().ЛимитМощности().ТогдаВозвращает(2000);
    МокЧитатель.Когда().АгрегацияГистограммПоУмолчанию().ТогдаВозвращает("explicit_bucket_histogram");
    МокЧитатель.Когда().Закрыть(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("ошибка закрытия");
    Провайдер = Новый ОтелПровайдерМетрик(Новый ОтелРесурс(), МокЧитатель);

    // Когда
    Результат = Провайдер.Закрыть();

    // Тогда - возвращает ошибку
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
КонецПроцедуры

// Вспомогательный метод-конфигуратор для тестов ОбновитьКонфигуратор.
// Возвращает отключенную конфигурацию метра.
//
// Параметры:
//   ОбластьИнструментирования - ОтелОбластьИнструментирования
//
// Возвращаемое значение:
//   ОтелКонфигурацияМетра
//
Функция ОтключеннаяКонфигурацияМетра(ОбластьИнструментирования) Экспорт // BSLLS:UnusedParameters-off
    Возврат Новый ОтелКонфигурацияМетра(Ложь);
КонецФункции

// ============================================================
// Дополнительное покрытие ветвей
// ============================================================

&Тест
Процедура ЧитательОтказавшийсяОтРегистрации() Экспорт

    // Дано - читатель, отказывающийся от регистрации у провайдера
    МокЧитатель = Мок.Получить(Тип("ОтелПериодическийЧитательМетрик"));
    МокЧитатель.Когда().ЗарегистрироватьУПровайдера().ТогдаВозвращает(Ложь);

    // Когда - создаём провайдер с этим читателем (конструктор вызывает ЗарегистрироватьЧитатель внутри)
    Провайдер = Новый ОтелПровайдерМетрик(, МокЧитатель);

    // Тогда - читатель не добавлен в список
    Ожидаем.Что(Провайдер.ЧитателиМетрик().Количество()).Равно(0);
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьСТаймаутомЧитателя() Экспорт

    // Дано - читатель возвращает таймаут при СброситьБуфер
    МокЧитатель = Мок.Получить(Тип("ОтелПериодическийЧитательМетрик"));
    МокЧитатель.Когда().ЗарегистрироватьУПровайдера().ТогдаВозвращает(Истина);
    МокЧитатель.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(
        ОтелРезультатыЭкспорта.Таймаут());

    Провайдер = Новый ОтелПровайдерМетрик(, МокЧитатель);

    // Когда
    Результат = Провайдер.ПринудительноВыгрузитьСРезультатом();

    // Тогда - таймаут
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьСОшибкойЧитателяБуфер() Экспорт

    // Дано - читатель возвращает ошибку при СброситьБуфер
    МокЧитатель = Мок.Получить(Тип("ОтелПериодическийЧитательМетрик"));
    МокЧитатель.Когда().ЗарегистрироватьУПровайдера().ТогдаВозвращает(Истина);
    МокЧитатель.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(
        ОтелРезультатыЭкспорта.Ошибка());

    Провайдер = Новый ОтелПровайдерМетрик(, МокЧитатель);

    // Когда
    Результат = Провайдер.ПринудительноВыгрузитьСРезультатом();

    // Тогда - ошибка
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьУспешно() Экспорт

    // Дано - читатель успешно сбрасывает буфер
    МокЧитатель = Мок.Получить(Тип("ОтелПериодическийЧитательМетрик"));
    МокЧитатель.Когда().ЗарегистрироватьУПровайдера().ТогдаВозвращает(Истина);
    МокЧитатель.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(
        ОтелРезультатыЭкспорта.Успех());

    Провайдер = Новый ОтелПровайдерМетрик(, МокЧитатель);

    // Когда
    Результат = Провайдер.ПринудительноВыгрузитьСРезультатом();

    // Тогда - возвращает успех
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьЧитательБросает() Экспорт

    // Дано - читатель выбрасывает исключение при СброситьБуфер
    МокЧитатель = Мок.Получить(Тип("ОтелПериодическийЧитательМетрик"));
    МокЧитатель.Когда().ЗарегистрироватьУПровайдера().ТогдаВозвращает(Истина);
    МокЧитатель.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("сбой буфера");

    Провайдер = Новый ОтелПровайдерМетрик(, МокЧитатель);

    // Когда
    Результат = Провайдер.ПринудительноВыгрузитьСРезультатом();

    // Тогда - возвращает ошибку
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Провайдер.Закрыть();

КонецПроцедуры
