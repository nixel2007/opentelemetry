// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts

Функция СоздатьМетр()
    Ресурс = Новый ОтелРесурс(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Возврат Новый ОтелМетр(Область, Ресурс);
КонецФункции

Функция СобратьДанные(Инструмент, Метр)
    Возврат Инструмент.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Инструмент.Имя(), Инструмент.Описание());
КонецФункции

Функция СоздатьСоветСГраницами()
    Границы = Новый Массив;
    Границы.Добавить(5);
    Границы.Добавить(10);
    Границы.Добавить(25);
    Совет = Новый Структура("ГраницыГистограммы", Границы);
    Возврат Совет;
КонецФункции

Функция СоздатьСоветСКлючами()
    Ключи = Новый Массив;
    Ключи.Добавить("http.method");
    Ключи.Добавить("http.status_code");
    Совет = Новый Структура("КлючиАтрибутов", Ключи);
    Возврат Совет;
КонецФункции

&Тест
Процедура ГистограммаСAdvisoryГраницами() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Совет = СоздатьСоветСГраницами();

    // Когда
    Гистограмма = Метр.СоздатьГистограмму("test.histogram", , , Совет);

    // Тогда - границы из advisory применены
    Гистограмма.Записать(1);
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];

    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")).ИмеетДлину(3);
    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")[0]).Равно(5);
    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")[1]).Равно(10);
    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")[2]).Равно(25);

КонецПроцедуры

&Тест
Процедура СчетчикБезСовета() Экспорт

    // Дано
    Метр = СоздатьМетр();

    // Когда
    Счетчик = Метр.СоздатьСчетчик("test.counter", "описание", "1");

    // Тогда - инструмент создан без ошибок
    Счетчик.Добавить(42);
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ПовторноеСозданиеВозвращаетТотЖеИнструмент() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Совет = СоздатьСоветСГраницами();

    // Когда
    Гистограмма1 = Метр.СоздатьГистограмму("test.hist", , , Совет);
    Гистограмма2 = Метр.СоздатьГистограмму("test.hist", , , Совет);

    // Тогда
    Ожидаем.Что(Гистограмма1).Равно(Гистограмма2);

КонецПроцедуры

&Тест
Процедура ГистограммаБезСоветаИспользуетДефолтныеГраницы() Экспорт

    // Дано
    Метр = СоздатьМетр();

    // Когда
    Гистограмма = Метр.СоздатьГистограмму("test.default.hist");

    // Тогда
    Гистограмма.Записать(1);
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")).ИмеетДлину(14);

КонецПроцедуры

&Тест
Процедура СоветСКлючамиАтрибутовФильтруетАтрибуты() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Совет = СоздатьСоветСКлючами();

    // Когда
    Счетчик = Метр.СоздатьСчетчик("test.filtered", , , Совет);

    Атрибуты = Новый ОтелАтрибуты;
    Атрибуты.Установить("http.method", "GET");
    Атрибуты.Установить("http.status_code", "200");
    Атрибуты.Установить("http.url", "/api/test");
    Счетчик.Добавить(1, Атрибуты);

    // Тогда - только разрешенные атрибуты сохранены
    Данные = СобратьДанные(Счетчик, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    МассивАтрибутов = ТочкаДанных.Получить("attributes");

    Ожидаем.Что(МассивАтрибутов.Количество()).Равно(2);

КонецПроцедуры

&Тест
Процедура НаблюдаемыйСчетчикСAdvisory() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Совет = СоздатьСоветСКлючами();

    // Когда - создаем наблюдаемый счетчик с advisory
    Счетчик = Метр.СоздатьНаблюдаемыйСчетчик("test.obs.counter", , , , Совет);

    // Тогда - инструмент создан
    Ожидаем.Что(Счетчик.Имя()).Равно("test.obs.counter");

КонецПроцедуры

&Тест
Процедура ДатчикСAdvisory() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Совет = СоздатьСоветСКлючами();

    // Когда
    Датчик = Метр.СоздатьДатчик("test.gauge", , , Совет);

    // Тогда
    Ожидаем.Что(Датчик.Имя()).Равно("test.gauge");

КонецПроцедуры

&Тест
Процедура РеверсивныйСчетчикСAdvisory() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Совет = СоздатьСоветСКлючами();

    // Когда
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test.updown", , , Совет);

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("test.updown");

КонецПроцедуры
