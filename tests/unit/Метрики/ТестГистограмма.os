// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура СозданиеГистограммы() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("http.duration", "Время ответа HTTP", "ms");

    // Тогда
    Ожидаем.Что(Гистограмма.Имя()).Равно("http.duration");
    Ожидаем.Что(Гистограмма.Описание()).Равно("Время ответа HTTP");
    Ожидаем.Что(Гистограмма.ЕдиницаИзмерения()).Равно("ms");
    Ожидаем.Что(Гистограмма.ТипМетрики()).Равно("histogram");
    Ожидаем.Что(Гистограмма.ТипЗначения()).Равно("double");

КонецПроцедуры

&Тест
Процедура ЗаписьЗначения() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("test.histogram");

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    Ожидаем.Что(Гистограмма.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(1);

КонецПроцедуры

&Тест
Процедура ДефолтныеГраницы() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("test.histogram");

    // Тогда - 15 стандартных границ OTel
    Ожидаем.Что(Гистограмма.Границы()).ИмеетДлину(15);
    Ожидаем.Что(Гистограмма.Границы()[0]).Равно(0);
    Ожидаем.Что(Гистограмма.Границы()[1]).Равно(5);
    Ожидаем.Что(Гистограмма.Границы()[14]).Равно(10000);

КонецПроцедуры

&Тест
Процедура КастомныеГраницы() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(1);
    Границы.Добавить(5);
    Границы.Добавить(10);

    // Когда
    Гистограмма = Новый ОтелГистограмма("test.histogram", "", "", Границы);

    // Тогда
    Ожидаем.Что(Гистограмма.Границы()).ИмеетДлину(3);
    Ожидаем.Что(Гистограмма.Границы()[0]).Равно(1);
    Ожидаем.Что(Гистограмма.Границы()[1]).Равно(5);
    Ожидаем.Что(Гистограмма.Границы()[2]).Равно(10);

КонецПроцедуры

&Тест
Процедура АгрегацияДанных() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("test.histogram", "Test", "ms");

    // Когда
    Гистограмма.Записать(100);
    Гистограмма.Записать(200);
    Гистограмма.Записать(150);

    // Тогда
    Ожидаем.Что(Гистограмма.ТочкиДанных()).ИмеетДлину(1);

    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(3);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(450);
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(100);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(200);
    Ожидаем.Что(ТочкаДанных.Получить("bucketCounts")).ИмеетДлину(16);
    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")).ИмеетДлину(15);

КонецПроцедуры

&Тест
Процедура ЗаписьВПоследнийБакет() Экспорт

    // Дано - значение больше всех границ -> попадает в +Inf бакет
    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(100);
    Гистограмма = Новый ОтелГистограмма("test", "", "", Границы);

    // Когда
    Гистограмма.Записать(999);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    СчетчикиБакетов = ТочкаДанных.Получить("bucketCounts");
    Ожидаем.Что(СчетчикиБакетов).ИмеетДлину(3);
    Ожидаем.Что(СчетчикиБакетов[0]).Равно(0);
    Ожидаем.Что(СчетчикиБакетов[1]).Равно(0);
    Ожидаем.Что(СчетчикиБакетов[2]).Равно(1);

КонецПроцедуры

&Тест
Процедура ЗаписьСАтрибутами() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("test");
    Атр = Новый ОтелАтрибуты();
    Атр.Установить("method", "GET");

    // Когда
    Гистограмма.Записать(50, Атр);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("attributes")).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ОчиститьТочкиДанных() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("test");
    Гистограмма.Записать(42);
    Ожидаем.Что(Гистограмма.ТочкиДанных()).ИмеетДлину(1);

    // Когда
    Гистограмма.ОчиститьТочкиДанных();

    // Тогда
    Ожидаем.Что(Гистограмма.ТочкиДанных()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ЛимитМощности() Экспорт

    // Дано - лимит = 2 серии
    Гистограмма = Новый ОтелГистограмма("test");
    Гистограмма.УстановитьЛимитМощности(2);

    Атр1 = Новый ОтелАтрибуты();
    Атр1.Установить("key", "a");
    Атр2 = Новый ОтелАтрибуты();
    Атр2.Установить("key", "b");
    Атр3 = Новый ОтелАтрибуты();
    Атр3.Установить("key", "c");

    // Когда - первые два ok, третий -> overflow
    Гистограмма.Записать(1, Атр1);
    Гистограмма.Записать(2, Атр2);
    Гистограмма.Записать(3, Атр3);

    // Тогда - 3 серии: 2 нормальных + 1 overflow
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(3);

КонецПроцедуры

&Тест
Процедура УстановитьФильтрЭкземпляров() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("test");

    // Когда / Тогда - не падает
    Гистограмма.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

КонецПроцедуры

&Тест
Процедура ЗахватЭкземпляров() Экспорт

    // Дано - фильтр ВсегдаВключен + спан в контексте
    Гистограмма = Новый ОтелГистограмма("test");
    Гистограмма.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    Область = ОтелКонтекст.СделатьСпанТекущим(Спан);

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("asDouble")).Равно(42);

    Область.Закрыть();

КонецПроцедуры
