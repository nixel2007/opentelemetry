// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts

Функция СоздатьМетр()
    Ресурс = Новый ОтелРесурс(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Возврат Новый ОтелМетр(Область, Ресурс);
КонецФункции

Функция СобратьДанные(Инструмент, Метр)
    Возврат Инструмент.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Инструмент.Имя(), Инструмент.Описание());
КонецФункции

&Тест
Процедура СозданиеГистограммы() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("http.duration", "Время ответа HTTP", "ms");

    // Тогда - проверяем свойства инструмента
    Ожидаем.Что(Гистограмма.Имя()).Равно("http.duration");
    Ожидаем.Что(Гистограмма.Описание()).Равно("Время ответа HTTP");
    Ожидаем.Что(Гистограмма.ЕдиницаИзмерения()).Равно("ms");

    // Тогда - проверяем метаданные через Собрать
    Гистограмма.Записать(1);
    Данные = СобратьДанные(Гистограмма, Метр);
    Ожидаем.Что(Данные.ТипМетрики()).Равно("histogram");
    Ожидаем.Что(Данные.ТипЗначения()).Равно("double");

КонецПроцедуры

&Тест
Процедура ЗаписьЗначения() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    Данные = СобратьДанные(Гистограмма, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(1);

КонецПроцедуры

&Тест
Процедура ДефолтныеГраницы() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");

    // Когда
    Гистограмма.Записать(42);

    // Тогда - стандартные границы OTel через explicitBounds в данных
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")).ИмеетДлину(14);
    Ожидаем.Что(ТочкаДанных.Получить("bucketCounts")).ИмеетДлину(15);

КонецПроцедуры

&Тест
Процедура АгрегацияДанных() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram", "Test", "ms");

    // Когда
    Гистограмма.Записать(100);
    Гистограмма.Записать(200);
    Гистограмма.Записать(150);

    // Тогда
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(3);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(450);
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(100);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(200);
    Ожидаем.Что(ТочкаДанных.Получить("bucketCounts").Количество() > 0).ЭтоИстина();
    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds").Количество() > 0).ЭтоИстина();

КонецПроцедуры

// BSLLS:Typo-off
&Тест
Процедура ЗаписьВПоследнийБакет() Экспорт
// BSLLS:Typo-on

    // Дано - значение больше всех дефолтных границ -> попадает в +Inf бакет
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test");

    // Когда
    Гистограмма.Записать(50000);

    // Тогда - значение попадает в последний бакет (+Inf)
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    СчетчикиБакетов = ТочкаДанных.Получить("bucketCounts");
    Ожидаем.Что(СчетчикиБакетов).ИмеетДлину(15);
    Ожидаем.Что(СчетчикиБакетов[14]).Равно(1);

КонецПроцедуры

&Тест
Процедура ЗаписьСАтрибутами() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");
    Атрибуты1 = Новый ОтелАтрибуты();
    Атрибуты1.Установить("method", "GET");
    Атрибуты2 = Новый ОтелАтрибуты();
    Атрибуты2.Установить("method", "POST");

    // Когда
    Гистограмма.Записать(10, Атрибуты1);
    Гистограмма.Записать(20, Атрибуты2);

    // Тогда - две серии
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(2);
    Данные = СобратьДанные(Гистограмма, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ОчиститьТочкиДанных() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");
    Гистограмма.Записать(42);

    // Когда - проверяем что данные есть
    Данные = СобратьДанные(Гистограмма, Метр);
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();

    // Тогда - очищаем и проверяем
    Гистограмма.ОчиститьТочкиДанных();
    Данные = СобратьДанные(Гистограмма, Метр);
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ЛимитМощности() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");
    Гистограмма.УстановитьЛимитМощности(2);

    // Когда - три разных набора атрибутов
    КлючПуть = "path";
    Атрибуты1 = Новый ОтелАтрибуты();
    Атрибуты1.Установить(КлючПуть, "/a");
    Атрибуты2 = Новый ОтелАтрибуты();
    Атрибуты2.Установить(КлючПуть, "/b");
    Атрибуты3 = Новый ОтелАтрибуты();
    Атрибуты3.Установить(КлючПуть, "/c");

    Гистограмма.Записать(1, Атрибуты1);
    Гистограмма.Записать(2, Атрибуты2);
    Гистограмма.Записать(3, Атрибуты3);

    // Тогда - третья серия ушла в переполнение (2 основных + 1 overflow)
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(3);

КонецПроцедуры

&Тест
Процедура УстановитьФильтрЭкземпляров() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");

    // Когда / Тогда - не падает
    Гистограмма.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

КонецПроцедуры

&Тест
Процедура ЗахватЭкземпляров() Экспорт

    // Дано - фильтр ВсегдаВключен + спан в контексте
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");
    Гистограмма.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Область = ОтелКонтекст.СделатьСпанТекущим(Спан);

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ВключенПоУмолчанию() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");

    // Тогда
    Ожидаем.Что(Гистограмма.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОтключенныйИнструментНеНакапливает() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");
    Гистограмма.Отключить();

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    Ожидаем.Что(Гистограмма.Включен()).Равно(Ложь);
    Данные = СобратьДанные(Гистограмма, Метр);
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ЗаписатьСЯвнымКонтекстом() Экспорт

    // Дано - гистограмма с фильтром ВсегдаВключен
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram.ctx");
    Гистограмма.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест-контекст", Ресурс, ОбластьИнструментирования);

    // Строим явный контекст (Соответствие) с нашим спаном
    ЯвныйКонтекст = Новый Соответствие();
    ЯвныйКонтекст.Вставить("otel-span", Спан);

    // Когда - вызов с явным контекстом
    Гистограмма.Записать(42, Неопределено, ЯвныйКонтекст);

    // Тогда - exemplar содержит trace/span из явного контекста
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

КонецПроцедуры

&Тест
Процедура ЗаписатьОбратнаяСовместимость() Экспорт

    // Дано - вызов без контекста (обратная совместимость)
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьГистограмму("test.histogram.compat");

    // Когда - несколько вариантов вызова
    Гистограмма.Записать(100);
    Гистограмма.Записать(200, Неопределено);
    Гистограмма.Записать(150, Неопределено, Неопределено);

    // Тогда - все значения суммируются
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(3);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(450);

КонецПроцедуры
