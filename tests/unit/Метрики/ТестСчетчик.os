// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура СозданиеСчетчика() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("http.requests", "Количество запросов", "1");

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("http.requests");
    Ожидаем.Что(Счетчик.Описание()).Равно("Количество запросов");
    Ожидаем.Что(Счетчик.ЕдиницаИзмерения()).Равно("1");
    Ожидаем.Что(Счетчик.ТипМетрики()).Равно("sum");
    Ожидаем.Что(Счетчик.Монотонный()).Равно(Истина);
    Ожидаем.Что(Счетчик.ТипЗначения()).Равно("int");

КонецПроцедуры

&Тест
Процедура ДобавлениеЗначения() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");

    // Когда
    Счетчик.Добавить(5);
    Счетчик.Добавить(3);

    // Тогда
    Ожидаем.Что(Счетчик.НакопленноеЗначение()).Равно(8);
    Ожидаем.Что(Счетчик.КоличествоСерий()).Равно(1);

КонецПроцедуры

&Тест
Процедура ОтклонениеОтрицательных() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");

    // Когда
    Счетчик.Добавить(-1);

    // Тогда - отрицательное значение проигнорировано
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура АтрибутыТочекДанных() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");
    Атр1 = Новый ОтелАтрибуты();
    Атр1.Установить("env", "prod");
    Атр2 = Новый ОтелАтрибуты();
    Атр2.Установить("env", "dev");

    // Когда
    Счетчик.Добавить(3, Атр1);
    Счетчик.Добавить(7, Атр1);
    Счетчик.Добавить(2, Атр2);

    // Тогда - две серии
    Ожидаем.Что(Счетчик.КоличествоСерий()).Равно(2);
    Ожидаем.Что(Счетчик.НакопленноеЗначение(Атр1)).Равно(10);
    Ожидаем.Что(Счетчик.НакопленноеЗначение(Атр2)).Равно(2);
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ОчисткаТочекДанных() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");
    Счетчик.Добавить(5);
    Счетчик.Добавить(3);

    // Когда
    Счетчик.ОчиститьТочкиДанных();

    // Тогда
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ТипЗначенияDouble() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter", "", "", "double");

    // Когда
    Счетчик.Добавить(1.5);
    Счетчик.Добавить(2.3);

    // Тогда
    Ожидаем.Что(Счетчик.ТипЗначения()).Равно("double");
    Ожидаем.Что(Счетчик.НакопленноеЗначение()).Равно(3.8);

КонецПроцедуры
