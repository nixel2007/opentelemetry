// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

Функция СоздатьМетр()
    Ресурс = Новый ОтелРесурс(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Возврат Новый ОтелМетр(Область, Ресурс);
КонецФункции

Функция СобратьДанные(Инструмент, Метр)
    Возврат Инструмент.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Инструмент.Имя(), Инструмент.Описание());
КонецФункции

&Тест
Процедура СозданиеСчетчика() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("http.requests", "Количество запросов", "1");

    // Тогда - проверяем свойства инструмента
    Ожидаем.Что(Счетчик.Имя()).Равно("http.requests");
    Ожидаем.Что(Счетчик.Описание()).Равно("Количество запросов");
    Ожидаем.Что(Счетчик.ЕдиницаИзмерения()).Равно("1");

    // Тогда - проверяем метаданные через СобратьДанные
    Счетчик.Добавить(1);
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТипМетрики()).Равно("sum");
    Ожидаем.Что(Данные.Монотонный()).Равно(Истина);
    Ожидаем.Что(Данные.ТипЗначения()).Равно("int");

КонецПроцедуры

&Тест
Процедура ДобавлениеЗначения() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter");

    // Когда
    Счетчик.Добавить(5);
    Счетчик.Добавить(3);

    // Тогда
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(8);
    Ожидаем.Что(Счетчик.КоличествоСерий()).Равно(1);

КонецПроцедуры

&Тест
Процедура ОтклонениеОтрицательных() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter");

    // Когда
    Счетчик.Добавить(-1);

    // Тогда - отрицательное значение проигнорировано
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура АтрибутыТочекДанных() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter");
    Атрибуты1 = Новый ОтелАтрибуты();
    Атрибуты1.Установить("env", "prod");
    Атрибуты2 = Новый ОтелАтрибуты();
    Атрибуты2.Установить("env", "dev");

    // Когда
    Счетчик.Добавить(3, Атрибуты1);
    Счетчик.Добавить(7, Атрибуты1);
    Счетчик.Добавить(2, Атрибуты2);

    // Тогда - две серии
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Счетчик.КоличествоСерий()).Равно(2);
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ОчисткаТочекДанных() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter");
    Счетчик.Добавить(5);
    Счетчик.Добавить(3);

    // Когда
    Счетчик.ОчиститьТочкиДанных();

    // Тогда
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура УстановитьФильтрЭкземпляров() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter");

    // Когда / Тогда - не падает
    Счетчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

КонецПроцедуры

&Тест
Процедура ЗахватЭкземпляров() Экспорт

    // Дано - фильтр ВсегдаВключен + спан в контексте
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter");
    Счетчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Область = ОтелКонтекст.СделатьСпанТекущим(Спан);

    // Когда
    Счетчик.Добавить(42);

    // Тогда
    Данные = СобратьДанные(Счетчик, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("asDouble")).Равно(42);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ЭкземплярыПоУмолчаниюПоТрассировке() Экспорт

    // Дано - фильтр по умолчанию = ПоТрассировке, без спана в контексте
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter");

    // Когда
    Счетчик.Добавить(10);

    // Тогда - нет exemplars, т.к. нет активного спана
    Данные = СобратьДанные(Счетчик, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Если Экземпляры <> Неопределено Тогда
        Ожидаем.Что(Экземпляры).ИмеетДлину(0);
    КонецЕсли;

КонецПроцедуры

&Тест
Процедура ОчисткаСбрасываетЭкземпляры() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter");
    Счетчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Область = ОтелКонтекст.СделатьСпанТекущим(Спан);
    Счетчик.Добавить(42);
    Область.Закрыть();

    // Когда
    Счетчик.ОчиститьТочкиДанных();
    Счетчик.Добавить(1);

    // Тогда - exemplars сброшены
    Данные = СобратьДанные(Счетчик, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Если Экземпляры <> Неопределено Тогда
        Ожидаем.Что(Экземпляры).ИмеетДлину(0);
    КонецЕсли;

КонецПроцедуры

&Тест
Процедура ВключенПоУмолчанию() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.enabled");

    // Тогда
    Ожидаем.Что(Счетчик.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОтключенныйИнструментНеНакапливает() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.disabled");
    Счетчик.Отключить();

    // Когда
    Счетчик.Добавить(42);

    // Тогда
    Ожидаем.Что(Счетчик.Включен()).Равно(Ложь);
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ДобавитьСЯвнымКонтекстом() Экспорт

    // Дано - счетчик с фильтром ВсегдаВключен
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter.ctx");
    Счетчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест-контекст", Ресурс, ОбластьИнструментирования);

    // Строим явный контекст с нашим спаном
    ЯвныйКонтекст = ОтелКонтекст.КонтекстСоСпаном(ОтелКонтекст.Текущий(), Спан);

    // Когда - вызов с явным контекстом
    Счетчик.Добавить(10, Неопределено, ЯвныйКонтекст);

    // Тогда - exemplar содержит trace/span из явного контекста
    Данные = СобратьДанные(Счетчик, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

КонецПроцедуры

&Тест
Процедура ДобавитьОбратнаяСовместимость() Экспорт

    // Дано - вызов без контекста (обратная совместимость)
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьСчетчик("test.counter.compat");

    // Когда - разные варианты вызова
    Счетчик.Добавить(5);
    Счетчик.Добавить(3, Неопределено);
    Счетчик.Добавить(2, Неопределено, Неопределено);

    // Тогда - все значения суммируются
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(10);

КонецПроцедуры
