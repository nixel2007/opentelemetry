&Тест
Процедура РасширениеБакетовВлево() Экспорт

    // Дано - записываем сначала большое значение, потом маленькое для расширения бакетов влево
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.histogram");

    // Когда - большое значение первым, потом маленькое
    Гистограмма.Записать(1000);
    Гистограмма.Записать(1);

    // Тогда
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(2);
    Положительные = ТочкаДанных.Получить("positive");
    Ожидаем.Что(Положительные.Получить("bucketCounts").Количество() > 1).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ЗахватЭкземпляраЭкспГистограммы() Экспорт

    // Дано - фильтр ВсегдаВключен + спан в контексте
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.histogram");
    Гистограмма.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Область = ОтелКонтекст.СделатьСпанТекущим(Спан);

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ОтрицательнаяШкала() Экспорт

    // Дано - маленький лимит бакетов и очень широкий разброс значений
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.neg.scale", , , 4);

    // Когда - значения с огромным разбросом вызывают даунскейл
    Гистограмма.Записать(0.001);
    Гистограмма.Записать(1000000);

    // Тогда - данные должны быть корректны
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(2);
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(0.001);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(1000000);

КонецПроцедуры

