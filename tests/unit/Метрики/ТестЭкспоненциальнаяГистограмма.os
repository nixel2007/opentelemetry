&Тест
Процедура СозданиеЭкспоненциальнойГистограммы() Экспорт

    // Дано
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("request.duration", "Время обработки запроса", "ms");

    // Тогда
    Ожидаем.Что(Гистограмма.Имя()).Равно("request.duration");
    Ожидаем.Что(Гистограмма.Описание()).Равно("Время обработки запроса");
    Ожидаем.Что(Гистограмма.ЕдиницаИзмерения()).Равно("ms");
    Ожидаем.Что(Гистограмма.ТипМетрики()).Равно("exponentialHistogram");
    Ожидаем.Что(Гистограмма.ТипЗначения()).Равно("double");

КонецПроцедуры

&Тест
Процедура ЗаписьПоложительногоЗначения() Экспорт

    // Дано
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram");

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    Ожидаем.Что(Гистограмма.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(1);

    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(1);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(42);
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(42);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(42);
    Ожидаем.Что(ТочкаДанных.Получить("zeroCount")).Равно(0);

    Положительные = ТочкаДанных.Получить("positive");
    Ожидаем.Что(Положительные.Получить("bucketCounts")).ИмеетДлину(1);
    Ожидаем.Что(Положительные.Получить("bucketCounts")[0]).Равно(1);

    Отрицательные = ТочкаДанных.Получить("negative");
    Ожидаем.Что(Отрицательные.Получить("bucketCounts")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ЗаписьНулевогоЗначения() Экспорт

    // Дано
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram");

    // Когда
    Гистограмма.Записать(0);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(1);
    Ожидаем.Что(ТочкаДанных.Получить("zeroCount")).Равно(1);
    Ожидаем.Что(ТочкаДанных.Получить("positive").Получить("bucketCounts")).ИмеетДлину(0);
    Ожидаем.Что(ТочкаДанных.Получить("negative").Получить("bucketCounts")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ЗаписьОтрицательногоЗначения() Экспорт

    // Дано
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram");

    // Когда
    Гистограмма.Записать(-5);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(1);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(-5);
    Ожидаем.Что(ТочкаДанных.Получить("zeroCount")).Равно(0);
    Ожидаем.Что(ТочкаДанных.Получить("positive").Получить("bucketCounts")).ИмеетДлину(0);
    Ожидаем.Что(ТочкаДанных.Получить("negative").Получить("bucketCounts")).ИмеетДлину(1);
    Ожидаем.Что(ТочкаДанных.Получить("negative").Получить("bucketCounts")[0]).Равно(1);

КонецПроцедуры

&Тест
Процедура АгрегацияНесколькихЗначений() Экспорт

    // Дано
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram");

    // Когда - записываем набор значений
    Гистограмма.Записать(1);
    Гистограмма.Записать(2);
    Гистограмма.Записать(4);
    Гистограмма.Записать(8);
    Гистограмма.Записать(0);
    Гистограмма.Записать(-3);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(6);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(12); // 1+2+4+8+0-3 = 12
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(-3);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(8);
    Ожидаем.Что(ТочкаДанных.Получить("zeroCount")).Равно(1);

    // Положительные: 4 значения (1, 2, 4, 8)
    Положительные = ТочкаДанных.Получить("positive");
    ОбщийСчет = 0;
    Для Каждого Счетчик Из Положительные.Получить("bucketCounts") Цикл
        ОбщийСчет = ОбщийСчет + Счетчик;
    КонецЦикла;
    Ожидаем.Что(ОбщийСчет).Равно(4);

    // Отрицательные: 1 значение (-3)
    Отрицательные = ТочкаДанных.Получить("negative");
    ОбщийСчет = 0;
    Для Каждого Счетчик Из Отрицательные.Получить("bucketCounts") Цикл
        ОбщийСчет = ОбщийСчет + Счетчик;
    КонецЦикла;
    Ожидаем.Что(ОбщийСчет).Равно(1);

КонецПроцедуры

&Тест
Процедура ШкалаНоль_КорректныеИндексы() Экспорт

    // BSLLS:CommentedCode-off
    // Дано - шкала 0: base = 2, бакеты - степени двойки
    // Бакет i содержит (2^i, 2^(i+1)]
    // Значение 1: log2(1) = 0, ceil(0) - 1 = -1  -> бакет -1 = (0.5, 1]
    // Значение 2: log2(2) = 1, ceil(1) - 1 = 0   -> бакет 0 = (1, 2]
    // Значение 3: log2(3) ~ 1.585, ceil(1.585) - 1 = 1 -> бакет 1 = (2, 4]
    // Значение 4: log2(4) = 2, ceil(2) - 1 = 1   -> бакет 1 = (2, 4]
    // Значение 5: log2(5) ~ 2.322, ceil(2.322) - 1 = 2 -> бакет 2 = (4, 8]
    // BSLLS:CommentedCode-on
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram", , , , 0);

    // Когда
    Гистограмма.Записать(1);
    Гистограмма.Записать(2);
    Гистограмма.Записать(3);
    Гистограмма.Записать(4);
    Гистограмма.Записать(5);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Положительные = ТочкаДанных.Получить("positive");
    Смещение = Положительные.Получить("offset");
    СчетчикиБакетов = Положительные.Получить("bucketCounts");

    // offset должен быть -1 (первый бакет: значение 1 -> индекс -1)
    Ожидаем.Что(Смещение).Равно(-1);

    // Бакеты: [-1]=1(значение 1), [0]=1(значение 2), [1]=2(значения 3,4), [2]=1(значение 5)
    Ожидаем.Что(СчетчикиБакетов).ИмеетДлину(4);
    Ожидаем.Что(СчетчикиБакетов[0]).Равно(1); // бакет -1: значение 1
    Ожидаем.Что(СчетчикиБакетов[1]).Равно(1); // бакет 0: значение 2
    Ожидаем.Что(СчетчикиБакетов[2]).Равно(2); // бакет 1: значения 3, 4
    Ожидаем.Что(СчетчикиБакетов[3]).Равно(1); // бакет 2: значение 5

КонецПроцедуры

&Тест
Процедура ДаунскейлПриПереполнении() Экспорт

    // Дано - маленький лимит бакетов, чтобы вызвать downscale
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram", , , 4, 0);

    // Когда - записываем значения с широким диапазоном
    // При шкале 0: value 1 -> index -1, value 1000 -> index 9
    // Диапазон = 11 бакетов > 4 -> downscale
    Гистограмма.Записать(1);
    Гистограмма.Записать(1000);

    // Тогда - шкала должна была снизиться
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(2);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(1001);

    Положительные = ТочкаДанных.Получить("positive");
    СчетчикиБакетов = Положительные.Получить("bucketCounts");
    // Бакетов должно быть <= 4 после downscale
    Ожидаем.Что(СчетчикиБакетов.Количество() <= 4).Равно(Истина);

    // Общий счёт в бакетах = 2
    ОбщийСчет = 0;
    Для Каждого Счетчик Из СчетчикиБакетов Цикл
        ОбщийСчет = ОбщийСчет + Счетчик;
    КонецЦикла;
    Ожидаем.Что(ОбщийСчет).Равно(2);

КонецПроцедуры

&Тест
Процедура ОчисткаТочекДанных() Экспорт

    // Дано
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram");
    Гистограмма.Записать(100);
    Гистограмма.Записать(200);
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(1);

    // Когда
    Гистограмма.ОчиститьТочкиДанных();

    // Тогда
    Ожидаем.Что(Гистограмма.ТочкиДанных()).ИмеетДлину(0);
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(0);

КонецПроцедуры

&Тест
Процедура РазныеНаборыАтрибутов() Экспорт

    // Дано
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram");

    Атрибуты1 = Новый ОтелАтрибуты();
    Атрибуты1.Установить("method", "GET");

    Атрибуты2 = Новый ОтелАтрибуты();
    Атрибуты2.Установить("method", "POST");

    // Когда
    Гистограмма.Записать(10, Атрибуты1);
    Гистограмма.Записать(20, Атрибуты2);

    // Тогда - две серии
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(2);
    Ожидаем.Что(Гистограмма.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ПорогНуля() Экспорт

    // Дано - порог нуля = 0.5
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram", , , , 20, 0.5);

    // Когда - значение 0.3 ниже порога
    Гистограмма.Записать(0.3);
    Гистограмма.Записать(-0.2);
    Гистограмма.Записать(1);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("zeroCount")).Равно(2); // 0.3 и -0.2 ниже порога
    Ожидаем.Что(ТочкаДанных.Получить("zeroThreshold")).Равно(0.5);

    Положительные = ТочкаДанных.Получить("positive");
    ОбщийСчет = 0;
    Для Каждого Счетчик Из Положительные.Получить("bucketCounts") Цикл
        ОбщийСчет = ОбщийСчет + Счетчик;
    КонецЦикла;
    Ожидаем.Что(ОбщийСчет).Равно(1); // только значение 1

КонецПроцедуры

&Тест
Процедура ШкалаВТочкеДанных() Экспорт

    // Дано
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram", , , , 5);

    // Когда
    Гистограмма.Записать(42);

    // Тогда - шкала должна быть 5 (начальная)
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("scale")).Равно(5);

КонецПроцедуры

&Тест
Процедура РасширениеБакетовВлево() Экспорт

    // Дано - записываем сначала большое значение, потом маленькое, чтобы расширить бакеты влево
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.histogram", , , , 0);

    // Когда - большое значение первым, потом маленькое
    Гистограмма.Записать(1000);
    Гистограмма.Записать(1);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(2);
    Положительные = ТочкаДанных.Получить("positive");
    СчетчикиБакетов = Положительные.Получить("bucketCounts");
    Ожидаем.Что(СчетчикиБакетов.Количество()).БольшеИлиРавно(2);

КонецПроцедуры

&Тест
Процедура ЗахватЭкземпляраЭкспГистограммы() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерТрассировки(Ресурс);
    Трассировщик = Провайдер.ПолучитьТрассировщик("библ", "1.0");
    Спан = Трассировщик.НачатьСпан("операция");
    ОтелКонтекст.СделатьСпанТекущим(Спан);

    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.exemplar");
    Гистограмма.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("exemplars")).ИмеетТип("Массив");
    Ожидаем.Что(ТочкаДанных.Получить("exemplars").Количество()).Равно(1);
    Экземпляр = ТочкаДанных.Получить("exemplars")[0];
    Ожидаем.Что(Экземпляр.Получить("asDouble")).Равно(42);

    Спан.Завершить();
    ОтелКонтекст.ВосстановитьПредыдущийКонтекст();

КонецПроцедуры

&Тест
Процедура ОтрицательнаяШкала() Экспорт

    // Дано - создаем гистограмму и заставляем шкалу понизиться до отрицательной
    // записывая значения с очень большим разбросом при малом количестве бакетов
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.neg.scale", , , , 20, 4);

    // Когда - значения с огромным разбросом вызовут даунскейл
    Гистограмма.Записать(0.001);
    Гистограмма.Записать(1000000);

    // Тогда - данные должны быть корректны
    ТочкаДанных = Гистограмма.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(2);
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(0.001);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(1000000);

КонецПроцедуры
