&Тест
Процедура АгрегацияНесколькихЗначений() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.histogram");

    // Когда
    Гистограмма.Записать(1);
    Гистограмма.Записать(2);
    Гистограмма.Записать(4);
    Гистограмма.Записать(8);
    Гистограмма.Записать(0);
    Гистограмма.Записать(-3);

    // Тогда
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(6);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(12);
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(-3);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(8);
    Ожидаем.Что(ТочкаДанных.Получить("zeroCount")).Равно(1);

КонецПроцедуры

&Тест
Процедура ШкалаНоль_КорректныеИндексы() Экспорт

    // Дано - шкала по умолчанию, записываем значения для проверки бакетов
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.histogram");

    // Когда
    Гистограмма.Записать(1);
    Гистограмма.Записать(2);
    Гистограмма.Записать(3);
    Гистограмма.Записать(4);
    Гистограмма.Записать(5);

    // Тогда
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(5);
    Ожидаем.Что(ТочкаДанных.Получить("positive").Получить("bucketCounts").Количество() > 0).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура УменьшениеМасштабаПриПереполнении() Экспорт

    // Дано - маленький максимум бакетов для провоцирования понижения шкалы
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.histogram", , , 4);

    // Когда - записываем значения в широком диапазоне
    Гистограмма.Записать(1);
    Гистограмма.Записать(1000);
    Гистограмма.Записать(1000000);

    // Тогда - данные корректны, бакетов не больше лимита
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(3);
    Ожидаем.Что(ТочкаДанных.Получить("positive").Получить("bucketCounts").Количество() <= 4).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ОчисткаТочекДанных() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.histogram");
    Гистограмма.Записать(42);

    // Когда - проверяем что данные есть
    Данные = СобратьДанные(Гистограмма, Метр);
    Ожидаем.Что(Данные <> Неопределено).ЭтоИстина();

    // Тогда - очищаем и проверяем
    Гистограмма.ОчиститьТочкиДанных();
    Данные = СобратьДанные(Гистограмма, Метр);
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура РазныеНаборыАтрибутов() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.histogram");
    Атрибуты1 = Новый ОтелАтрибуты();
    Атрибуты1.Установить("method", "GET");
    Атрибуты2 = Новый ОтелАтрибуты();
    Атрибуты2.Установить("method", "POST");

    // Когда
    Гистограмма.Записать(10, Атрибуты1);
    Гистограмма.Записать(20, Атрибуты2);

    // Тогда - две серии
    Ожидаем.Что(Гистограмма.КоличествоСерий()).Равно(2);

КонецПроцедуры

&Тест
Процедура ПорогНуля() Экспорт

    // Дано - значения близкие к нулю
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.histogram");

    // Когда - записываем ноль и положительное значение
    Гистограмма.Записать(0);
    Гистограмма.Записать(1);

    // Тогда - ноль попадает в zeroCount
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(2);
    Ожидаем.Что(ТочкаДанных.Получить("zeroCount")).Равно(1);

КонецПроцедуры

