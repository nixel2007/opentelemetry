#Использовать "../../.."
#Использовать asserts

Функция СоздатьМетр()
    Ресурс = Новый ОтелРесурс(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Возврат Новый ОтелМетр(Область, Ресурс);
КонецФункции

Функция СобратьДанные(Инструмент, Метр)
    Возврат Инструмент.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Инструмент.Имя(), Инструмент.Описание());
КонецФункции

&Тест
Процедура СозданиеЭкспоненциальнойГистограммы() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("http.duration", "Длительность", "ms");

    // Тогда - проверяем свойства инструмента
    Ожидаем.Что(Гистограмма.Имя()).Равно("http.duration");
    Ожидаем.Что(Гистограмма.Описание()).Равно("Длительность");
    Ожидаем.Что(Гистограмма.ЕдиницаИзмерения()).Равно("ms");

    // Тогда - проверяем метаданные через Собрать
    Гистограмма.Записать(1);
    Данные = СобратьДанные(Гистограмма, Метр);
    Ожидаем.Что(Данные.ТипМетрики()).Равно("exponentialHistogram");
    Ожидаем.Что(Данные.ТипЗначения()).Равно("double");

КонецПроцедуры

&Тест
Процедура ЗаписьПоложительногоЗначения() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.histogram");

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    Данные = СобратьДанные(Гистограмма, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(1);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(42);
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(42);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(42);
    Ожидаем.Что(ТочкаДанных.Получить("positive").Получить("bucketCounts").Количество() > 0).ЭтоИстина();

КонецПроцедуры

