	// Когда
	Агрегатор = ОтелАгрегация.СоздатьАгрегаторИзКонфигурации("last_value", АгрегаторБаза);

	// Тогда
	Ожидаем.Что(Агрегатор).Не_().ИмеетТип("Неопределено");

КонецПроцедуры

