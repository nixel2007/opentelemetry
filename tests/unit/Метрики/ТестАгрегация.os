&Тест
Процедура ГистограммаСЯвнымиГраницами() Экспорт

	// Дано
	Границы = Новый Массив();
	Границы.Добавить(1);
	Границы.Добавить(5);
	Границы.Добавить(10);

	// Когда
	Результат = ОтелАгрегация.ГистограммаСЯвнымиГраницами(Границы);

	// Тогда
	Ожидаем.Что(ТипЗнч(Результат)).Равно(Тип("Соответствие"));
	Ожидаем.Что(Результат.Получить("Тип")).Равно("explicit_bucket_histogram");
	Ожидаем.Что(Результат.Получить("Границы")).Равно(Границы);

КонецПроцедуры

&Тест
Процедура ГистограммаСЯвнымиГраницамиБезПараметра() Экспорт

	// Когда - без явных границ используются границы по умолчанию
	Результат = ОтелАгрегация.ГистограммаСЯвнымиГраницами();

	// Тогда
	Ожидаем.Что(ТипЗнч(Результат)).Равно(Тип("Соответствие"));
	Ожидаем.Что(Результат.Получить("Тип")).Равно("explicit_bucket_histogram");

КонецПроцедуры

&Тест
Процедура ГистограммаЭкспоненциальная() Экспорт

	// Когда
	Результат = ОтелАгрегация.ГистограммаЭкспоненциальная(20);

	// Тогда
	Ожидаем.Что(ТипЗнч(Результат)).Равно(Тип("Соответствие"));
	Ожидаем.Что(Результат.Получить("Тип")).Равно("exponential_histogram");
	Ожидаем.Что(Результат.Получить("МаксБакетов")).Равно(20);

КонецПроцедуры

&Тест
Процедура ГистограммаЭкспоненциальнаяПоУмолчанию() Экспорт

	// Когда - без параметра используется 160 бакетов по умолчанию
	Результат = ОтелАгрегация.ГистограммаЭкспоненциальная();

	// Тогда
	Ожидаем.Что(Результат.Получить("МаксБакетов")).Равно(160);

КонецПроцедуры

&Тест
Процедура СоздатьАгрегаторИзКонфигурацииСумма() Экспорт

	// Дано
	АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

	// Когда
	Агрегатор = ОтелАгрегация.СоздатьАгрегаторИзКонфигурации("sum", АгрегаторБаза);

	// Тогда
	Ожидаем.Что(Агрегатор).Не_().ИмеетТип("Неопределено");

КонецПроцедуры

&Тест
Процедура СоздатьАгрегаторИзКонфигурацииПоУмолчанию() Экспорт

	// Дано
	АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

	// Когда - "default" возвращает Неопределено
	Агрегатор = ОтелАгрегация.СоздатьАгрегаторИзКонфигурации("default", АгрегаторБаза);

	// Тогда
	Ожидаем.Что(Агрегатор).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура СоздатьАгрегаторИзКонфигурацииПоследнееЗначение() Экспорт

	// Дано
