&Тест
Процедура СоздатьАгрегаторИзКонфигурацииГистограмма() Экспорт

	// Дано
	АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Гистограмма(), Истина, "double");
	КонфигГистограммы = ОтелАгрегация.ГистограммаСЯвнымиГраницами();

	// Когда
	Агрегатор = ОтелАгрегация.СоздатьАгрегаторИзКонфигурации(КонфигГистограммы, АгрегаторБаза);

	// Тогда
	Ожидаем.Что(Агрегатор).Не_().ИмеетТип("Неопределено");

КонецПроцедуры

&Тест
Процедура СоздатьАгрегаторИзКонфигурацииЭкспоненциальнаяГистограмма() Экспорт

	// Дано
	АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.ЭкспоненциальнаяГистограмма(), Истина, "double");
	КонфигЭкспоненциальной = ОтелАгрегация.ГистограммаЭкспоненциальная(40);

	// Когда
	Агрегатор = ОтелАгрегация.СоздатьАгрегаторИзКонфигурации(КонфигЭкспоненциальной, АгрегаторБаза);

	// Тогда
	Ожидаем.Что(Агрегатор).Не_().ИмеетТип("Неопределено");

КонецПроцедуры

&Тест
Процедура СоздатьАгрегаторИзКонфигурацииНеизвестный() Экспорт

	// Дано
	АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

	// Когда - неизвестный тип агрегации возвращает Неопределено
	Агрегатор = ОтелАгрегация.СоздатьАгрегаторИзКонфигурации("unknown_aggregation", АгрегаторБаза);

	// Тогда
	Ожидаем.Что(Агрегатор).Равно(Неопределено);

КонецПроцедуры
