&Тест
Процедура СозданиеРезервуара() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(20);
    Границы.Добавить(30);

    // Когда
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Тогда - бакеты + 1 (overflow)
    Ожидаем.Что(Резервуар.МаксРазмер()).Равно(4);

КонецПроцедуры

&Тест
Процедура РаспределениеПоБакетам() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(20);
    Границы.Добавить(30);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда - значения в разные бакеты
    Резервуар.Предложить("key1", 5.0);
    Резервуар.Предложить("key1", 15.0);
    Резервуар.Предложить("key1", 25.0);
    Резервуар.Предложить("key1", 100.0);

    // Тогда - по одному на бакет
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(4);

КонецПроцедуры

&Тест
Процедура ПоследнееЗначениеВБакетеМожетБытьЗамененоВероятностно() Экспорт

    // Дано - reservoir sampling: каждое измерение принимается с вероятностью 1/N
    // При большом N первое и последнее значения имеют равную вероятность
    Границы = Новый Массив();
    Границы.Добавить(1000);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда - 100 измерений в один бакет
    КоличествоИзмерений = 100;
    Для Сч = 1 По КоличествоИзмерений Цикл
        Резервуар.Предложить("key1", Сч);
    КонецЦикла;

    // Тогда - один экземпляр в бакете, значение из диапазона [1, 100]
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(1);
    Ожидаем.Что(Результат[0].Получить("asDouble") >= 1).Равно(Истина);
    Ожидаем.Что(Результат[0].Получить("asDouble") <= КоличествоИзмерений).Равно(Истина);

КонецПроцедуры

&Тест
Процедура РавномерноеРаспределениеВыборки() Экспорт

    // Дано - при uniform sampling каждое значение имеет равную вероятность
    // Проверяем статистически: за много раундов среднее значение ~= 50
    Границы = Новый Массив();
    Границы.Добавить(1000);
    КоличествоРаундов = 200;
    КоличествоИзмерений = 100;
    СуммаЗначений = 0;

    Для Раунд = 1 По КоличествоРаундов Цикл // BSLLS:UnusedLocalVariable-off
        Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);
        Для Сч = 1 По КоличествоИзмерений Цикл
            Резервуар.Предложить("key1", Сч);
        КонецЦикла;
        Результат = Резервуар.Собрать("key1");
        СуммаЗначений = СуммаЗначений + Результат[0].Получить("asDouble");
    КонецЦикла;

    // Тогда - среднее должно быть примерно 50.5 (± 15 для 3σ)
    Среднее = СуммаЗначений / КоличествоРаундов;
    ОжидаемоеСреднее = 50.5;
    Допуск = 15;
    Ожидаем.Что(Среднее >= ОжидаемоеСреднее - Допуск).Равно(Истина);
    Ожидаем.Что(Среднее <= ОжидаемоеСреднее + Допуск).Равно(Истина);

КонецПроцедуры

&Тест
Процедура СчетчикиСбрасываютсяПриОчистке() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда - 100 измерений, очистка, затем одно измерение
    КоличествоИзмерений = 100;
    Для Сч = 1 По КоличествоИзмерений Цикл
        Резервуар.Предложить("key1", Сч);
    КонецЦикла;
    Резервуар.Очистить();
    Резервуар.Предложить("key1", 42);

    // Тогда - первое измерение после очистки всегда принимается
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(1);
    Ожидаем.Что(Результат[0].Получить("asDouble")).Равно(42);

КонецПроцедуры

&Тест
Процедура ОчисткаСбрасываетВсе() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);
    Резервуар.Предложить("key1", 5.0);
    Ожидаем.Что(Резервуар.Собрать("key1")).ИмеетДлину(1);

    // Когда
    Резервуар.Очистить();

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("key1")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура СобратьБезКлючаВозвращаетПустойМассив() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("несуществующий")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ПустыеБакетыОтфильтровываются() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(20);
    Границы.Добавить(30);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда - только в первый и последний бакеты
    Резервуар.Предложить("key1", 5.0);
    Резервуар.Предложить("key1", 100.0);

    // Тогда - 2, а не 4
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ЭкземплярСодержитМетаданные() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда
    Резервуар.Предложить("key1", 5.5);

    // Тогда
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(1);
    Ожидаем.Что(Результат[0].Получить("asDouble")).Равно(5.5);
    Ожидаем.Что(Результат[0].Получить("timeUnixNano") <> Неопределено).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ФильтрованныеАтрибуты() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    АтрибутыИзмерения = Новый ОтелАтрибуты();
    АтрибутыИзмерения.Установить("method", "GET");
    АтрибутыИзмерения.Установить("path", "/api");

    АтрибутыСерии = Новый ОтелАтрибуты();
    АтрибутыСерии.Установить("method", "GET");

    // Когда
    Резервуар.Предложить("key1", 5.0, АтрибутыИзмерения, АтрибутыСерии);

    // Тогда
    Результат = Резервуар.Собрать("key1");
    Отфильтрованные = Результат[0].Получить("filteredAttributes");
    Ожидаем.Что(Отфильтрованные).ИмеетДлину(1);
    Ожидаем.Что(Отфильтрованные[0].Получить("key")).Равно("path");

КонецПроцедуры

&Тест
Процедура РазныеКлючиНезависимы() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда
    Резервуар.Предложить("key1", 5.0);
    Резервуар.Предложить("key2", 15.0);

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("key1")).ИмеетДлину(1);
    Ожидаем.Что(Резервуар.Собрать("key2")).ИмеетДлину(1);

КонецПроцедуры
