&Тест
Процедура СозданиеРезервуара() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(20);
    Границы.Добавить(30);

    // Когда
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Тогда - бакеты + 1 (overflow)
    Ожидаем.Что(Резервуар.МаксРазмер()).Равно(4);

КонецПроцедуры

&Тест
Процедура РаспределениеПоБакетам() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(20);
    Границы.Добавить(30);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда - значения в разные бакеты
    Резервуар.Предложить("key1", 5.0);
    Резервуар.Предложить("key1", 15.0);
    Резервуар.Предложить("key1", 25.0);
    Резервуар.Предложить("key1", 100.0);

    // Тогда - по одному на бакет
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(4);

КонецПроцедуры

&Тест
Процедура ПоследнееЗначениеВБакетеЗаменяетПредыдущее() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда - два значения в один бакет
    Резервуар.Предложить("key1", 3.0);
    Резервуар.Предложить("key1", 7.0);

    // Тогда - только одно (последнее)
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(1);
    Ожидаем.Что(Результат[0].Получить("asDouble")).Равно(7.0);

КонецПроцедуры

&Тест
Процедура ОчисткаСбрасываетВсе() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);
    Резервуар.Предложить("key1", 5.0);
    Ожидаем.Что(Резервуар.Собрать("key1")).ИмеетДлину(1);

    // Когда
    Резервуар.Очистить();

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("key1")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура СобратьБезКлючаВозвращаетПустойМассив() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("несуществующий")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ПустыеБакетыОтфильтровываются() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Границы.Добавить(20);
    Границы.Добавить(30);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда - только в первый и последний бакеты
    Резервуар.Предложить("key1", 5.0);
    Резервуар.Предложить("key1", 100.0);

    // Тогда - 2, а не 4
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ЭкземплярСодержитМетаданные() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда
    Резервуар.Предложить("key1", 5.5);

    // Тогда
    Результат = Резервуар.Собрать("key1");
    Ожидаем.Что(Результат).ИмеетДлину(1);
    Ожидаем.Что(Результат[0].Получить("asDouble")).Равно(5.5);
    Ожидаем.Что(Результат[0].Получить("timeUnixNano") <> Неопределено).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ФильтрованныеАтрибуты() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    АтрибутыИзмерения = Новый ОтелАтрибуты();
    АтрибутыИзмерения.Установить("method", "GET");
    АтрибутыИзмерения.Установить("path", "/api");

    АтрибутыСерии = Новый ОтелАтрибуты();
    АтрибутыСерии.Установить("method", "GET");

    // Когда
    Резервуар.Предложить("key1", 5.0, АтрибутыИзмерения, АтрибутыСерии);

    // Тогда
    Результат = Резервуар.Собрать("key1");
    Отфильтрованные = Результат[0].Получить("filteredAttributes");
    Ожидаем.Что(Отфильтрованные).ИмеетДлину(1);
    Ожидаем.Что(Отфильтрованные[0].Получить("key")).Равно("path");

КонецПроцедуры

&Тест
Процедура РазныеКлючиНезависимы() Экспорт

    // Дано
    Границы = Новый Массив();
    Границы.Добавить(10);
    Резервуар = Новый ОтелВыровненныйРезервуарГистограммы(Границы);

    // Когда
    Резервуар.Предложить("key1", 5.0);
    Резервуар.Предложить("key2", 15.0);

    // Тогда
    Ожидаем.Что(Резервуар.Собрать("key1")).ИмеетДлину(1);
    Ожидаем.Что(Резервуар.Собрать("key2")).ИмеетДлину(1);

КонецПроцедуры
