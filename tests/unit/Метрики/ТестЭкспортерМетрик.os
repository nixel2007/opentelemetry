&Тест
Процедура ЗакрытьИдемпотентно() Экспорт

	// Дано
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

	// Когда - два вызова Закрыть
	Экспортер.Закрыть();
	Результат = Экспортер.Закрыть();

	// Тогда - повторный вызов также успешен (идемпотентность)
	Ожидаем.Что(Результат.Успешно()).Равно(Истина);

КонецПроцедуры

