&Тест
Процедура ЭкспортПустогоМассиваВозвращаетУспех() Экспорт

	// Дано
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

	// Когда
	Результат = Экспортер.Экспортировать(Новый Массив());

	// Тогда - пустой массив → успех, транспорт не вызывается
	Ожидаем.Что(Результат).Равно(Истина);
	Ожидаем.Что(Транспорт.ПолучитьОтправленные().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ЭкспортПослеЗакрытияВозвращаетЛожь() Экспорт

	// Дано
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
	Экспортер.Закрыть();

	// Когда - экспорт после закрытия (даже с пустым массивом - проверка Закрыт идёт первой)
	МассивДанных = Новый Массив();
	МассивДанных.Добавить(СоздатьДанныеМетрикиСумма("test.closed", 1));
	Результат = Экспортер.Экспортировать(МассивДанных);

	// Тогда
	Ожидаем.Что(Результат).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЭкспортВалидныхДанныхМетрики() Экспорт

	// Дано
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
	МассивДанных = Новый Массив();
	МассивДанных.Добавить(СоздатьДанныеМетрикиСумма("test.counter", 42));

	// Когда
	Результат = Экспортер.Экспортировать(МассивДанных);

	// Тогда - транспорт получил данные по пути /v1/metrics
	Ожидаем.Что(Результат).Равно(Истина);
	Ожидаем.Что(Транспорт.ПолучитьОтправленные().Количество()).Равно(1);
	Ожидаем.Что(
		Транспорт.ПолучитьОтправленные()[0].Получить("Путь")
	).Равно("/v1/metrics");

КонецПроцедуры

&Тест
Процедура ЭкспортНеподдерживаемогоТипаМетрикиВозвращаетЛожь() Экспорт

	// Дано - ВалидироватьСовместимостьДанных: неподдерживаемый тип → Ложь
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

	ТочкиДанных = Новый Массив();
	Данные = Новый ОтелДанныеМетрики(
		Новый ОтелРесурс(),
		Новый ОтелОбластьИнструментирования("test-lib", "1.0"),
		"test.metric", "", "",
		"unknown_type",
		ТочкиДанных, Ложь, "int"
	);
	МассивДанных = Новый Массив();
	МассивДанных.Добавить(Данные);

	// Когда
	Результат = Экспортер.Экспортировать(МассивДанных);

	// Тогда
	Ожидаем.Что(Результат).Равно(Ложь);
	Ожидаем.Что(Транспорт.ПолучитьОтправленные().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ЭкспортМетрикиСНеУказаннойТемпоральностьюВозвращаетЛожь() Экспорт

	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

	// Создаём точку данных как Структура с Темпоральность = 0 (НеУказана)
	ТочкаДанных = Новый Структура();
	ТочкаДанных.Вставить("value", 10);
	ТочкаДанных.Вставить("startTimeUnixNano", "0");
	ТочкаДанных.Вставить("timeUnixNano", "0");
	ТочкаДанных.Вставить("attributes", Новый Массив());
	ТочкаДанных.Вставить("Темпоральность", ОтелВременнаяАгрегация.НеУказана());
	ТочкиДанных = Новый Массив();
	ТочкиДанных.Добавить(ТочкаДанных);

	Данные = Новый ОтелДанныеМетрики(
		Новый ОтелРесурс(),
		Новый ОтелОбластьИнструментирования("test-lib", "1.0"),
		"test.metric", "", "",
		ОтелТипМетрики.Сумма(),
		ТочкиДанных, Истина, "int"
	);
	МассивДанных = Новый Массив();
	МассивДанных.Добавить(Данные);

	// Когда
	Результат = Экспортер.Экспортировать(МассивДанных);

	// Тогда
	Ожидаем.Что(Результат).Равно(Ложь);
	Ожидаем.Что(Транспорт.ПолучитьОтправленные().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ПолучитьВременнуюАгрегациюПоУмолчаниюВозвращаетКумулятивную() Экспорт

	// Дано - конструктор по умолчанию использует ВсегдаКумулятивная()
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

	// Когда
	Результат = Экспортер.ПолучитьВременнуюАгрегацию("counter");

	// Тогда
	Ожидаем.Что(Результат).Равно(ОтелВременнаяАгрегация.Кумулятивная());

КонецПроцедуры

&Тест
Процедура КонструкторСПользовательскимСелектором() Экспорт

	// Дано - пользовательский селектор ПредпочтительноДельта
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(
		Транспорт,
		ОтелСелекторВременнойАгрегации.ПредпочтительноДельта()
	);

	// Когда
	РезультатCounter = Экспортер.ПолучитьВременнуюАгрегацию("counter");
	РезультатUpDown = Экспортер.ПолучитьВременнуюАгрегацию("up_down_counter");

	// Тогда - counter → Дельта, up_down_counter → Кумулятивная
	Ожидаем.Что(РезультатCounter).Равно(ОтелВременнаяАгрегация.Дельта());
	Ожидаем.Что(РезультатUpDown).Равно(ОтелВременнаяАгрегация.Кумулятивная());

КонецПроцедуры

&Тест
Процедура СброситьБуферВсегдаВозвращаетУспех() Экспорт

	// Дано
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

	// Когда
	Результат = Экспортер.СброситьБуфер();

	// Тогда - синхронный экспортер не буферизует данные
	Ожидаем.Что(Результат.Успешно()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ЗакрытьВозвращаетУспех() Экспорт

	// Дано
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

	// Когда
	Результат = Экспортер.Закрыть();

	// Тогда
	Ожидаем.Что(Результат.Успешно()).Равно(Истина);

