&Тест
Процедура ЭкспортДатчикаПропускаетПроверкуТемпоральности() Экспорт

	// Дано - ВалидироватьСовместимостьДанных: тип Датчик → Продолжить (пропуск проверки темпоральности)
	Транспорт = Новый ОтелВПамятьТранспорт();
	Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

	// Точка данных без Темпоральности - для Датчика проверка пропускается
	ТочкаДанных = Новый Соответствие;
	ТочкаДанных.Вставить("value", 99.5);
	ТочкаДанных.Вставить("timeUnixNano", "0");
	ТочкаДанных.Вставить("attributes", Новый Массив());
	ТочкиДанных = Новый Массив();
	ТочкиДанных.Добавить(ТочкаДанных);

	Данные = Новый ОтелДанныеМетрики(
		Новый ОтелРесурс(),
		Новый ОтелОбластьИнструментирования("test-lib", "1.0"),
		"test.gauge", "", "",
		ОтелТипМетрики.Датчик(),
		ТочкиДанных, Ложь, "double"
	);
	МассивДанных = Новый Массив();
	МассивДанных.Добавить(Данные);

	// Когда
	Результат = Экспортер.Экспортировать(МассивДанных);

	// Тогда - Датчик успешно экспортирован без проверки темпоральности
	Ожидаем.Что(Результат).Равно(Истина);
	Ожидаем.Что(Транспорт.ПолучитьОтправленные().Количество()).Равно(1);

КонецПроцедуры

// ------------------------------------------------------------------
// Служебные
// ------------------------------------------------------------------

Функция СоздатьДанныеМетрикиСумма(ИмяМетрики, Значение)

	ТочкаДанных = Новый Соответствие;
	ТочкаДанных.Вставить("value", Значение);
	ТочкаДанных.Вставить("startTimeUnixNano", "0");
	ТочкаДанных.Вставить("timeUnixNano", "0");
	ТочкаДанных.Вставить("attributes", Новый Массив());
	ТочкиДанных = Новый Массив();
	ТочкиДанных.Добавить(ТочкаДанных);

	Возврат Новый ОтелДанныеМетрики(
		Новый ОтелРесурс(),
		Новый ОтелОбластьИнструментирования("test-lib", "1.0"),
		ИмяМетрики, "", "",
		ОтелТипМетрики.Сумма(),
		ТочкиДанных, Истина, "int"
	);

КонецФункции
