// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
// BSLLS:DuplicateStringLiteral-off
#Использовать "../../.."
#Использовать asserts
#Использовать lambdas

// Тесты требований #17 (view-aggregation-applied) и #18 (view-cardinality-limit-applied)
// Спека: SDK MUST accept stream configuration parameters, including aggregation and cardinality limit.

Функция СоздатьМетрСПредставлением(Селектор, Представление)
    Ресурс = Новый ОтелРесурс(Истина);
    Область = Новый ОтелОбластьИнструментирования("test", "1.0");
    Метр = Новый ОтелМетр(Область, Ресурс);
    Пары = Новый Массив();
    Пара = Новый Соответствие();
    Пара.Вставить("Селектор", Селектор);
    Пара.Вставить("Представление", Представление);
    Пары.Добавить(Пара);
    Метр.УстановитьПредставления(Пары);
    Возврат Метр;
КонецФункции

Функция СобратьТочкиСчетчика(Счетчик, Метр)
    Данные = Счетчик.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Счетчик.Имя(), Счетчик.Описание());
    Если Данные = Неопределено Тогда
        Возврат Новый Массив();
    КонецЕсли;
    Возврат Данные.ТочкиДанных();
КонецФункции

// ============================================================
// #17 view-aggregation-applied
// ============================================================

&Тест
Процедура ViewАгрегацияSum_СчетчикИспользуетСумму() Экспорт

    // Дано - View с агрегацией sum явно задаёт sum для инструмента
    Селектор = Новый ОтелСелекторИнструментов("test.counter");
    Представление = Новый ОтелПредставление(, , , , ОтелАгрегация.Сумма());

    Метр = СоздатьМетрСПредставлением(Селектор, Представление);
    Счетчик = Метр.СоздатьСчетчик("test.counter");

    // Когда
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("key", "a");
    Счетчик.Добавить(42, Атрибуты);

    // Тогда - данные собираются (sum-агрегация активна)
    Точки = СобратьТочкиСчетчика(Счетчик, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(1);
    Ожидаем.Что(Точки[0].Получить("value")).Равно(42);

КонецПроцедуры

&Тест
Процедура ViewАгрегацияDrop_СчетчикНеПроизводитДанных() Экспорт

    // Дано - View с агрегацией drop
    Селектор = Новый ОтелСелекторИнструментов("test.counter");
    Представление = Новый ОтелПредставление(, , , , ОтелАгрегация.Отбросить());

    Метр = СоздатьМетрСПредставлением(Селектор, Представление);
    Счетчик = Метр.СоздатьСчетчик("test.counter");

    // Когда
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("key", "a");
    Счетчик.Добавить(42, Атрибуты);

    // Тогда - данные не производятся (Drop-агрегация)
    Данные = Счетчик.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Счетчик.Имя(), Счетчик.Описание());
    Ожидаем.Что(Данные).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ViewАгрегацияDrop_ГистограммаНеПроизводитДанных() Экспорт

    // Дано - View с drop для Гистограммы
    Селектор = Новый ОтелСелекторИнструментов("test.histogram");
    Представление = Новый ОтелПредставление(, , , , ОтелАгрегация.Отбросить());

    Метр = СоздатьМетрСПредставлением(Селектор, Представление);
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");

    // Когда
    Гистограмма.Записать(42);

    // Тогда
    Данные = Гистограмма.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Гистограмма.Имя(), Гистограмма.Описание());
    Ожидаем.Что(Данные).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ViewАгрегацияLastValue_ДатчикИспользуетПоследнееЗначение() Экспорт

    // Дано - View с last_value для датчика (уже default для Gauge, проверяем что применяется)
    Селектор = Новый ОтелСелекторИнструментов("test.gauge");
    Представление = Новый ОтелПредставление(, , , , ОтелАгрегация.ПоследнееЗначение());

    Метр = СоздатьМетрСПредставлением(Селектор, Представление);
    Датчик = Метр.СоздатьДатчик("test.gauge");

    // Когда
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("key", "a");
    Датчик.Записать(10, Атрибуты);
    Датчик.Записать(99, Атрибуты);

    // Тогда - последнее значение побеждает
    Точки = СобратьТочкиСчетчика(Датчик, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(1);
    Ожидаем.Что(Точки[0].Получить("value")).Равно(99);

КонецПроцедуры

&Тест
Процедура ViewАгрегацияЯвнаяГистограмма_ПрименяетКастомныеГраницы() Экспорт

    // Дано - View с кастомными границами гистограммы
    Границы = Новый Массив();
    Границы.Добавить(1);
    Границы.Добавить(10);
    Границы.Добавить(100);

    Селектор = Новый ОтелСелекторИнструментов("test.histogram");
    АгрегацияГистограммы = ОтелАгрегация.ГистограммаСЯвнымиГраницами(Границы);
    Представление = Новый ОтелПредставление(, , , , АгрегацияГистограммы);

    Метр = СоздатьМетрСПредставлением(Селектор, Представление);
    Гистограмма = Метр.СоздатьГистограмму("test.histogram");

    // Когда
    Гистограмма.Записать(5);
    Гистограмма.Записать(50);
    Гистограмма.Записать(500);

    // Тогда - 4 бакета (3 границы = 4 бакета)
    Точки = СобратьТочкиСчетчика(Гистограмма, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(1);
    БакетыКоличество = Точки[0].Получить("bucketCounts");
    Ожидаем.Что(БакетыКоличество.Количество()).Равно(4);

КонецПроцедуры

&Тест
Процедура ViewАгрегацияDrop_НаблюдаемыйСчетчикНеПроизводитДанных() Экспорт

    // Дано - View с drop для наблюдаемого счётчика
    Селектор = Новый ОтелСелекторИнструментов("test.obs.counter");
    Представление = Новый ОтелПредставление(, , , , ОтелАгрегация.Отбросить());

    Метр = СоздатьМетрСПредставлением(Селектор, Представление);

    Callback = Новый Действие(ЭтотОбъект, "ТестовыйCallback");
    НаблюдаемыйСчетчик = Метр.СоздатьНаблюдаемыйСчетчик("test.obs.counter", Callback);

    // Тогда - данные не производятся
    Данные = НаблюдаемыйСчетчик.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        НаблюдаемыйСчетчик.Имя(), НаблюдаемыйСчетчик.Описание());
    Ожидаем.Что(Данные).Равно(Неопределено);

КонецПроцедуры

Процедура ТестовыйCallback(Наблюдение) Экспорт
    Наблюдение.Записать(42, Новый ОтелАтрибуты());
КонецПроцедуры

// ============================================================
// #18 view-cardinality-limit-applied
// ============================================================

Функция ЭтоOverflow(Точка)
    МассивАтрибутов = Точка.Получить("attributes");
    Если МассивАтрибутов = Неопределено Тогда
        Возврат Ложь;
    КонецЕсли;
    Для Каждого Атрибут Из МассивАтрибутов Цикл
        Если Атрибут.Получить("key") = "otel.metric.overflow" Тогда
            ЗначениеАтрибута = Атрибут.Получить("value");
            Если ЗначениеАтрибута <> Неопределено И ЗначениеАтрибута.Получить("boolValue") = Истина Тогда
                Возврат Истина;
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
    Возврат Ложь;
КонецФункции

&Тест
Процедура ViewЛимитМощности_ПереопределяетЛимитЧитателя() Экспорт

    // Дано - reader устанавливает лимит 100, View устанавливает лимит 2
    Селектор = Новый ОтелСелекторИнструментов("test.counter");
    Представление = Новый ОтелПредставление(, , , , , , , 2);

    Метр = СоздатьМетрСПредставлением(Селектор, Представление);
    Метр.УстановитьЛимитМощности(100); // лимит от ридера

    Счетчик = Метр.СоздатьСчетчик("test.counter");

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("key", "a");
    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("key", "b");
    АтрибутыВ = Новый ОтелАтрибуты();
    АтрибутыВ.Установить("key", "c");

    // Когда - записываем 3 разных серии, лимит View = 2
    Счетчик.Добавить(1, АтрибутыА);
    Счетчик.Добавить(2, АтрибутыБ);
    Счетчик.Добавить(3, АтрибутыВ);

    // Тогда - 3 точки: 2 обычных + 1 overflow (лимит View = 2 применён)
    Точки = СобратьТочкиСчетчика(Счетчик, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(3);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ViewБезЛимита_ИспользуетЛимитЧитателя() Экспорт

    // Дано - View без лимита, лимит ридера = 2
    Селектор = Новый ОтелСелекторИнструментов("test.counter");
    Представление = Новый ОтелПредставление(); // нет ЛимитМощностиАгрегации

    Метр = СоздатьМетрСПредставлением(Селектор, Представление);
    Метр.УстановитьЛимитМощности(2); // лимит от ридера

    Счетчик = Метр.СоздатьСчетчик("test.counter");

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("key", "a");
    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("key", "b");
    АтрибутыВ = Новый ОтелАтрибуты();
    АтрибутыВ.Установить("key", "c");

    // Когда - 3 серии, лимит ридера = 2
    Счетчик.Добавить(1, АтрибутыА);
    Счетчик.Добавить(2, АтрибутыБ);
    Счетчик.Добавить(3, АтрибутыВ);

    // Тогда - overflow применён (лимит 2 от ридера)
    Точки = СобратьТочкиСчетчика(Счетчик, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(3);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ViewЛимит_ИспользуетсяДажеКогдаЧитательИмеетБольшийЛимит() Экспорт

    // Дано - View ограничивает до 1, ридер разрешает 1000
    Селектор = Новый ОтелСелекторИнструментов("test.gauge");
    Представление = Новый ОтелПредставление(, , , , , , , 1);

    Метр = СоздатьМетрСПредставлением(Селектор, Представление);
    Метр.УстановитьЛимитМощности(1000);

    Датчик = Метр.СоздатьДатчик("test.gauge");

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("key", "a");
    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("key", "b");

    // Когда - 2 серии, лимит View = 1
    Датчик.Записать(10, АтрибутыА);
    Датчик.Записать(20, АтрибутыБ);

    // Тогда - overflow активен (лимит View = 1)
    Точки = СобратьТочкиСчетчика(Датчик, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(2);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).ЭтоИстина();

КонецПроцедуры
