    // Тогда - первый успех, второй с ошибкой "Reader закрыт"
    Ожидаем.Что(Результат1.Успешно()).Равно(Истина);
    Ожидаем.Что(Результат2.Успешно()).Равно(Ложь);
    Ожидаем.Что(Результат2.Описание()).Равно("Reader закрыт");

