&Тест
Процедура МетрПолучитьПредставленияБросает() Экспорт

    // Дано - метр, бросающий в ПолучитьПредставления (→ Представления = Новый Массив)
    ТекстМетра = "
    |Функция ВызватьМультиОбратныеВызовы() Экспорт КонецФункции
    |Функция Включен() Экспорт Возврат Истина; КонецФункции
    |Функция Ресурс() Экспорт Возврат Неопределено; КонецФункции
    |Функция ОбластьИнструментирования() Экспорт Возврат Неопределено; КонецФункции
    |Функция Инструменты() Экспорт Возврат Новый Массив; КонецФункции
    |Функция ПолучитьПредставления() Экспорт
    |    ВызватьИсключение ""тест: ошибка представлений"";
    |КонецФункции";
    МетрБросающий = ЗагрузитьСценарийИзСтроки(ТекстМетра);

    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    МокЭкспортер.Когда().ПолучитьВременнуюАгрегацию(
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(ОтелВременнаяАгрегация.Кумулятивная());
    МокЭкспортер.Когда().Экспортировать(
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(Истина);

    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);
    Читатель.ДобавитьМетр(МетрБросающий);

    // Когда - исключение из ПолучитьПредставления должно быть поглощено
    Результат = Читатель.СброситьБуфер();

    // Тогда - данных нет, операция успешна (нет инструментов после fallback)
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);

