    ТочкаДанных.Вставить("attributes", Новый Массив());
    ТочкиДанных = Новый Массив();
    ТочкиДанных.Добавить(ТочкаДанных);
    ДанныеМетрики = Новый ОтелДанныеМетрики(
        Ресурс, ОбластьИнструментирования,
        "prod.metric", "", "1", ОтелТипМетрики.Датчик(), ТочкиДанных);

    ТекстРезультата = "
    |Перем Метрики Экспорт;
    |Функция Успех() Экспорт Возврат Истина; КонецФункции";
    ОбъектРезультата = ЗагрузитьСценарийИзСтроки(ТекстРезультата);
