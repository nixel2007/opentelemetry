&Тест
Процедура НаблюдаемыйСчетчикСАтрибутамиДельта() Экспорт

    // Дано - ObservableCounter с атрибутами и читатель с дельта-темпоральностью.
    // При сборе СформироватьКлючАтрибутов обходит OTLP-атрибуты (Соответствие),
    // покрывая ветки lines 521-523, 527.
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    Захватчик = ЗагрузитьСценарий(ОбъединитьПути(КаталогФикстур, "ЗахватчикЭкспорта.os"));
    Захватчик.УстановитьВременность(ОтелВременнаяАгрегация.Дельта());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("obs-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    ТекстНаблюдателя = "
    |Процедура Наблюдать(Наблюдение) Экспорт
    |    Атрибуты = Новый ОтелАтрибуты();
    |    Атрибуты.Установить(""env"", ""prod"");
    |    Наблюдение.Записать(50, Атрибуты);
    |КонецПроцедуры";
    Наблюдатель = ЗагрузитьСценарийИзСтроки(ТекстНаблюдателя);
    Действие = Новый Действие(Наблюдатель, "Наблюдать");
    Метр.СоздатьНаблюдаемыйСчетчик("obs.with.attrs", Действие);

    Читатель = Новый ОтелПериодическийЧитательМетрик(Захватчик);
    Читатель.ДобавитьМетр(Метр);

    // Когда - первый сбор (абсолютное значение = дельта от 0)
    Читатель.СброситьБуфер();
    // Второй сбор (дельта = 0, т.к. значение не изменилось)
    Читатель.СброситьБуфер();

    // Тогда - два экспорта выполнены, атрибуты обработаны через ключ-формирование
    Ожидаем.Что(Захватчик.ЗахваченныеЗначения.Количество()).Равно(2);
    Ожидаем.Что(Захватчик.ЗахваченныеЗначения[0][0]).Равно(50);
    Ожидаем.Что(Захватчик.ЗахваченныеЗначения[1][0]).Равно(0);

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьУспешноБезЭкспортера() Экспорт

    // Дано - читатель без экспортера (Неопределено) и без метров
    Читатель = Новый ОтелПериодическийЧитательМетрик(Неопределено);

    // Когда - форсфлаш без экспортера и пустого буфера
    Результат = Читатель.ПринудительноВыгрузитьСРезультатом();

    // Тогда - успешно (нечего экспортировать, нет экспортера)
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьСЭкспортеромБросающимИсключение() Экспорт

    // Дано - экспортер бросает исключение при ПринудительноВыгрузитьСРезультатом (строки 677, 685, 691)
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    МокЭкспортер.Когда()
        .ПринудительноВыгрузитьСРезультатом(Матчеры.ЛюбоеЗначение())
        .ТогдаВыбрасываетИсключение("форс-флаш недоступен");
    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);

    // Когда - форсфлаш без метров (буфер пуст)
    Результат = Читатель.ПринудительноВыгрузитьСРезультатом();

    // Тогда - успех: исключение поймано (ИмеетФорсФлаш=Ложь), ТекущийРезультат=Неопределено → Успешно
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);

    Читатель.Закрыть();

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьСЭкспортеромВозвращающимУспех() Экспорт

    // Дано - экспортер возвращает успех при ПринудительноВыгрузитьСРезультатом (строки 685, 691)
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    МокЭкспортер.Когда()
        .ПринудительноВыгрузитьСРезультатом(Матчеры.ЛюбоеЗначение())
        .ТогдаВозвращает(ОтелРезультатыЗакрытия.Успех());
    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);

    // Когда - форсфлаш без метров (буфер пуст)
    Результат = Читатель.ПринудительноВыгрузитьСРезультатом();

    // Тогда - успех: ЭкспортерВернулОшибку=Ложь (т.к. Успешно=Истина), ТекущийРезультат остаётся Неопределено
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);

    Читатель.Закрыть();

КонецПроцедуры
