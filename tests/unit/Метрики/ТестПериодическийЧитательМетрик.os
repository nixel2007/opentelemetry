&Тест
Процедура СобратьИЭкспортировать() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("test.counter");
    Счетчик.Добавить(5);

    Читатель.ДобавитьМетр(Метрика);

    // Когда
    Читатель.СброситьБуфер();

    // Тогда - транспорт получил данные
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(1);
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()[0].Получить("Путь")).Равно("/v1/metrics");

КонецПроцедуры

&Тест
Процедура ЗакрытьЧитатель() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("test.counter");
    Счетчик.Добавить(10);

    Читатель.ДобавитьМетр(Метрика);

    // Когда - закрытие вызывает финальный экспорт
    Читатель.Закрыть();

    // Тогда
    Ожидаем.Что(Транспорт.ПолучитьОтправленные()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ИнтервалПоУмолчанию() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);

    // Когда
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    // Тогда - интервал задается при создании, проверяем что объект создан без ошибок
    Ожидаем.Что(Читатель).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ЗакрытьВызываетЗакрытьЭкспортера() Экспорт

    // Дано - мок экспортер для проверки вызова Закрыть
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);

    // Когда - закрываем читатель
    Читатель.Закрыть();

    // Тогда - экспортер.Закрыть() должен быть вызван (per spec: Shutdown MUST call exporter.Shutdown)
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Закрыть();

КонецПроцедуры

&Тест
Процедура ОшибкаЭкспортера() Экспорт

    // Дано - экспортер бросает исключение
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    МокЭкспортер.Когда().Экспортировать(
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВыбрасываетИсключение("тест: ошибка экспорта метрик");
    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("test.counter");
    Счетчик.Добавить(5);

    Читатель.ДобавитьМетр(Метрика);

    // Когда - сбрасываем буфер, экспортер падает
    Читатель.СброситьБуфер();

    // Тогда - ошибка обработана, читатель не сломался
    Читатель.Закрыть();
    Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ДвойнойЗапуск() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер, 100);

    // Когда - двойной запуск
    Читатель.Запустить();
    Читатель.Запустить(); // повторный вызов должен быть безопасен

    // Тогда - без ошибок
    Ожидаем.Что(Истина).Равно(Истина);

    Читатель.Закрыть();

КонецПроцедуры

&Тест
Процедура ФоновыйПериодическийСбор() Экспорт

    // Дано - короткий интервал для быстрого срабатывания
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер, 100);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("test.counter");
    Счетчик.Добавить(5);
    Читатель.ДобавитьМетр(Метрика);

    // Когда - запускаем фоновый сбор и ждем
    Читатель.Запустить();
    Приостановить(300);

    // Тогда - закрываем, фоновый сбор должен остановиться
    Читатель.Закрыть();
    Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура АгрегацияПоУмолчаниюВозвращаетКорректныеЗначения() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);

    // Тогда
    Ожидаем.Что(Читатель.АгрегацияПоУмолчанию("Counter")).Равно("sum");
    Ожидаем.Что(Читатель.АгрегацияПоУмолчанию("UpDownCounter")).Равно("sum");
    Ожидаем.Что(Читатель.АгрегацияПоУмолчанию("Histogram")).Равно("explicit_bucket_histogram");
    Ожидаем.Что(Читатель.АгрегацияПоУмолчанию("Gauge")).Равно("last_value");
    Ожидаем.Что(Читатель.АгрегацияПоУмолчанию("ObservableCounter")).Равно("sum");
    Ожидаем.Что(Читатель.АгрегацияПоУмолчанию("ObservableUpDownCounter")).Равно("sum");
    Ожидаем.Что(Читатель.АгрегацияПоУмолчанию("ObservableGauge")).Равно("last_value");

КонецПроцедуры

&Тест
Процедура АгрегацияПоУмолчаниюНастраивается() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);

    // Когда
    Читатель.УстановитьАгрегациюПоУмолчанию("Histogram", "base2_exponential_bucket_histogram");

    // Тогда
    Ожидаем.Что(Читатель.АгрегацияПоУмолчанию("Histogram")).Равно("base2_exponential_bucket_histogram");
    Ожидаем.Что(Читатель.АгрегацияГистограммПоУмолчанию()).Равно("base2_exponential_bucket_histogram");

КонецПроцедуры

&Тест
Процедура АгрегацияГистограммИзКонструктораОтражаетсяВСелекторе() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));

    // Когда
    Читатель = Новый ОтелПериодическийЧитательМетрик(
        МокЭкспортер, , , "base2_exponential_bucket_histogram");

    // Тогда
    Ожидаем.Что(Читатель.АгрегацияПоУмолчанию("Histogram")).Равно("base2_exponential_bucket_histogram");
