&Тест
Процедура МетрикаЧастичноеПринятиеФильтром() Экспорт

    // Дано - фильтр с ЧастичноеПринятие и захватчик экспорта
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    Захватчик = ЗагрузитьСценарий(ОбъединитьПути(КаталогФикстур, "ЗахватчикЭкспорта.os"));

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("partial.counter");
    Счетчик.Добавить(55);

    Читатель = Новый ОтелПериодическийЧитательМетрик(Захватчик);
    Читатель.ДобавитьМетр(Метрика);

    МокФильтр = Мок.Получить(Тип("ОтелФильтрМетрик"));
    МокФильтр.Когда().ТестМетрики(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(ОтелРезультатФильтраМетрик.ЧастичноеПринятие());
    МокФильтр.Когда().ТестАтрибутов(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(ОтелРезультатФильтраАтрибутов.Принять());
    Читатель.УстановитьФильтрМетрик(МокФильтр);

    // Когда
    Результат = Читатель.СброситьБуфер();

    // Тогда - метрика прошла частичный фильтр и была экспортирована
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    Ожидаем.Что(Захватчик.ЗахваченныеЗначения.Количество()).Равно(1);
    Ожидаем.Что(Захватчик.ЗахваченныеЗначения[0][0]).Равно(55);

