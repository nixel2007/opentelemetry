&Тест
Процедура ПродюсерВозвращаетОбъектСОшибкой() Экспорт

    // Дано - захватчик экспорта
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    Захватчик = ЗагрузитьСценарий(ОбъединитьПути(КаталогФикстур, "ЗахватчикЭкспорта.os"));

    // Результирующий объект продюсера с Успех() = Ложь
    ТекстРезультата = "
    |Перем Статус Экспорт;
    |Перем СообщениеОшибки Экспорт;
    |Перем Метрики Экспорт;
    |Функция Успех() Экспорт
    |    Возврат Ложь;
    |КонецФункции
    |Статус = ""error"";
    |СообщениеОшибки = ""тест: ошибка продюсера"";
    |Метрики = Новый Массив();";
    ОбъектРезультата = ЗагрузитьСценарийИзСтроки(ТекстРезультата);

    // Продюсер, возвращающий объект с Успех() = Ложь
    ТекстПродюсера = "
    |Перем ОбъектРезультата Экспорт;
    |Функция Произвести(Фильтр) Экспорт
    |    Возврат ОбъектРезультата;
    |КонецФункции";
    Продюсер = ЗагрузитьСценарийИзСтроки(ТекстПродюсера);
    Продюсер.ОбъектРезультата = ОбъектРезультата;

    Читатель = Новый ОтелПериодическийЧитательМетрик(Захватчик);
    Читатель.ДобавитьПродюсер(Продюсер);

    // Когда
    Результат = Читатель.СброситьБуфер();

    // Тогда - продюсер вернул ошибку, читатель не упал, данные не экспортированы
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    Ожидаем.Что(Захватчик.ЗахваченныеЗначения.Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ОбогатитьФильтрЭкспортерБросает() Экспорт

    // Дано - мок экспортер, бросающий исключение при ПолучитьВременнуюАгрегацию
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    МокЭкспортер.Когда().ПолучитьВременнуюАгрегацию(
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВыбрасываетИсключение("тест: ошибка получения временности");

    // Продюсер, захватывающий переданный фильтр
    ТекстПродюсера = "
    |Перем ЗахваченныйФильтр Экспорт;
    |Функция Произвести(Фильтр) Экспорт
    |    ЗахваченныйФильтр = Фильтр;
    |    Возврат Новый Массив();
    |КонецФункции";
    Продюсер = ЗагрузитьСценарийИзСтроки(ТекстПродюсера);

    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);
    Читатель.ДобавитьПродюсер(Продюсер);

    // Когда
    Читатель.СброситьБуферБезОчистки();

    // Тогда - при исключении в ПолучитьВременнуюАгрегацию фильтр для продюсера = Неопределено
    Ожидаем.Что(Продюсер.ЗахваченныйФильтр).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ОбогатитьФильтрСоздаетНовыйФильтрСТемпоральностью() Экспорт

    // Дано - мок экспортер, возвращающий Дельта() из ПолучитьВременнуюАгрегацию
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    МокЭкспортер.Когда().ПолучитьВременнуюАгрегацию(
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(ОтелВременнаяАгрегация.Дельта());

    // Продюсер, захватывающий переданный фильтр
    ТекстПродюсера = "
    |Перем ЗахваченныйФильтр Экспорт;
    |Функция Произвести(Фильтр) Экспорт
    |    ЗахваченныйФильтр = Фильтр;
    |    Возврат Новый Массив();
    |КонецФункции";
    Продюсер = ЗагрузитьСценарийИзСтроки(ТекстПродюсера);

    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);
    Читатель.ДобавитьПродюсер(Продюсер);

    // Когда - нет пользовательского фильтра (ФильтрМетрик = Неопределено)
    Читатель.СброситьБуферБезОчистки();

    // Тогда - создан новый ОтелФильтрМетрик с предпочтительной темпоральностью Дельта
    Ожидаем.Что(Продюсер.ЗахваченныйФильтр).Не_().Равно(Неопределено);
    Ожидаем.Что(Продюсер.ЗахваченныйФильтр.ПредпочтительнаяТемпоральность())
        .Равно(ОтелВременнаяАгрегация.Дельта());

КонецПроцедуры

&Тест
Процедура ОбогатитьФильтрДобавляетТемпоральностьВСуществующийФильтр() Экспорт

    // Дано - мок экспортер, возвращающий Кумулятивная() из ПолучитьВременнуюАгрегацию
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    МокЭкспортер.Когда().ПолучитьВременнуюАгрегацию(
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(ОтелВременнаяАгрегация.Кумулятивная());

    // Существующий фильтр без предпочтительной темпоральности
    СуществующийФильтр = Новый ОтелФильтрМетрик();

    // Продюсер, захватывающий переданный фильтр
    ТекстПродюсера = "
    |Перем ЗахваченныйФильтр Экспорт;
    |Функция Произвести(Фильтр) Экспорт
    |    ЗахваченныйФильтр = Фильтр;
    |    Возврат Новый Массив();
    |КонецФункции";
    Продюсер = ЗагрузитьСценарийИзСтроки(ТекстПродюсера);

    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);
    Читатель.УстановитьФильтрМетрик(СуществующийФильтр);
    Читатель.ДобавитьПродюсер(Продюсер);

    // Когда
    Читатель.СброситьБуферБезОчистки();

    // Тогда - существующий фильтр получил предпочтительную темпоральность от экспортера
    Ожидаем.Что(Продюсер.ЗахваченныйФильтр).Равно(СуществующийФильтр);
    Ожидаем.Что(Продюсер.ЗахваченныйФильтр.ПредпочтительнаяТемпоральность())
        .Равно(ОтелВременнаяАгрегация.Кумулятивная());

КонецПроцедуры

