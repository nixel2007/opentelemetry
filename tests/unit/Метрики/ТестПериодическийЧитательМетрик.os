&Тест
Процедура ЧитательНельзяЗарегистрироватьУДвухПровайдеров() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерМетрик"));
    Читатель = Новый ОтелПериодическийЧитательМетрик(МокЭкспортер);

    // Когда - первая регистрация успешна
    Результат1 = Читатель.ЗарегистрироватьУПровайдера();

    // Тогда
    Ожидаем.Что(Результат1).Равно(Истина);

    // Когда - вторая регистрация отклонена
    Результат2 = Читатель.ЗарегистрироватьУПровайдера();

    // Тогда
    Ожидаем.Что(Результат2).Равно(Ложь);

КонецПроцедуры

Функция СобратьЗначенияНаблюдаемого(Временность)
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    Захватчик = ЗагрузитьСценарий(ОбъединитьПути(КаталогФикстур, "ЗахватчикЭкспорта.os"));
    Захватчик.УстановитьВременность(Временность);

    Наблюдатель = ЗагрузитьСценарий(ОбъединитьПути(КаталогФикстур, "ИнкрементныйНаблюдатель.os"));
    Наблюдатель.УстановитьШаг(100);

    Читатель = Новый ОтелПериодическийЧитательМетрик(Захватчик);

    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(Область, Ресурс);
    Действие = Новый Действие(Наблюдатель, "Наблюдать");
    Метр.СоздатьНаблюдаемыйСчетчик("async.counter", Действие);

    Читатель.ДобавитьМетр(Метр);

    Читатель.СброситьБуфер();
    Наблюдатель.УстановитьШаг(50);
    Читатель.СброситьБуфер();
    Наблюдатель.УстановитьШаг(25);
    Читатель.СброситьБуфер();

    Возврат Захватчик.ЗахваченныеЗначения;
КонецФункции

&Тест
Процедура НаблюдаемыйСчетчикКумулятивнаяВременностьПередаетАбсолютныеЗначения() Экспорт

    // Дано+Когда
    Захваченные = СобратьЗначенияНаблюдаемого(ОтелВременнаяАгрегация.Кумулятивная());

    // Тогда - cumulative reader получает абсолютные значения наблюдений
    Ожидаем.Что(Захваченные).ИмеетДлину(3);
    Ожидаем.Что(Захваченные[0][0]).Равно(100);
    Ожидаем.Что(Захваченные[1][0]).Равно(150);
    Ожидаем.Что(Захваченные[2][0]).Равно(175);

КонецПроцедуры

&Тест
Процедура НаблюдаемыйСчетчикДельтаВременностьВычисляетПриращения() Экспорт

    // Дано+Когда
    Захваченные = СобратьЗначенияНаблюдаемого(ОтелВременнаяАгрегация.Дельта());

    // Тогда - delta reader получает приращения относительно предыдущего наблюдения
    Ожидаем.Что(Захваченные).ИмеетДлину(3);
    Ожидаем.Что(Захваченные[0][0]).Равно(100);
    Ожидаем.Что(Захваченные[1][0]).Равно(50);
    Ожидаем.Что(Захваченные[2][0]).Равно(25);

КонецПроцедуры

