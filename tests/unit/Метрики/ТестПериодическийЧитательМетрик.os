    ТекстЭкспортера = "
    |Перем ЗахваченныеИмена Экспорт;
    |Функция Экспортировать(МассивДанных, Таймаут = Неопределено) Экспорт
    |    Для Каждого Данные Из МассивДанных Цикл
    |        ЗахваченныеИмена.Добавить(Данные.Имя());
    |    КонецЦикла;
    |    Возврат Истина;
    |КонецФункции
    |Функция ПолучитьВременнуюАгрегацию(ТипИнструмента) Экспорт
    |    Возврат Неопределено;
    |КонецФункции
    |Процедура Закрыть() Экспорт
    |КонецПроцедуры
    |ЗахваченныеИмена = Новый Массив();";
    ЭкспортерЗахватчик = ЗагрузитьСценарийИзСтроки(ТекстЭкспортера);

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("original.counter");
    Счетчик.Добавить(1);

    // Задаём представление: переименовать "original.counter" → "renamed.counter"
    Пары = Новый Массив();
    Пара = Новый Соответствие();
    Пара.Вставить("Селектор", Новый ОтелСелекторИнструментов("original.counter"));
    Пара.Вставить("Представление", Новый ОтелПредставление("renamed.counter"));
    Пары.Добавить(Пара);
    Метрика.УстановитьПредставления(Пары);

    Читатель = Новый ОтелПериодическийЧитательМетрик(ЭкспортерЗахватчик);
    Читатель.ДобавитьМетр(Метрика);

    // Когда
    Читатель.СброситьБуфер();

    // Тогда - метрика экспортирована с новым именем
    Ожидаем.Что(ЭкспортерЗахватчик.ЗахваченныеИмена.Количество()).Равно(1);
    Ожидаем.Что(ЭкспортерЗахватчик.ЗахваченныеИмена[0]).Равно("renamed.counter");

КонецПроцедуры

