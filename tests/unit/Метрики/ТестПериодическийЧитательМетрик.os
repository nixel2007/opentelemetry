&Тест
Процедура ЗакрытьСРезультатомПовторныйВызовОшибка() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    // Когда
    Результат1 = Читатель.ЗакрытьСРезультатом();
    Результат2 = Читатель.ЗакрытьСРезультатом();

    // Тогда - первый успех, второй с ошибкой "Reader закрыт"
    Ожидаем.Что(Результат1.Успешно()).Равно(Истина);
    Ожидаем.Что(Результат2.Успешно()).Равно(Ложь);
    Ожидаем.Что(Результат2.Описание()).Равно("Reader закрыт");

КонецПроцедуры

&Тест
Процедура СтарыйЗакрытьРаботает() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);

    // Когда / Тогда - повторный вызов не падает
    Читатель.Закрыть();
    Читатель.Закрыть();

