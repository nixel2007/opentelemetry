    Читатель = Новый ОтелПериодическийЧитательМетрик(Захватчик);
    Читатель.ДобавитьПродюсер(Продюсер);

    // Когда
    Результат = Читатель.СброситьБуфер();

    // Тогда - продюсер с Успех()=Истина: данные экспортированы
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    Ожидаем.Что(Захватчик.ЗахваченныеЗначения.Количество()).Равно(1);
    Ожидаем.Что(Захватчик.ЗахваченныеЗначения[0][0]).Равно(77);

