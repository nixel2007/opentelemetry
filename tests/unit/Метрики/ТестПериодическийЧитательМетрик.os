&Тест
Процедура ПринудительноВыгрузитьПередаетТаймаутВЭкспортер() Экспорт

    // Дано - фикстура, захватывающая таймаут
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    Захватчик = ЗагрузитьСценарий(ОбъединитьПути(КаталогФикстур, "ЗахватчикТаймаута.os"));

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("test.counter");
    Счетчик.Добавить(1);

    Читатель = Новый ОтелПериодическийЧитательМетрик(Захватчик);
    Читатель.ДобавитьМетр(Метрика);

    // Когда - СброситьБуфер с конкретным таймаутом
    ОжидаемыйТаймаут = 5000;
    Читатель.СброситьБуфер(ОжидаемыйТаймаут);

    // Тогда - таймаут передан в Экспортировать
    Ожидаем.Что(Захватчик.ЗахваченныйТаймаут).Равно(ОжидаемыйТаймаут);

КонецПроцедуры

&Тест
Процедура ФильтрОтбрасываетМетрику() Экспорт

    // Дано - фильтр, отбрасывающий все метрики
    КаталогФикстур = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures");
    Захватчик = ЗагрузитьСценарий(ОбъединитьПути(КаталогФикстур, "ЗахватчикЭкспорта.os"));

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("test.counter");
    Счетчик.Добавить(42);

    Читатель = Новый ОтелПериодическийЧитательМетрик(Захватчик);
    Читатель.ДобавитьМетр(Метрика);

    МокФильтр = Мок.Получить(Тип("ОтелФильтрМетрик"));
    МокФильтр.Когда().ТестМетрики(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(ОтелРезультатФильтраМетрик.Отбросить());
    Читатель.УстановитьФильтрМетрик(МокФильтр);

    // Когда
    Читатель.СброситьБуфер();

    // Тогда - фильтр отбросил метрику - экспортер не вызывался
    Ожидаем.Что(Захватчик.ЗахваченныеЗначения.Количество()).Равно(0);

КонецПроцедуры

