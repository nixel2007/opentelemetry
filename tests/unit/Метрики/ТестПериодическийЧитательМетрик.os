&Тест
Процедура СброситьБуферПослеЗакрытияВозвращаетОшибку() Экспорт

    // Дано
    Транспорт = Новый ОтелВПамятьТранспорт();
    Экспортер = Новый ОтелЭкспортерМетрик(Транспорт);
    Читатель = Новый ОтелПериодическийЧитательМетрик(Экспортер);
    Читатель.Закрыть();

    // Когда
    Результат = Читатель.СброситьБуфер();
    РезультатБезОчистки = Читатель.СброситьБуферБезОчистки();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Ожидаем.Что(РезультатБезОчистки.Успешно()).Равно(Ложь);

КонецПроцедуры
