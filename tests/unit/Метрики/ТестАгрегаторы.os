&Тест
Процедура АгрегаторСуммыСоздатьАккумулятор() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();

    // Когда
    Аккумулятор = Агрегатор.СоздатьАккумулятор();

    // Тогда
    Ожидаем.Что(Аккумулятор <> Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура АгрегаторСуммыЗаписатьНакапливает() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();

    // Когда
    Агрегатор.Записать(Аккумулятор, 10);
    Агрегатор.Записать(Аккумулятор, 32);

    // Тогда
    Ожидаем.Что(Аккумулятор.Получить()).Равно(42);

КонецПроцедуры

&Тест
Процедура АгрегаторСуммыТочкаДанных() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();
    Агрегатор.Записать(Аккумулятор, 42);
    Атрибуты = Новый Массив;
    Экземпляры = Новый Массив;

    // Когда
    ТочкаДанных = Агрегатор.СформироватьТочкуДанных(Аккумулятор, "1000", "2000", Атрибуты, Экземпляры);

    // Тогда
    Ожидаем.Что(ТочкаДанных.Получить("value")).Равно(42);
    Ожидаем.Что(ТочкаДанных.Получить("startTimeUnixNano")).Равно("1000");
    Ожидаем.Что(ТочкаДанных.Получить("timeUnixNano")).Равно("2000");
    Ожидаем.Что(ТочкаДанных.Получить("attributes")).Равно(Атрибуты);

КонецПроцедуры

&Тест
Процедура АгрегаторСуммыДанныеМонотонный() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Истина, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    ТочкиДанных = Новый Массив;
    ТочкиДанных.Добавить(Новый Соответствие);

    // Когда
    Данные = Агрегатор.СформироватьДанныеМетрики(Ресурс, Область, "my.counter", "desc", "1", ТочкиДанных);

    // Тогда
    Ожидаем.Что(Данные.ТипМетрики()).Равно(ОтелТипМетрики.Сумма());
    Ожидаем.Что(Данные.Монотонный()).Равно(Истина);
    Ожидаем.Что(Данные.Имя()).Равно("my.counter");
    Ожидаем.Что(Данные.Описание()).Равно("desc");
    Ожидаем.Что(Данные.ЕдиницаИзмерения()).Равно("1");
    Ожидаем.Что(Данные.ТипЗначения()).Равно("int");
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура АгрегаторСуммыДанныеНеМонотонный() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Сумма(), Ложь, "int");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторСуммы(), АгрегаторБаза).Построить();
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    ТочкиДанных = Новый Массив;

    // Когда
    Данные = Агрегатор.СформироватьДанныеМетрики(Ресурс, Область, "my.updown", "desc", "1", ТочкиДанных);

    // Тогда
    Ожидаем.Что(Данные.Монотонный()).Равно(Ложь);

КонецПроцедуры

