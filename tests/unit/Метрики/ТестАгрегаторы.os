&Тест
Процедура АгрегаторГистограммыОтключенSum() Экспорт

    // Дано - агрегатор с отключённым сбором суммы
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Гистограмма(), Ложь, "double");
    Агрегатор = Новый ПостроительНаследника(
        Новый ОтелАгрегаторГистограммы(Неопределено, Ложь), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();
    Атрибуты = Новый Массив;
    Экземпляры = Новый Массив;

    // Когда - записываем значение и формируем точку данных
    Агрегатор.Записать(Аккумулятор, 42);
    ТочкаДанных = Агрегатор.СформироватьТочкуДанных(Аккумулятор, "1000", "2000", Атрибуты, Экземпляры);

    // Тогда - поле sum отсутствует в точке данных
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(Неопределено);
    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(1);

КонецПроцедуры

&Тест
Процедура АгрегаторГистограммыПустыеГраницы() Экспорт

    // Дано - агрегатор с пустым массивом границ (Количество = 0 → НормализоватьГраницы → Возврат as-is)
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Гистограмма(), Ложь, "double");
    ПустыеГраницы = Новый Массив;
    Агрегатор = Новый ПостроительНаследника(
        Новый ОтелАгрегаторГистограммы(ПустыеГраницы), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();
    Атрибуты = Новый Массив;
    Экземпляры = Новый Массив;

    // Когда
    Агрегатор.Записать(Аккумулятор, 5);
    ТочкаДанных = Агрегатор.СформироватьТочкуДанных(Аккумулятор, "1000", "2000", Атрибуты, Экземпляры);

    // Тогда - граней нет, только один бакет «всё»
    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура АгрегаторГистограммыНормализацияНеотсортированных() Экспорт

    // Дано - границы в неправильном порядке → должны быть отсортированы
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Гистограмма(), Ложь, "double");
    Границы = Новый Массив;
    Границы.Добавить(100);
    Границы.Добавить(10);
    Границы.Добавить(50);
    Агрегатор = Новый ПостроительНаследника(
        Новый ОтелАгрегаторГистограммы(Границы), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();
    Атрибуты = Новый Массив;
    Экземпляры = Новый Массив;

    // Когда
    Агрегатор.Записать(Аккумулятор, 25);
    ТочкаДанных = Агрегатор.СформироватьТочкуДанных(Аккумулятор, "1000", "2000", Атрибуты, Экземпляры);

    // Тогда - границы отсортированы: [10, 50, 100]
    ГраницыРезультата = ТочкаДанных.Получить("explicitBounds");
    Ожидаем.Что(ГраницыРезультата).ИмеетДлину(3);
    Ожидаем.Что(ГраницыРезультата[0]).Равно(10);
    Ожидаем.Что(ГраницыРезультата[1]).Равно(50);
    Ожидаем.Что(ГраницыРезультата[2]).Равно(100);

КонецПроцедуры

