    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    ТочкиДанных = Новый Массив;

    // Когда
    Данные = Агрегатор.СформироватьДанныеМетрики(Ресурс, Область, "my.exphist", "desc", "ms", ТочкиДанных);

    // Тогда
    Ожидаем.Что(Данные.ТипМетрики()).Равно(ОтелТипМетрики.ЭкспоненциальнаяГистограмма());
    Ожидаем.Что(Данные.Монотонный()).Равно(Ложь);

КонецПроцедуры

