КонецПроцедуры

&Тест
Процедура АгрегаторЭкспГистограммыЗначениеВПорогеНуля() Экспорт

    // Дано - агрегатор с ненулевым порогом нуля (ПорогНуля = 1.0)
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(
        ОтелТипМетрики.ЭкспоненциальнаяГистограмма(), Ложь, "double");
    // BSLLS:MagicNumber-off
    Агрегатор = Новый ПостроительНаследника(
        Новый ОтелАгрегаторЭкспоненциальнойГистограммы(160, 20, 1.0), АгрегаторБаза).Построить();
    // BSLLS:MagicNumber-on
    Аккумулятор = Агрегатор.СоздатьАккумулятор();

    // Когда - записываем значение ≤ порога нуля (0.5 ≤ 1.0)
    Агрегатор.Записать(Аккумулятор, 0.5);

    // Тогда - значение попало в zeroCount, а не в положительные бакеты
    Ожидаем.Что(Аккумулятор.Получить("zeroCount").Получить()).Равно(1);
    Ожидаем.Что(Аккумулятор.Получить("positive").Получить("bucketCounts").Количество()).Равно(0);

КонецПроцедуры
