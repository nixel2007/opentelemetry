// ОтелАгрегаторГистограммы
// ============================================================

&Тест
Процедура АгрегаторГистограммыСоздатьАккумулятор() Экспорт

    // Дано
    Границы = Новый Массив;
    Границы.Добавить(10);
    Границы.Добавить(100);
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Гистограмма(), Ложь, "double");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторГистограммы(Границы), АгрегаторБаза).Построить();

    // Когда
    Аккумулятор = Агрегатор.СоздатьАккумулятор();

    // Тогда
    Ожидаем.Что(Аккумулятор <> Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура АгрегаторГистограммыНеУчитываетОтрицательныеВSum() Экспорт

    // Дано
    Границы = Новый Массив;
    Границы.Добавить(10);
    Границы.Добавить(100);
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Гистограмма(), Ложь, "double");
    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторГистограммы(Границы), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();

    // Когда - записываем смесь положительных и отрицательных значений
    Агрегатор.Записать(Аккумулятор, 5);
    Агрегатор.Записать(Аккумулятор, -3);
    Агрегатор.Записать(Аккумулятор, 50);
    Агрегатор.Записать(Аккумулятор, -10);

    // Тогда - count учитывает все, sum игнорирует отрицательные
    ТочкаДанных = Агрегатор.СформироватьТочкуДанных(Аккумулятор, "0", "1000", Новый Массив, Новый Массив);

    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(4);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(55);

    БакетыСчетчики = ТочкаДанных.Получить("bucketCounts");
    Ожидаем.Что(БакетыСчетчики[0]).Равно(3);
    Ожидаем.Что(БакетыСчетчики[1]).Равно(1);
    Ожидаем.Что(БакетыСчетчики[2]).Равно(0);

КонецПроцедуры

// BSLLS:Typo-off
&Тест
Процедура АгрегаторГистограммыРаспределяетПоБакетам() Экспорт
// BSLLS:Typo-on

    // Дано - границы [10, 100] -> 3 бакета: (<=10], (10,100], (>100)
    Границы = Новый Массив;
    Границы.Добавить(10);
    Границы.Добавить(100);
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Гистограмма(), Ложь, "double");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторГистограммы(Границы), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();

    // Когда
    Агрегатор.Записать(Аккумулятор, 5);
    Агрегатор.Записать(Аккумулятор, 50);
    Агрегатор.Записать(Аккумулятор, 200);

    // Тогда
    ТочкаДанных = Агрегатор.СформироватьТочкуДанных(Аккумулятор, "0", "1000", Новый Массив, Новый Массив);

    Ожидаем.Что(ТочкаДанных.Получить("count")).Равно(3);
    Ожидаем.Что(ТочкаДанных.Получить("sum")).Равно(255);
    Ожидаем.Что(ТочкаДанных.Получить("min")).Равно(5);
    Ожидаем.Что(ТочкаДанных.Получить("max")).Равно(200);

    БакетыСчетчики = ТочкаДанных.Получить("bucketCounts");
    Ожидаем.Что(БакетыСчетчики).ИмеетДлину(3);
    Ожидаем.Что(БакетыСчетчики[0]).Равно(1);
    Ожидаем.Что(БакетыСчетчики[1]).Равно(1);
    Ожидаем.Что(БакетыСчетчики[2]).Равно(1);

    Ожидаем.Что(ТочкаДанных.Получить("explicitBounds")).Равно(Границы);

КонецПроцедуры

&Тест
Процедура АгрегаторГистограммыДанные() Экспорт

    // Дано
    Границы = Новый Массив;
    Границы.Добавить(10);
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(ОтелТипМетрики.Гистограмма(), Ложь, "double");

    Агрегатор = Новый ПостроительНаследника(Новый ОтелАгрегаторГистограммы(Границы), АгрегаторБаза).Построить();
    Ресурс = Новый ОтелРесурс();
    Область = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    ТочкиДанных = Новый Массив;

    // Когда
    Данные = Агрегатор.СформироватьДанныеМетрики(Ресурс, Область, "my.hist", "desc", "ms", ТочкиДанных);

    // Тогда
    Ожидаем.Что(Данные.ТипМетрики()).Равно(ОтелТипМетрики.Гистограмма());
    Ожидаем.Что(Данные.Монотонный()).Равно(Ложь);

КонецПроцедуры

// ============================================================
// ОтелАгрегаторЭкспоненциальнойГистограммы
// ============================================================

&Тест
Процедура АгрегаторЭкспГистограммыСоздатьАккумулятор() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(

        ОтелТипМетрики.ЭкспоненциальнаяГистограмма(), Ложь, "double");

    Агрегатор = Новый ПостроительНаследника(

        Новый ОтелАгрегаторЭкспоненциальнойГистограммы(), АгрегаторБаза).Построить();

    // Когда
    Аккумулятор = Агрегатор.СоздатьАккумулятор();

    // Тогда
    Ожидаем.Что(Аккумулятор <> Неопределено).ЭтоИстина();
    Ожидаем.Что(Аккумулятор.Получить("count").Получить()).Равно(0);
    Ожидаем.Что(Аккумулятор.Получить("sum").Получить()).Равно(0);
    Ожидаем.Что(Аккумулятор.Получить("zeroCount").Получить()).Равно(0);
    Ожидаем.Что(Аккумулятор.Получить("scale")).Равно(20);

КонецПроцедуры

&Тест
Процедура АгрегаторЭкспГистограммыЗаписатьОдноЗначение() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(

        ОтелТипМетрики.ЭкспоненциальнаяГистограмма(), Ложь, "double");

    Агрегатор = Новый ПостроительНаследника(

        Новый ОтелАгрегаторЭкспоненциальнойГистограммы(), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();

    // Когда
    Агрегатор.Записать(Аккумулятор, 42);

    // Тогда
    Ожидаем.Что(Аккумулятор.Получить("count").Получить()).Равно(1);
    Ожидаем.Что(Аккумулятор.Получить("sum").Получить()).Равно(42);
    Ожидаем.Что(Аккумулятор.Получить("min").Получить()).Равно(42);
    Ожидаем.Что(Аккумулятор.Получить("max").Получить()).Равно(42);

    Положительные = Аккумулятор.Получить("positive");
    Ожидаем.Что(Положительные.Получить("bucketCounts").Количество() > 0).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура АгрегаторЭкспГистограммыЗаписатьНоль() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(

        ОтелТипМетрики.ЭкспоненциальнаяГистограмма(), Ложь, "double");

    Агрегатор = Новый ПостроительНаследника(

        Новый ОтелАгрегаторЭкспоненциальнойГистограммы(), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();

    // Когда
    Агрегатор.Записать(Аккумулятор, 0);

    // Тогда
    Ожидаем.Что(Аккумулятор.Получить("count").Получить()).Равно(1);
    Ожидаем.Что(Аккумулятор.Получить("zeroCount").Получить()).Равно(1);

КонецПроцедуры

&Тест
Процедура АгрегаторЭкспГистограммыТочкаДанных() Экспорт

    // Дано
    АгрегаторБаза = Новый ОтелБазовыйАгрегатор(

        ОтелТипМетрики.ЭкспоненциальнаяГистограмма(), Ложь, "double");

    Агрегатор = Новый ПостроительНаследника(

        Новый ОтелАгрегаторЭкспоненциальнойГистограммы(), АгрегаторБаза).Построить();
    Аккумулятор = Агрегатор.СоздатьАккумулятор();
    Агрегатор.Записать(Аккумулятор, 42);
    Атрибуты = Новый Массив;
    Экземпляры = Новый Массив;

    // Когда
    ТочкаДанных = Агрегатор.СформироватьТочкуДанных(Аккумулятор, "1000", "2000", Атрибуты, Экземпляры);

