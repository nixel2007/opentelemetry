// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура СозданиеДатчика() Экспорт

    // Дано
    Датчик = Новый ОтелДатчик("cpu.usage", "Использование CPU", "%");

    // Тогда
    Ожидаем.Что(Датчик.Имя()).Равно("cpu.usage");
    Ожидаем.Что(Датчик.Описание()).Равно("Использование CPU");
    Ожидаем.Что(Датчик.ЕдиницаИзмерения()).Равно("%");
    Ожидаем.Что(Датчик.ТипМетрики()).Равно("gauge");
    Ожидаем.Что(Датчик.ТипЗначения()).Равно("double");

КонецПроцедуры

&Тест
Процедура ЗаписьЗначения() Экспорт

    // Дано
    Датчик = Новый ОтелДатчик("test.gauge");

    // Когда
    Датчик.Записать(42);

    // Тогда
    Ожидаем.Что(Датчик.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Датчик.ТекущееЗначение()).Равно(42);
    Ожидаем.Что(Датчик.КоличествоСерий()).Равно(1);

КонецПроцедуры

&Тест
Процедура ПоследнееЗначение() Экспорт

    // Дано
    Датчик = Новый ОтелДатчик("test.gauge");

    // Когда - несколько записей, хранится последнее
    Датчик.Записать(10);
    Датчик.Записать(20);

    // Тогда - последнее значение перезаписывает предыдущее
    Ожидаем.Что(Датчик.КоличествоСерий()).Равно(1);
    Ожидаем.Что(Датчик.ТекущееЗначение()).Равно(20);

КонецПроцедуры
