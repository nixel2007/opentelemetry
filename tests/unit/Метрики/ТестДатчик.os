// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

Функция СоздатьМетр()
    Ресурс = Новый ОтелРесурс(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Возврат Новый ОтелМетр(Область, Ресурс);
КонецФункции

Функция СобратьДанные(Инструмент, Метр)
    Возврат Инструмент.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Инструмент.Имя(), Инструмент.Описание());
КонецФункции

&Тест
Процедура СозданиеДатчика() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("cpu.usage", "Использование CPU", "%");

    // Тогда - проверяем свойства инструмента
    Ожидаем.Что(Датчик.Имя()).Равно("cpu.usage");
    Ожидаем.Что(Датчик.Описание()).Равно("Использование CPU");
    Ожидаем.Что(Датчик.ЕдиницаИзмерения()).Равно("%");

    // Тогда - проверяем метаданные через СобратьДанные
    Датчик.Записать(1);
    Данные = СобратьДанные(Датчик, Метр);
    Ожидаем.Что(Данные.ТипМетрики()).Равно("gauge");
    Ожидаем.Что(Данные.ТипЗначения()).Равно("double");

КонецПроцедуры

&Тест
Процедура ЗаписьЗначения() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("test.gauge");

    // Когда
    Датчик.Записать(42);

    // Тогда
    Данные = СобратьДанные(Датчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(42);
    Ожидаем.Что(Датчик.КоличествоСерий()).Равно(1);

КонецПроцедуры

&Тест
Процедура ПоследнееЗначение() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("test.gauge");

    // Когда - несколько записей, хранится последнее
    Датчик.Записать(10);
    Датчик.Записать(20);

    // Тогда - последнее значение перезаписывает предыдущее
    Данные = СобратьДанные(Датчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(20);
    Ожидаем.Что(Датчик.КоличествоСерий()).Равно(1);

КонецПроцедуры

&Тест
Процедура ОчисткаТочекДанных() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("test.gauge");
    Датчик.Записать(42);

    // Когда
    Датчик.ОчиститьТочкиДанных();

    // Тогда
    Данные = СобратьДанные(Датчик, Метр);
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ЗаписьБезАтрибутов() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("test.gauge");

    // Когда - запись без атрибутов
    Датчик.Записать(55);

    // Тогда - точка данных с пустым массивом атрибутов
    Данные = СобратьДанные(Датчик, Метр);
    ТочкиДанных = Данные.ТочкиДанных();
    Ожидаем.Что(ТочкиДанных).ИмеетДлину(1);
    Ожидаем.Что(ТочкиДанных[0].Получить("attributes")).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ЗахватЭкземпляров() Экспорт

    // Дано - фильтр ВсегдаВключен + спан в контексте
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("test.gauge");
    Датчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Область = ОтелКонтекст.СделатьСпанТекущим(Спан);

    // Когда
    Датчик.Записать(42);

    // Тогда
    Данные = СобратьДанные(Датчик, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("asDouble")).Равно(42);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ВключенПоУмолчанию() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("test.enabled");

    // Тогда
    Ожидаем.Что(Датчик.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОтключенныйИнструментНеНакапливает() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("test.disabled");
    Датчик.Отключить();

    // Когда
    Датчик.Записать(42);

    // Тогда
    Ожидаем.Что(Датчик.Включен()).Равно(Ложь);
    Данные = СобратьДанные(Датчик, Метр);
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ЗаписатьСЯвнымКонтекстом() Экспорт

    // Дано - датчик с фильтром ВсегдаВключен
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("test.gauge.ctx");
    Датчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест-контекст", Ресурс, ОбластьИнструментирования);

    // Строим явный контекст (Соответствие) с нашим спаном
    ЯвныйКонтекст = Новый Соответствие();
    ЯвныйКонтекст.Вставить("otel-span", Спан);

    // Когда - вызов с явным контекстом
    Датчик.Записать(42, Неопределено, ЯвныйКонтекст);

    // Тогда - exemplar содержит trace/span из явного контекста
    Данные = СобратьДанные(Датчик, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

КонецПроцедуры

&Тест
Процедура ЗаписатьОбратнаяСовместимость() Экспорт

    // Дано - вызов без контекста (обратная совместимость)
    Метр = СоздатьМетр();
    Датчик = Метр.СоздатьДатчик("test.gauge.compat");

    // Когда - несколько вариантов вызова
    Датчик.Записать(10);
    Датчик.Записать(20, Неопределено);
    Датчик.Записать(30, Неопределено, Неопределено);

    // Тогда - последнее значение
    Данные = СобратьДанные(Датчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(30);

КонецПроцедуры
