&Тест
Процедура СозданиеСчетчика() Экспорт

    // Дано
    Счетчик = Новый ОтелРеверсивныйСчетчик("active.connections", "Активные соединения", "1");

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("active.connections");
    Ожидаем.Что(Счетчик.Описание()).Равно("Активные соединения");
    Ожидаем.Что(Счетчик.ЕдиницаИзмерения()).Равно("1");
    Ожидаем.Что(Счетчик.ТипМетрики()).Равно("sum");
    Ожидаем.Что(Счетчик.Монотонный()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура Увеличение() Экспорт

    // Дано
    Счетчик = Новый ОтелРеверсивныйСчетчик("test.updown");

    // Когда
    Счетчик.Добавить(5);
    Счетчик.Добавить(3);

    // Тогда
    Ожидаем.Что(Счетчик.НакопленноеЗначение()).Равно(8);

КонецПроцедуры

&Тест
Процедура Уменьшение() Экспорт

    // Дано
    Счетчик = Новый ОтелРеверсивныйСчетчик("test.updown");

    // Когда
    Счетчик.Добавить(10);
    Счетчик.Добавить(-3);

    // Тогда
    Ожидаем.Что(Счетчик.НакопленноеЗначение()).Равно(7);
    Ожидаем.Что(Счетчик.КоличествоСерий()).Равно(1);

КонецПроцедуры

&Тест
Процедура СмешанныеОперации() Экспорт

    // Дано
    Счетчик = Новый ОтелРеверсивныйСчетчик("test.updown");

    // Когда
    Счетчик.Добавить(10);
    Счетчик.Добавить(-3);
    Счетчик.Добавить(5);
    Счетчик.Добавить(-5);

    // Тогда
    Ожидаем.Что(Счетчик.НакопленноеЗначение()).Равно(7);
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ЗахватЭкземпляров() Экспорт

    // Дано - фильтр ВсегдаВключен + спан в контексте
    Счетчик = Новый ОтелРеверсивныйСчетчик("test.updown");
    Счетчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    Спан = Новый ОтелСпан("тест", Ресурс, "библ", "1.0");
    Область = ОтелКонтекст.СделатьСпанТекущим(Спан);

    // Когда
    Счетчик.Добавить(42);

    // Тогда
    ТочкаДанных = Счетчик.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("asDouble")).Равно(42);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ВключенПоУмолчанию() Экспорт

    // Дано
    Счетчик = Новый ОтелРеверсивныйСчетчик("test.enabled");

    // Тогда
    Ожидаем.Что(Счетчик.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОтключенныйИнструментНеНакапливает() Экспорт

    // Дано
    Счетчик = Новый ОтелРеверсивныйСчетчик("test.disabled");
    Счетчик.Отключить();

    // Когда
    Счетчик.Добавить(42);

    // Тогда
    Ожидаем.Что(Счетчик.Включен()).Равно(Ложь);
    Ожидаем.Что(Счетчик.ТочкиДанных()).ИмеетДлину(0);

КонецПроцедуры
