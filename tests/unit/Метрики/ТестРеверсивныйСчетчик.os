// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

Функция СоздатьМетр()
    Ресурс = Новый ОтелРесурс(Истина);
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Возврат Новый ОтелМетр(Область, Ресурс);
КонецФункции

Функция СобратьДанные(Инструмент, Метр)
    Возврат Инструмент.Собрать(
        Метр.Ресурс(), Метр.ОбластьИнструментирования(),
        Инструмент.Имя(), Инструмент.Описание());
КонецФункции

&Тест
Процедура СозданиеСчетчика() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("active.connections", "Активные соединения", "1");

    // Тогда - проверяем свойства инструмента
    Ожидаем.Что(Счетчик.Имя()).Равно("active.connections");
    Ожидаем.Что(Счетчик.Описание()).Равно("Активные соединения");
    Ожидаем.Что(Счетчик.ЕдиницаИзмерения()).Равно("1");

    // Тогда - проверяем метаданные через СобратьДанные
    Счетчик.Добавить(1);
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТипМетрики()).Равно("sum");
    Ожидаем.Что(Данные.Монотонный()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура Увеличение() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test.updown");

    // Когда
    Счетчик.Добавить(5);
    Счетчик.Добавить(3);

    // Тогда
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(8);

КонецПроцедуры

&Тест
Процедура Уменьшение() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test.updown");

    // Когда
    Счетчик.Добавить(10);
    Счетчик.Добавить(-3);

    // Тогда
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(7);
    Ожидаем.Что(Счетчик.КоличествоСерий()).Равно(1);

КонецПроцедуры

&Тест
Процедура СмешанныеОперации() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test.updown");

    // Когда
    Счетчик.Добавить(10);
    Счетчик.Добавить(-3);
    Счетчик.Добавить(5);
    Счетчик.Добавить(-5);

    // Тогда
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(7);
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ЗахватЭкземпляров() Экспорт

    // Дано - фильтр ВсегдаВключен + спан в контексте
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test.updown");
    Счетчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", Ресурс, ОбластьИнструментирования);
    Область = ОтелКонтекст.СделатьСпанТекущим(Спан);

    // Когда
    Счетчик.Добавить(42);

    // Тогда
    Данные = СобратьДанные(Счетчик, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("asDouble")).Равно(42);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ВключенПоУмолчанию() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test.enabled");

    // Тогда
    Ожидаем.Что(Счетчик.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОтключенныйИнструментНеНакапливает() Экспорт

    // Дано
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test.disabled");
    Счетчик.Отключить();

    // Когда
    Счетчик.Добавить(42);

    // Тогда
    Ожидаем.Что(Счетчик.Включен()).Равно(Ложь);
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные = Неопределено).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ДобавитьСЯвнымКонтекстом() Экспорт

    // Дано - счетчик с фильтром ВсегдаВключен
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test.updown.ctx");
    Счетчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест-контекст", Ресурс, ОбластьИнструментирования);

    // Строим явный контекст (Соответствие) с нашим спаном
    ЯвныйКонтекст = Новый Соответствие();
    ЯвныйКонтекст.Вставить("otel-span", Спан);

    // Когда - вызов с явным контекстом
    Счетчик.Добавить(10, Неопределено, ЯвныйКонтекст);

    // Тогда - exemplar содержит trace/span из явного контекста
    Данные = СобратьДанные(Счетчик, Метр);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);
    Ожидаем.Что(Экземпляры[0].Получить("traceId")).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Экземпляры[0].Получить("spanId")).Равно(Спан.КонтекстСпана().ИдСпана());

КонецПроцедуры

&Тест
Процедура ДобавитьОбратнаяСовместимость() Экспорт

    // Дано - вызов без контекста (обратная совместимость)
    Метр = СоздатьМетр();
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test.updown.compat");

    // Когда - разные варианты вызова
    Счетчик.Добавить(5);
    Счетчик.Добавить(-2, Неопределено);
    Счетчик.Добавить(3, Неопределено, Неопределено);

    // Тогда - все значения суммируются
    Данные = СобратьДанные(Счетчик, Метр);
    Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(6);

КонецПроцедуры
