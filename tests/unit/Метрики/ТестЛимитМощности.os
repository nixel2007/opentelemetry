        Если ЭтоOverflow(Точка) Тогда
            Ожидаем.Что(Точка.Получить("value")).Равно(30);
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ЭкспоненциальнаяГистограммаПеренаправляетВПереполнение() Экспорт

    // Дано
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма("test.exphist");
    Гистограмма.УстановитьЛимитМощности(2);

    АтрА = Новый ОтелАтрибуты();
    АтрА.Установить("region", "us");
    АтрБ = Новый ОтелАтрибуты();
    АтрБ.Установить("region", "eu");
    АтрВ = Новый ОтелАтрибуты();
    АтрВ.Установить("region", "asia");

    // Когда
    Гистограмма.Записать(1.5, АтрА);
    Гистограмма.Записать(2.5, АтрБ);
    Гистограмма.Записать(3.5, АтрВ);

    // Тогда
    Точки = Гистограмма.ТочкиДанных();
    Ожидаем.Что(Точки.Количество()).Равно(3);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            Ожидаем.Что(Точка.Получить("count")).Равно(1);
            Ожидаем.Что(Точка.Получить("sum")).Равно(3.5);
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).Равно(Истина);

КонецПроцедуры

&Тест
Процедура МетрПередаетЛимитМощностиИнструментам() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метр = Новый ОтелМетр("test", "1.0", Ресурс);
    Метр.УстановитьЛимитМощности(2);

    // Когда
    Счетчик = Метр.СоздатьСчетчик("test.count");

    АтрА = Новый ОтелАтрибуты();
    АтрА.Установить("k", "a");
    АтрБ = Новый ОтелАтрибуты();
    АтрБ.Установить("k", "b");
    АтрВ = Новый ОтелАтрибуты();
    АтрВ.Установить("k", "c");

    Счетчик.Добавить(1, АтрА);
    Счетчик.Добавить(1, АтрБ);
    Счетчик.Добавить(1, АтрВ); // overflow

    // Тогда - 2 + 1 overflow = 3
    Точки = Счетчик.ТочкиДанных();
    Ожидаем.Что(Точки.Количество()).Равно(3);

КонецПроцедуры

&Тест
Процедура СуществующиеСерииНеПеренаправляются() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");
    Счетчик.УстановитьЛимитМощности(2);

    АтрА = Новый ОтелАтрибуты();
    АтрА.Установить("key", "a");
    АтрБ = Новый ОтелАтрибуты();
    АтрБ.Установить("key", "b");

    // Когда - заполняем до лимита
    Счетчик.Добавить(1, АтрА);
    Счетчик.Добавить(2, АтрБ);
    // Повторное добавление в существующую серию не переполняет
    Счетчик.Добавить(10, АтрА);
    Счетчик.Добавить(20, АтрБ);

    // Тогда - только 2 серии, без overflow
    Точки = Счетчик.ТочкиДанных();
    Ожидаем.Что(Точки.Количество()).Равно(2);

    Для Каждого Точка Из Точки Цикл
        Ожидаем.Что(ЭтоOverflow(Точка)).Равно(Ложь);
    КонецЦикла;

КонецПроцедуры

&Тест
Процедура НесколькоЗначенийНакапливаютсяВПереполнении() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");
    Счетчик.УстановитьЛимитМощности(1);

    АтрА = Новый ОтелАтрибуты();
    АтрА.Установить("key", "a");

    // Когда - первый занимает единственное место
    Счетчик.Добавить(1, АтрА);
    // Остальные идут в overflow
    Для Сч = 1 По 5 Цикл
        Атр = Новый ОтелАтрибуты();
        Атр.Установить("key", "overflow_" + Строка(Сч));
        Счетчик.Добавить(10, Атр);
    КонецЦикла;

    // Тогда
    Точки = Счетчик.ТочкиДанных();
    // 1 обычная + 1 overflow = 2
    Ожидаем.Что(Точки.Количество()).Равно(2);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            Ожидаем.Что(Точка.Получить("value")).Равно(50); // 5 * 10
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).Равно(Истина);

КонецПроцедуры
