    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("host", "srv2");
    АтрибутыВ = Новый ОтелАтрибуты();
    АтрибутыВ.Установить("host", "srv3");

    // Когда
    Датчик.Записать(10, АтрибутыА);
    Датчик.Записать(20, АтрибутыБ);
    Датчик.Записать(30, АтрибутыВ);

    // Тогда
    Точки = СобратьТочки(Датчик, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(3);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            Ожидаем.Что(Точка.Получить("value")).Равно(30);
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ЭкспоненциальнаяГистограммаПеренаправляетВПереполнение() Экспорт

    // Дано
    Метр = СоздатьМетрСЛимитом(2);
    Гистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("test.exphist");

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("region", "us");
    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("region", "eu");
    АтрибутыВ = Новый ОтелАтрибуты();
    АтрибутыВ.Установить("region", "asia");

    // Когда
    Гистограмма.Записать(1.5, АтрибутыА);
    Гистограмма.Записать(2.5, АтрибутыБ);
    Гистограмма.Записать(3.5, АтрибутыВ);

    // Тогда
    Точки = СобратьТочки(Гистограмма, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(3);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            Ожидаем.Что(Точка.Получить("count")).Равно(1);
            Ожидаем.Что(Точка.Получить("sum")).Равно(3.5);
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).Равно(Истина);

КонецПроцедуры

&Тест
Процедура МетрПередаетЛимитМощностиИнструментам() Экспорт

    // Дано
    Метр = СоздатьМетрСЛимитом(2);
    Счетчик = Метр.СоздатьСчетчик("test.count");

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("k", "a");
    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("k", "b");
    АтрибутыВ = Новый ОтелАтрибуты();
    АтрибутыВ.Установить("k", "c");

    Счетчик.Добавить(1, АтрибутыА);
    Счетчик.Добавить(1, АтрибутыБ);
    Счетчик.Добавить(1, АтрибутыВ);

    // Тогда - всего 3 точки (2 обычных и 1 overflow)
    Точки = СобратьТочки(Счетчик, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(3);

КонецПроцедуры

&Тест
Процедура СуществующиеСерииНеПеренаправляются() Экспорт

    // Дано
    Метр = СоздатьМетрСЛимитом(2);
    Счетчик = Метр.СоздатьСчетчик("test.counter");

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("key", "a");
    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("key", "b");

    // Когда - заполняем до лимита, повторно в существующие
    Счетчик.Добавить(1, АтрибутыА);
    Счетчик.Добавить(2, АтрибутыБ);
    Счетчик.Добавить(10, АтрибутыА);
    Счетчик.Добавить(20, АтрибутыБ);

    // Тогда - только 2 серии, без overflow
    Точки = СобратьТочки(Счетчик, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(2);

    Для Каждого Точка Из Точки Цикл
        Ожидаем.Что(ЭтоOverflow(Точка)).Равно(Ложь);
    КонецЦикла;

КонецПроцедуры

&Тест
Процедура НесколькоЗначенийНакапливаютсяВПереполнении() Экспорт

    // Дано
    Метр = СоздатьМетрСЛимитом(1);
    Счетчик = Метр.СоздатьСчетчик("test.counter");

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("key", "a");

    // Когда - первый занимает единственное место
    Счетчик.Добавить(1, АтрибутыА);
    // Остальные идут в overflow
    Для Сч = 1 По 5 Цикл
        Атрибут = Новый ОтелАтрибуты();
        Атрибут.Установить("key", "overflow_" + Строка(Сч));
        Счетчик.Добавить(10, Атрибут);
    КонецЦикла;

    // Тогда - всего 2 точки (1 обычная и 1 overflow)
    Точки = СобратьТочки(Счетчик, Метр);
    Ожидаем.Что(Точки.Количество()).Равно(2);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            Ожидаем.Что(Точка.Получить("value")).Равно(50);
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).Равно(Истина);

КонецПроцедуры
