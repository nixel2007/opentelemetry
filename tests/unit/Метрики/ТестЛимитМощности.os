// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
// BSLLS:DuplicatedInsertionIntoCollection-off
// BSLLS:DuplicateStringLiteral-off
#Использовать "../../.."
#Использовать asserts

// Тесты лимита мощности (cardinality limit) для метрических инструментов.
// По спецификации OpenTelemetry, при достижении лимита новые серии атрибутов
// перенаправляются в overflow-серию с атрибутом otel.metric.overflow=true.

// Проверяет, является ли точка данных overflow-серией.
// Атрибуты хранятся в OTLP формате: [{"key": "...", "value": {"boolValue": ...}}, ...]
Функция ЭтоOverflow(Точка)
    МассивАтрибутов = Точка.Получить("attributes");
    Если МассивАтрибутов = Неопределено Тогда
        Возврат Ложь;
    КонецЕсли;
    Для Каждого Атрибут Из МассивАтрибутов Цикл
        Если Атрибут.Получить("key") = "otel.metric.overflow" Тогда
            ЗначениеАтрибута = Атрибут.Получить("value");
            Если ЗначениеАтрибута <> Неопределено И ЗначениеАтрибута.Получить("boolValue") = Истина Тогда
                Возврат Истина;
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
    Возврат Ложь;
КонецФункции

&Тест
Процедура СчетчикПеренаправляетВПереполнениеПриДостиженииЛимита() Экспорт

    // Дано
    Счетчик = Новый ОтелСчетчик("test.counter");
    Счетчик.УстановитьЛимитМощности(3);

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("key", "a");
    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("key", "b");
    АтрибутыВ = Новый ОтелАтрибуты();
    АтрибутыВ.Установить("key", "c");
    АтрибутыГ = Новый ОтелАтрибуты();
    АтрибутыГ.Установить("key", "d");

    // Когда
    Счетчик.Добавить(1, АтрибутыА);
    Счетчик.Добавить(2, АтрибутыБ);
    Счетчик.Добавить(3, АтрибутыВ);
    Счетчик.Добавить(10, АтрибутыГ);
    АтрибутыД = Новый ОтелАтрибуты();
    АтрибутыД.Установить("key", "e");
    Счетчик.Добавить(20, АтрибутыД);

    // Тогда
    Точки = Счетчик.ТочкиДанных();
    Ожидаем.Что(Точки.Количество()).Равно(4);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            Ожидаем.Что(Точка.Получить("value")).Равно(30);
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ГистограммаПеренаправляетВПереполнение() Экспорт

    // Дано
    Гистограмма = Новый ОтелГистограмма("test.histogram");
    Гистограмма.УстановитьЛимитМощности(2);

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("method", "GET");
    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("method", "POST");
    АтрибутыВ = Новый ОтелАтрибуты();
    АтрибутыВ.Установить("method", "DELETE");

    // Когда
    Гистограмма.Записать(100, АтрибутыА);
    Гистограмма.Записать(200, АтрибутыБ);
    Гистограмма.Записать(300, АтрибутыВ);

    // Тогда
    Точки = Гистограмма.ТочкиДанных();
    Ожидаем.Что(Точки.Количество()).Равно(3);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            Ожидаем.Что(Точка.Получить("count")).Равно(1);
            Ожидаем.Что(Точка.Получить("sum")).Равно(300);
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).Равно(Истина);

КонецПроцедуры

&Тест
Процедура РеверсивныйСчетчикПеренаправляетВПереполнение() Экспорт

    // Дано
    Счетчик = Новый ОтелРеверсивныйСчетчик("test.updown");
    Счетчик.УстановитьЛимитМощности(2);

    АтрибутыА = Новый ОтелАтрибуты();
    АтрибутыА.Установить("key", "a");
    АтрибутыБ = Новый ОтелАтрибуты();
    АтрибутыБ.Установить("key", "b");
    АтрибутыВ = Новый ОтелАтрибуты();
    АтрибутыВ.Установить("key", "c");

    // Когда
    Счетчик.Добавить(5, АтрибутыА);
    Счетчик.Добавить(-3, АтрибутыБ);
    Счетчик.Добавить(7, АтрибутыВ);

    // Тогда
    Точки = Счетчик.ТочкиДанных();
    Ожидаем.Что(Точки.Количество()).Равно(3);

    НайденOverflow = Ложь;
    Для Каждого Точка Из Точки Цикл
        Если ЭтоOverflow(Точка) Тогда
            Ожидаем.Что(Точка.Получить("value")).Равно(7);
            НайденOverflow = Истина;
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НайденOverflow).Равно(Истина);

КонецПроцедуры

&Тест
