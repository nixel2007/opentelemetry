КонецПроцедуры

&Тест
Процедура ФильтрОтбрасываетМетрику() Экспорт

    // Дано - фильтр возвращает Отбросить для метрики
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("filter-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метр.СоздатьСчетчик("filtered_counter");
    Счетчик.Добавить(10);

    МокФильтр = Мок.Получить(Тип("ОтелФильтрМетрик"));
    МокФильтр.Когда().ТестМетрики(
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(ОтелРезультатФильтраМетрик.Отбросить());

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);
    Читатель.УстановитьФильтрМетрик(МокФильтр);

    // Когда
    Семейства = Читатель.СобратьСемейства();

    // Тогда - метрика отброшена
    Ожидаем.Что(Семейства.Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ФильтрЧастичноеПринятиеУдаляетТочкиДанных() Экспорт

    // Дано - фильтр возвращает ЧастичноеПринятие и Отбросить для атрибутов
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("partial-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метр.СоздатьСчетчик("partial_counter");

    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("env", "test");
    Счетчик.Добавить(10, Атрибуты);

    МокФильтр = Мок.Получить(Тип("ОтелФильтрМетрик"));
    МокФильтр.Когда().ТестМетрики(
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(ОтелРезультатФильтраМетрик.ЧастичноеПринятие());
    МокФильтр.Когда().ТестАтрибутов(
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(ОтелРезультатФильтраАтрибутов.Отбросить());

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);
    Читатель.УстановитьФильтрМетрик(МокФильтр);

    // Когда
    Семейства = Читатель.СобратьСемейства();

    // Тогда - все точки данных отброшены, семейства пусты
    Ожидаем.Что(Семейства.Количество()).Равно(0);

КонецПроцедуры
