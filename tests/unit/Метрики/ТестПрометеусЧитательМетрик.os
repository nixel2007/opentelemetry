&Тест
Процедура НормализацияИменСТочками() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метр.СоздатьСчетчик("http.server.requests", "Запросы");

    Счетчик.Добавить(1);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Текст = Читатель.СобратьВТексте();

    // Тогда - точки заменены на подчеркивания
    Ожидаем.Что(СтрНайти(Текст, "http_server_requests_total") > 0).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура СобратьСемейства() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метр.СоздатьСчетчик("test_counter");
    Счетчик.Добавить(1);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Семейства = Читатель.СобратьСемейства();

    // Тогда
    Ожидаем.Что(Семейства).ИмеетДлину(1);
    Ожидаем.Что(Семейства[0].Получить("Имя")).Равно("test_counter");
    Ожидаем.Что(Семейства[0].Получить("Тип")).Равно("counter");

КонецПроцедуры

&Тест
Процедура ЗакрытьОчищаетМетры() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метр.СоздатьСчетчик("test_counter");
    Счетчик.Добавить(1);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Читатель.Закрыть();

    // Тогда - после закрытия метрик нет
    Текст = Читатель.СобратьВТексте();
    Ожидаем.Что(Текст).Равно("");

КонецПроцедуры

&Тест
Процедура НесколькоМетров() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования1 = Новый ОтелОбластьИнструментирования("lib1", "1.0");
    Метр1 = Новый ОтелМетр(ОбластьИнструментирования1, Ресурс);
    Счетчик1 = Метр1.СоздатьСчетчик("counter_one");
    Счетчик1.Добавить(10);

    ОбластьИнструментирования2 = Новый ОтелОбластьИнструментирования("lib2", "2.0");
    Метр2 = Новый ОтелМетр(ОбластьИнструментирования2, Ресурс);
    Счетчик2 = Метр2.СоздатьСчетчик("counter_two");
    Счетчик2.Добавить(20);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр1);
    Читатель.ДобавитьМетр(Метр2);

    // Когда
    Текст = Читатель.СобратьВТексте();

    // Тогда - обе метрики присутствуют с разными scope лейблами
    Ожидаем.Что(СтрНайти(Текст, "counter_one_total") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "counter_two_total") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "10") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "20") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "otel_scope_name=""lib1""") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "otel_scope_name=""lib2""") > 0).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура ЭкспоненциальнаяГистограммаПропускается() Экспорт

    // Дано - по спеке exponential histograms SHOULD be dropped в text format 0.0.4
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    ЭкспоненциальнаяГистограмма = Метр.СоздатьЭкспоненциальнуюГистограмму("exp_histo", "Тест");

    Атрибуты = Новый ОтелАтрибуты();
    ЭкспоненциальнаяГистограмма.Записать(100, Атрибуты);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Семейства = Читатель.СобратьСемейства();

    // Тогда - экспоненциальная гистограмма пропущена
    Ожидаем.Что(Семейства).ИмеетДлину(0);

КонецПроцедуры

&Тест
Процедура ОдноименныеМетрикиИзРазныхМетровОбъединяются() Экспорт

    // Дано - два метра дают инструменты с одним именем и одинаковым типом
    ИмяМетрики = "http_requests";
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования1 = Новый ОтелОбластьИнструментирования("lib1", "1.0");
    Метр1 = Новый ОтелМетр(ОбластьИнструментирования1, Ресурс);
    Счетчик1 = Метр1.СоздатьСчетчик(ИмяМетрики);
    Счетчик1.Добавить(10);

    ОбластьИнструментирования2 = Новый ОтелОбластьИнструментирования("lib2", "2.0");
    Метр2 = Новый ОтелМетр(ОбластьИнструментирования2, Ресурс);
    Счетчик2 = Метр2.СоздатьСчетчик(ИмяМетрики);
    Счетчик2.Добавить(20);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр1);
    Читатель.ДобавитьМетр(Метр2);

    // Когда
    Семейства = Читатель.СобратьСемейства();

    // Тогда - одно семейство с двумя сэмплами (различаются по scope лейблам)
    Ожидаем.Что(Семейства).ИмеетДлину(1);
    Ожидаем.Что(Семейства[0].Получить("Имя")).Равно(ИмяМетрики);
    СэмплыСемейства = Семейства[0].Получить("Сэмплы");
    Ожидаем.Что(СэмплыСемейства.Количество()).Равно(2);

КонецПроцедуры

&Тест
Процедура КонфликтТиповПропускается() Экспорт

    // Дано - два метра с одним именем, но разным TYPE
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования1 = Новый ОтелОбластьИнструментирования("lib1", "1.0");
    Метр1 = Новый ОтелМетр(ОбластьИнструментирования1, Ресурс);
    Счетчик = Метр1.СоздатьСчетчик("conflicting_metric");
    Счетчик.Добавить(10);

    ОбластьИнструментирования2 = Новый ОтелОбластьИнструментирования("lib2", "2.0");
    Метр2 = Новый ОтелМетр(ОбластьИнструментирования2, Ресурс);
    Датчик = Метр2.СоздатьДатчик("conflicting_metric");
    Датчик.Записать(99);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр1);
    Читатель.ДобавитьМетр(Метр2);

    // Когда
    Семейства = Читатель.СобратьСемейства();

    // Тогда - только первая метрика, вторая пропущена из-за конфликта TYPE
    Ожидаем.Что(Семейства).ИмеетДлину(1);
    Ожидаем.Что(Семейства[0].Получить("Тип")).Равно("counter");

КонецПроцедуры

&Тест
Процедура НормализацияВедущаяЦифра() Экспорт

    // Дано - имя начинается с цифры
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метр.СоздатьСчетчик("2xx_responses", "Ответы 2xx");

    Счетчик.Добавить(5);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Семейства = Читатель.СобратьСемейства();

    // Тогда - ведущая цифра получает префикс "_"
    Ожидаем.Что(Семейства[0].Получить("Имя")).Равно("_2xx_responses");

