&Тест
Процедура МультиПровайдерЗащита() Экспорт

    // Дано - один читатель Prometheus
    Читатель = Новый ОтелПрометеусЧитательМетрик();

    // Когда - первая регистрация
    Результат1 = Читатель.ЗарегистрироватьУПровайдера();

    // Тогда - успешно
    Ожидаем.Что(Результат1).Равно(Истина);

    // Когда - вторая регистрация (у другого провайдера)
    Результат2 = Читатель.ЗарегистрироватьУПровайдера();

    // Тогда - отклонена
    Ожидаем.Что(Результат2).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура НеизвестныйТипМетрикиПропускается() Экспорт

    // Дано - инструмент с неизвестным типом метрики
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    ТочкиДанных = Новый Массив();
    ТочкаДанных = Новый Соответствие();
    ТочкаДанных.Вставить("value", 1);
    ТочкиДанных.Добавить(ТочкаДанных);
    МетрикаСНеизвестнымТипом = Новый ОтелДанныеМетрики(
        Ресурс, ОбластьИнструментирования,
        "unknown_metric", "", "1", "unknown_type", ТочкиДанных);

    МокИнструмент = Мок.Получить(Тип("ОтелБазовыйСинхронныйИнструмент"));
    МокИнструмент.Когда().Имя().ТогдаВозвращает("unknown_metric");
    МокИнструмент.Когда().Описание().ТогдаВозвращает("");
    МокИнструмент.Когда().Собрать(
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(МетрикаСНеизвестнымТипом);

    СписокИнструментов = Новый Массив();
    СписокИнструментов.Добавить(МокИнструмент);

    МокМетр = Мок.Получить(Тип("ОтелМетр"));
    МокМетр.Когда().Ресурс().ТогдаВозвращает(Ресурс);
    МокМетр.Когда().ОбластьИнструментирования().ТогдаВозвращает(ОбластьИнструментирования);
    МокМетр.Когда().Инструменты().ТогдаВозвращает(СписокИнструментов);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(МокМетр);

    // Когда
    Семейства = Читатель.СобратьСемейства();

    // Тогда - неизвестный тип метрики пропущен, семейства пусты
    Ожидаем.Что(Семейства.Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура АтрибутЦелоеЧисло() Экспорт

    // Дано - счетчик с целочисленным атрибутом (intValue ветка в КонвертироватьАтрибутыВЛейблы)
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("int-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метр.СоздатьСчетчик("req_by_code");

    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("status_code", 200); // число без дробной части -> intValue

    Счетчик.Добавить(5, Атрибуты);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Текст = Читатель.СобратьВТексте();

    // Тогда - метка status_code присутствует со строковым значением "200"
    Ожидаем.Что(СтрНайти(Текст, "status_code=""200""") > 0).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура АтрибутДробноеЧисло() Экспорт

    // Дано - датчик с дробным атрибутом (doubleValue ветка)
