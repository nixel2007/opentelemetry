&Тест
Процедура ScopeЛейблыНаГистограмме() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("histo-lib", "3.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Гистограмма = Метр.СоздатьГистограмму("req_duration", "Длительность");

    Атрибуты = Новый ОтелАтрибуты();
    Гистограмма.Записать(50, Атрибуты);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Текст = Читатель.СобратьВТексте();

    // Тогда - scope лейблы присутствуют на всех сэмплах гистограммы
    Ожидаем.Что(СтрНайти(Текст, "otel_scope_name=""histo-lib""") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "otel_scope_version=""3.0""") > 0).ЭтоИстина();

