#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура СобратьПустойТекст() Экспорт

    // Дано
    Читатель = Новый ОтелПрометеусЧитательМетрик();

    // Когда
    Текст = Читатель.СобратьВТексте();

    // Тогда - пустой текст если нет метров
    Ожидаем.Что(Текст).Равно("");

КонецПроцедуры

&Тест
Процедура СобратьСчетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метр.СоздатьСчетчик("test_counter", "Тестовый счетчик", "1");

    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("method", "GET");
    Счетчик.Добавить(42, Атрибуты);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Текст = Читатель.СобратьВТексте();

    // Тогда - текст содержит counter с суффиксом _total и scope лейблами
    Ожидаем.Что(СтрНайти(Текст, "test_counter_total") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "42") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "# TYPE test_counter counter") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "method") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "otel_scope_name=""test-lib""") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "otel_scope_version=""1.0""") > 0).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура СобратьДатчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Датчик = Метр.СоздатьДатчик("test_gauge", "Тестовый датчик");

    Атрибуты = Новый ОтелАтрибуты();
    Датчик.Записать(99, Атрибуты);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Текст = Читатель.СобратьВТексте();

    // Тогда
    Ожидаем.Что(СтрНайти(Текст, "test_gauge") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "99") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "# TYPE test_gauge gauge") > 0).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура СобратьГистограмму() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Гистограмма = Метр.СоздатьГистограмму("test_histogram", "Тестовая гистограмма");

    Атрибуты = Новый ОтелАтрибуты();
    Гистограмма.Записать(50, Атрибуты);
    Гистограмма.Записать(500, Атрибуты);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Текст = Читатель.СобратьВТексте();

    // Тогда - текст содержит histogram с _bucket, _count, _sum
    Ожидаем.Что(СтрНайти(Текст, "test_histogram") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "_bucket") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "_count") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "_sum") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "# TYPE test_histogram histogram") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "+Inf") > 0).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура СобратьРеверсивныйСчетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Метр = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метр.СоздатьРеверсивныйСчетчик("test_updown", "Реверсивный счетчик");

    Атрибуты = Новый ОтелАтрибуты();
    Счетчик.Добавить(10, Атрибуты);
    Счетчик.Добавить(-3, Атрибуты);

    Читатель = Новый ОтелПрометеусЧитательМетрик();
    Читатель.ДобавитьМетр(Метр);

    // Когда
    Текст = Читатель.СобратьВТексте();

    // Тогда - UpDownCounter (monotonic=false) -> gauge, без _total
    Ожидаем.Что(СтрНайти(Текст, "test_updown") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "# TYPE test_updown gauge") > 0).ЭтоИстина();
    Ожидаем.Что(СтрНайти(Текст, "7") > 0).ЭтоИстина();

КонецПроцедуры

&Тест
Процедура СовместимостьИнтерфейса() Экспорт

    // Дано
    Читатель = Новый ОтелПрометеусЧитательМетрик();

    // Когда - Запустить/СброситьБуфер/Закрыть не падают
    Читатель.Запустить();
    Читатель.СброситьБуфер();
    Читатель.Закрыть();

    // Тогда - ошибок нет
    Ожидаем.Что(Истина).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ContentType() Экспорт

