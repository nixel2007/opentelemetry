&Тест
Процедура ЗарегистрироватьОбратныйВызовЧужойИнструмент() Экспорт

	// Дано - два разных метра
	Ресурс = Новый ОтелРесурс();
	Метрика1 = Новый ОтелМетр(Новый ОтелОбластьИнструментирования("meter-1", "1.0.0"), Ресурс);
	Метрика2 = Новый ОтелМетр(Новый ОтелОбластьИнструментирования("meter-2", "1.0.0"), Ресурс);
	МокЛог = Мок.Получить(Тип("Лог"));
	Метрика1.УстановитьЛог(МокЛог);

	// Инструмент создан в другом метре
	ЧужойИнструмент = Метрика2.СоздатьНаблюдаемыйДатчик("foreign.gauge", Неопределено);

	// Когда - пытаемся зарегистрировать чужой инструмент в Метрика1
	Инструменты = Новый Массив();
	Инструменты.Добавить(ЧужойИнструмент);
	Callback = Новый Действие(ЭтотОбъект, "НоопОбратныйВызов");
	Метрика1.ЗарегистрироватьОбратныйВызов(Callback, Инструменты);

	// Тогда - предупреждение залогировано
	МокЛог.ПроверитьЧтоВызывалсяМетод().Предупреждение(Матчеры.Содержит("не созданный этим Meter"));

