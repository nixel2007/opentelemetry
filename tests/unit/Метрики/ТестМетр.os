&Тест
Процедура ExemplarReservoirPoUmolchaniyu() Экспорт

    // Дано - счетчик с View "sum" (должен получить SimpleFixedSize(1) резервуар)
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test", "1.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    Пары = Новый Массив();
    Пара = Новый Соответствие();
    Пара.Вставить("Селектор", Новый ОтелСелекторИнструментов("exem.counter"));
    Пара.Вставить("Представление", Новый ОтелПредставление(, , , , ОтелАгрегация.Сумма()));
    Пары.Добавить(Пара);
    Метрика.УстановитьПредставления(Пары);

    Счетчик = Метрика.СоздатьСчетчик("exem.counter");
    Счетчик.УстановитьФильтрЭкземпляров(ОтелФильтрЭкземпляров.ВсегдаВключен());

    // Создаём спан в контексте, чтобы exemplar захватил traceId/spanId
    ОбластьСпан = Новый ОтелРесурс(Истина);
    ОбластьИнструментированияСпан = Новый ОтелОбластьИнструментирования("библ", "1.0");
    Спан = Новый ОтелСпан("тест", ОбластьСпан, ОбластьИнструментированияСпан);
    КонтекстОбласть = ОтелКонтекст.СделатьСпанТекущим(Спан);

    // Когда - записываем значение (exemplar должен захватиться)
    Счетчик.Добавить(42);

    // Тогда - exemplar есть в точке данных (резервуар = SimpleFixedSize(1))
    Данные = СобратьДанные(Счетчик, Метрика);
    ТочкаДанных = Данные.ТочкиДанных()[0];
    Экземпляры = ТочкаДанных.Получить("exemplars");
    Ожидаем.Что(Экземпляры <> Неопределено).Равно(Истина);
    Ожидаем.Что(Экземпляры).ИмеетДлину(1);

    КонтекстОбласть.Закрыть();
    ОтелКонтекст.Очистить();

