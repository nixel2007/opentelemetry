Процедура МультиCallbackСоСостоянием() Экспорт

	// Дано - multi-callback с параметром Состояние
	Ресурс = Новый ОтелРесурс();
	ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0.0");
