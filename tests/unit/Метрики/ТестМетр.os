&Тест
Процедура КонфликтОписанияСViewОписаниеПодавляется() Экспорт

	// Дано - View задаёт НовоеОписание для инструмента
	Ресурс = Новый ОтелРесурс();
	ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0.0");
	Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
	МокЛог = Мок.Получить(Тип("Лог"));
	Метрика.УстановитьЛог(МокЛог);

	Пары = Новый Массив();
	Пара = Новый Соответствие();
	Пара.Вставить("Селектор", Новый ОтелСелекторИнструментов("view.desc.counter"));
	Пара.Вставить("Представление", Новый ОтелПредставление(, "Описание из View"));
	Пары.Добавить(Пара);
	Метрика.УстановитьПредставления(Пары);

	// Регистрируем первый счетчик с описанием
	Первый = Метрика.СоздатьСчетчик("view.desc.counter", "Первое описание");

	// Когда - регистрируем второй с другим описанием (конфликт описания)
	Второй = Метрика.СоздатьСчетчик("view.desc.counter", "Другое описание");

	// Тогда - возвращён первый инструмент (предупреждение подавлено View)
	Ожидаем.Что(Второй).Равно(Первый);

КонецПроцедуры

&Тест
Процедура ViewАгрегацияExponentialHistogramДляAsyncUpDown() Экспорт

	// Дано - View с exponential histogram для ObservableUpDownCounter (несовместимо)
	Ресурс = Новый ОтелРесурс(Истина);
	ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test", "1.0");
	Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

	Пары = Новый Массив();
	Пара = Новый Соответствие();
	Пара.Вставить("Селектор", Новый ОтелСелекторИнструментов("async.updown"));
	Пара.Вставить("Представление", Новый ОтелПредставление(, , , , ОтелАгрегация.ГистограммаЭкспоненциальная()));
	Пары.Добавить(Пара);
	Метрика.УстановитьПредставления(Пары);

	Callback = Лямбда.Выражение("н -> н.Записать(5)").ВДействие();

	// Когда - создаём ObservableUpDownCounter с несовместимой View
	Счетчик = Метрика.СоздатьНаблюдаемыйРеверсивныйСчетчик("async.updown", Callback);

	// Тогда - View-агрегация проигнорирована, используется default (sum)
	Данные = СобратьДанные(Счетчик, Метрика);
	Ожидаем.Что(Данные.ТипМетрики()).Равно(ОтелТипМетрики.Сумма());

