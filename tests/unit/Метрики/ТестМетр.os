&Тест
Процедура КонфликтВидовВозвращаетПервый() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    // Когда
    Счетчик = Метрика.СоздатьСчетчик("shared.name", "Counter desc", "1");
    Гистограмма = Метрика.СоздатьГистограмму("shared.name", "Histogram desc", "ms");

    // Тогда
    // При конфликте видов вызывающий получает первый (Counter) инструмент (spec SHOULD),
    // но оба экземпляра добавляются в коллекцию экспорта (pass-through).
    Ожидаем.Что(Гистограмма).Равно(Счетчик);
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ОбратныйВызовНесколькихИнструментов() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    Датчик1 = Метрика.СоздатьНаблюдаемыйДатчик("gauge1", Неопределено, "Первый");
    Датчик2 = Метрика.СоздатьНаблюдаемыйДатчик("gauge2", Неопределено, "Второй");

    // Регистрируем мульти-callback
    Инструменты = Новый Массив();
    Инструменты.Добавить(Датчик1);
    Инструменты.Добавить(Датчик2);

    МультиCallback = Новый Действие(ЭтотОбъект, "МультиОбратныйВызовДляТеста");
    Метрика.ЗарегистрироватьОбратныйВызов(МультиCallback, Инструменты);

    // Когда
    Метрика.ВызватьМультиОбратныеВызовы();

    // Тогда
    Данные1 = СобратьДанные(Датчик1, Метрика);
    Данные2 = СобратьДанные(Датчик2, Метрика);
    Ожидаем.Что(Данные1.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные2.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные1.ТочкиДанных()[0].Получить("value")).Равно(10);
    Ожидаем.Что(Данные2.ТочкиДанных()[0].Получить("value")).Равно(20);

КонецПроцедуры

Процедура МультиОбратныйВызовДляТеста(Наблюдения) Экспорт
    Наблюдения.Получить("gauge1").Записать(10);
    Наблюдения.Получить("gauge2").Записать(20);
КонецПроцедуры

&Тест
Процедура МультиCallbackСовместноССобственным() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    СобственныйCallback = Лямбда.Выражение("н -> н.Записать(100)").ВДействие();
    Датчик = Метрика.СоздатьНаблюдаемыйДатчик("combined.gauge", СобственныйCallback);

    // Регистрируем мульти-callback
    Инструменты = Новый Массив();
    Инструменты.Добавить(Датчик);
    МультиCallback = Новый Действие(ЭтотОбъект, "КомбинированныйМультиОбратныйВызов");
    Метрика.ЗарегистрироватьОбратныйВызов(МультиCallback, Инструменты);

    // Когда
    Метрика.ВызватьМультиОбратныеВызовы();
    Данные = СобратьДанные(Датчик, Метрика);

    // Тогда - оба значения (100 от собственного + 200 от мульти)
    Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(2);

КонецПроцедуры

Процедура КомбинированныйМультиОбратныйВызов(Наблюдения) Экспорт
    Наблюдения.Получить("combined.gauge").Записать(200);
КонецПроцедуры

&Тест
Процедура МультиCallbackОчисткаВнешнихНаблюдений() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    Датчик = Метрика.СоздатьНаблюдаемыйДатчик("clean.gauge", Неопределено);

    Инструменты = Новый Массив();
    Инструменты.Добавить(Датчик);
    МультиCallback = Новый Действие(ЭтотОбъект, "ОчисткаМультиОбратныйВызов");
    Метрика.ЗарегистрироватьОбратныйВызов(МультиCallback, Инструменты);

    // Когда - первый сбор
    Метрика.ВызватьМультиОбратныеВызовы();
    Данные1 = СобратьДанные(Датчик, Метрика);

    // Когда - второй сбор
    Метрика.ВызватьМультиОбратныеВызовы();
    Данные2 = СобратьДанные(Датчик, Метрика);

    // Тогда - каждый раз по одной точке, нет дублирования
    Ожидаем.Что(Данные1.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные2.ТочкиДанных()).ИмеетДлину(1);
    Ожидаем.Что(Данные1.ТочкиДанных()[0].Получить("value")).Равно(55);
    Ожидаем.Что(Данные2.ТочкиДанных()[0].Получить("value")).Равно(55);

КонецПроцедуры

Процедура ОчисткаМультиОбратныйВызов(Наблюдения) Экспорт
    Наблюдения.Получить("clean.gauge").Записать(55);
КонецПроцедуры

&Тест
Процедура КонфликтИменПоРегиструЗаписываетсяИВозвращаетПервый() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    МокЛог = Мок.Получить(Тип("Лог"));
    Метрика.УстановитьЛог(МокЛог);

    // Когда
    ИмяСчетчика = "MyCounter";
    Первый = Метрика.СоздатьСчетчик(ИмяСчетчика);
    Второй = Метрика.СоздатьСчетчик("mycounter");

    // Тогда - возвращён первый-виденный инструмент
    Ожидаем.Что(Второй).Равно(Первый);
    Ожидаем.Что(Первый.Имя()).Равно(ИмяСчетчика);

    // И - лог содержит оба имени через форматную строку с %1 и %2
    МокЛог.ПроверитьЧтоВызывалсяМетод().Предупреждение(
        Матчеры.Содержит("case-only"),
        ИмяСчетчика,
        "mycounter");

КонецПроцедуры

