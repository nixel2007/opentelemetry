&Тест
Процедура СоздатьНаблюдаемыйРеверсивныйСчетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Callback = Лямбда.Выражение("н -> н.Записать(42)").ВДействие();

    // Когда
    Счетчик = Метрика.СоздатьНаблюдаемыйРеверсивныйСчетчик("queue.size", Callback, "Размер очереди", "1");

    // Тогда
    Ожидаем.Что(Счетчик <> Неопределено).Равно(Истина);
    Ожидаем.Что(Счетчик.Имя()).Равно("queue.size");
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(1);

КонецПроцедуры

