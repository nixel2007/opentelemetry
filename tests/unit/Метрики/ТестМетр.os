#Использовать lambdas

&Тест
Процедура СоздатьСчетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Счетчик = Метрика.СоздатьСчетчик("http.requests", "Количество запросов", "1");

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("http.requests");
    Ожидаем.Что(Счетчик.ТипМетрики()).Равно("sum");

КонецПроцедуры

&Тест
Процедура СоздатьВсеТипы() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Метрика.СоздатьСчетчик("counter1");
    Метрика.СоздатьГистограмму("histogram1");
    Метрика.СоздатьРеверсивныйСчетчик("updown1");
    Метрика.СоздатьДатчик("gauge1");

    // Тогда
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(4);

КонецПроцедуры

&Тест
Процедура ДедупликацияИнструментов() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда - создаём счетчик с одним именем дважды
    Счетчик1 = Метрика.СоздатьСчетчик("http.requests", "Запросы", "1");
    Счетчик2 = Метрика.СоздатьСчетчик("http.requests", "Другое описание", "req");

    // Тогда - возвращается тот же объект
    Ожидаем.Что(Счетчик1).Равно(Счетчик2);
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ПолучитьИнструмент() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("http.requests");

    // Когда - создаём ещё раз по тому же имени
    Полученный = Метрика.СоздатьСчетчик("http.requests");

    // Тогда - возвращается тот же экземпляр
    Ожидаем.Что(Полученный).Равно(Счетчик);

КонецПроцедуры

&Тест
Процедура ПолучитьИнструменты() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Метрика.СоздатьСчетчик("counter1");
    Метрика.СоздатьГистограмму("histogram1");
    Метрика.СоздатьДатчик("gauge1");

    // Тогда
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(3);
    Ожидаем.Что(Метрика.ИмяБиблиотеки()).Равно("test-library");
    Ожидаем.Что(Метрика.ВерсияБиблиотеки()).Равно("1.0.0");

КонецПроцедуры

&Тест
Процедура ДедупликацияГистограмм() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Г1 = Метрика.СоздатьГистограмму("http.duration");
    Г2 = Метрика.СоздатьГистограмму("http.duration");

    // Тогда - возвращается тот же объект
    Ожидаем.Что(Г1).Равно(Г2);

КонецПроцедуры

&Тест
Процедура ДедупликацияДатчиков() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Д1 = Метрика.СоздатьДатчик("cpu.usage");
    Д2 = Метрика.СоздатьДатчик("cpu.usage");

    // Тогда - возвращается тот же объект
    Ожидаем.Что(Д1).Равно(Д2);

КонецПроцедуры

&Тест
Процедура СоздатьНаблюдаемыйРеверсивныйСчетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);
    Callback = Лямбда.Выражение("-> Возврат 42").ВДействие();

    // Когда
    Счетчик = Метрика.СоздатьНаблюдаемыйРеверсивныйСчетчик("queue.size", Callback, "Размер очереди", "1");

    // Тогда
    Ожидаем.Что(Счетчик <> Неопределено).Равно(Истина);
    Ожидаем.Что(Счетчик.Имя()).Равно("queue.size");
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура СоздатьНаблюдаемыйДатчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);
    Callback = Лямбда.Выражение("-> Возврат 99").ВДействие();

    // Когда
    Датчик = Метрика.СоздатьНаблюдаемыйДатчик("temperature", Callback, "Температура", "C");

    // Тогда
    Ожидаем.Что(Датчик <> Неопределено).Равно(Истина);
    Ожидаем.Что(Датчик.Имя()).Равно("temperature");
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ДедупликацияНаблюдаемыхИнструментов() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);
    Callback = Лямбда.Выражение("-> Возврат 1").ВДействие();

    // Когда
    НС1 = Метрика.СоздатьНаблюдаемыйРеверсивныйСчетчик("q.size", Callback);
    НС2 = Метрика.СоздатьНаблюдаемыйРеверсивныйСчетчик("q.size", Callback);
    НД1 = Метрика.СоздатьНаблюдаемыйДатчик("temp", Callback);
    НД2 = Метрика.СоздатьНаблюдаемыйДатчик("temp", Callback);

    // Тогда - дедупликация по имени
    Ожидаем.Что(НС1).Равно(НС2);
    Ожидаем.Что(НД1).Равно(НД2);
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура СоздатьЭкспоненциальнуюГистограмму() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Гистограмма = Метрика.СоздатьЭкспоненциальнуюГистограмму("http.duration", "Длительность", "ms", 64);

    // Тогда
    Ожидаем.Что(Гистограмма <> Неопределено).Равно(Истина);
    Ожидаем.Что(Гистограмма.Имя()).Равно("http.duration");
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(1);

КонецПроцедуры

