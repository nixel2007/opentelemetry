// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito
#Использовать lambdas

Функция СобратьДанные(Инструмент, Метрика)
    Возврат Инструмент.Собрать(
        Метрика.Ресурс(), Метрика.ОбластьИнструментирования(),
        Инструмент.Имя(), Инструмент.Описание());
КонецФункции

&Тест
Процедура СоздатьСчетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    // Когда
    Счетчик = Метрика.СоздатьСчетчик("http.requests", "Количество запросов", "1");

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("http.requests");

    // Тогда - метаданные через Собрать
    Счетчик.Добавить(1);
    Данные = СобратьДанные(Счетчик, Метрика);
    Ожидаем.Что(Данные.ТипМетрики()).Равно("sum");

КонецПроцедуры

&Тест
Процедура СоздатьВсеТипы() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    // Когда
    Метрика.СоздатьСчетчик("counter1");
    Метрика.СоздатьГистограмму("histogram1");
    Метрика.СоздатьРеверсивныйСчетчик("updown1");
    Метрика.СоздатьДатчик("gauge1");

    // Тогда
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(4);

КонецПроцедуры

&Тест
Процедура ДедупликацияИнструментов() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

    // Когда
    Счетчик1 = Метрика.СоздатьСчетчик("http.requests", "Запросы", "1");
    Счетчик2 = Метрика.СоздатьСчетчик("http.requests", "Другое описание", "req");

    // Тогда
    // При конфликте единиц вызывающий получает первый инструмент (spec SHOULD),
    // но оба экземпляра добавляются в коллекцию экспорта (pass-through).
    Ожидаем.Что(Счетчик1).Равно(Счетчик2);
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(2);

КонецПроцедуры

&Тест
Процедура ПолучитьИнструмент() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("http.requests");

    // Когда
    Полученный = Метрика.СоздатьСчетчик("http.requests");

    // Тогда
    Ожидаем.Что(Полученный).Равно(Счетчик);

