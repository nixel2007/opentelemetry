	Пара.Вставить("Представление", Новый ОтелПредставление(, , , , ОтелАгрегация.Отбросить()));
	Пары.Добавить(Пара);
	Метрика.УстановитьПредставления(Пары);

	// Когда - создаём счетчик с View-агрегацией "drop"
	Счетчик = Метрика.СоздатьСчетчик("drop.counter");

	// Тогда - инструмент создан, Собрать возвращает Неопределено (drop)
	Ожидаем.Что(Счетчик).Не_().Равно(Неопределено);
	Счетчик.Добавить(5);
	Данные = Счетчик.Собрать(Метрика.Ресурс(), Метрика.ОбластьИнструментирования(),
		Счетчик.Имя(), Счетчик.Описание());
	Ожидаем.Что(Данные).Равно(Неопределено);

