&Тест
Процедура ПроходНасквозьЭкспоненциальнойГистограммы() Экспорт

	// Дано - экспоненциальная гистограмма уже зарегистрирована с единицей "ms"
	Ресурс = Новый ОтелРесурс();
	ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0.0");
	Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

	Г1 = Метрика.СоздатьЭкспоненциальнуюГистограмму("expo.dup", "", "ms");

	// Когда - создаём с тем же именем, но другой единицей (конфликт единиц → pass-through)
	Г2 = Метрика.СоздатьЭкспоненциальнуюГистограмму("expo.dup", "", "s");

	// Тогда - вызывающий получает первый инструмент, оба в коллекции (pass-through)
	Ожидаем.Что(Г2).Равно(Г1);
	Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(2);

