&Тест
Процедура УстановитьПредставленияСНеопределённымПредставлением() Экспорт

	// Дано - список пар, где у одной пары Представление = Неопределено
	Ресурс = Новый ОтелРесурс();
	ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0.0");
	Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);

	Пары = Новый Массив();

	// Первая пара: Представление = Неопределено → должна быть пропущена
	ПараСНеоп = Новый Соответствие();
	ПараСНеоп.Вставить("Селектор", Новый ОтелСелекторИнструментов("any.instrument"));
	ПараСНеоп.Вставить("Представление", Неопределено);
	Пары.Добавить(ПараСНеоп);

	// Вторая пара: корректная
	НормПара = Новый Соответствие();
	НормПара.Вставить("Селектор", Новый ОтелСелекторИнструментов("counter.normal"));
	НормПара.Вставить("Представление", Новый ОтелПредставление(, , , , ОтелАгрегация.Сумма()));
	Пары.Добавить(НормПара);

	// Когда - устанавливаем представления (не должно падать, Неопределено пропускается)
	Метрика.УстановитьПредставления(Пары);

	// Тогда - корректная пара работает
	Счетчик = Метрика.СоздатьСчетчик("counter.normal");
	Счетчик.Добавить(1);
	Данные = СобратьДанные(Счетчик, Метрика);
	Ожидаем.Что(Данные).Не_().Равно(Неопределено);

