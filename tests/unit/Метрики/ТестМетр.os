	ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0.0");
	Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
	МокЛог = Мок.Получить(Тип("Лог"));
	Метрика.УстановитьЛог(МокЛог);

	Г1 = Новый Массив();
	Г1.Добавить(1);
	Г1.Добавить(5);
	Совет1 = Новый Структура("ГраницыГистограммы", Г1);
	Метрика.СоздатьГистограмму("hist.совет.длинамассива", "", "", Совет1);

	// Когда - с ГраницыГистограммы [1, 5, 10] (другая длина)
	Г2 = Новый Массив();
	Г2.Добавить(1);
	Г2.Добавить(5);
	Г2.Добавить(10);
	Совет2 = Новый Структура("ГраницыГистограммы", Г2);
	Метрика.СоздатьГистограмму("hist.совет.длинамассива", "", "", Совет2);

	// Тогда - конфликт advisory (разная длина массива; 8 аргументов: шаблон + 7 параметров)
	МокЛог.ПроверитьЧтоВызывалсяМетод().Предупреждение(
		Матчеры.Содержит("повторной регистрации"),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение());

КонецПроцедуры

&Тест
Процедура КонфликтСоветаРазныеЭлементыМассива() Экспорт

	// Дано - гистограмма с ГраницыГистограммы [1, 5, 10]
	Ресурс = Новый ОтелРесурс();
	ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0.0");
	Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
	МокЛог = Мок.Получить(Тип("Лог"));
	Метрика.УстановитьЛог(МокЛог);

	Г1 = Новый Массив();
	Г1.Добавить(1);
	Г1.Добавить(5);
	Г1.Добавить(10);
	Совет1 = Новый Структура("ГраницыГистограммы", Г1);
	Метрика.СоздатьГистограмму("hist.совет.разныеэлем", "", "", Совет1);

	// Когда - с ГраницыГистограммы [1, 5, 20] (одна длина, разные элементы)
	Г2 = Новый Массив();
	Г2.Добавить(1);
	Г2.Добавить(5);
	Г2.Добавить(20);
	Совет2 = Новый Структура("ГраницыГистограммы", Г2);
	Метрика.СоздатьГистограмму("hist.совет.разныеэлем", "", "", Совет2);

	// Тогда - конфликт advisory (разные элементы массива; 8 аргументов: шаблон + 7 параметров)
	МокЛог.ПроверитьЧтоВызывалсяМетод().Предупреждение(
		Матчеры.Содержит("повторной регистрации"),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение());

КонецПроцедуры
