	Датчик = Метрика.СоздатьНаблюдаемыйДатчик("state.gauge", Неопределено);

	Инструменты = Новый Массив();
	Инструменты.Добавить(Датчик);

	Состояние = Новый Структура("Значение", 77);
	МультиCallback = Новый Действие(ЭтотОбъект, "МультиCallbackОбработчикСоСостоянием");
	Метрика.ЗарегистрироватьОбратныйВызов(МультиCallback, Инструменты, Состояние);

	// Когда
	Метрика.ВызватьМультиОбратныеВызовы();

	// Тогда - значение из Состояния записано датчиком
	Данные = СобратьДанные(Датчик, Метрика);
	Ожидаем.Что(Данные.ТочкиДанных()).ИмеетДлину(1);
	Ожидаем.Что(Данные.ТочкиДанных()[0].Получить("value")).Равно(77);

КонецПроцедуры

Процедура МультиCallbackОбработчикСоСостоянием(Наблюдения, Состояние) Экспорт
	Наблюдения.Получить("state.gauge").Записать(Состояние.Значение);
КонецПроцедуры

&Тест
Процедура МультиCallbackИсключениеВCallback() Экспорт

	// Дано - multi-callback бросает исключение
	Ресурс = Новый ОтелРесурс();
	ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0.0");
	Метрика = Новый ОтелМетр(ОбластьИнструментирования, Ресурс);
	МокЛог = Мок.Получить(Тип("Лог"));
	Метрика.УстановитьЛог(МокЛог);

	Датчик = Метрика.СоздатьНаблюдаемыйДатчик("error.gauge", Неопределено);

	Инструменты = Новый Массив();
	Инструменты.Добавить(Датчик);

	МультиCallback = Новый Действие(ЭтотОбъект, "МультиCallbackБросающийОбработчик");
	Метрика.ЗарегистрироватьОбратныйВызов(МультиCallback, Инструменты);

	// Когда - исключение не пробрасывается наружу
	ЕстьИсключение = Ложь;
	Попытка
		Метрика.ВызватьМультиОбратныеВызовы();
	Исключение
		ЕстьИсключение = Истина;
	КонецПопытки;

	// Тогда - исключение поглощено, ошибка залогирована
	Ожидаем.Что(ЕстьИсключение).Равно(Ложь);
	МокЛог.ПроверитьЧтоВызывалсяМетод().Предупреждение(Матчеры.Содержит("мульти-callback"));

КонецПроцедуры

