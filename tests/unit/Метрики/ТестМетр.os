#Использовать asserts
#Использовать moskito
#Использовать lambdas

&Тест
Процедура СоздатьСчетчик() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Счетчик = Метрика.СоздатьСчетчик("http.requests", "Количество запросов", "1");

    // Тогда
    Ожидаем.Что(Счетчик.Имя()).Равно("http.requests");
    Ожидаем.Что(Счетчик.ТипМетрики()).Равно("sum");

КонецПроцедуры

&Тест
Процедура СоздатьВсеТипы() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Метрика.СоздатьСчетчик("counter1");
    Метрика.СоздатьГистограмму("histogram1");
    Метрика.СоздатьРеверсивныйСчетчик("updown1");
    Метрика.СоздатьДатчик("gauge1");

    // Тогда
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(4);

КонецПроцедуры

&Тест
Процедура ДедупликацияИнструментов() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда - создаём счетчик с одним именем дважды
    Счетчик1 = Метрика.СоздатьСчетчик("http.requests", "Запросы", "1");
    Счетчик2 = Метрика.СоздатьСчетчик("http.requests", "Другое описание", "req");

    // Тогда - возвращается тот же объект
    Ожидаем.Что(Счетчик1).Равно(Счетчик2);
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(1);

КонецПроцедуры

&Тест
Процедура ПолучитьИнструмент() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);
    Счетчик = Метрика.СоздатьСчетчик("http.requests");

    // Когда - создаём ещё раз по тому же имени
    Полученный = Метрика.СоздатьСчетчик("http.requests");

    // Тогда - возвращается тот же экземпляр
    Ожидаем.Что(Полученный).Равно(Счетчик);

КонецПроцедуры

&Тест
Процедура ПолучитьИнструменты() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Метрика = Новый ОтелМетр("test-library", "1.0.0", Ресурс);

    // Когда
    Метрика.СоздатьСчетчик("counter1");
    Метрика.СоздатьГистограмму("histogram1");
    Метрика.СоздатьДатчик("gauge1");

    // Тогда
    Ожидаем.Что(Метрика.Инструменты()).ИмеетДлину(3);
    Ожидаем.Что(Метрика.ИмяБиблиотеки()).Равно("test-library");
    Ожидаем.Что(Метрика.ВерсияБиблиотеки()).Равно("1.0.0");

КонецПроцедуры
