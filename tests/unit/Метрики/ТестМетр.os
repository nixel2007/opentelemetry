	// Когда - второй с тем же типом и единицей, но другим описанием
	Второй = Метрика.СоздатьСчетчик("desc.conflict", "Другое описание", "1");

	// Тогда - возвращён первый, залогировано предупреждение с рецептом через View
	Ожидаем.Что(Второй).Равно(Первый);
	МокЛог.ПроверитьЧтоВызывалсяМетод().Предупреждение(
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.ЛюбоеЗначение(),
		Матчеры.Содержит("НовоеОписание"));

