&Тест
Процедура ПодставитьРекурсивноСтрока() Экспорт
    // Дано - строка с переменной
    УстановитьПеременнуюСреды("TEST_VAR_SUBST", "hello");
    Попытка
        // Когда
        Результат = ОтелПодстановкаПеременных.ПодставитьРекурсивно("${TEST_VAR_SUBST}");
        // Тогда
        Ожидаем.Что(Результат).Равно("hello");
    Исключение
        УстановитьПеременнуюСреды("TEST_VAR_SUBST", "");
        ВызватьИсключение;
    КонецПопытки;
    УстановитьПеременнуюСреды("TEST_VAR_SUBST", "");
КонецПроцедуры

&Тест
Процедура ПодставитьРекурсивноСоответствие() Экспорт
    // Дано - соответствие со строковым значением
    УстановитьПеременнуюСреды("TEST_MAP_VAR", "world");
    Попытка
        Вход = Новый Соответствие;
        Вход.Вставить("key", "${TEST_MAP_VAR}");
        // Когда
        Результат = ОтелПодстановкаПеременных.ПодставитьРекурсивно(Вход);
        // Тогда
        Ожидаем.Что(Результат.Получить("key")).Равно("world");
    Исключение
        УстановитьПеременнуюСреды("TEST_MAP_VAR", "");
        ВызватьИсключение;
    КонецПопытки;
    УстановитьПеременнуюСреды("TEST_MAP_VAR", "");
КонецПроцедуры

&Тест
Процедура ПодставитьРекурсивноМассив() Экспорт
    // Дано - массив со строковым элементом
    УстановитьПеременнуюСреды("TEST_ARR_VAR", "item");
    Попытка
        Вход = Новый Массив;
        Вход.Добавить("${TEST_ARR_VAR}");
        // Когда
        Результат = ОтелПодстановкаПеременных.ПодставитьРекурсивно(Вход);
        // Тогда
        Ожидаем.Что(Результат[0]).Равно("item");
    Исключение
        УстановитьПеременнуюСреды("TEST_ARR_VAR", "");
        ВызватьИсключение;
    КонецПопытки;
    УстановитьПеременнуюСреды("TEST_ARR_VAR", "");
КонецПроцедуры

&Тест
Процедура ПодставитьРекурсивноЧисло() Экспорт
    // Дано - числовое значение (не строка) — возвращается как есть
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьРекурсивно(42);
    // Тогда
    Ожидаем.Что(Результат).Равно(42);
КонецПроцедуры

&Тест
Процедура ПодставитьВСтрокеПустаяСтрока() Экспорт
    // Дано - пустая строка
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("");
    // Тогда
    Ожидаем.Что(Результат).Равно("");
КонецПроцедуры

&Тест
Процедура ПодставитьДвойнойДолларЭкранирование() Экспорт
    // Дано - $$ должно экранироваться в одиночный $
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("price $$100");
    // Тогда
    Ожидаем.Что(Результат).Равно("price $100");
КонецПроцедуры

&Тест
Процедура ПодставитьЭкранированныйМаркер() Экспорт
    // Дано - \${ должно выводиться как ${
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("\${NOT_VAR}");
    // Тогда
    Ожидаем.Что(Результат).Равно("${NOT_VAR}");
КонецПроцедуры

&Тест
Процедура ПодставитьПеременнуюСПрефиксомEnv() Экспорт
    // Дано - синтаксис ${env:VAR}
    УстановитьПеременнуюСреды("TEST_ENV_VAR", "envvalue");
    Попытка
        // Когда
        Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("${env:TEST_ENV_VAR}");
        // Тогда
        Ожидаем.Что(Результат).Равно("envvalue");
    Исключение
        УстановитьПеременнуюСреды("TEST_ENV_VAR", "");
        ВызватьИсключение;
    КонецПопытки;
    УстановитьПеременнуюСреды("TEST_ENV_VAR", "");
КонецПроцедуры

&Тест
Процедура ПодставитьПеременнуюСоЗначениемПоУмолчанию() Экспорт
    // Дано - переменная не задана, есть default
    УстановитьПеременнуюСреды("TEST_UNSET_VAR12", "");
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("${TEST_UNSET_VAR12:-default_val}");
    // Тогда
    Ожидаем.Что(Результат).Равно("default_val");
КонецПроцедуры

&Тест
Процедура ПодставитьПеременнуюНеЗаданаБезДефолта() Экспорт
    // Дано - переменная не задана, нет default → пустая строка
    УстановитьПеременнуюСреды("TEST_UNSET_VAR13", "");
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("${TEST_UNSET_VAR13}");
    // Тогда
    Ожидаем.Что(Результат).Равно("");
КонецПроцедуры

&Тест
Процедура ПодставитьОдиночныйДолларВКонце() Экспорт
    // Дано - строка заканчивается $, нет { → добавляется как обычный символ
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("text$");
    // Тогда
    Ожидаем.Что(Результат).Равно("text$");
КонецПроцедуры

&Тест
Процедура ПодставитьДолларБезСкобки() Экспорт
    // Дано - $x без { → доллар + символ не являются плейсхолдером
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("text$x");
    // Тогда
    Ожидаем.Что(Результат).Равно("text$x");
КонецПроцедуры

&Тест
Процедура ПодставитьПлейсхолдерБезЗакрывающейСкобки() Экспорт
    // Дано - незакрытый плейсхолдер ${VAR → доллар как литерал, остаток без изменений
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("${UNCLOSED");
    // Тогда - $ выводится как литерал, остаток строки добавляется как есть
    Ожидаем.Что(СтрНачинаетсяС(Результат, "$")).Равно(Истина);
КонецПроцедуры

&Тест
Процедура ПодставитьПеременнуюЗадана() Экспорт
    // Дано - переменная задана, есть default → переменная имеет приоритет
    УстановитьПеременнуюСреды("TEST_SET_VAR14", "real");
    Попытка
        // Когда
        Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("${TEST_SET_VAR14:-fallback}");
        // Тогда
        Ожидаем.Что(Результат).Равно("real");
    Исключение
        УстановитьПеременнуюСреды("TEST_SET_VAR14", "");
        ВызватьИсключение;
    КонецПопытки;
    УстановитьПеременнуюСреды("TEST_SET_VAR14", "");
КонецПроцедуры

&Тест
Процедура ЭкранированиеВКонцеСтроки() Экспорт
    // Дано - строка заканчивается \$ (без {) — слишком коротко для \${
    // Когда
    Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("\$");
    // Тогда - не является экранированным маркером, возвращается как есть
    Ожидаем.Что(Результат).Равно("\$");
КонецПроцедуры
