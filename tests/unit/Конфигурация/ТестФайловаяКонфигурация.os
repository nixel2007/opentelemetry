&Тест
Процедура ПодстановкаРекурсивноВСоответствии() Экспорт

	// Дано
	УстановитьПеременнуюСреды("OTEL_TEST_REC", "replaced");
	Данные = Новый Соответствие;
	Данные.Вставить("key", "${OTEL_TEST_REC}");
	Данные.Вставить("num", 42);

	// Когда
	Результат = ОтелПодстановкаПеременных.ПодставитьРекурсивно(Данные);

	// Тогда
	Ожидаем.Что(Результат["key"]).Равно("replaced");
	Ожидаем.Что(Результат["num"]).Равно(42);

КонецПроцедуры

&Тест
Процедура ПодстановкаРекурсивноВМассиве() Экспорт

	// Дано
	УстановитьПеременнуюСреды("OTEL_TEST_ARR", "item");
	Данные = Новый Массив;
	Данные.Добавить("${OTEL_TEST_ARR}");
	Данные.Добавить(99);

	// Когда
	Результат = ОтелПодстановкаПеременных.ПодставитьРекурсивно(Данные);

	// Тогда
	Ожидаем.Что(Результат[0]).Равно("item");
	Ожидаем.Что(Результат[1]).Равно(99);

КонецПроцедуры

