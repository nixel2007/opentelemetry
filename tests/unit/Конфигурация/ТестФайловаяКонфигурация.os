// ------------------------------------------------------------------
// Подстановка переменных окружения
// ------------------------------------------------------------------

&Тест
Процедура ПодстановкаПростойПеременной() Экспорт

	// Дано
	УстановитьПеременнуюСреды("OTEL_TEST_VAR", "hello");

	// Когда
	Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("prefix-${OTEL_TEST_VAR}-suffix");

	// Тогда
	Ожидаем.Что(Результат).Равно("prefix-hello-suffix");

КонецПроцедуры

&Тест
Процедура ПодстановкаСоЗначениемПоУмолчанию() Экспорт

	// Дано - переменная НЕ задана
	УдалитьПеременнуюСреды("OTEL_TEST_UNSET_VAR");

	// Когда
	Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("${OTEL_TEST_UNSET_VAR:-fallback}");

	// Тогда
	Ожидаем.Что(Результат).Равно("fallback");

КонецПроцедуры

&Тест
Процедура ПодстановкаЗаданнаяПеременнаяИгнорируетDefault() Экспорт

	// Дано
	УстановитьПеременнуюСреды("OTEL_TEST_SET_VAR", "real_value");

	// Когда
	Результат = ОтелПодстановкаПеременных.ПодставитьВСтроке("${OTEL_TEST_SET_VAR:-fallback}");

	// Тогда
	Ожидаем.Что(Результат).Равно("real_value");

КонецПроцедуры

&Тест
Процедура ПодстановкаНеопределеннойПеременнойДаетПустуюСтроку() Экспорт

	// Дано
