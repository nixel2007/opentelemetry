// ------------------------------------------------------------------
// Парсинг файловой конфигурации - минимальный файл
// ------------------------------------------------------------------

&Тест
Процедура РазборМинимальногоФайла() Экспорт

	// Дано
	ПутьКФайлу = СоздатьТестовыйФайл("minimal.yaml", "file_format: ""1.0""");

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Ожидаем.Что(Конфигурация.ФорматФайла).Равно("1.0");
	Ожидаем.Что(Конфигурация.Отключен).Равно(Ложь);
	Ожидаем.Что(Конфигурация.Ресурс).Равно(Неопределено);
	Ожидаем.Что(Конфигурация.ЛимитыАтрибутов).Равно(Неопределено);
	Ожидаем.Что(Конфигурация.Пропагатор).Равно(Неопределено);
	Ожидаем.Что(Конфигурация.ПровайдерТрассировки).Равно(Неопределено);
	Ожидаем.Что(Конфигурация.ПровайдерМетрик).Равно(Неопределено);
	Ожидаем.Что(Конфигурация.ПровайдерЛогирования).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура РазборDisabledTrue() Экспорт

	// Дано
	Yaml = "file_format: ""1.0""" + Символы.ПС + "disabled: true";
	ПутьКФайлу = СоздатьТестовыйФайл("disabled.yaml", Yaml);

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Ожидаем.Что(Конфигурация.Отключен).Равно(Истина);

КонецПроцедуры

