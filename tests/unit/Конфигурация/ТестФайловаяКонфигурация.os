// ------------------------------------------------------------------
// Ресурс
// ------------------------------------------------------------------

&Тест
Процедура РазборРесурсаСАтрибутами() Экспорт

	// Дано
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"resource:",
		"  attributes:",
		"    - name: service.name",
		"      value: my-service",
		"    - name: service.version",
		"      value: ""1.2.3""",
		"  attributes_list: ""env=prod,zone=us"""
	);
	Yaml = СтрСоединить(СтрокиYaml, Символы.ПС);
	ПутьКФайлу = СоздатьТестовыйФайл("resource.yaml", Yaml);

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Ожидаем.Что(Конфигурация.Ресурс).ИмеетТип("ОтелКонфигурацияРесурса");
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты.Количество()).Равно(2);
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты[0].Имя).Равно("service.name");
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты[0].Значение).Равно("my-service");
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты[1].Имя).Равно("service.version");
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты[1].Значение).Равно("1.2.3");
	Ожидаем.Что(Конфигурация.Ресурс.СписокАтрибутов).Равно("env=prod,zone=us");

КонецПроцедуры

