// ------------------------------------------------------------------
// TracerProvider
// ------------------------------------------------------------------

&Тест
Процедура РазборПровайдераТрассировкиСПроцессором() Экспорт

	// Дано
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  processors:",
		"    - batch:",
		"        schedule_delay: 3000",
		"        export_timeout: 15000",
		"        max_queue_size: 1024",
		"        max_export_batch_size: 256",
		"        exporter:",
		"          otlp_http:",
		"            endpoint: http://collector:4318/v1/traces",
		"            compression: gzip",
		"            timeout: 5000"
	);
	Yaml = СтрСоединить(СтрокиYaml, Символы.ПС);
	ПутьКФайлу = СоздатьТестовыйФайл("tracer_processor.yaml", Yaml);

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Провайдер = Конфигурация.ПровайдерТрассировки;
	Ожидаем.Что(Провайдер).ИмеетТип("ОтелКонфигурацияПровайдераТрассировки");
	Ожидаем.Что(Провайдер.Процессоры.Количество()).Равно(1);

	Процессор = Провайдер.Процессоры[0];
	Ожидаем.Что(Процессор).ИмеетТип("ОтелКонфигурацияПакетногоПроцессора");
	Ожидаем.Что(Процессор.ЗадержкаОтправки).Равно(3000);
	Ожидаем.Что(Процессор.ТаймаутЭкспорта).Равно(15000);
	Ожидаем.Что(Процессор.МаксРазмерОчереди).Равно(1024);
	Ожидаем.Что(Процессор.МаксРазмерПакета).Равно(256);

	Экспортер = Процессор.Экспортер;
	Ожидаем.Что(Экспортер).ИмеетТип("ОтелКонфигурацияЭкспортераOtlpHttp");
	Ожидаем.Что(Экспортер.Адрес).Равно("http://collector:4318/v1/traces");
	Ожидаем.Что(Экспортер.Сжатие).Равно("gzip");
	Ожидаем.Что(Экспортер.Таймаут).Равно(5000);

КонецПроцедуры

&Тест
Процедура РазборЛимитовСпана() Экспорт

	// Дано
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  limits:",
		"    attribute_value_length_limit: 512",
		"    attribute_count_limit: 64",
		"    event_count_limit: 32",
		"    link_count_limit: 16",
		"    event_attribute_count_limit: 48",
		"    link_attribute_count_limit: 24"
	);
	Yaml = СтрСоединить(СтрокиYaml, Символы.ПС);
	ПутьКФайлу = СоздатьТестовыйФайл("span_limits.yaml", Yaml);

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Лимиты = Конфигурация.ПровайдерТрассировки.Лимиты;
	Ожидаем.Что(Лимиты).ИмеетТип("ОтелКонфигурацияЛимитовСпана");
	Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута).Равно(512);
	Ожидаем.Что(Лимиты.МаксКоличествоАтрибутов).Равно(64);
	Ожидаем.Что(Лимиты.МаксСобытий).Равно(32);
	Ожидаем.Что(Лимиты.МаксЛинков).Равно(16);
	Ожидаем.Что(Лимиты.МаксАтрибутовНаСобытие).Равно(48);
	Ожидаем.Что(Лимиты.МаксАтрибутовНаЛинк).Равно(24);

КонецПроцедуры

&Тест
Процедура ЛимитыСпанаПоУмолчанию() Экспорт

	// Дано
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
