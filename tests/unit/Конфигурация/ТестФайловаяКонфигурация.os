&Тест
Процедура ОшибкаОтсутствующийФайл() Экспорт

	// Дано
	ПутьКФайлу = КаталогТестовыхДанных + "/несуществующий.yaml";

	// Тогда
	Попытка
		ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);
		Ожидаем.Что(Ложь).Равно(Истина); // не должны сюда попасть
	Исключение
		Ожидаем.Что(ОписаниеОшибки()).Содержит("не найден");
	КонецПопытки;

КонецПроцедуры

