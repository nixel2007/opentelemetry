// ------------------------------------------------------------------

&Тест
Процедура РазборЭкспортераСЗаголовками() Экспорт

	// Дано
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  processors:",
		"    - batch:",
		"        exporter:",
		"          otlp_http:",
		"            endpoint: http://collector:4318/v1/traces",
		"            headers:",
		"              - name: Authorization",
		"                value: ""Bearer token123""",
		"              - name: X-Custom",
		"                value: custom-value",
		"            headers_list: ""extra=val"""
	);
	Yaml = СтрСоединить(СтрокиYaml, Символы.ПС);
	ПутьКФайлу = СоздатьТестовыйФайл("exporter_headers.yaml", Yaml);

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Экспортер = Конфигурация.ПровайдерТрассировки.Процессоры[0].Экспортер;
	Ожидаем.Что(Экспортер.Заголовки.Количество()).Равно(2);
	Ожидаем.Что(Экспортер.Заголовки[0].Имя).Равно("Authorization");
	Ожидаем.Что(Экспортер.Заголовки[0].Значение).Равно("Bearer token123");
	Ожидаем.Что(Экспортер.Заголовки[1].Имя).Равно("X-Custom");
	Ожидаем.Что(Экспортер.Заголовки[1].Значение).Равно("custom-value");
	Ожидаем.Что(Экспортер.СписокЗаголовков).Равно("extra=val");

КонецПроцедуры

// ------------------------------------------------------------------
// Подстановка переменных в YAML-файле
// ------------------------------------------------------------------

&Тест
Процедура ПодстановкаПеременныхВФайлеКонфигурации() Экспорт

	// Дано
	УстановитьПеременнуюСреды("OTEL_TEST_ENDPOINT", "http://remote:4318/v1/traces");
	УстановитьПеременнуюСреды("OTEL_TEST_SVC_NAME", "test-svc");

	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"resource:",
		"  attributes:",
		"    - name: service.name",
		"      value: ${OTEL_TEST_SVC_NAME}",
		"tracer_provider:",
		"  processors:",
		"    - batch:",
		"        exporter:",
		"          otlp_http:",
		"            endpoint: ${OTEL_TEST_ENDPOINT}"
	);
	Yaml = СтрСоединить(СтрокиYaml, Символы.ПС);
	ПутьКФайлу = СоздатьТестовыйФайл("envvar_substitution.yaml", Yaml);

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты[0].Значение).Равно("test-svc");
	Ожидаем.Что(
		Конфигурация.ПровайдерТрассировки.Процессоры[0].Экспортер.Адрес
	).Равно("http://remote:4318/v1/traces");

КонецПроцедуры

// ------------------------------------------------------------------
// Полная конфигурация - все секции
// ------------------------------------------------------------------

&Тест
Процедура РазборПолнойКонфигурации() Экспорт

	// Дано
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"disabled: false",
		"resource:",
		"  attributes:",
		"    - name: service.name",
		"      value: full-test",
		"attribute_limits:",
		"  attribute_count_limit: 100",
		"propagator:",
		"  composite:",
		"    - tracecontext",
		"    - baggage",
		"tracer_provider:",
		"  processors:",
		"    - batch:",
		"        exporter:",
		"          otlp_http:",
		"            endpoint: http://localhost:4318/v1/traces",
		"  sampler:",
		"    parent_based:",
		"      root:",
		"        always_on:",
		"meter_provider:",
		"  readers:",
		"    - periodic:",
		"        exporter:",
		"          otlp_http:",
		"            endpoint: http://localhost:4318/v1/metrics",
		"logger_provider:",
		"  processors:",
		"    - batch:",
		"        exporter:",
		"          otlp_http:",
		"            endpoint: http://localhost:4318/v1/logs"
	);
	Yaml = СтрСоединить(СтрокиYaml, Символы.ПС);
	ПутьКФайлу = СоздатьТестовыйФайл("full_config.yaml", Yaml);

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Ожидаем.Что(Конфигурация.ФорматФайла).Равно("1.0");
	Ожидаем.Что(Конфигурация.Отключен).Равно(Ложь);
	Ожидаем.Что(Конфигурация.Ресурс).ИмеетТип("ОтелКонфигурацияРесурса");
	Ожидаем.Что(Конфигурация.ЛимитыАтрибутов).ИмеетТип("ОтелКонфигурацияЛимитовАтрибутов");
	Ожидаем.Что(Конфигурация.Пропагатор).ИмеетТип("ОтелКонфигурацияПропагатора");
	Ожидаем.Что(Конфигурация.ПровайдерТрассировки).ИмеетТип("ОтелКонфигурацияПровайдераТрассировки");
	Ожидаем.Что(Конфигурация.ПровайдерМетрик).ИмеетТип("ОтелКонфигурацияПровайдераМетрик");
	Ожидаем.Что(Конфигурация.ПровайдерЛогирования).ИмеетТип("ОтелКонфигурацияПровайдераЛогирования");

	// Проверяем вложенность
	Ожидаем.Что(Конфигурация.ПровайдерТрассировки.Сэмплер.Тип).Равно("parent_based");
	Ожидаем.Что(Конфигурация.ПровайдерТрассировки.Сэмплер.Корневой.Тип).Равно("always_on");

КонецПроцедуры

