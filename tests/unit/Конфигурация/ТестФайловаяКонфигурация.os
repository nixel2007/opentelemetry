КонецПроцедуры

&Тест
Процедура НеOtlpHttpЭкспортерПропускается() Экспорт

	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  processors:",
		"    - batch:",
		"        exporter:",
		"          otlp_grpc:",
		"            endpoint: http://localhost:4317"
	);
	ПутьКФайлу = СоздатьТестовыйФайл("non_otlp_http_exporter.yaml",
		СтрСоединить(СтрокиYaml, Символы.ПС));

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда - процессор есть, но экспортер Неопределено
	Ожидаем.Что(Конфигурация.ПровайдерТрассировки.Процессоры.Количество()).Равно(1);
	Ожидаем.Что(Конфигурация.ПровайдерТрассировки.Процессоры[0].Экспортер).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура OtlpHttpЭкспортерСНеСоответствиемВозвращаетПустой() Экспорт

	// Дано - РазобратьЭкспортер: otlp_http имеет строковое значение (не Соответствие) → пустой экспортер
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  processors:",
		"    - batch:",
		"        exporter:",
		"          otlp_http: ""http://localhost:4318/v1/traces"""
	);
	ПутьКФайлу = СоздатьТестовыйФайл("otlp_http_str_val.yaml",
		СтрСоединить(СтрокиYaml, Символы.ПС));

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда - возвращается пустой объект экспортера
	Экспортер = Конфигурация.ПровайдерТрассировки.Процессоры[0].Экспортер;
	Ожидаем.Что(Экспортер).ИмеетТип("ОтелКонфигурацияЭкспортераOtlpHttp");
	Ожидаем.Что(Экспортер.Адрес).Равно("");

КонецПроцедуры

&Тест
Процедура LocalParentSampledВParentBased() Экспорт

	// Дано - РазобратьПараметрыParentBased: ветки local_parent_sampled/not_sampled
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  sampler:",
		"    parent_based:",
		"      local_parent_sampled:",
		"        always_on:",
		"      local_parent_not_sampled:",
		"        always_off:"
	);
	ПутьКФайлу = СоздатьТестовыйФайл("local_parent_sampled.yaml",
		СтрСоединить(СтрокиYaml, Символы.ПС));

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Сэмплер = Конфигурация.ПровайдерТрассировки.Сэмплер;
	Ожидаем.Что(Сэмплер.Тип).Равно("parent_based");
	Ожидаем.Что(Сэмплер.ЛокальныйРодительСэмплирован.Тип).Равно("always_on");
	Ожидаем.Что(Сэмплер.ЛокальныйРодительНеСэмплирован.Тип).Равно("always_off");

КонецПроцедуры

&Тест
Процедура РесурсАтрибутНеСоответствиеПропускается() Экспорт

	// Дано - ЗаполнитьРесурс: элемент массива атрибутов - строка (не Соответствие) → пропускается
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"resource:",
		"  attributes:",
		"    - ""plain_string""",
		"    - name: service.name",
		"      value: test-svc"
	);
	ПутьКФайлу = СоздатьТестовыйФайл("resource_non_map_attr.yaml",
		СтрСоединить(СтрокиYaml, Символы.ПС));

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда - строковый элемент пропущен, добавлен только валидный атрибут
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты.Количество()).Равно(1);
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты[0].Имя).Равно("service.name");

КонецПроцедуры

&Тест
Процедура РесурсАтрибутБезИмениПропускается() Экспорт

	// Дано - ЗаполнитьРесурс: атрибут без ключа "name" → пропускается
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"resource:",
		"  attributes:",
		"    - value: orphan-value",
		"    - name: service.name",
		"      value: my-svc"
	);
	ПутьКФайлу = СоздатьТестовыйФайл("resource_no_name_attr.yaml",
		СтрСоединить(СтрокиYaml, Символы.ПС));

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда - только атрибут с именем добавлен
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты.Количество()).Равно(1);
	Ожидаем.Что(Конфигурация.Ресурс.Атрибуты[0].Имя).Равно("service.name");

КонецПроцедуры

&Тест
Процедура ЗаголовокЭкспортераБезЗначения() Экспорт

	// Дано - РазобратьЗаголовкиЭкспортера: заголовок без ключа "value" → значение = ""
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  processors:",
		"    - batch:",
		"        exporter:",
		"          otlp_http:",
		"            endpoint: http://localhost:4318/v1/traces",
		"            headers:",
		"              - name: X-Header-No-Value"
	);
	ПутьКФайлу = СоздатьТестовыйФайл("header_no_value.yaml",
		СтрСоединить(СтрокиYaml, Символы.ПС));

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда - заголовок добавлен со значением ""
	Экспортер = Конфигурация.ПровайдерТрассировки.Процессоры[0].Экспортер;
	Ожидаем.Что(Экспортер.Заголовки.Количество()).Равно(1);
	Ожидаем.Что(Экспортер.Заголовки[0].Имя).Равно("X-Header-No-Value");
	Ожидаем.Что(Экспортер.Заголовки[0].Значение).Равно("");

КонецПроцедуры

&Тест
Процедура ФайлСоСпискомВместоСоответствияВызываетИсключение() Экспорт

	// Дано - ПрочитатьЯМЛФайл: верхний уровень YAML - список, не Соответствие → исключение
	ПутьКФайлу = СоздатьТестовыйФайл("yaml_list.yaml",
		"- item1" + Символы.ПС + "- item2");

	// Тогда
	Попытка
		ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);
		Ожидаем.Что(Ложь).Равно(Истина); // не должны сюда попасть
	Исключение
		Ожидаем.Что(ОписаниеОшибки()).Содержит("mapping");
	КонецПопытки;

КонецПроцедуры

&Тест
Процедура СэмплерПустоеСоответствиеВозвращаетНеопределено() Экспорт

	// Дано - РазобратьСэмплер: пустое Соответствие → Неопределено (строка Возврат Неопределено после цикла)
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  sampler: {}"
	);
	ПутьКФайлу = СоздатьТестовыйФайл("empty_sampler.yaml",
		СтрСоединить(СтрокиYaml, Символы.ПС));

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Ожидаем.Что(Конфигурация.ПровайдерТрассировки.Сэмплер).Равно(Неопределено);

КонецПроцедуры

// ------------------------------------------------------------------
// Служебные
// ------------------------------------------------------------------

Функция МассивСтрок(Знач Стр1, Знач Стр2 = "_!ПУСТО!_", Знач Стр3 = "_!ПУСТО!_",
	Знач Стр4 = "_!ПУСТО!_", Знач Стр5 = "_!ПУСТО!_", Знач Стр6 = "_!ПУСТО!_",
	Знач Стр7 = "_!ПУСТО!_", Знач Стр8 = "_!ПУСТО!_", Знач Стр9 = "_!ПУСТО!_",
	Знач Стр10 = "_!ПУСТО!_", Знач Стр11 = "_!ПУСТО!_", Знач Стр12 = "_!ПУСТО!_",
	Знач Стр13 = "_!ПУСТО!_", Знач Стр14 = "_!ПУСТО!_", Знач Стр15 = "_!ПУСТО!_",
	Знач Стр16 = "_!ПУСТО!_", Знач Стр17 = "_!ПУСТО!_", Знач Стр18 = "_!ПУСТО!_",
	Знач Стр19 = "_!ПУСТО!_", Знач Стр20 = "_!ПУСТО!_", Знач Стр21 = "_!ПУСТО!_",
	Знач Стр22 = "_!ПУСТО!_", Знач Стр23 = "_!ПУСТО!_", Знач Стр24 = "_!ПУСТО!_",
	Знач Стр25 = "_!ПУСТО!_", Знач Стр26 = "_!ПУСТО!_", Знач Стр27 = "_!ПУСТО!_",
	Знач Стр28 = "_!ПУСТО!_", Знач Стр29 = "_!ПУСТО!_", Знач Стр30 = "_!ПУСТО!_",
	Знач Стр31 = "_!ПУСТО!_", Знач Стр32 = "_!ПУСТО!_", Знач Стр33 = "_!ПУСТО!_",
	Знач Стр34 = "_!ПУСТО!_", Знач Стр35 = "_!ПУСТО!_")

	Результат = Новый Массив;
	ВсеСтроки = Новый Массив;
	ВсеСтроки.Добавить(Стр1);
	ВсеСтроки.Добавить(Стр2);
	ВсеСтроки.Добавить(Стр3);
	ВсеСтроки.Добавить(Стр4);
	ВсеСтроки.Добавить(Стр5);
	ВсеСтроки.Добавить(Стр6);
	ВсеСтроки.Добавить(Стр7);
	ВсеСтроки.Добавить(Стр8);
	ВсеСтроки.Добавить(Стр9);
	ВсеСтроки.Добавить(Стр10);
	ВсеСтроки.Добавить(Стр11);
	ВсеСтроки.Добавить(Стр12);
	ВсеСтроки.Добавить(Стр13);
	ВсеСтроки.Добавить(Стр14);
	ВсеСтроки.Добавить(Стр15);
	ВсеСтроки.Добавить(Стр16);
	ВсеСтроки.Добавить(Стр17);
	ВсеСтроки.Добавить(Стр18);
	ВсеСтроки.Добавить(Стр19);
	ВсеСтроки.Добавить(Стр20);
	ВсеСтроки.Добавить(Стр21);
	ВсеСтроки.Добавить(Стр22);
	ВсеСтроки.Добавить(Стр23);
	ВсеСтроки.Добавить(Стр24);
	ВсеСтроки.Добавить(Стр25);
	ВсеСтроки.Добавить(Стр26);
	ВсеСтроки.Добавить(Стр27);
	ВсеСтроки.Добавить(Стр28);
	ВсеСтроки.Добавить(Стр29);
	ВсеСтроки.Добавить(Стр30);
	ВсеСтроки.Добавить(Стр31);
	ВсеСтроки.Добавить(Стр32);
	ВсеСтроки.Добавить(Стр33);
	ВсеСтроки.Добавить(Стр34);
	ВсеСтроки.Добавить(Стр35);

	Для Каждого Стр Из ВсеСтроки Цикл
		Если Стр = "_!ПУСТО!_" Тогда
			Прервать;
		КонецЕсли;
		Результат.Добавить(Стр);
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция СоздатьТестовыйФайл(Знач ИмяФайла, Знач Содержимое)

	ПутьКФайлу = КаталогТестовыхДанных + "/" + ИмяФайла;
	Запись = Новый ЗаписьТекста(ПутьКФайлу, КодировкаТекста.UTF8);
	Запись.Записать(Содержимое);
	Запись.Закрыть();
	Возврат ПутьКФайлу;

КонецФункции

Процедура УдалитьПеременнуюСреды(Знач Имя)

	Попытка
		УстановитьПеременнуюСреды(Имя, "");
	Исключение // BSLLS:MissingCodeTryCatchEx-off
		// В некоторых средах нет возможности удалить переменную - устанавливаем пустую строку
	КонецПопытки;

КонецПроцедуры

&ТестовыйНабор
Процедура ПриСозданииОбъекта()

	КаталогТестовыхДанных = ОбъединитьПути(КаталогВременныхФайлов(), "otel_file_config_tests");
	СоздатьКаталог(КаталогТестовыхДанных);

КонецПроцедуры
