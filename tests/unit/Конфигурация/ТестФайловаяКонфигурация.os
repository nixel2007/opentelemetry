&Тест
Процедура РазборСэмплераParentBased() Экспорт

	// Дано
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  sampler:",
		"    parent_based:",
		"      root:",
		"        trace_id_ratio_based:",
		"          ratio: 0.25",
		"      remote_parent_sampled:",
		"        always_on:",
		"      remote_parent_not_sampled:",
		"        always_off:"
	);
	Yaml = СтрСоединить(СтрокиYaml, Символы.ПС);
	ПутьКФайлу = СоздатьТестовыйФайл("sampler_parent_based.yaml", Yaml);

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Сэмплер = Конфигурация.ПровайдерТрассировки.Сэмплер;
	Ожидаем.Что(Сэмплер.Тип).Равно("parent_based");

	Ожидаем.Что(Сэмплер.Корневой).ИмеетТип("ОтелКонфигурацияСэмплера");
	Ожидаем.Что(Сэмплер.Корневой.Тип).Равно("trace_id_ratio_based");
	Ожидаем.Что(Сэмплер.Корневой.Доля).Равно(0.25);

	Ожидаем.Что(Сэмплер.УдаленныйРодительСэмплирован.Тип).Равно("always_on");
	Ожидаем.Что(Сэмплер.УдаленныйРодительНеСэмплирован.Тип).Равно("always_off");
	Ожидаем.Что(Сэмплер.ЛокальныйРодительСэмплирован).Равно(Неопределено);
	Ожидаем.Что(Сэмплер.ЛокальныйРодительНеСэмплирован).Равно(Неопределено);

КонецПроцедуры

// ------------------------------------------------------------------
// MeterProvider
// ------------------------------------------------------------------

&Тест
Процедура РазборПровайдераМетрик() Экспорт

	// Дано
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"meter_provider:",
		"  exemplar_filter: always_on",
		"  readers:",
		"    - periodic:",
		"        interval: 30000",
		"        timeout: 10000",
		"        exporter:",
		"          otlp_http:",
		"            endpoint: http://collector:4318/v1/metrics",
		"            temporality_preference: delta",
		"            default_histogram_aggregation: base2_exponential_bucket_histogram"
	);
	Yaml = СтрСоединить(СтрокиYaml, Символы.ПС);
	ПутьКФайлу = СоздатьТестовыйФайл("meter_provider.yaml", Yaml);

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда
	Провайдер = Конфигурация.ПровайдерМетрик;
	Ожидаем.Что(Провайдер).ИмеетТип("ОтелКонфигурацияПровайдераМетрик");
	Ожидаем.Что(Провайдер.ФильтрЭкземпляров).Равно("always_on");
	Ожидаем.Что(Провайдер.Читатели.Количество()).Равно(1);

	Читатель = Провайдер.Читатели[0];
	Ожидаем.Что(Читатель).ИмеетТип("ОтелКонфигурацияПериодическогоЧитателя");
	Ожидаем.Что(Читатель.Интервал).Равно(30000);
	Ожидаем.Что(Читатель.Таймаут).Равно(10000);

	Экспортер = Читатель.Экспортер;
	Ожидаем.Что(Экспортер.Адрес).Равно("http://collector:4318/v1/metrics");
	Ожидаем.Что(Экспортер.ПредпочтениеВременнойАгрегации).Равно("delta");
	Ожидаем.Что(Экспортер.АгрегацияГистограммПоУмолчанию).Равно("base2_exponential_bucket_histogram");

КонецПроцедуры

&Тест
Процедура ПровайдерМетрикПоУмолчанию() Экспорт

	// Дано
	СтрокиYaml = МассивСтрок(
