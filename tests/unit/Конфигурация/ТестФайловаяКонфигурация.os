&Тест
Процедура НеПакетныйПроцессорПропускается() Экспорт

	// Дано - РазобратьПроцессор: ключ не "batch" → процессор пропускается
	СтрокиYaml = МассивСтрок(
		"file_format: ""1.0""",
		"tracer_provider:",
		"  processors:",
		"    - simple:"
	);
	ПутьКФайлу = СоздатьТестовыйФайл("non_batch_proc.yaml",
		СтрСоединить(СтрокиYaml, Символы.ПС));

	// Когда
	Конфигурация = ОтелФайловаяКонфигурация.Разобрать(ПутьКФайлу);

	// Тогда - non-batch процессор не добавляется в список
	Ожидаем.Что(Конфигурация.ПровайдерТрассировки.Процессоры.Количество()).Равно(0);

КонецПроцедуры

