&Тест
Процедура ТранспортДляСигналаСКлиентскимСертификатомEnv() Экспорт

    // Дано - клиентский сертификат и ключ
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.exporter.otlp.client.certificate", "/tmp/client.crt");
    Параметры.Вставить("otel.exporter.otlp.client.key", "/tmp/client.key");
    Параметры.Вставить("otel.exporter.otlp.timeout", "1");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Результат = ОтелАвтоконфигурация.СоздатьТранспортДляСигнала(Менеджер, "traces");

    // Тогда - транспорт получил настройки TLS с клиентским сертификатом
    НастройкиTls = Результат.Транспорт.ПолучитьНастройкиTls();
    Ожидаем.Что(НастройкиTls).Не_().Равно(Неопределено);
    Ожидаем.Что(НастройкиTls.ФайлКлиентскогоСертификата).Равно("/tmp/client.crt");
    Ожидаем.Что(НастройкиTls.ФайлКлиентскогоКлюча).Равно("/tmp/client.key");

КонецПроцедуры

// --- Тесты SHOULD/SHOULD NOT требований OTel spec ---

&Тест
Процедура ПротоколПоУмолчаниюHttpProtobuf() Экспорт

    // Дано - менеджер без явного протокола
    Менеджер = Новый МенеджерПараметров();
    Менеджер.Прочитать();

    // Когда - создаём транспорт для сигнала без указания протокола
    Результат = ОтелАвтоконфигурация.СоздатьТранспортДляСигнала(Менеджер, "traces");

    // Тогда - по спеке протокол по умолчанию http/protobuf, поэтому HTTP-транспорт (порт 4318)
    Ожидаем.Что(ТипЗнч(Результат.Транспорт)).Равно(Тип("ОтелHttpТранспорт"));

КонецПроцедуры

&Тест
Процедура ПротоколПоУмолчаниюДляОбщегоТранспортаHttpProtobuf() Экспорт

    // Дано - менеджер без явного протокола (общий СоздатьТранспорт)
    Менеджер = Новый МенеджерПараметров();
    Менеджер.Прочитать();

    // Когда
    Транспорт = ОтелАвтоконфигурация.СоздатьТранспорт(Менеджер);

    // Тогда - используется HTTP-транспорт (http/protobuf на порту 4318), а не grpc (4317)
    Ожидаем.Что(ТипЗнч(Транспорт)).Равно(Тип("ОтелHttpТранспорт"));

КонецПроцедуры

&Тест
Процедура НевалидныйОтелSdkDisabledТрактуетсяКакЛожь() Экспорт

    // Дано - невалидное значение boolean env-переменной
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.sdk.disabled", "yes");
    Параметры.Вставить("otel.traces.exporter", "none");
    Параметры.Вставить("otel.logs.exporter", "none");
    Параметры.Вставить("otel.metrics.exporter", "none");
    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда - инициализация не должна падать
    Сдк = ОтелАвтоконфигурация.Инициализировать(Менеджер);

    // Тогда - SDK активен (умолчание false), а не выключен
    Ожидаем.Что(ТипЗнч(Сдк.ПолучитьТрассировщик("тест"))).Равно(Тип("ОтелТрассировщик"));

КонецПроцедуры

