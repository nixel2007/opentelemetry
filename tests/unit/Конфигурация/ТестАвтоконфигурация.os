    // Тогда - спан-специфичные перекрывают общие
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(256);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(4096);

КонецПроцедуры

