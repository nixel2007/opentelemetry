&Тест
Процедура ПропагаторыNoneСДругимиВызываетИсключение() Экспорт

    // Дано - none вместе с tracecontext - недопустимо по спеке Java SDK
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.traces.exporter", "none");
    Параметры.Вставить("otel.logs.exporter", "none");
    Параметры.Вставить("otel.metrics.exporter", "none");
    Параметры.Вставить("otel.service.name", "тест-сервис");
    Параметры.Вставить("otel.propagators", "tracecontext,none");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда/Тогда - исключение
    Попытка
        ОтелАвтоконфигурация.СоздатьПропагаторы(Менеджер);
        Ожидаем.Что(Ложь).Равно(Истина); // не должны сюда попасть
    Исключение
        Ожидаем.Что(ОписаниеОшибки()).Содержит("none");
    КонецПопытки;

КонецПроцедуры

