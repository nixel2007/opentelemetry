// ====== TLS ======

&Тест
Процедура ТранспортДляСигналаСCertificateEnv() Экспорт

    // Дано - общий env OTEL_EXPORTER_OTLP_CERTIFICATE
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.exporter.otlp.certificate", "/etc/ssl/ca.crt");
    Параметры.Вставить("otel.exporter.otlp.timeout", "1");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Результат = ОтелАвтоконфигурация.СоздатьТранспортДляСигнала(Менеджер, "traces");

    // Тогда - транспорт создан и настройки TLS переданы
    Ожидаем.Что(Результат.Транспорт).Не_().Равно(Неопределено);
    Ожидаем.Что(Результат.Транспорт.ПолучитьНастройкиTls()).Не_().Равно(Неопределено);
    Ожидаем.Что(Результат.Транспорт.ПолучитьНастройкиTls().ФайлСертификата).Равно("/etc/ssl/ca.crt");

КонецПроцедуры

&Тест
Процедура ТранспортДляСигналаСPerSignalCertificateEnv() Экспорт

