&Тест
Процедура ПровайдерМетрикСЭкспортеромИмеетЧитатель() Экспорт

    // Дано - конфигурация с otlp экспортером метрик
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.traces.exporter", "none");
    Параметры.Вставить("otel.logs.exporter", "none");
    Параметры.Вставить("otel.metrics.exporter", "otlp");
    Параметры.Вставить("otel.metric.export.interval", "100");
    Параметры.Вставить("otel.exporter.otlp.timeout", "1");
    Параметры.Вставить("otel.service.name", "тест-сервис");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Провайдер = ОтелАвтоконфигурация.СоздатьПровайдерМетрик(Менеджер);

    // Тогда - провайдер содержит читатель метрик
    Ожидаем.Что(Провайдер.ЧитательМетрик()).Не_().Равно(Неопределено);

    // Очистка - закрыть чтобы остановить фоновый поток
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ПровайдерМетрикБезЭкспортераНеИмеетЧитатель() Экспорт

    // Дано - конфигурация с exporter = none
    Менеджер = СоздатьМенеджерСПараметрами();

    // Когда
    Провайдер = ОтелАвтоконфигурация.СоздатьПровайдерМетрик(Менеджер);

    // Тогда - провайдер не содержит читатель (нет экспортера)
    Ожидаем.Что(Провайдер.ЧитательМетрик()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ИнициализацияСоздаетПропагаторыПоУмолчанию() Экспорт

    // Дано - стандартная конфигурация, OTEL_PROPAGATORS не задан
    Менеджер = СоздатьМенеджерСПараметрами();

    // Когда
    Сдк = ОтелАвтоконфигурация.Инициализировать(Менеджер);

    // Тогда - пропагаторы созданы (по умолчанию tracecontext,baggage)
    Ожидаем.Что(Сдк.Пропагаторы()).Не_().Равно(Неопределено);

    // Проверяем, что пропагатор знает про traceparent и baggage
    Поля = Сдк.Пропагаторы().Поля();
    Ожидаем.Что(Поля).Содержит("traceparent");
    Ожидаем.Что(Поля).Содержит("baggage");

КонецПроцедуры

