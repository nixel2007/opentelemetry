    // Когда
    Результат = ОтелАвтоконфигурация.СоздатьТранспортДляСигнала(Менеджер, "traces");

    // Тогда - per-signal перекрывает общий
    Ожидаем.Что(Результат.Транспорт.ПолучитьНастройкиTls().ФайлСертификата)
        .Равно("/etc/ssl/traces-ca.crt");

