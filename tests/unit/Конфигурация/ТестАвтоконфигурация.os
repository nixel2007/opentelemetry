КонецПроцедуры

&ПослеКаждого
Процедура Очистка() Экспорт
    ОтелГлобальный.СброситьИЗакрыть();
КонецПроцедуры

&Тест
Процедура СозданиеРесурсаБезПеременных() Экспорт

    // Дано - менеджер параметров без провайдеров (нет переменных окружения)
    Менеджер = Новый МенеджерПараметров();
    Менеджер.Прочитать();

    // Когда
    Ресурс = ОтелАвтоконфигурация.СоздатьРесурс(Менеджер);

    // Тогда - ресурс создан без ошибок
    Ожидаем.Что(Ресурс).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура СозданиеТранспортаПоУмолчанию() Экспорт

    // Дано - менеджер без явного адреса (используется значение по умолчанию)
    Менеджер = Новый МенеджерПараметров();
    Менеджер.Прочитать();

    // Когда
    Транспорт = ОтелАвтоконфигурация.СоздатьТранспорт(Менеджер);

    // Тогда - транспорт создан (HTTP по умолчанию)
    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура СозданиеМенеджераПараметровПоУмолчанию() Экспорт

    // Когда - создаем менеджер параметров по умолчанию
    Менеджер = ОтелАвтоконфигурация.СоздатьМенеджерПараметровПоУмолчанию();

    // Тогда - менеджер создан и прочитан без ошибок
    Ожидаем.Что(Менеджер).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ИнициализацияСМенеджеромПараметров() Экспорт

    // Дано - отключаем экспортеры чтобы не нужен реальный адрес
    Менеджер = СоздатьМенеджерСПараметрами();

    // Когда
    Сдк = ОтелАвтоконфигурация.Инициализировать(Менеджер);

    // Тогда - SDK создан и зарегистрирован глобально
    Ожидаем.Что(Сдк).Не_().Равно(Неопределено);
    Ожидаем.Что(ОтелГлобальный.Получить()).Равно(Сдк);

КонецПроцедуры

&Тест
Процедура ИнициализацияСоздаетВсеПровайдеры() Экспорт

    // Дано
    Менеджер = СоздатьМенеджерСПараметрами();

    // Когда
    Сдк = ОтелАвтоконфигурация.Инициализировать(Менеджер);

    // Тогда - все 3 провайдера доступны
    Ожидаем.Что(Сдк.ПровайдерТрассировки()).Не_().Равно(Неопределено);
    Ожидаем.Что(Сдк.ПровайдерЛогирования()).Не_().Равно(Неопределено);
    Ожидаем.Что(Сдк.ПровайдерМетрик()).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ИнициализацияСОтключеннымСдк() Экспорт

    // Дано - otel.sdk.disabled = true
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.sdk.disabled", "true");
    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Сдк = ОтелАвтоконфигурация.Инициализировать(Менеджер);

    // Тогда - SDK создан и зарегистрирован
    Ожидаем.Что(Сдк).Не_().Равно(Неопределено);
    Ожидаем.Что(ОтелГлобальный.Получить()).Равно(Сдк);

    // Трассировщик возвращает NoOp-спаны
    Трассировщик = Сдк.ПолучитьТрассировщик("тест");
    Спан = Трассировщик.НачатьСпан("операция");
    Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНезаписывающийСпан"));
    Ожидаем.Что(Спан.ЗаписьАктивна()).Равно(Ложь);

    // Все вызовы безопасны
    Спан.УстановитьАтрибут("ключ", "значение");
    Спан.Завершить();

КонецПроцедуры

&Тест
Процедура ИнициализацияSdkDisabledFalse() Экспорт

    // Дано - otel.sdk.disabled = false (явно) и отключённые экспортеры
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.sdk.disabled", "false");
    Параметры.Вставить("otel.traces.exporter", "none");
    Параметры.Вставить("otel.logs.exporter", "none");
    Параметры.Вставить("otel.metrics.exporter", "none");
    Параметры.Вставить("otel.service.name", "тест-сервис");
    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Сдк = ОтелАвтоконфигурация.Инициализировать(Менеджер);

    // Тогда - SDK активен (не NoOp-трассировщик)
    Трассировщик = Сдк.ПолучитьТрассировщик("тест");
    Ожидаем.Что(ТипЗнч(Трассировщик)).Равно(Тип("ОтелТрассировщик"));

КонецПроцедуры

