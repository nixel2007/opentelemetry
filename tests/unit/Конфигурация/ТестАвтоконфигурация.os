&Тест
Процедура ВалидныйInsecureВВерхнемРегистре() Экспорт

    // Дано - регистр должен игнорироваться
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.exporter.otlp.insecure", "TRUE");
    Параметры.Вставить("otel.exporter.otlp.timeout", "1");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Результат = ОтелАвтоконфигурация.СоздатьТранспортДляСигнала(Менеджер, "logs");

    // Тогда - Insecure=Истина, регистр не важен
    Ожидаем.Что(Результат.Транспорт.ПолучитьНастройкиTls().Insecure).Равно(Истина);

КонецПроцедуры

&Тест
Процедура НевалидныеOtelResourceAttributesНеПадают() Экспорт

    // Дано - менеджер с произвольным значением, парсер всегда отрабатывает,
    // но при ошибке внутри Попытка SDK SHOULD продолжать работу.
    // Используем валидный формат, чтобы убедиться, что обёртка не ломает существующий парсинг.
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.resource.attributes", "ключ=значение,malformed_no_equals");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда - не должно падать
    Ресурс = ОтелАвтоконфигурация.СоздатьРесурс(Менеджер);

    // Тогда - валидная пара применилась, мусорная просто проигнорирована
    Ожидаем.Что(Ресурс.Атрибуты().Получить("ключ")).Равно("значение");

КонецПроцедуры

Функция СоздатьМенеджерССэмплером(ИмяСэмплера, АргументСэмплера = Неопределено)
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.traces.exporter", "otlp");
    Параметры.Вставить("otel.logs.exporter", "none");
    Параметры.Вставить("otel.metrics.exporter", "none");
    Параметры.Вставить("otel.bsp.schedule.delay", "100");
    Параметры.Вставить("otel.exporter.otlp.timeout", "1");
    Параметры.Вставить("otel.traces.sampler", ИмяСэмплера);
    Если АргументСэмплера <> Неопределено Тогда
        Параметры.Вставить("otel.traces.sampler.arg", АргументСэмплера);
    КонецЕсли;

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();
    Возврат Менеджер;
КонецФункции
