&Тест
Процедура СоздатьПровайдерЛогированияСЭкспортером() Экспорт

    // Дано - конфигурация с otlp экспортером логов
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.traces.exporter", "none");
    Параметры.Вставить("otel.logs.exporter", "otlp");
    Параметры.Вставить("otel.metrics.exporter", "none");
    Параметры.Вставить("otel.blrp.schedule.delay", "100");
    Параметры.Вставить("otel.exporter.otlp.timeout", "1");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Провайдер = ОтелАвтоконфигурация.СоздатьПровайдерЛогирования(Менеджер);

    // Тогда
    Ожидаем.Что(Провайдер).Не_().Равно(Неопределено);

    // Очистка
    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура СоздатьТранспортGrpc() Экспорт

    // Дано
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.exporter.otlp.protocol", "grpc");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Транспорт = ОтелАвтоконфигурация.СоздатьТранспорт(Менеджер);

    // Тогда
