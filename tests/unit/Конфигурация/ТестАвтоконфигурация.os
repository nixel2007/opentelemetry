    Ожидаем.Что(Транспорт).Не_().Равно(Неопределено);

КонецПроцедуры

// --- Тесты лимитов атрибутов ---

&Тест
Процедура ЛимитыСпанаПоУмолчанию() Экспорт

    // Дано - конфигурация без лимитов
    Менеджер = Новый МенеджерПараметров();
    Менеджер.Прочитать();

    // Когда
    Лимиты = ОтелАвтоконфигурация.СоздатьЛимитыСпана(Менеджер);

    // Тогда - значения по умолчанию
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(128);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(0);

КонецПроцедуры

&Тест
Процедура ЛимитыСпанаИзОбщейКонфигурации() Экспорт

    // Дано - общие лимиты (без спан-специфичных)
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.attribute.count.limit", "64");
    Параметры.Вставить("otel.attribute.value.length.limit", "1024");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Лимиты = ОтелАвтоконфигурация.СоздатьЛимитыСпана(Менеджер);

    // Тогда - берутся из общих лимитов
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(64);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(1024);

КонецПроцедуры

&Тест
Процедура ЛимитыСпанаСпецифичныеПерекрываютОбщие() Экспорт

    // Дано - и общие и спан-специфичные лимиты
