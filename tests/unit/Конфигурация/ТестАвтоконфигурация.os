&Тест
Процедура НеизвестныйПропагаторВызываетИсключение() Экспорт

    // Дано
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.propagators", "unknown_propagator");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда / Тогда
    Попытка
        ОтелАвтоконфигурация.СоздатьПропагаторы(Менеджер);
        Ожидаем.Что(Ложь).Равно(Истина); // Не должно дойти сюда
    Исключение
        Ожидаем.Что(ОписаниеОшибки()).Содержит("Неизвестный пропагатор");
    КонецПопытки;

КонецПроцедуры

// --- Тесты OTEL_RESOURCE_ATTRIBUTES ---

&Тест
Процедура РесурсСАтрибутамиОкружения() Экспорт

    // Дано - otel.resource.attributes с несколькими парами
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.resource.attributes", "env=production,region=us-east-1,version=1.2.3");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Ресурс = ОтелАвтоконфигурация.СоздатьРесурс(Менеджер);

    // Тогда - ресурс содержит все атрибуты из otel.resource.attributes
    Ожидаем.Что(Ресурс.Атрибуты().Получить("env")).Равно("production");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("region")).Равно("us-east-1");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("version")).Равно("1.2.3");

КонецПроцедуры

&Тест
Процедура РесурсServiceNameПерекрываетАтрибуты() Экспорт

    // Дано - service.name в resource attributes и в otel.service.name
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.resource.attributes", "service.name=из-атрибутов,env=test");
    Параметры.Вставить("otel.service.name", "из-переменной");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Ресурс = ОтелАвтоконфигурация.СоздатьРесурс(Менеджер);

    // Тогда - otel.service.name перекрывает service.name из resource attributes
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("из-переменной");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("env")).Равно("test");

КонецПроцедуры

&Тест
Процедура РесурсСПустымиАтрибутамиОкружения() Экспорт

    // Дано - пустая строка otel.resource.attributes
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.resource.attributes", "");
    Параметры.Вставить("otel.service.name", "тест-сервис");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();

    // Когда
    Ресурс = ОтелАвтоконфигурация.СоздатьРесурс(Менеджер);

    // Тогда - ресурс создан без ошибок, service.name установлен
    Ожидаем.Что(Ресурс).Не_().Равно(Неопределено);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("тест-сервис");

КонецПроцедуры

// --- Тесты OTEL_EXPORTER_OTLP_HEADERS и OTEL_EXPORTER_OTLP_COMPRESSION ---

&Тест
Процедура ТранспортСЗаголовкамиOTLP() Экспорт

    // Дано - otel.exporter.otlp.headers с парами ключ=значение
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.exporter.otlp.headers", "Authorization=Bearer token123,X-Custom=value");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
