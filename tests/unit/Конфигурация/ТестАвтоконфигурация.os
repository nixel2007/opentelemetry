// --- Тесты разбора пар ключ-значение ---

&Тест
Процедура РазборПарКлючЗначение() Экспорт

    // Когда - стандартная строка с парами
    Результат = ОтелАвтоконфигурация.РазобратьПарыКлючЗначение("key1=value1,key2=value2,key3=value3");

    // Тогда
    Ожидаем.Что(Результат.Получить("key1")).Равно("value1");
    Ожидаем.Что(Результат.Получить("key2")).Равно("value2");
    Ожидаем.Что(Результат.Получить("key3")).Равно("value3");

КонецПроцедуры

&Тест
Процедура РазборПарКлючЗначениеСПробелами() Экспорт

    // Когда - пары с пробелами вокруг ключей и значений
    Результат = ОтелАвтоконфигурация.РазобратьПарыКлючЗначение(" key1 = value1 , key2 = value2 ");

    // Тогда - пробелы обрезаны
    Ожидаем.Что(Результат.Получить("key1")).Равно("value1");
    Ожидаем.Что(Результат.Получить("key2")).Равно("value2");

КонецПроцедуры

&Тест
Процедура РазборПарКлючЗначениеПустаяСтрока() Экспорт

    // Когда - пустая строка
    Результат = ОтелАвтоконфигурация.РазобратьПарыКлючЗначение("");

    // Тогда - пустое соответствие
    Ожидаем.Что(Результат.Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура РазборПарКлючЗначениеСРавноВЗначении() Экспорт

    // Когда - значение содержит знак равенства
    Результат = ОтелАвтоконфигурация.РазобратьПарыКлючЗначение("Authorization=Bearer token=abc");

    // Тогда - разбивается по первому знаку равно
    Ожидаем.Что(Результат.Получить("Authorization")).Равно("Bearer token=abc");

КонецПроцедуры

Функция СоздатьМенеджерСПараметрами()
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.traces.exporter", "none");
    Параметры.Вставить("otel.logs.exporter", "none");
    Параметры.Вставить("otel.metrics.exporter", "none");
    Параметры.Вставить("otel.service.name", "тест-сервис");

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();
    Возврат Менеджер;
КонецФункции

Функция СоздатьМенеджерССэмплером(ИмяСэмплера, АргументСэмплера = Неопределено)
    Параметры = Новый Соответствие();
    Параметры.Вставить("otel.traces.exporter", "otlp");
    Параметры.Вставить("otel.logs.exporter", "none");
    Параметры.Вставить("otel.metrics.exporter", "none");
    Параметры.Вставить("otel.bsp.schedule.delay", "100");
    Параметры.Вставить("otel.exporter.otlp.timeout", "1");
    Параметры.Вставить("otel.traces.sampler", ИмяСэмплера);
    Если АргументСэмплера <> Неопределено Тогда
        Параметры.Вставить("otel.traces.sampler.arg", АргументСэмплера);
    КонецЕсли;

    Менеджер = Новый МенеджерПараметров();
    Менеджер.ДобавитьПровайдерПараметров(Новый ПровайдерПараметровСоответствие(Параметры));
    Менеджер.Прочитать();
    Возврат Менеджер;
КонецФункции
