&Тест
Процедура СоздатьПропагаторыNoneСДругимиВыбрасываетИсключение() Экспорт

	// Дано
	КонфигПропагатора = Новый ОтелКонфигурацияПропагатора();
	КонфигПропагатора.Составной.Добавить("none");
	КонфигПропагатора.Составной.Добавить("tracecontext");

	// Когда / Тогда
	Попытка
		ОтелКонфигурационнаяФабрика.СоздатьПропагаторы(
			КонфигПропагатора);
		Ожидаем.Что(Ложь).ЭтоИстина("Должно было быть исключение");
	Исключение
		Ожидаем.Что(ИнформацияОбОшибке().Описание).Содержит("none");
	КонецПопытки;

КонецПроцедуры

&Тест
Процедура СоздатьПропагаторыДедупликация() Экспорт

	// Дано - дубликаты должны быть удалены
	КонфигПропагатора = Новый ОтелКонфигурацияПропагатора();
	КонфигПропагатора.Составной.Добавить("tracecontext");
	КонфигПропагатора.Составной.Добавить("tracecontext");

	// Когда
	Пропагаторы = ОтелКонфигурационнаяФабрика.СоздатьПропагаторы(
		КонфигПропагатора);

	// Тогда - должен быть создан без ошибок
	Ожидаем.Что(ТипЗнч(Пропагаторы)).Равно(
		Тип("ОтелКомпозитныйПропагатор"));

КонецПроцедуры

// ===== Полный SDK с конфигурацией =====

&Тест
Процедура СоздатьSdkСПровайдерамиИРесурсом() Экспорт

	// Дано
	Модель = Новый ОтелКонфигурация();

	// Ресурс
	Модель.Ресурс = Новый ОтелКонфигурацияРесурса();
	ЗаписьАтрибута = Новый Структура(
		"Имя, Значение", "service.name", "factory-test");
	Модель.Ресурс.Атрибуты.Добавить(ЗаписьАтрибута);

	// Провайдер трассировки
	Модель.ПровайдерТрассировки = Новый ОтелКонфигурацияПровайдераТрассировки();

	// Провайдер логирования
	Модель.ПровайдерЛогирования = Новый ОтелКонфигурацияПровайдераЛогирования();

	// Провайдер метрик
	Модель.ПровайдерМетрик = Новый ОтелКонфигурацияПровайдераМетрик();

	// Когда
	Sdk = ОтелКонфигурационнаяФабрика.Создать(Модель);

	// Тогда
	Ожидаем.Что(ТипЗнч(Sdk)).Равно(Тип("ОтелSdk"));

	// Проверяем что ресурс передан в провайдеры
	Ожидаем.Что(
		Sdk.ПровайдерТрассировки().Ресурс()
			.Атрибуты().Получить("service.name")).Равно("factory-test");
	Ожидаем.Что(
		Sdk.ПровайдерЛогирования().Ресурс()
			.Атрибуты().Получить("service.name")).Равно("factory-test");
	Ожидаем.Что(
		Sdk.ПровайдерМетрик().Ресурс()
			.Атрибуты().Получить("service.name")).Равно("factory-test");

КонецПроцедуры
