	КонфигЧитателя2 = Новый ОтелКонфигурацияПериодическогоЧитателя();
	КонфигЧитателя2.Экспортер = Новый ОтелКонфигурацияЭкспортераOtlpHttp();
	КонфигПровайдера.Читатели.Добавить(КонфигЧитателя1);
