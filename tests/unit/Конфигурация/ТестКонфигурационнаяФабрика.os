&Тест
Процедура СоздатьПровайдерТрассировкиСTraceIdRatioСэмплером() Экспорт

	// Дано
	Ресурс = Новый ОтелРесурс();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();
	КонфигСэмплера = Новый ОтелКонфигурацияСэмплера();
	КонфигСэмплера.Тип = "trace_id_ratio_based";
	КонфигСэмплера.Доля = 0.5;
	КонфигПровайдера.Сэмплер = КонфигСэмплера;

	// Когда
	Провайдер = ОтелКонфигурационнаяФабрика.СоздатьПровайдерТрассировки(
		Ресурс, КонфигПровайдера);

	// Тогда
	Ожидаем.Что(Провайдер.СтратегияСэмплирования()).Равно(
		ОтелСэмплер.ПоДолеТрассировок());
	Ожидаем.Что(Провайдер.ДоляСэмплирования()).Равно(0.5);

КонецПроцедуры

&Тест
Процедура СоздатьПровайдерТрассировкиСParentBasedСэмплером() Экспорт

	// Дано
	Ресурс = Новый ОтелРесурс();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();
	КонфигСэмплера = Новый ОтелКонфигурацияСэмплера();
	КонфигСэмплера.Тип = "parent_based";
	КорневойСэмплер = Новый ОтелКонфигурацияСэмплера();
	КорневойСэмплер.Тип = "always_off";
	КонфигСэмплера.Корневой = КорневойСэмплер;
	КонфигПровайдера.Сэмплер = КонфигСэмплера;

	// Когда
	Провайдер = ОтелКонфигурационнаяФабрика.СоздатьПровайдерТрассировки(
		Ресурс, КонфигПровайдера);

	// Тогда
	Ожидаем.Что(Провайдер.СтратегияСэмплирования()).Равно(
		ОтелСэмплер.НаОсновеРодителя());
	Ожидаем.Что(Провайдер.КорневаяСтратегия()).Равно(
		ОтелСэмплер.ВсегдаВыключен());

КонецПроцедуры

&Тест
Процедура СоздатьПровайдерТрассировкиСЛимитамиСпана() Экспорт

	// Дано
	Ресурс = Новый ОтелРесурс();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();

	КонфигЛимитов = Новый ОтелКонфигурацияЛимитовСпана();
	КонфигЛимитов.МаксКоличествоАтрибутов = 64;
	КонфигЛимитов.МаксДлинаЗначенияАтрибута = 256;
	КонфигЛимитов.МаксСобытий = 32;
	КонфигЛимитов.МаксЛинков = 16;
	КонфигЛимитов.МаксАтрибутовНаСобытие = 8;
	КонфигЛимитов.МаксАтрибутовНаЛинк = 4;
	КонфигПровайдера.Лимиты = КонфигЛимитов;

	// Когда
	Провайдер = ОтелКонфигурационнаяФабрика.СоздатьПровайдерТрассировки(
		Ресурс, КонфигПровайдера);

	// Тогда
	Лимиты = Провайдер.ЛимитыСпана();
	Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(64);
	Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(256);
	Ожидаем.Что(Лимиты.МаксСобытий()).Равно(32);
	Ожидаем.Что(Лимиты.МаксЛинков()).Равно(16);
	Ожидаем.Что(Лимиты.МаксАтрибутовНаСобытие()).Равно(8);
	Ожидаем.Что(Лимиты.МаксАтрибутовНаЛинк()).Равно(4);

КонецПроцедуры

&Тест
Процедура ЛимитыСпанаСРезервомНаГлобальные() Экспорт

	// Дано - нет лимитов в провайдере, есть глобальные
	Ресурс = Новый ОтелРесурс();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();

	ГлобальныеЛимиты = Новый ОтелКонфигурацияЛимитовАтрибутов();
	ГлобальныеЛимиты.МаксКоличествоАтрибутов = 50;
	ГлобальныеЛимиты.МаксДлинаЗначенияАтрибута = 100;

	// Когда
	Провайдер = ОтелКонфигурационнаяФабрика.СоздатьПровайдерТрассировки(
		Ресурс, КонфигПровайдера, ГлобальныеЛимиты);

	// Тогда
	Лимиты = Провайдер.ЛимитыСпана();
	Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(50);
	Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(100);

КонецПроцедуры

