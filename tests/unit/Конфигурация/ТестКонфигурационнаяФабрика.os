&Тест
Процедура СоздатьПровайдерТрассировкиСTraceIdRatioСэмплером() Экспорт

	// Дано
	Ресурс = Новый ОтелРесурс();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();
	КонфигСэмплера = Новый ОтелКонфигурацияСэмплера();
	КонфигСэмплера.Тип = "trace_id_ratio_based";
	КонфигСэмплера.Доля = 0.5;
	КонфигПровайдера.Сэмплер = КонфигСэмплера;

	// Когда
	Провайдер = ОтелКонфигурационнаяФабрика.СоздатьПровайдерТрассировки(
		Ресурс, КонфигПровайдера);

	// Тогда
	Ожидаем.Что(Провайдер.СтратегияСэмплирования()).Равно(
		ОтелСэмплер.ПоДолеТрассировок());
	Ожидаем.Что(Провайдер.ДоляСэмплирования()).Равно(0.5);

КонецПроцедуры

&Тест
Процедура СоздатьПровайдерТрассировкиСParentBasedСэмплером() Экспорт

	// Дано
	Ресурс = Новый ОтелРесурс();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();
	КонфигСэмплера = Новый ОтелКонфигурацияСэмплера();
	КонфигСэмплера.Тип = "parent_based";
	КорневойСэмплер = Новый ОтелКонфигурацияСэмплера();
	КорневойСэмплер.Тип = "always_off";
	КонфигСэмплера.Корневой = КорневойСэмплер;
