	КонфигПропагатора = Новый ОтелКонфигурацияПропагатора();
	КонфигПропагатора.Составной.Добавить("tracecontext");
	КонфигПропагатора.Составной.Добавить("unknown_propagator");
	Модель.Пропагатор = КонфигПропагатора;
	Модель.ПровайдерТрассировки = Новый ОтелКонфигурацияПровайдераТрассировки();
	Модель.ПровайдерЛогирования = Новый ОтелКонфигурацияПровайдераЛогирования();
	Модель.ПровайдерМетрик = Новый ОтелКонфигурацияПровайдераМетрик();

	// Когда - неизвестный пропагатор пропускается
	Sdk = ОтелКонфигурационнаяФабрика.Создать(Модель);

	// Тогда - SDK создан, известные пропагаторы установлены
	Ожидаем.Что(ТипЗнч(Sdk)).Равно(Тип("ОтелSdk"));
	Ожидаем.Что(Sdk.Пропагаторы()).Не_().ИмеетТип("Неопределено");

КонецПроцедуры

