&Тест
Процедура СоздатьПровайдерТрассировкиСParentBasedСДелегатами() Экспорт

	// Дано - parent_based с полной конфигурацией всех 4 делегатов
	Модель = Новый ОтелКонфигурация();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();
	КонфигСэмплера = Новый ОтелКонфигурацияСэмплера();
	КонфигСэмплера.Тип = "parent_based";

	УдалСэмплСэмпл = Новый ОтелКонфигурацияСэмплера();
	УдалСэмплСэмпл.Тип = "always_on";
	КонфигСэмплера.УдаленныйРодительСэмплирован = УдалСэмплСэмпл;

	УдалСэмплНеСэмпл = Новый ОтелКонфигурацияСэмплера();
	УдалСэмплНеСэмпл.Тип = "always_off";
	КонфигСэмплера.УдаленныйРодительНеСэмплирован = УдалСэмплНеСэмпл;

	ЛокСэмплСэмпл = Новый ОтелКонфигурацияСэмплера();
	ЛокСэмплСэмпл.Тип = "always_on";
	КонфигСэмплера.ЛокальныйРодительСэмплирован = ЛокСэмплСэмпл;

	ЛокСэмплНеСэмпл = Новый ОтелКонфигурацияСэмплера();
	ЛокСэмплНеСэмпл.Тип = "always_off";
	КонфигСэмплера.ЛокальныйРодительНеСэмплирован = ЛокСэмплНеСэмпл;

	КонфигПровайдера.Сэмплер = КонфигСэмплера;
	Модель.ПровайдерТрассировки = КонфигПровайдера;
	Модель.ПровайдерЛогирования = Новый ОтелКонфигурацияПровайдераЛогирования();
	Модель.ПровайдерМетрик = Новый ОтелКонфигурацияПровайдераМетрик();

	// Когда
	Sdk = ОтелКонфигурационнаяФабрика.Создать(Модель);

	// Тогда
	Ожидаем.Что(ТипЗнч(Sdk)).Равно(Тип("ОтелSdk"));

