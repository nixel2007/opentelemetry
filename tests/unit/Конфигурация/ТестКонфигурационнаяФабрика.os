// ------------------------------------------------------------------
// Тесты модуля ОтелКонфигурационнаяФабрика
// ------------------------------------------------------------------

// ===== Создание полного SDK =====

&Тест
Процедура СоздатьМинимальныйSdk() Экспорт

	// Дано - пустая модель без провайдеров, все Неопределено
	Модель = Новый ОтелКонфигурация();

	// Когда - без провайдеров построитель должен все равно создать SDK
	Модель.ПровайдерТрассировки = Новый ОтелКонфигурацияПровайдераТрассировки();
	Модель.ПровайдерЛогирования = Новый ОтелКонфигурацияПровайдераЛогирования();
	Модель.ПровайдерМетрик = Новый ОтелКонфигурацияПровайдераМетрик();
	Sdk = ОтелКонфигурационнаяФабрика.Создать(Модель);

	// Тогда
	Ожидаем.Что(ТипЗнч(Sdk)).Равно(Тип("ОтелSdk"));
	Ожидаем.Что(Sdk.ПровайдерТрассировки()).Не_().ИмеетТип("Неопределено");
	Ожидаем.Что(Sdk.ПровайдерЛогирования()).Не_().ИмеетТип("Неопределено");
	Ожидаем.Что(Sdk.ПровайдерМетрик()).Не_().ИмеетТип("Неопределено");

КонецПроцедуры

&Тест
Процедура СоздатьНоопSdkПриОтключенномКонфиге() Экспорт

	// Дано
	Модель = Новый ОтелКонфигурация();
	Модель.Отключен = Истина;

	// Когда
	Sdk = ОтелКонфигурационнаяФабрика.Создать(Модель);

	// Тогда
	Ожидаем.Что(ТипЗнч(Sdk)).Равно(Тип("ОтелSdk"));

	Трассировщик = Sdk.ПровайдерТрассировки().ПостроительТрассировщика("test").Построить();
	Спан = Трассировщик.НачатьСпан("тест");
	Ожидаем.Что(ТипЗнч(Спан)).Равно(Тип("ОтелНезаписывающийСпан"));

КонецПроцедуры

// ===== Ресурс =====

&Тест
Процедура СоздатьРесурсИзМассиваАтрибутов() Экспорт

	// Дано
	КонфигРесурса = Новый ОтелКонфигурацияРесурса();
	Запись1 = Новый Структура("Имя, Значение", "service.name", "my-service");
	Запись2 = Новый Структура("Имя, Значение", "service.version", "1.0.0");
	КонфигРесурса.Атрибуты.Добавить(Запись1);
	КонфигРесурса.Атрибуты.Добавить(Запись2);

	// Когда
	Ресурс = ОтелКонфигурационнаяФабрика.СоздатьРесурс(КонфигРесурса);

	// Тогда
	Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("my-service");
	Ожидаем.Что(Ресурс.Атрибуты().Получить("service.version")).Равно("1.0.0");

КонецПроцедуры

&Тест
Процедура СоздатьРесурсИзСтрокиАтрибутов() Экспорт

	// Дано
	КонфигРесурса = Новый ОтелКонфигурацияРесурса();
	КонфигРесурса.СписокАтрибутов = "service.name=test,env=prod";

	// Когда
	Ресурс = ОтелКонфигурационнаяФабрика.СоздатьРесурс(КонфигРесурса);

	// Тогда
	Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("test");
	Ожидаем.Что(Ресурс.Атрибуты().Получить("env")).Равно("prod");

КонецПроцедуры

&Тест
Процедура СоздатьРесурсБезКонфига() Экспорт

	// Когда
	Ресурс = ОтелКонфигурационнаяФабрика.СоздатьРесурс();

	// Тогда
	Ожидаем.Что(ТипЗнч(Ресурс)).Равно(Тип("ОтелРесурс"));

КонецПроцедуры

// ===== Провайдер трассировки =====

&Тест
Процедура СоздатьПровайдерТрассировкиСДефолтами() Экспорт

	// Дано
	Ресурс = Новый ОтелРесурс();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();

	// Когда
	Провайдер = ОтелКонфигурационнаяФабрика.СоздатьПровайдерТрассировки(
		Ресурс, КонфигПровайдера);

	// Тогда
	Ожидаем.Что(ТипЗнч(Провайдер)).Равно(Тип("ОтелПровайдерТрассировки"));
	// Сэмплер по умолчанию - parent_based
	Ожидаем.Что(Провайдер.СтратегияСэмплирования()).Равно(
		ОтелСэмплер.НаОсновеРодителя());
	Ожидаем.Что(Провайдер.КорневаяСтратегия()).Равно(
		ОтелСэмплер.ВсегдаВключен());

КонецПроцедуры

&Тест
Процедура СоздатьПровайдерТрассировкиСAlwaysOnСэмплером() Экспорт

