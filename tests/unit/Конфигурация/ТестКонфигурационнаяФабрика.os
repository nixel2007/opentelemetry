&Тест
Процедура ПровайдерЛогированияСГлобальнымиЛимитами() Экспорт

	// Дано - глобальные лимиты атрибутов без специфичных для провайдера (строки 484-485, 496-497)
	Модель = Новый ОтелКонфигурация();
	КонфигГлобЛимитов = Новый ОтелКонфигурацияЛимитовАтрибутов();
	КонфигГлобЛимитов.МаксКоличествоАтрибутов = 100;
	КонфигГлобЛимитов.МаксДлинаЗначенияАтрибута = 500;
	Модель.ЛимитыАтрибутов = КонфигГлобЛимитов;
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераЛогирования();
	// КонфигПровайдера.Лимиты = Неопределено (по умолчанию) → используются глобальные лимиты
	Модель.ПровайдерЛогирования = КонфигПровайдера;
	Модель.ПровайдерТрассировки = Новый ОтелКонфигурацияПровайдераТрассировки();

	// Когда
	Sdk = ОтелКонфигурационнаяФабрика.Создать(Модель);

	// Тогда
	Ожидаем.Что(ТипЗнч(Sdk)).Равно(Тип("ОтелSdk"));

КонецПроцедуры
