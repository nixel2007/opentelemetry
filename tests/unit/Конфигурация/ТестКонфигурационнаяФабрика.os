// ===== Провайдер трассировки =====

&Тест
Процедура СоздатьПровайдерТрассировкиСДефолтами() Экспорт

	// Дано
	Ресурс = Новый ОтелРесурс();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();

	// Когда
	Провайдер = ОтелКонфигурационнаяФабрика.СоздатьПровайдерТрассировки(
		Ресурс, КонфигПровайдера);

	// Тогда
	Ожидаем.Что(ТипЗнч(Провайдер)).Равно(Тип("ОтелПровайдерТрассировки"));
	// Сэмплер по умолчанию - parent_based
	Ожидаем.Что(Провайдер.СтратегияСэмплирования()).Равно(
		ОтелСэмплер.НаОсновеРодителя());
	Ожидаем.Что(Провайдер.КорневаяСтратегия()).Равно(
		ОтелСэмплер.ВсегдаВключен());

КонецПроцедуры

&Тест
Процедура СоздатьПровайдерТрассировкиСAlwaysOnСэмплером() Экспорт

	// Дано
	Ресурс = Новый ОтелРесурс();
	КонфигПровайдера = Новый ОтелКонфигурацияПровайдераТрассировки();
	КонфигСэмплера = Новый ОтелКонфигурацияСэмплера();
	КонфигСэмплера.Тип = "always_on";
	КонфигПровайдера.Сэмплер = КонфигСэмплера;

	// Когда
	Провайдер = ОтелКонфигурационнаяФабрика.СоздатьПровайдерТрассировки(
		Ресурс, КонфигПровайдера);

	// Тогда
	Ожидаем.Что(Провайдер.СтратегияСэмплирования()).Равно(
		ОтелСэмплер.ВсегдаВключен());

КонецПроцедуры

