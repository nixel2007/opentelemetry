&Тест
Процедура ЗаписьБезИмениСобытияНеДобавляетсяВСпан() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Провайдер = Новый ОтелПровайдерТрассировки();
    Трассировщик = Провайдер.ПолучитьТрассировщик("тест");
    Спан = Трассировщик.НачатьСпан("active");
    Токен = ОтелКонтекст.СделатьСпанТекущим(Спан);

    Процессор = Новый ОтелПроцессорСобытийВSpanEvents();
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("просто лог");

    // Когда
    Процессор.ПриПоявлении(Запись);

    // Тогда
    Ожидаем.Что(Спан.События().Количество()).Равно(0);

    ОтелКонтекст.ОтсоединитьКонтекст(Токен);
    Спан.Завершить();

КонецПроцедуры

&Тест
Процедура ЗаписьСИменемСобытияДобавляетсяКаКSpanEvent() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Провайдер = Новый ОтелПровайдерТрассировки();
    Трассировщик = Провайдер.ПолучитьТрассировщик("тест");
    Спан = Трассировщик.НачатьСпан("active");
    Токен = ОтелКонтекст.СделатьСпанТекущим(Спан);

    Процессор = Новый ОтелПроцессорСобытийВSpanEvents();
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("user.id", "42");

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьИмяСобытия("user.signed_in");
    Запись.УстановитьАтрибут("user.id", "42");

    // Когда
    Процессор.ПриПоявлении(Запись);

    // Тогда
    События = Спан.События();
    Ожидаем.Что(События.Количество()).Равно(1);
    Ожидаем.Что(События[0].Имя()).Равно("user.signed_in");

    ОтелКонтекст.ОтсоединитьКонтекст(Токен);
    Спан.Завершить();

КонецПроцедуры

&Тест
Процедура ЗаписьБезАктивногоСпанаПропускается() Экспорт

    // Дано
    ОтелКонтекст.Очистить();

    Процессор = Новый ОтелПроцессорСобытийВSpanEvents();
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьИмяСобытия("orphan");

    // Когда / Тогда — не должно быть исключений
    Процессор.ПриПоявлении(Запись);

КонецПроцедуры

&Тест
Процедура ПослеЗакрытьЗаписиИгнорируются() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Провайдер = Новый ОтелПровайдерТрассировки();
    Трассировщик = Провайдер.ПолучитьТрассировщик("тест");
    Спан = Трассировщик.НачатьСпан("active");
    Токен = ОтелКонтекст.СделатьСпанТекущим(Спан);

    Процессор = Новый ОтелПроцессорСобытийВSpanEvents();
    Процессор.Закрыть();

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьИмяСобытия("after.close");

    // Когда
    Процессор.ПриПоявлении(Запись);

    // Тогда
    Ожидаем.Что(Спан.События().Количество()).Равно(0);
    Ожидаем.Что(Процессор.Включен()).Равно(Ложь);

    ОтелКонтекст.ОтсоединитьКонтекст(Токен);
    Спан.Завершить();

КонецПроцедуры
