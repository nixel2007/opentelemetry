// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура СозданиеЗаписи() Экспорт

    // Дано / Когда
    ОтелКонтекст.Очистить();
    Запись = Новый ОтелЗаписьЛога();

    // Тогда — проверяем значения по умолчанию
    Ожидаем.Что(Запись.НомерСерьезности()).Равно(ОтелСтепеньСерьезности.Info());
    Ожидаем.Что(Запись.ТекстСерьезности()).Равно("INFO");
    Ожидаем.Что(Запись.Тело()).Равно("");
    Ожидаем.Что(Запись.ИдТрассировки()).Равно("");
    Ожидаем.Что(Запись.ИдСпана()).Равно("");
    Ожидаем.Что(Запись.Атрибуты().Количество()).Равно(0);
    Ожидаем.Что(Запись.Время() <> "").Равно(Истина);
    Ожидаем.Что(Запись.ВремяНаблюдения() <> "").Равно(Истина);

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура УстановкаТела() Экспорт

    // Дано
    Запись = Новый ОтелЗаписьЛога();

    // Когда
    Результат = Запись.УстановитьТело("test message");

    // Тогда
    Ожидаем.Что(Запись.Тело()).Равно("test message");
    // Fluent API — возвращает тот же объект
    Ожидаем.Что(Результат).Равно(Запись);

КонецПроцедуры

&Тест
Процедура УстановкаСерьезности() Экспорт

    // Дано
    Запись = Новый ОтелЗаписьЛога();

    // Когда
    Запись.УстановитьСерьезность(ОтелСтепеньСерьезности.Error());

    // Тогда
    Ожидаем.Что(Запись.НомерСерьезности()).Равно(17);
    Ожидаем.Что(Запись.ТекстСерьезности()).Равно("ERROR");

КонецПроцедуры

&Тест
Процедура УстановкаАтрибутов() Экспорт

    // Дано
    Запись = Новый ОтелЗаписьЛога();

    // Когда
    Запись.УстановитьАтрибут("key1", "value1")
        .УстановитьАтрибут("key2", 42)
        .УстановитьАтрибут("key3", Истина);

    // Тогда
    Ожидаем.Что(Запись.Атрибуты().Количество()).Равно(3);
    Ожидаем.Что(Запись.Атрибуты().Получить("key1")).Равно("value1");
    Ожидаем.Что(Запись.Атрибуты().Получить("key2")).Равно(42);
    Ожидаем.Что(Запись.Атрибуты().Получить("key3")).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КорреляцияСТрассировкой() Экспорт

    // Дано
    Запись = Новый ОтелЗаписьЛога();
    ИдТрассировки = "0af7651916cd43dd8448eb211c80319c";
    ИдСпана = "b7ad6b7169203331";

    // Когда
    Запись.УстановитьКонтекстТрассировки(ИдТрассировки, ИдСпана);

    // Тогда
    Ожидаем.Что(Запись.ИдТрассировки()).Равно(ИдТрассировки);
    Ожидаем.Что(Запись.ИдСпана()).Равно(ИдСпана);

КонецПроцедуры

&Тест
Процедура ЛимитАтрибутов() Экспорт

    // Дано — лимит 2 атрибута
    Лимиты = Новый ОтелЛимитыЗаписейЛога()
        .УстановитьМаксАтрибутов(2);
    Запись = Новый ОтелЗаписьЛога(Лимиты);

    // Когда — добавляем 3
    Запись.УстановитьАтрибут("a", 1);
    Запись.УстановитьАтрибут("b", 2);
    Запись.УстановитьАтрибут("c", 3);

    // Тогда — только 2
    Ожидаем.Что(Запись.Атрибуты().Количество()).Равно(2);
    Ожидаем.Что(Запись.Атрибуты().Получить("a")).Равно(1);
    Ожидаем.Что(Запись.Атрибуты().Получить("b")).Равно(2);
    Ожидаем.Что(Запись.Атрибуты().Получить("c")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ОбрезкаЗначенийАтрибутов() Экспорт

    // Дано — усечение до 5 символов
    Лимиты = Новый ОтелЛимитыЗаписейЛога()
        .УстановитьМаксДлинаЗначенияАтрибута(5);
    Запись = Новый ОтелЗаписьЛога(Лимиты);

    // Когда
    Запись.УстановитьАтрибут("short", "abc");
    Запись.УстановитьАтрибут("long", "abcdefghij");
    Запись.УстановитьАтрибут("number", 12345);

    // Тогда
    Ожидаем.Что(Запись.Атрибуты().Получить("short")).Равно("abc");
    Ожидаем.Что(Запись.Атрибуты().Получить("long")).Равно("abcde");
    Ожидаем.Что(Запись.Атрибуты().Получить("number")).Равно(12345);

КонецПроцедуры

&Тест
Процедура ПерезаписьАтрибута() Экспорт

    // Дано — лимит 2 атрибута
    Лимиты = Новый ОтелЛимитыЗаписейЛога()
        .УстановитьМаксАтрибутов(2);
    Запись = Новый ОтелЗаписьЛога(Лимиты);

    // Когда — 2 атрибута, потом перезаписываем первый
    Запись.УстановитьАтрибут("a", "old");
    Запись.УстановитьАтрибут("b", "value");
    Запись.УстановитьАтрибут("a", "new");

    // Тогда — всё ещё 2, значение обновлено
    Ожидаем.Что(Запись.Атрибуты().Количество()).Равно(2);
    Ожидаем.Что(Запись.Атрибуты().Получить("a")).Равно("new");
    Ожидаем.Что(Запись.Атрибуты().Получить("b")).Равно("value");

КонецПроцедуры
