    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    // Когда
    КомпозитныйПроцессор.СброситьБуфер();

    // Тогда - оба процессора получили вызов СброситьБуфер
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().СброситьБуфер(Матчеры.ЛюбоеЗначение());

КонецПроцедуры

&Тест
Процедура ОшибкаПервогоПроцессораНеПрерываетВторой() Экспорт

    // Дано - первый процессор бросает исключение
    ОтелКонтекст.Очистить();
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор1.Когда().ПриПоявлении(Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("тестовая ошибка");
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("тест");

    // Когда - обрабатываем запись (первый процессор бросит ошибку)
    КомпозитныйПроцессор.ПриПоявлении(Запись);

    // Тогда - второй процессор всё равно получил вызов
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().ПриПоявлении(Матчеры.ЛюбоеЗначение());

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура КомпозитВключенЕслиЕстьПроцессоры() Экспорт

    // Дано
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор1.Когда().Включен().ТогдаВозвращает(Истина);
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    // Когда / Тогда
    Ожидаем.Что(КомпозитныйПроцессор.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура КомпозитВыключенЕслиНетПроцессоров() Экспорт

    // Дано
    Процессоры = Новый Массив();
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    // Когда / Тогда
    Ожидаем.Что(КомпозитныйПроцессор.Включен()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура НулевойТаймаут() Экспорт

	// Дано
	МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
	Процессоры = Новый Массив();
	Процессоры.Добавить(МокПроцессор);
	КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

	// Когда - закрытие с нулевым таймаутом
	Результат = КомпозитныйПроцессор.Закрыть(0);

	// Тогда - завершился успешно
	Ожидаем.Что(Результат.Успешно()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ВключенИсключениеПроцессора() Экспорт
    // Дано - процессор не реализует Включен() - бросает исключение
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор.Когда().Включен(
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()
    ).ТогдаВыбрасываетИсключение("метод не реализован");
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    // Когда / Тогда - исключение поглощается, возвращает Истина
    Ожидаем.Что(КомпозитныйПроцессор.Включен()).Равно(Истина);
КонецПроцедуры

&Тест
Процедура СброситьБуферОшибкаПроцессора() Экспорт
    // Дано - процессор возвращает Ошибка()
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение()).ТогдаВозвращает(ОтелРезультатыЭкспорта.Ошибка());
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    // Когда
    Результат = КомпозитныйПроцессор.СброситьБуфер();

    // Тогда - итоговый результат Ошибка
    Ожидаем.Что(Результат.Успешно()).ЭтоЛожь();
КонецПроцедуры

