&Тест
Процедура ДелегацияОбработки() Экспорт

    // Дано - два мок-процессора
    ОтелКонтекст.Очистить();
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("composite test");

    // Когда
    КомпозитныйПроцессор.Обработать(Запись);

    // Тогда - оба процессора получили вызов Обработать
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().Обработать(
        Матчеры.ЛюбоеЗначение()
    );
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().Обработать(
        Матчеры.ЛюбоеЗначение()
    );

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ДелегацияЗакрытия() Экспорт

    // Дано - два мок-процессора
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    // Когда
    КомпозитныйПроцессор.Закрыть();

    // Тогда - оба процессора получили вызов Закрыть
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().Закрыть();
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().Закрыть();

КонецПроцедуры

&Тест
Процедура ДелегацияСбросаБуфера() Экспорт

    // Дано - два мок-процессора
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    // Когда
    КомпозитныйПроцессор.СброситьБуфер();

    // Тогда - оба процессора получили вызов СброситьБуфер
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().СброситьБуфер();
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().СброситьБуфер();

КонецПроцедуры

&Тест
Процедура ОшибкаПервогоПроцессораНеПрерываетВторой() Экспорт

    // Дано - первый процессор бросает исключение
    ОтелКонтекст.Очистить();
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор1.Когда().Обработать(Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("тестовая ошибка");
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор1);
    Процессоры.Добавить(МокПроцессор2);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("тест");

    // Когда - обрабатываем запись (первый процессор бросит ошибку)
    КомпозитныйПроцессор.Обработать(Запись);

    // Тогда - второй процессор всё равно получил вызов
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().Обработать(Матчеры.ЛюбоеЗначение());

    ОтелКонтекст.Очистить();

КонецПроцедуры
