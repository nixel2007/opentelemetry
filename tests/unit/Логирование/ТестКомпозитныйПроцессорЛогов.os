КонецПроцедуры

&Тест
Процедура ЗакрытьТаймаут() Экспорт
    // Дано - первый процессор медленный (больше таймаута)
    ПутьКФикстуре = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures", "МедленныйПроцессорЛогов.os");
    МедленныйПроцессор = ЗагрузитьСценарий(ПутьКФикстуре);
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МедленныйПроцессор);
    Процессоры.Добавить(МокПроцессор2);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    // Когда - закрываем с таймаутом 1мс
    Результат = КомпозитныйПроцессор.Закрыть(1);

    // Тогда - превышен таймаут
    Ожидаем.Что(Результат.Успешно()).ЭтоЛожь();
КонецПроцедуры

&Тест
Процедура ЗакрытьИсключениеПроцессора() Экспорт
    // Дано - процессор бросает исключение в Закрыть
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор.Когда().Закрыть(Матчеры.ЛюбоеЗначение()).ТогдаВыбрасываетИсключение("тест: ошибка закрытия");
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Процессоры = Новый Массив();
    Процессоры.Добавить(МокПроцессор);
    Процессоры.Добавить(МокПроцессор2);
    КомпозитныйПроцессор = Новый ОтелКомпозитныйПроцессорЛогов(Процессоры);

    // Когда - не должно выбрасывать исключение
    Результат = КомпозитныйПроцессор.Закрыть();

    // Тогда - успешно (исключение поглощено)
    Ожидаем.Что(Результат.Успешно()).ЭтоИстина();
КонецПроцедуры
