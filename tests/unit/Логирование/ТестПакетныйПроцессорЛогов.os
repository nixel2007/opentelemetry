#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура Буферизация() Экспорт

    // Дано - МаксРазмерПакета = 10, чтобы не сработал автоэкспорт
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПакетныйПроцессорЛогов(МокЭкспортер, 2048, 10);
    Ресурс = Новый ОтелРесурс(Истина);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("buffered");

    // Когда - добавляем одну запись (меньше МаксРазмерПакета)
    Процессор.Обработать(Запись, Ресурс, "test-lib", "1.0");

    // Тогда - экспортер НЕ вызван (буфер не заполнен)
    Попытка
        МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
            Матчеры.ЛюбоеЗначение(),
            Матчеры.ЛюбоеЗначение(),
            Матчеры.ЛюбоеЗначение(),
            Матчеры.ЛюбоеЗначение()
        );
        // Если не выбросилось исключение - экспортер был вызван, тест не прошёл
        Ожидаем.Что(Истина).Равно(Ложь);
    Исключение
        // Ожидаемо - экспортер не вызывался
    КонецПопытки;

    Процессор.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура СброситьБуфер() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПакетныйПроцессорЛогов(МокЭкспортер, 2048, 100);
    Ресурс = Новый ОтелРесурс(Истина);

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("flush test");
    Процессор.Обработать(Запись, Ресурс, "test-lib", "1.0");

    // Когда - принудительно сбрасываем буфер
    Процессор.СброситьБуфер();

    // Тогда - экспортер вызван
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    );

    Процессор.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПакетныйПроцессорЛогов(МокЭкспортер, 2048, 100);
    Ресурс = Новый ОтелРесурс(Истина);

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("close test");
    Процессор.Обработать(Запись, Ресурс, "test-lib", "1.0");

    // Когда - закрываем процессор
    Процессор.Закрыть();

    // Тогда - оставшиеся записи экспортированы
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    );

    ОтелКонтекст.Очистить();

КонецПроцедуры
