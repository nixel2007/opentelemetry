&Тест
Процедура БазовыйПроцессор_ЗакрытьТаймаутЭкспорта() Экспорт
    // Дано - медленный экспортер, большой пакет чтобы не было автоэкспорта
    ОтелКонтекст.Очистить();
    ПутьКФикстуре = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures", "МедленныйЭкспортерЛогов.os");
    МедленныйЭкспортер = ЗагрузитьСценарий(ПутьКФикстуре);
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МедленныйЭкспортер, "logs", 2048, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    // Добавляем 2 записи — нет автоэкспорта (2 < 100)
    Запись1 = Новый ОтелЗаписьЛога();
    Запись1.УстановитьТело("запись-1");
    Процессор.ПриПоявлении(Запись1);
    Запись2 = Новый ОтелЗаписьЛога();
    Запись2.УстановитьТело("запись-2");
    Процессор.ПриПоявлении(Запись2);

    // Когда - закрываем с таймаутом 1мс (экспортер спит 200мс → второй проход цикла превысит таймаут)
    Результат = Процессор.Закрыть(1);

    // Тогда - превышен таймаут
    Ожидаем.Что(Результат.Успешно()).ЭтоЛожь();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура БазовыйПроцессор_ЗакрытьОшибкаЭкспорта() Экспорт
    // Дано - экспортер бросает исключение при Экспортировать
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    МокЭкспортер.Когда().Экспортировать(
        Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение()
    ).ТогдаВыбрасываетИсключение("тест: ошибка экспорта при закрытии");
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    // Добавляем запись чтобы был финальный экспорт
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("error export");
    Процессор.ПриПоявлении(Запись);

    // Когда - закрываем
    Результат = Процессор.Закрыть();

    // Тогда - ошибка
    Ожидаем.Что(Результат.Успешно()).ЭтоЛожь();
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура БазовыйПроцессор_ПринудительноВыгрузитьТаймаут() Экспорт
    // Дано - медленный экспортер, большой пакет чтобы не было автоэкспорта
    ОтелКонтекст.Очистить();
    ПутьКФикстуре = ОбъединитьПути(ТекущийСценарий().Каталог, "fixtures", "МедленныйЭкспортерЛогов.os");
    МедленныйЭкспортер = ЗагрузитьСценарий(ПутьКФикстуре);
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МедленныйЭкспортер, "logs", 2048, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    // Добавляем 2 записи — нет автоэкспорта (2 < 100)
    Запись1 = Новый ОтелЗаписьЛога();
    Запись1.УстановитьТело("запись-1");
    Процессор.ПриПоявлении(Запись1);
    Запись2 = Новый ОтелЗаписьЛога();
    Запись2.УстановитьТело("запись-2");
    Процессор.ПриПоявлении(Запись2);

    // Когда - принудительная выгрузка с таймаутом 1мс (экспортер спит 200мс → второй проход цикла превысит таймаут)
    Результат = Процессор.ПринудительноВыгрузитьСРезультатом(1);

    // Тогда - превышен таймаут
    Ожидаем.Что(Результат.Успешно()).ЭтоЛожь();

    Процессор.Закрыть();
    ОтелКонтекст.Очистить();
КонецПроцедуры
