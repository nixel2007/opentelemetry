&Тест
Процедура Буферизация() Экспорт

    // Дано - МаксРазмерПакета = 10, чтобы не сработал автоэкспорт
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 10);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("buffered");

    // Когда - добавляем одну запись (меньше МаксРазмерПакета)
    Процессор.ПриПоявлении(Запись);

    // Тогда - экспортер НЕ вызван (буфер не заполнен)
    // BSLLS:MissingCodeTryCatchEx-off
    Попытка
        МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
            Матчеры.ЛюбоеЗначение()
        );
        // Если не выбросилось исключение - экспортер был вызван, тест не прошёл
        Ожидаем.Что(Истина).Равно(Ложь);
    Исключение
        // Ожидаемо - экспортер не вызывался
    КонецПопытки;

    Процессор.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура СброситьБуфер() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("flush test");
    Процессор.ПриПоявлении(Запись);

    // Когда - принудительно сбрасываем буфер
    Процессор.СброситьБуфер();

    // Тогда - экспортер вызван
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
        Матчеры.ЛюбоеЗначение()
    );

    Процессор.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("close test");
    Процессор.ПриПоявлении(Запись);

    // Когда - закрываем процессор
    Процессор.Закрыть();

    // Тогда - оставшиеся записи экспортированы
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    );

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ЭкспортПриДостиженииРазмераПакета() Экспорт

    // Дано - маленький размер пакета (2), чтобы автоматически запустить экспорт
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 2);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    // Когда - добавляем 2 записи (равно размеру пакета)
    Для Сч = 1 По 2 Цикл
        Запись = Новый ОтелЗаписьЛога();
        Запись.УстановитьТело("запись-" + Сч);
        Процессор.ПриПоявлении(Запись);
    КонецЦикла;

    // Тогда - экспорт вызван автоматически
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
        Матчеры.ЛюбоеЗначение()
    );

    Процессор.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ЧастичныйЭкспортБольшогоБуфера() Экспорт

    // Дано - размер пакета 2, но добавим 3 записи
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 2);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    // Добавляем 3 записи - при 2-й вызовется авто-экспорт
    Для Сч = 1 По 3 Цикл
        Запись = Новый ОтелЗаписьЛога();
        Запись.УстановитьТело("запись-" + Сч);
        Процессор.ПриПоявлении(Запись);
    КонецЦикла;

    // Когда - сбрасываем остаток
    Процессор.СброситьБуфер();

    Процессор.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ОбработкаПослеЗакрытия() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    Процессор.Закрыть();

    // Когда - обработка записи после закрытия
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("after close");
    Процессор.ПриПоявлении(Запись);

    // Тогда - ничего не падает
    Ожидаем.Что(Истина).Равно(Истина);
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ПовторныйЗапускФоновогоЭкспорта() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 100, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    // Когда - двойной запуск
    Процессор.ЗапуститьФоновыйЭкспорт();
    Процессор.ЗапуститьФоновыйЭкспорт(); // повторный вызов - должен быть безопасен

    // Тогда - без ошибок
    Ожидаем.Что(Истина).Равно(Истина);

    Процессор.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ОшибкаЭкспортера() Экспорт

    // Дано - экспортер бросает исключение при вызове
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    МокЭкспортер.Когда().Экспортировать(
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВыбрасываетИсключение("тест: ошибка экспорта логов");
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("error test");
    Процессор.ПриПоявлении(Запись);

    // Когда - сброс вызывает экспорт, который падает
    Процессор.СброситьБуфер();

    // Тогда - ошибка обработана, процессор не сломался
    Процессор.Закрыть();
    Ожидаем.Что(Истина).Равно(Истина);
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ФоновыйПериодическийЭкспорт() Экспорт

    // Дано - короткий интервал для быстрого срабатывания
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 2048, 100, 100);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("background test");
    Процессор.ПриПоявлении(Запись);

    // Когда - запускаем фоновый экспорт и ждем его срабатывания
    Процессор.ЗапуститьФоновыйЭкспорт();
    Приостановить(300);

    // Тогда - закрываем, фоновый экспорт должен остановиться
    Процессор.Закрыть();
    Ожидаем.Что(Истина).Равно(Истина);
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура СчетчикОтброшенныхЗаписей() Экспорт

    // Дано - буфер на 3 записи
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "logs", 3, 1000, 60000);
    Процессор = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорЛогов(), Базовый).Построить();

    // Когда - добавляем 5 записей (буфер вместит только 3)
    Для Сч = 1 По 5 Цикл
        Запись = Новый ОтелЗаписьЛога();
        Запись.УстановитьТело("запись-" + Сч);
        Процессор.ПриПоявлении(Запись);
    КонецЦикла;

    // Тогда - 2 записи отброшены
    Ожидаем.Что(Процессор.КоличествоОтброшенных()).Равно(2);

    Процессор.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

