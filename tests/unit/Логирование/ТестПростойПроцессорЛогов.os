#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура ОбработкаЗаписи() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("test message");

    // Когда
    Процессор.ПриПоявлении(Запись);

    // Тогда - экспортер вызван с массивом записей
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
        Матчеры.ЛюбоеЗначение()
    );

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда
    Процессор.Закрыть();

    // Тогда - per spec: Shutdown MUST call Exporter.Shutdown
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Закрыть();

КонецПроцедуры

&Тест
Процедура ВключенВозвращаетИстину() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда / Тогда - по умолчанию процессор включен
    Ожидаем.Что(Процессор.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОшибкаЭкспортераНеПробрасывается() Экспорт

    // Дано - экспортер выбрасывает исключение
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    МокЭкспортер.Когда().Экспортировать(Матчеры.ЛюбоеЗначение())
        .ТогдаВыбрасываетИсключение("тест: ошибка экспорта логов");
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("test message");

    // Когда / Тогда - вызов не должен пробрасывать исключение
    ИсключениеПойманоНеожиданно = Ложь;
    Попытка
        Процессор.ПриПоявлении(Запись);
    Исключение
        ИсключениеПойманоНеожиданно = Истина;
    КонецПопытки;
    Ожидаем.Что(ИсключениеПойманоНеожиданно).Равно(Ложь);

    // И повторный вызов также безопасен (блокировка корректно освобождена)
    Попытка
        Процессор.ПриПоявлении(Запись);
    Исключение
        ИсключениеПойманоНеожиданно = Истина;
    КонецПопытки;
    Ожидаем.Что(ИсключениеПойманоНеожиданно).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЗакрытьУспех() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда
    Результат = Процессор.Закрыть();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Закрыть();

КонецПроцедуры

&Тест
Процедура ЗакрытьДваждыИдемпотентно() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда
    Результат1 = Процессор.Закрыть();
    Результат2 = Процессор.Закрыть();

    // Тогда - оба успешны (идемпотентно)
    Ожидаем.Что(Результат1.Успешно()).Равно(Истина);
    Ожидаем.Что(Результат2.Успешно()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура СтарыйЗакрытьРаботает() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда - старая процедура без возврата значения
    Процессор.Закрыть();

    // Тогда - экспортер закрыт
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Закрыть();

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьСРезультатом() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда
    Результат = Процессор.ПринудительноВыгрузитьСРезультатом();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьПослеЗакрытияВозвращаетОшибку() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);
    Процессор.Закрыть();

    // Когда
    Результат = Процессор.ПринудительноВыгрузитьСРезультатом();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Ожидаем.Что(Результат.Описание()).Равно("Процессор закрыт");

КонецПроцедуры

&Тест
Процедура ПриПоявленииБезЭкспортера() Экспорт
    // Дано - процессор без экспортера
    Процессор = Новый ОтелПростойПроцессорЛогов(Неопределено);
    Запись = Новый ОтелЗаписьЛога();

    // Когда / Тогда - не бросает исключение
    Процессор.ПриПоявлении(Запись);
КонецПроцедуры

&Тест
Процедура СброситьБуферБезЭкспортера() Экспорт
    // Дано
    Процессор = Новый ОтелПростойПроцессорЛогов(Неопределено);

    // Когда
    Результат = Процессор.СброситьБуфер();

    // Тогда - возвращает успех
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
КонецПроцедуры

&Тест
Процедура ЗакрытьБезЭкспортера() Экспорт
    // Дано
    Процессор = Новый ОтелПростойПроцессорЛогов(Неопределено);

    // Когда
    Результат = Процессор.Закрыть();

    // Тогда - возвращает успех
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
КонецПроцедуры
