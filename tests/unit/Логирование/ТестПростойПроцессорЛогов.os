    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
КонецПроцедуры

&Тест
Процедура ЗакрытьБезЭкспортера() Экспорт
    // Дано
    Процессор = Новый ОтелПростойПроцессорЛогов(Неопределено);

    // Когда
    Результат = Процессор.Закрыть();

