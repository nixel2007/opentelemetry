    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
КонецПроцедуры

&Тест
Процедура ПриПоявленииПослеЗакрытияИгнорирует() Экспорт
    // Дано - spy-экспортер, считающий вызовы
    ТекстСпая =
        "Перем Вызовы Экспорт;" + Символы.ПС
        + "Процедура ПриСозданииОбъекта()" + Символы.ПС
        + "    Вызовы = 0;" + Символы.ПС
        + "КонецПроцедуры" + Символы.ПС
        + "Процедура Экспортировать(Записи) Экспорт" + Символы.ПС
        + "    Вызовы = Вызовы + 1;" + Символы.ПС
        + "КонецПроцедуры" + Символы.ПС
        + "Функция СброситьБуфер(ТаймаутМс = 0) Экспорт" + Символы.ПС
        + "    Возврат Неопределено;" + Символы.ПС
        + "КонецФункции" + Символы.ПС
        + "Функция Закрыть(ТаймаутМс = 30000) Экспорт" + Символы.ПС
        + "    Возврат Неопределено;" + Символы.ПС
        + "КонецФункции";
    СпайЭкспортер = ЗагрузитьСценарийИзСтроки(ТекстСпая);
    Процессор = Новый ОтелПростойПроцессорЛогов(СпайЭкспортер);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("test");
    Процессор.Закрыть();

    // Когда - вызов ПриПоявлении на закрытом процессоре
    Процессор.ПриПоявлении(Запись);

    // Тогда - экспортер НЕ должен быть вызван
    Ожидаем.Что(СпайЭкспортер.Вызовы).Равно(0);
КонецПроцедуры

&Тест
Процедура ЗакрытьЕслиЭкспортерВыбрасываетИсключение() Экспорт
    // Дано - экспортер выбрасывает исключение при закрытии
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    МокЭкспортер.Когда().Закрыть().ТогдаВыбрасываетИсключение("тест: ошибка закрытия");
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда
    Результат = Процессор.Закрыть();

    // Тогда - возвращает ошибку вместо исключения
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьЕслиСброситьВызываетИсключение() Экспорт
    // Дано - экспортер выбрасывает исключение при СброситьБуфер
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    МокЭкспортер.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение())
        .ТогдаВыбрасываетИсключение("тест: ошибка сброса");
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда
    Результат = Процессор.ПринудительноВыгрузитьСРезультатом();

    // Тогда - возвращает ошибку
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьЕслиТаймаут() Экспорт
    // Дано - экспортер возвращает таймаут
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    МокЭкспортер.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение())
        .ТогдаВозвращает(ОтелРезультатыЭкспорта.Таймаут());
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда
    Результат = Процессор.ПринудительноВыгрузитьСРезультатом();

    // Тогда - возвращает ИзТаймаута
    Ожидаем.Что(Результат.ИстекТаймаут()).Равно(Истина);
КонецПроцедуры

&Тест
Процедура ПринудительноВыгрузитьЕслиОшибка() Экспорт
    // Дано - экспортер возвращает ошибку
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    МокЭкспортер.Когда().СброситьБуфер(Матчеры.ЛюбоеЗначение())
        .ТогдаВозвращает(ОтелРезультатыЭкспорта.Ошибка());
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда
    Результат = Процессор.ПринудительноВыгрузитьСРезультатом();

    // Тогда - возвращает ошибку
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
КонецПроцедуры
