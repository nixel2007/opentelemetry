// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура ОбработкаЗаписи() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("test message");

    // Когда
    Процессор.ПриПоявлении(Запись);

    // Тогда - экспортер вызван с массивом записей
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Экспортировать(
        Матчеры.ЛюбоеЗначение()
    );

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда
    Процессор.Закрыть();

    // Тогда - per spec: Shutdown MUST call Exporter.Shutdown
    МокЭкспортер.ПроверитьЧтоВызывалсяМетод().Закрыть();

КонецПроцедуры

&Тест
Процедура ВключенВозвращаетИстину() Экспорт

    // Дано
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);

    // Когда / Тогда - по умолчанию процессор включен
    Ожидаем.Что(Процессор.Включен()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ОшибкаЭкспортераНеПробрасывается() Экспорт

    // Дано - экспортер выбрасывает исключение
    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерЛогов"));
    МокЭкспортер.Когда().Экспортировать(Матчеры.ЛюбоеЗначение())
        .ТогдаВыбрасываетИсключение("тест: ошибка экспорта логов");
    Процессор = Новый ОтелПростойПроцессорЛогов(МокЭкспортер);
    Запись = Новый ОтелЗаписьЛога();
    Запись.УстановитьТело("test message");

    // Когда / Тогда - вызов не должен пробрасывать исключение
    ИсключениеПойманоНеожиданно = Ложь;
    Попытка
        Процессор.ПриПоявлении(Запись);
    Исключение
        ИсключениеПойманоНеожиданно = Истина;
    КонецПопытки;
    Ожидаем.Что(ИсключениеПойманоНеожиданно).Равно(Ложь);

    // И повторный вызов также безопасен (блокировка корректно освобождена)
    Попытка
        Процессор.ПриПоявлении(Запись);
    Исключение
        ИсключениеПойманоНеожиданно = Истина;
    КонецПопытки;
    Ожидаем.Что(ИсключениеПойманоНеожиданно).Равно(Ложь);

КонецПроцедуры
