// BSLLS:MagicNumber-off
#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура ДефолтныеЛимиты() Экспорт

    // Дано / Когда
    Лимиты = Новый ОтелЛимитыЗаписейЛога();

    // Тогда
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(128);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(0);

КонецПроцедуры

&Тест
Процедура УстановкаЛимитов() Экспорт

    // Дано
    Лимиты = Новый ОтелЛимитыЗаписейЛога();

    // Когда
    Лимиты.УстановитьМаксАтрибутов(50);
    Лимиты.УстановитьМаксДлинаЗначенияАтрибута(256);

    // Тогда
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(50);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(256);

КонецПроцедуры

&Тест
Процедура FluentAPI() Экспорт

    // Дано / Когда - цепочка вызовов
    Лимиты = Новый ОтелЛимитыЗаписейЛога()
        .УстановитьМаксАтрибутов(64)
        .УстановитьМаксДлинаЗначенияАтрибута(1024);

    // Тогда
    Ожидаем.Что(Лимиты.МаксАтрибутов()).Равно(64);
    Ожидаем.Что(Лимиты.МаксДлинаЗначенияАтрибута()).Равно(1024);

КонецПроцедуры
