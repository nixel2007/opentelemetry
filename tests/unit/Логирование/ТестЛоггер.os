&Тест
Процедура СоздатьЗаписьЛога() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнстр = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Логгер = Новый ОтелЛоггер(ОбластьИнстр, Ресурс);

    // Когда
    Запись = Логгер.СоздатьЗаписьЛога();

    // Тогда
    Ожидаем.Что(Запись <> Неопределено).Равно(Истина);
    Ожидаем.Что(Запись.Тело()).Равно("");
    Ожидаем.Что(Запись.НомерСерьезности()).Равно(ОтелСтепеньСерьезности.Info());

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура Записать() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнстр = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Логгер = Новый ОтелЛоггер(ОбластьИнстр, Ресурс, МокПроцессор);

    // Когда
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("test");
    Логгер.Записать(Запись);

    // Тогда - проверяем, что Обработать был вызван
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().Обработать(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    );

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура АвтокорреляцияСТекущимСпаном() Экспорт

    // Дано - создаём спан и делаем его текущим
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнстр = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Спан = Новый ОтелСпан("test-operation", Ресурс, ОбластьИнстр);
    Область = Спан.СделатьТекущим();

    ОбластьИнстр = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Логгер = Новый ОтелЛоггер(ОбластьИнстр, Ресурс);

    // Когда - создаём запись лога при наличии текущего спана
    Запись = Логгер.СоздатьЗаписьЛога();

    // Тогда - TraceId и SpanId автоматически заполнены из контекста
    Ожидаем.Что(Запись.ИдТрассировки()).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Запись.ИдСпана()).Равно(Спан.КонтекстСпана().ИдСпана());
    Ожидаем.Что(Запись.ИдТрассировки() <> "").Равно(Истина);
    Ожидаем.Что(Запись.ИдСпана() <> "").Равно(Истина);

    Область.Закрыть();
    Спан.Завершить();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ПередачаЛимитов() Экспорт

    // Дано - создаём логгер с лимитами
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Лимиты = Новый ОтелЛимитыЗаписейЛога()
        .УстановитьМаксАтрибутов(2);
    ОбластьИнстр = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Логгер = Новый ОтелЛоггер(ОбластьИнстр, Ресурс, , Лимиты);

    // Когда
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьАтрибут("a", 1);
    Запись.УстановитьАтрибут("b", 2);
    Запись.УстановитьАтрибут("c", 3);

    // Тогда - лимит 2 передан в запись лога
    Ожидаем.Что(Запись.Атрибуты().Количество()).Равно(2);

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура АтрибутыОбластиИSchemaUrl() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    АтрибутыОбласти = Новый ОтелАтрибуты();
    АтрибутыОбласти.Установить("scope.key", "scope.val");

    // Когда
    ОбластьИнстр = Новый ОтелОбластьИнструментирования("test-lib", "1.0", АтрибутыОбласти, "https://schema.test");
    Логгер = Новый ОтелЛоггер(ОбластьИнстр, Ресурс);

    // Тогда
    Ожидаем.Что(Логгер.АтрибутыОбласти()).Равно(АтрибутыОбласти);
    Ожидаем.Что(Логгер.SchemaUrl()).Равно("https://schema.test");

    ОтелКонтекст.Очистить();

КонецПроцедуры
