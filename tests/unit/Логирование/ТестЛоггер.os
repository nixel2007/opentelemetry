&Тест
// BSLLS:Typo-off
Процедура ДобавленныйПроцессорВиденСуществующемуЛоггеру() Экспорт
// BSLLS:Typo-on

    // Дано - логгер создан ДО добавления процессора [318]
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    // Логгер выключен - нет процессоров
    Ожидаем.Что(Логгер.Включен()).Равно(Ложь);

    // Когда - добавляем процессор ПОСЛЕ создания логгера
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Провайдер.ДобавитьПроцессор(МокПроцессор);

    // Тогда - логгер видит новый процессор и включен
    Ожидаем.Что(Логгер.Включен()).Равно(Истина);

    // И запись обрабатывается новым процессором
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("test config propagation");
    Логгер.Записать(Запись);
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().ПриПоявлении(Матчеры.ЛюбоеЗначение());

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ЗаписатьСЯвнымКонтекстом() Экспорт

    // Дано - спан НЕ текущий, передаётся через явный контекст
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Спан = Новый ОтелСпан("explicit-context-op", Ресурс, ОбластьИнструментирования);

    // Создаём контекст со спаном, но НЕ делаем его текущим
    ЯвныйКонтекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);

    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    // Когда - записываем с явным контекстом
    Запись = Логгер.СоздатьЗаписьЛога();
    Логгер.Записать(Запись, ЯвныйКонтекст);

    // Тогда - trace context из явного контекста
    Ожидаем.Что(Запись.ИдТрассировки()).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Запись.ИдСпана()).Равно(Спан.КонтекстСпана().ИдСпана());

    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура КонтекстРазрешаетсяПриEmitАНеПриСозданииЗаписи() Экспорт

    // Дано - создаём запись БЕЗ текущего спана, потом делаем спан текущим
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    Запись = Логгер.СоздатьЗаписьЛога();
    // На момент создания записи нет текущего спана
    Ожидаем.Что(Запись.ИдТрассировки()).Равно("");

    // Теперь создаём спан и делаем текущим
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-lib", "1.0");
    Спан = Новый ОтелСпан("deferred-op", Ресурс, ОбластьИнструментирования);
    Область = Спан.СделатьТекущим();

    // Когда - emit в контексте спана
    Логгер.Записать(Запись);

    // Тогда - контекст разрешён при emit, а не при создании записи
    Ожидаем.Что(Запись.ИдТрассировки()).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Запись.ИдСпана()).Равно(Спан.КонтекстСпана().ИдСпана());

    Область.Закрыть();
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ВключенФильтрацияПоСерьезности() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Провайдер = Новый ОтелПровайдерЛогирования(Новый ОтелРесурс(Истина));
    Провайдер.ДобавитьПроцессор(Новый ОтелПростойПроцессорЛогов(Неопределено));
    Конфигурация = Новый ОтелКонфигурацияЛоггера(Истина, ОтелСтепеньСерьезности.Warn());
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Логгер = Новый ОтелЛоггер(Область, Новый ОтелРесурс(Истина), Провайдер, Конфигурация);

    // Тогда
    Ожидаем.Что(Логгер.Включен(, ОтелСтепеньСерьезности.Error())).ЭтоИстина();
    Ожидаем.Что(Логгер.Включен(, ОтелСтепеньСерьезности.Warn())).ЭтоИстина();
    Ожидаем.Что(Логгер.Включен(, ОтелСтепеньСерьезности.Info())).ЭтоЛожь();
    Ожидаем.Что(Логгер.Включен(, ОтелСтепеньСерьезности.Debug())).ЭтоЛожь();

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

