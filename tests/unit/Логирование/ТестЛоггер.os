&Тест
Процедура ВключенПередаетВсеПараметрыПроцессору() Экспорт

    // Дано - spy-процессор, захватывающий переданные параметры Включен
    ТекстСпая = "
    |Перем ВизванВключен Экспорт;
    |Перем ЗахваченКонтекст Экспорт;
    |Перем ЗахваченнаяОбласть Экспорт;
    |Перем ЗахваченаяСерьезность Экспорт;
    |Перем ЗахваченноеИмяСобытия Экспорт;
    |Процедура ПриПоявлении(ЗаписьЛога, Контекст = Неопределено) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Функция Включен(Контекст = Неопределено, ОбластьИнструментирования = Неопределено, СтепеньСерьезности = 0, ИмяСобытия = """") Экспорт
    |    ВизванВключен = Истина;
    |    ЗахваченКонтекст = Контекст;
    |    ЗахваченнаяОбласть = ОбластьИнструментирования;
    |    ЗахваченаяСерьезность = СтепеньСерьезности;
    |    ЗахваченноеИмяСобытия = ИмяСобытия;
    |    Возврат Истина;
    |КонецФункции
    |Процедура СброситьБуфер(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Процедура Закрыть(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |ВизванВключен = Ложь;
    |ЗахваченноеИмяСобытия = """";
    |ЗахваченаяСерьезность = 0;";
    Спай = ЗагрузитьСценарийИзСтроки(ТекстСпая);
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, Спай);
    Логгер = Провайдер.ПолучитьЛоггер("my-lib", "1.0");

    // Когда
    Результат = Логгер.Включен(, , ОтелСтепеньСерьезности.Warn(), "event.x");

    // Тогда - процессор вызван с нужными параметрами; результат - Истина
    Ожидаем.Что(Результат).Равно(Истина);
    Ожидаем.Что(Спай.ВизванВключен).Равно(Истина);
    Ожидаем.Что(Спай.ЗахваченаяСерьезность).Равно(ОтелСтепеньСерьезности.Warn());
    Ожидаем.Что(Спай.ЗахваченноеИмяСобытия).Равно("event.x");
    Ожидаем.Что(Спай.ЗахваченнаяОбласть).Не_().Равно(Неопределено);
    Ожидаем.Что(Спай.ЗахваченнаяОбласть.Имя()).Равно("my-lib");

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ВключенКороткоеЗамыканиеПоПроцессорам() Экспорт

    // Дано - первый процессор возвращает Истина, второй - считает вызовы
    ТекстПервого = "
    |Процедура ПриПоявлении(ЗаписьЛога, Контекст = Неопределено) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Функция Включен(Контекст = Неопределено, ОбластьИнструментирования = Неопределено, СтепеньСерьезности = 0, ИмяСобытия = """") Экспорт // BSLLS:UnusedParameters-off
    |    Возврат Истина;
    |КонецФункции
    |Процедура СброситьБуфер(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Процедура Закрыть(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры";
    ТекстВторого = "
    |Перем КоличествоВызовов Экспорт;
    |Процедура ПриПоявлении(ЗаписьЛога, Контекст = Неопределено) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Функция Включен(Контекст = Неопределено, ОбластьИнструментирования = Неопределено, СтепеньСерьезности = 0, ИмяСобытия = """") Экспорт // BSLLS:UnusedParameters-off
    |    КоличествоВызовов = КоличествоВызовов + 1;
    |    Возврат Истина;
    |КонецФункции
    |Процедура СброситьБуфер(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Процедура Закрыть(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |КоличествоВызовов = 0;";
    Первый = ЗагрузитьСценарийИзСтроки(ТекстПервого);
    Второй = ЗагрузитьСценарийИзСтроки(ТекстВторого);
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПостроительПровайдераЛогирования()
        .УстановитьРесурс(Ресурс)
        .ДобавитьПроцессор(Первый)
        .ДобавитьПроцессор(Второй)
        .Построить();
    Логгер = Провайдер.ПолучитьЛоггер("my-lib");

    // Когда
    Результат = Логгер.Включен();

    // Тогда - после Истина у первого, второй не вызван (short-circuit)
    Ожидаем.Что(Результат).Равно(Истина);
    Ожидаем.Что(Второй.КоличествоВызовов).Равно(0);

    Провайдер.Закрыть();

КонецПроцедуры

&Тест
Процедура ВключенМутацияОбластиНеПопадаетВCaller() Экспорт

    // Дано - процессор пытается мутировать переданную ему ОбластьИнструментирования
    ТекстМутирующего = "
    |Процедура ПриПоявлении(ЗаписьЛога, Контекст = Неопределено) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Функция Включен(Контекст = Неопределено, ОбластьИнструментирования = Неопределено, СтепеньСерьезности = 0, ИмяСобытия = """") Экспорт // BSLLS:UnusedParameters-off
    |    Если ОбластьИнструментирования <> Неопределено И ОбластьИнструментирования.Атрибуты() <> Неопределено Тогда
    |        ОбластьИнструментирования.Атрибуты().Установить(""мутация"", ""утекла"");
    |    КонецЕсли;
    |    Возврат Истина;
    |КонецФункции
    |Процедура СброситьБуфер(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Процедура Закрыть(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры";
    МутирующийПроцессор = ЗагрузитьСценарийИзСтроки(ТекстМутирующего);
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, МутирующийПроцессор);
    АтрибутыОбласти = Новый ОтелАтрибуты();
    АтрибутыОбласти.Установить("исходный", "значение");
    Логгер = Провайдер.ПолучитьЛоггер("тест.библиотека", "1.0", АтрибутыОбласти);

    // Когда
    Логгер.Включен();

    // Тогда - caller-объект (scope) не мутирован; исходные атрибуты сохранены
    Ожидаем.Что(АтрибутыОбласти.Получить("мутация")).Равно(Неопределено);
    Ожидаем.Что(АтрибутыОбласти.Количество()).Равно(1);
    Ожидаем.Что(Логгер.ОбластьИнструментирования().Атрибуты().Получить("мутация")).Равно(Неопределено);

    Провайдер.Закрыть();

КонецПроцедуры

