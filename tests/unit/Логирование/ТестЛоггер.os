    // Когда - закрываем провайдер
    Провайдер.Закрыть();

    // Тогда - ранее созданный логгер выключен [344]
    Ожидаем.Что(Логгер.Включен()).Равно(Ложь);

    ОтелКонтекст.Очистить();

