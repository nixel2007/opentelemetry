&Тест
Процедура ЗаписатьФильтруетПоСерьезностиВЗаписать() Экспорт

    // Дано - конфигурация с минимальной серьезностью Warn
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Провайдер.ДобавитьПроцессор(Новый ОтелПростойПроцессорЛогов(Неопределено));
    Конфигурация = Новый ОтелКонфигурацияЛоггера(Истина, ОтелСтепеньСерьезности.Warn());
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Логгер = Новый ОтелЛоггер(Область, Ресурс, Провайдер, Конфигурация);

    // Когда - записываем лог с серьезностью Info (ниже минимума)
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьСерьезность(ОтелСтепеньСерьезности.Info());
    Логгер.Записать(Запись);

    // Тогда - запись НЕ зафиксирована (emit вернулся до Зафиксировать)
    // Проверяем: сеттер всё ещё работает после Записать
    Запись.УстановитьТело("проверка");
    Ожидаем.Что(Запись.Тело()).Равно("проверка");

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ЗаписатьПропускаетПоСерьезностиВЗаписать() Экспорт

    // Дано - конфигурация с минимальной серьезностью Warn
    ОтелКонтекст.Очистить();
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, МокПроцессор);
    Конфигурация = Новый ОтелКонфигурацияЛоггера(Истина, ОтелСтепеньСерьезности.Warn());
    Область = Новый ОтелОбластьИнструментирования("тест", "1.0");
    Логгер = Новый ОтелЛоггер(Область, Ресурс, Провайдер, Конфигурация);

    // Когда - записываем лог с серьезностью Error (выше минимума)
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьСерьезность(ОтелСтепеньСерьезности.Error());
    Логгер.Записать(Запись);

    // Тогда - процессор должен быть вызван
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().ПриПоявлении(Матчеры.ЛюбоеЗначение(), Матчеры.ЛюбоеЗначение());

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

