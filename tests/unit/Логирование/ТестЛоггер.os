&Тест
Процедура ЗаписатьАтрибутыПользователяПриоритетнееИсключения() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, МокПроцессор);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    // Когда - создаем запись с пользовательским exception.message И исключением
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьАтрибут("exception.message", "Мое сообщение");
    Попытка
        ВызватьИсключение "SDK ошибка";
    Исключение
        Запись.УстановитьИсключение(ИнформацияОбОшибке());
    КонецПопытки;
    Логгер.Записать(Запись);

    // Тогда - пользовательский атрибут exception.message НЕ перезаписан
    Ожидаем.Что(Запись.Атрибуты().Получить("exception.message")).Равно("Мое сообщение");
    // Но exception.type и exception.stacktrace установлены из SDK
    Ожидаем.Что(Запись.Атрибуты().Получить("exception.type") <> Неопределено).Равно(Истина);
    Ожидаем.Что(Запись.Атрибуты().Получить("exception.stacktrace") <> Неопределено).Равно(Истина);

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

