&Тест
Процедура СоздатьЗаписьЛога() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    // Когда
    Запись = Логгер.СоздатьЗаписьЛога();

    // Тогда
    Ожидаем.Что(Запись <> Неопределено).Равно(Истина);
    Ожидаем.Что(Запись.Тело()).Равно("");
    Ожидаем.Что(Запись.НомерСерьезности()).Равно(ОтелСтепеньСерьезности.Info());

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура Записать() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, МокПроцессор);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    // Когда
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("test");
    Логгер.Записать(Запись);

    // Тогда - проверяем, что ПриПоявлении был вызван с записью и контекстом
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().ПриПоявлении(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    );

    // Проверяем, что scope и resource установлены на записи
    Ожидаем.Что(Запись.ОбластьИнструментирования().Имя()).Равно("test-lib");
    Ожидаем.Что(Запись.Ресурс()).Равно(Ресурс);

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура АвтокорреляцияСТекущимСпаном() Экспорт

    // Дано - создаём спан и делаем его текущим
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    ОбластьИнструментирования = Новый ОтелОбластьИнструментирования("test-library", "1.0.0");
    Спан = Новый ОтелСпан("test-operation", Ресурс, ОбластьИнструментирования);
    Область = Спан.СделатьТекущим();

    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    // Когда - создаём запись и отправляем (контекст разрешается при emit)
    Запись = Логгер.СоздатьЗаписьЛога();
    Логгер.Записать(Запись);

    // Тогда - TraceId и SpanId заполнены из текущего контекста при emit
    Ожидаем.Что(Запись.ИдТрассировки()).Равно(Спан.КонтекстСпана().ИдТрассировки());
    Ожидаем.Что(Запись.ИдСпана()).Равно(Спан.КонтекстСпана().ИдСпана());
    Ожидаем.Что(Запись.ИдТрассировки() <> "").Равно(Истина);
    Ожидаем.Что(Запись.ИдСпана() <> "").Равно(Истина);

    Область.Закрыть();
    Спан.Завершить();
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ПередачаЛимитов() Экспорт

    // Дано - создаём провайдер с лимитами
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Лимиты = Новый ОтелЛимитыЗаписейЛога()
        .УстановитьМаксАтрибутов(2);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, , Лимиты);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    // Когда
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьАтрибут("a", 1);
    Запись.УстановитьАтрибут("b", 2);
    Запись.УстановитьАтрибут("c", 3);

    // Тогда - лимит 2 передан через провайдер
    Ожидаем.Что(Запись.Атрибуты().Количество()).Равно(2);

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ScopeИResourceНаЗаписиПослеЗаписать() Экспорт
    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    АтрибутыОбласти = Новый ОтелАтрибуты();
    АтрибутыОбласти.Установить("scope.key", "scope.val");
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Логгер = Провайдер.ПостроительЛоггера("test-lib")
        .УстановитьВерсию("1.0")
        .УстановитьАтрибутыОбласти(АтрибутыОбласти)
        .УстановитьАдресСхемы("https://schema.test")
        .Построить();

    // Когда
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("test");
    Логгер.Записать(Запись);

    // Тогда - scope и resource установлены на записи логгером
    Ожидаем.Что(Запись.ОбластьИнструментирования().Имя()).Равно("test-lib");
    Ожидаем.Что(Запись.ОбластьИнструментирования().Версия()).Равно("1.0");
    Ожидаем.Что(Запись.ОбластьИнструментирования().Атрибуты()).Равно(АтрибутыОбласти);
    Ожидаем.Что(Запись.ОбластьИнструментирования().АдресСхемы()).Равно("https://schema.test");
    Ожидаем.Что(Запись.Ресурс()).Равно(Ресурс);

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

