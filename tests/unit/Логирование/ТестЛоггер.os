&Тест
Процедура ЗаписатьУстанавливаетObservedTimestamp() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    // Когда - создаем запись, ObservedTimestamp пустой
    Запись = Логгер.СоздатьЗаписьЛога();
    Ожидаем.Что(Запись.ВремяНаблюдения()).Равно("");

    // Записываем - SDK должен установить ObservedTimestamp
    Логгер.Записать(Запись);

    // Тогда - ObservedTimestamp заполнен SDK при emit
    Ожидаем.Что(Запись.ВремяНаблюдения() <> "").Равно(Истина);

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ЗаписатьСохраняетЯвноУстановленныйObservedTimestamp() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Логгер = Провайдер.ПолучитьЛоггер("test-lib", "1.0");

    // Когда - создаем запись и ЯВНО ставим ObservedTimestamp
    ЯвноеВремя = "9999999999000000000";
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьВремяНаблюдения(ЯвноеВремя);

    // Записываем - SDK НЕ должен перезаписать явно установленное значение
    Логгер.Записать(Запись);

    // Тогда - ObservedTimestamp сохранён как установлено пользователем
    Ожидаем.Что(Запись.ВремяНаблюдения()).Равно(ЯвноеВремя);

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

