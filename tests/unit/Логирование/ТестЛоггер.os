&Тест
Процедура ЗаписатьБезПровайдераНеПадает() Экспорт

    // Дано - логгер без провайдера
    ОтелКонтекст.Очистить();
    Область = Новый ОтелОбластьИнструментирования("test", "1.0");
    Ресурс = Новый ОтелРесурс();
    Логгер = Новый ОтелЛоггер(Область, Ресурс);

    // Когда - записываем лог без провайдера
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьТело("тестовое тело");
    Логгер.Записать(Запись);

    // Тогда - запись зафиксирована (Записать не падает и вызывает Зафиксировать)
    Запись.УстановитьТело("не изменилось");
    Ожидаем.Что(Запись.Тело()).Равно("тестовое тело");

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ВключенСОбластьюНеопределено() Экспорт

    // Дано - spy-процессор, захватывающий переданную область
    ОтелКонтекст.Очистить();
    ТекстСпая = "
    |Перем ЗахваченнаяОбласть Экспорт;
    |Процедура ПриПоявлении(ЗаписьЛога, Контекст = Неопределено) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Функция Включен(Контекст = Неопределено, ОбластьИнструментирования = Неопределено, СтепеньСерьезности = 0, ИмяСобытия = """") Экспорт // BSLLS:UnusedParameters-off
    |    ЗахваченнаяОбласть = ОбластьИнструментирования;
    |    Возврат Истина;
    |КонецФункции
    |Процедура СброситьБуфер(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |Процедура Закрыть(ТаймаутМс = 0) Экспорт // BSLLS:UnusedParameters-off
    |КонецПроцедуры
    |ЗахваченнаяОбласть = Неопределено;";
    Спай = ЗагрузитьСценарийИзСтроки(ТекстСпая);
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, Спай);
    // Создаем логгер с Неопределено областью инструментирования
    Логгер = Новый ОтелЛоггер(Неопределено, Ресурс, Провайдер);

    // Когда - вызываем Включен()
    Результат = Логгер.Включен();

    // Тогда - ЗащищеннаяКопияОбласти(Неопределено) вернула Неопределено → область передана Неопределено
    Ожидаем.Что(Результат).Равно(Истина);
    Ожидаем.Что(Спай.ЗахваченнаяОбласть).Равно(Неопределено);

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры
