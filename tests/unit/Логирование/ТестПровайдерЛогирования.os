#Использовать "../../.."
#Использовать asserts
#Использовать moskito

&Тест
Процедура ПолучитьЛоггер() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);

    // Когда
    Логгер = Провайдер.ПолучитьЛоггер("my-lib", "1.0");

    // Тогда
    Ожидаем.Что(Логгер <> Неопределено).Равно(Истина);
    Ожидаем.Что(Логгер.ИмяБиблиотеки()).Равно("my-lib");
    Ожидаем.Что(Логгер.ВерсияБиблиотеки()).Равно("1.0");

    Запись = Логгер.СоздатьЗаписьЛога();
    Ожидаем.Что(Запись <> Неопределено).Равно(Истина);

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура КэшированиеЛоггеров() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);

    // Когда - запрашиваем одного и того же логгера дважды
    Логгер1 = Провайдер.ПолучитьЛоггер("cached-lib", "2.0");
    Логгер2 = Провайдер.ПолучитьЛоггер("cached-lib", "2.0");

    // Тогда - возвращается тот же объект
    Ожидаем.Что(Логгер1).Равно(Логгер2);

КонецПроцедуры

&Тест
Процедура ПередачаЛимитов() Экспорт

    // Дано - лимиты через построитель провайдера
    ОтелКонтекст.Очистить();
    Лимиты = Новый ОтелЛимитыЗаписейЛога()
        .УстановитьМаксАтрибутов(3);
    Провайдер = Новый ОтелПостроительПровайдераЛогирования()
        .УстановитьЛимитыЗаписейЛога(Лимиты)
        .Построить();

    // Когда
    Логгер = Провайдер.ПолучитьЛоггер("lib", "1.0");
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьАтрибут("a", 1);
    Запись.УстановитьАтрибут("b", 2);
    Запись.УстановитьАтрибут("c", 3);
    Запись.УстановитьАтрибут("d", 4);

    // Тогда - лимит 3 передан через провайдер
    Ожидаем.Что(Запись.Атрибуты().Количество()).Равно(3);

    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт

    // Дано
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, МокПроцессор);

    // Когда
    Провайдер.Закрыть();

    // Тогда - Закрыть вызван у процессора
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().Закрыть();

КонецПроцедуры

&Тест
Процедура ПостроительЛоггера() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);

    // Когда
    Построитель = Провайдер.ПостроительЛоггера("моя-библ");

    // Тогда
    Ожидаем.Что(Построитель <> Неопределено).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ПолучитьЛоггерПослеЗакрытия() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Провайдер.Закрыть();

    // Когда - запрашиваем логгер после закрытия
    Логгер = Провайдер.ПолучитьЛоггер("библ", "1.0");

    // Тогда - логгер no-op (без процессора), но работает
    Ожидаем.Что(Логгер <> Неопределено).Равно(Истина);
    Ожидаем.Что(Логгер.ИмяБиблиотеки()).Равно("библ");
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ДобавитьПроцессорИСброситьБуфер() Экспорт

    // Дано
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Провайдер.ДобавитьПроцессор(МокПроцессор1);
    Провайдер.ДобавитьПроцессор(МокПроцессор2);

    // Когда
    Провайдер.СброситьБуфер();

    // Тогда - оба процессора сбросили буфер
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().СброситьБуфер();
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().СброситьБуфер();

КонецПроцедуры

&Тест
Процедура СброситьБуферАсинхронно() Экспорт

    // Дано
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, МокПроцессор);

    // Когда
    Обещание = Провайдер.СброситьБуферАсинхронно();
    Обещание.Получить(5000);

    // Тогда
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().СброситьБуфер();

КонецПроцедуры

&Тест
Процедура ЗакрытьАсинхронно() Экспорт

    // Дано
    МокПроцессор = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс, МокПроцессор);

    // Когда
    Обещание = Провайдер.ЗакрытьАсинхронно();
    Обещание.Получить(5000);

    // Тогда
    МокПроцессор.ПроверитьЧтоВызывалсяМетод().Закрыть();

КонецПроцедуры

&Тест
Процедура ПостроительСРесурсомИПроцессорами() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Ресурс.Атрибуты().Установить("service.name", "тест-сервис");
    МокПроцессор1 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));
    МокПроцессор2 = Мок.Получить(Тип("ОтелПростойПроцессорЛогов"));

    // Когда
    Провайдер = Новый ОтелПостроительПровайдераЛогирования()
        .УстановитьРесурс(Ресурс)
        .ДобавитьПроцессор(МокПроцессор1)
        .ДобавитьПроцессор(МокПроцессор2)
        .Построить();

    // Тогда
    Ожидаем.Что(Провайдер.Ресурс()).Равно(Ресурс);
    Провайдер.СброситьБуфер();
    МокПроцессор1.ПроверитьЧтоВызывалсяМетод().СброситьБуфер();
    МокПроцессор2.ПроверитьЧтоВызывалсяМетод().СброситьБуфер();

    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&Тест
Процедура ПостроительЛоггераFluentChain() Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    АтрибутыОбласти = Новый ОтелАтрибуты();
    АтрибутыОбласти.Установить("scope.key", "scope.value");

    // Когда - используем полный fluent chain построителя
    Логгер = Провайдер.ПостроительЛоггера("моя-библ")
        .УстановитьВерсию("2.0.0")
        .УстановитьSchemaUrl("https://schema.example.com")
        .УстановитьАтрибутыОбласти(АтрибутыОбласти)
        .Построить();

    // Тогда
    Ожидаем.Что(Логгер <> Неопределено).Равно(Истина);
    Ожидаем.Что(Логгер.ИмяБиблиотеки()).Равно("моя-библ");
    Ожидаем.Что(Логгер.ВерсияБиблиотеки()).Равно("2.0.0");
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение("Trace")
&ИсточникЗначение("Debug")
&ИсточникЗначение("Fatal")
Процедура ЛогированиеСРазнымиСтепенямиСерьезности(ИмяСтепени) Экспорт

    // Дано
    ОтелКонтекст.Очистить();
    Ресурс = Новый ОтелРесурс(Истина);
    Провайдер = Новый ОтелПровайдерЛогирования(Ресурс);
    Логгер = Провайдер.ПолучитьЛоггер("библ", "1.0");

    // BSLLS:IfElseIfEndsWithElse-off
    Если ИмяСтепени = "Trace" Тогда
        Серьезность = ОтелСтепеньСерьезности.Trace();
        ОжидаемыйТекст = "TRACE";
    ИначеЕсли ИмяСтепени = "Debug" Тогда
        Серьезность = ОтелСтепеньСерьезности.Debug();
        ОжидаемыйТекст = "DEBUG";
    ИначеЕсли ИмяСтепени = "Fatal" Тогда
        Серьезность = ОтелСтепеньСерьезности.Fatal();
        ОжидаемыйТекст = "FATAL";
    КонецЕсли;

    // Когда
    Запись = Логгер.СоздатьЗаписьЛога();
    Запись.УстановитьСерьезность(Серьезность);

    // Тогда
    Ожидаем.Что(Запись.НомерСерьезности()).Равно(Серьезность);
    Ожидаем.Что(ОтелСтепеньСерьезности.ТекстСерьезности(Серьезность)).Равно(ОжидаемыйТекст);
    Провайдер.Закрыть();
    ОтелКонтекст.Очистить();

КонецПроцедуры
