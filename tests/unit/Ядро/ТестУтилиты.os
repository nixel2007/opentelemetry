&Тест
Процедура ПодключаемыеЧасы() Экспорт

    // Дано
    ОжидаемоеВремя = "1234567890000000000";
    ТекстМокЧасов = "
    |Функция ТекущееВремяВНаносекундах() Экспорт
    |    Возврат ""1234567890000000000"";
    |КонецФункции";
    МокЧасы = ЗагрузитьСценарийИзСтроки(ТекстМокЧасов);

    // Когда
    ОтелУтилиты.УстановитьЧасы(МокЧасы);
    Время = ОтелУтилиты.ТекущееВремяВНаносекундах();

    // Тогда
    Ожидаем.Что(Время).Равно(ОжидаемоеВремя);

    // Сброс
    ОтелУтилиты.СброситьЧасы();
    ВремяПослеСброса = ОтелУтилиты.ТекущееВремяВНаносекундах();
    Ожидаем.Что(ВремяПослеСброса = ОжидаемоеВремя).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ПодключаемыйГенераторИд() Экспорт

    // Дано
    ОжидаемыйИдТрасс = "aaaabbbbccccddddeeee111122223333";
    ОжидаемыйИдСпана = "1111222233334444";
    ТекстМокГенератора = "
    |Функция СгенерироватьИдТрассировки() Экспорт
    |    Возврат ""aaaabbbbccccddddeeee111122223333"";
    |КонецФункции
    |
    |Функция СгенерироватьИдСпана() Экспорт
    |    Возврат ""1111222233334444"";
    |КонецФункции";
    МокГенератор = ЗагрузитьСценарийИзСтроки(ТекстМокГенератора);

    // Когда
    ОтелУтилиты.УстановитьГенераторИд(МокГенератор);

    // Тогда
    Ожидаем.Что(ОтелУтилиты.СгенерироватьИдТрассировки()).Равно(ОжидаемыйИдТрасс);
    Ожидаем.Что(ОтелУтилиты.СгенерироватьИдСпана()).Равно(ОжидаемыйИдСпана);

    // Сброс
    ОтелУтилиты.СброситьГенераторИд();
    ИдПослеСброса = ОтелУтилиты.СгенерироватьИдТрассировки();
    Ожидаем.Что(ИдПослеСброса = ОжидаемыйИдТрасс).Равно(Ложь);

КонецПроцедуры

Процедура ПроверитьЧтоСтрокаHex(Знач Строка_)
    ДопустимыеСимволы = "0123456789abcdef";
    СтрокаНижний = НРег(Строка_);
    Для Индекс = 1 По СтрДлина(СтрокаНижний) Цикл
        Символ = Сред(СтрокаНижний, Индекс, 1);
        Если СтрНайти(ДопустимыеСимволы, Символ) = 0 Тогда
            ВызватьИсключение "Строка содержит не-hex символ: " + Символ;
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

