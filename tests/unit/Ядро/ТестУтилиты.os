&Тест
Процедура ТранслитерацияСложныхБукв() Экспорт

    // Дано / Когда / Тогда - ё, ж, ц, ч, ш, щ, ъ, ы, ь, э, ю, я
    Ожидаем.Что(ОтелУтилиты.Транслитерировать("ёжик")).Равно("yozhik");
    Ожидаем.Что(ОтелУтилиты.Транслитерировать("цех")).Равно("tsekh");
    Ожидаем.Что(ОтелУтилиты.Транслитерировать("щётка")).Равно("shchyotka");
    Ожидаем.Что(ОтелУтилиты.Транслитерировать("объём")).Равно("obyom");
    Ожидаем.Что(ОтелУтилиты.Транслитерировать("юля")).Равно("yulya");

КонецПроцедуры

