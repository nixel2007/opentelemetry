&ПослеКаждого
Процедура Очистка() Экспорт
    ОтелУтилиты.СброситьЧасы();
    ОтелУтилиты.СброситьГенераторИд();
КонецПроцедуры

&Тест
Процедура ГенерацияИдТрассировки() Экспорт

    // Дано / Когда
    ИдТрассировки = ОтелУтилиты.СгенерироватьИдТрассировки();

    // Тогда
    Ожидаем.Что(СтрДлина(ИдТрассировки)).Равно(32);
    ПроверитьЧтоСтрокаHex(ИдТрассировки);

КонецПроцедуры

&Тест
Процедура ГенерацияИдСпана() Экспорт

    // Дано / Когда
    ИдСпана = ОтелУтилиты.СгенерироватьИдСпана();

    // Тогда
    Ожидаем.Что(СтрДлина(ИдСпана)).Равно(16);
    ПроверитьЧтоСтрокаHex(ИдСпана);

КонецПроцедуры

&Тест
Процедура ВремяВНаносекундах() Экспорт

    // Дано / Когда
    Время = ОтелУтилиты.ТекущееВремяВНаносекундах();

    // Тогда
    Ожидаем.Что(Время).ИмеетТип("Строка");
    Ожидаем.Что(СтрЗаканчиваетсяНа(Время, "000000")).Равно(Истина);
    Ожидаем.Что(СтрДлина(Время)).Равно(19);

КонецПроцедуры

&Тест
Процедура МиллисекундыВНаносекунды() Экспорт

    // Дано - известное значение: 1 января 1970 00:00:00.123 в мс от 0001-01-01
    СмещениеUnixМс = Цел((Дата(1970, 1, 1) - Дата(1, 1, 1)) * 1000);
    ИзвестныеМс = СмещениеUnixМс + 123; // 123 мс после Unix epoch

    // Когда
    Результат = ОтелУтилиты.МиллисекундыВНаносекунды(ИзвестныеМс);

    // Тогда
    Ожидаем.Что(Результат).Равно("123000000");

КонецПроцедуры

&Тест
Процедура ВШестнадцатеричнуюСтроку() Экспорт

    // Дано / Когда / Тогда
    Ожидаем.Что(ОтелУтилиты.ВШестнадцатеричнуюСтроку(255)).Равно("ff");
    Ожидаем.Что(ОтелУтилиты.ВШестнадцатеричнуюСтроку(0)).Равно("0");
    Ожидаем.Что(ОтелУтилиты.ВШестнадцатеричнуюСтроку(16)).Равно("10");

КонецПроцедуры

&Тест
Процедура ИзШестнадцатеричнойСтроки() Экспорт

    // Дано / Когда / Тогда
    Ожидаем.Что(ОтелУтилиты.ИзШестнадцатеричнойСтроки("ff")).Равно(255);
    Ожидаем.Что(ОтелУтилиты.ИзШестнадцатеричнойСтроки("0")).Равно(0);
    Ожидаем.Что(ОтелУтилиты.ИзШестнадцатеричнойСтроки("10")).Равно(16);
    Ожидаем.Что(ОтелУтилиты.ИзШестнадцатеричнойСтроки("FF")).Равно(255);

КонецПроцедуры

