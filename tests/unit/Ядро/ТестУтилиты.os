// ЗначениеАтрибутаВФорматОтел — дополнительные типы

&Тест
Процедура ЗначениеАтрибутаДробноеЧисло() Экспорт

    // Дано / Когда
    Результат = ОтелУтилиты.ЗначениеАтрибутаВФорматОтел(3.14);

    // Тогда - дробное → doubleValue
    Ожидаем.Что(Результат["doubleValue"]).Равно(3.14);

КонецПроцедуры

&Тест
Процедура ЗначениеАтрибутаМассив() Экспорт

    // Дано
    Значение = Новый Массив();
    Значение.Добавить("один");
    Значение.Добавить(42);

    // Когда
    Результат = ОтелУтилиты.ЗначениеАтрибутаВФорматОтел(Значение);

    // Тогда - массив → arrayValue с вложенными значениями
    МассивРезультат = Результат["arrayValue"];
    Ожидаем.Что(МассивРезультат).ИмеетТип("Соответствие");
    ЭлементыМассива = МассивРезультат["values"];
    Ожидаем.Что(ЭлементыМассива.Количество()).Равно(2);
    Ожидаем.Что(ЭлементыМассива[0]["stringValue"]).Равно("один");
    Ожидаем.Что(ЭлементыМассива[1]["intValue"]).Равно("42");

КонецПроцедуры

&Тест
Процедура ЗначениеАтрибутаНеизвестныйТипДаётСтроку() Экспорт

    // Дано - тип не Строка, Число, Булево, Массив → stringValue
    Значение = Новый Массив(); // используем специфический объект
    Значение = Новый Структура("Поле", "Значение"); // Структура — неизвестный тип

    // Когда
    Результат = ОтелУтилиты.ЗначениеАтрибутаВФорматОтел(Значение);

    // Тогда - записано как строка
    Ожидаем.Что(Результат["stringValue"]).ИмеетТип("Строка");

КонецПроцедуры

