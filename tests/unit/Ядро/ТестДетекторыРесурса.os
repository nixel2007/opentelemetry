&Тест
Процедура ДетекторХостаВозвращаетРесурс() Экспорт

    // Дано
    Детектор = Новый ОтелДетекторРесурсаХоста();

    // Когда
    Ресурс = Детектор.Обнаружить();

    // Тогда - должен вернуть ресурс с атрибутами хоста
    Ожидаем.Что(Ресурс).ИмеетТип("ОтелРесурс");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("host.name") <> Неопределено).Равно(Истина);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("os.type") <> Неопределено).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ДетекторХостаНеСодержитДефолтов() Экспорт

    // Дано
    Детектор = Новый ОтелДетекторРесурсаХоста();

    // Когда
    Ресурс = Детектор.Обнаружить();

    // Тогда - детектор НЕ должен добавлять service.name и telemetry.sdk.*
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно(Неопределено);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("telemetry.sdk.name")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ДетекторПроцессаВозвращаетPID() Экспорт

    // Дано
    Детектор = Новый ОтелДетекторРесурсаПроцесса();

    // Когда
    Ресурс = Детектор.Обнаружить();

    // Тогда
    Ожидаем.Что(Ресурс).ИмеетТип("ОтелРесурс");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("process.pid") <> Неопределено).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ДетекторПроцессаНеСодержитДефолтов() Экспорт

    // Дано
    Детектор = Новый ОтелДетекторРесурсаПроцесса();

    // Когда
    Ресурс = Детектор.Обнаружить();

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ДетекторПроцессораВозвращаетРесурс() Экспорт

    // Дано
    Детектор = Новый ОтелДетекторРесурсаПроцессора();

    // Когда
    Ресурс = Детектор.Обнаружить();

    // Тогда - должен вернуть ресурс с атрибутами процессора
    Ожидаем.Что(Ресурс).ИмеетТип("ОтелРесурс");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("host.cpu.model.name") <> Неопределено).Равно(Истина);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("host.cpu.count") <> Неопределено).Равно(Истина);
    Ожидаем.Что(Ресурс.Атрибуты().Получить("host.arch") <> Неопределено).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ДетекторПроцессораНеСодержитДефолтов() Экспорт

    // Дано
    Детектор = Новый ОтелДетекторРесурсаПроцессора();

    // Когда
    Ресурс = Детектор.Обнаружить();

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ДетекторХостаВозвращаетПустойSchemaUrl() Экспорт

    // Дано
    Детектор = Новый ОтелДетекторРесурсаХоста();

    // Когда
    Ресурс = Детектор.Обнаружить();

    // Тогда - по спеке Resource detector SHOULD использовать пустой Schema URL,
    // чтобы не блокировать слияние ресурсов с разными версиями семантических соглашений.
    Ожидаем.Что(Ресурс.АдресСхемы()).Равно("");

КонецПроцедуры
