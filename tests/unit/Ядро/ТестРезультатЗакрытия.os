&Тест
Процедура Тест_УспешноеЗакрытие() Экспорт

    // Дано
    Результат = ОтелРезультатыЗакрытия.Успех();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    Ожидаем.Что(Результат.ИстекТаймаут()).Равно(Ложь);
    Ожидаем.Что(Результат.Описание()).Равно("");
    Ожидаем.Что(Результат.Успех).Равно(Истина);

КонецПроцедуры

&Тест
Процедура Тест_СОшибкой() Экспорт

    // Дано
    ТестовоеСообщение = "что-то пошло не так";
    Результат = ОтелРезультатыЗакрытия.Ошибка(ТестовоеСообщение);

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Ожидаем.Что(Результат.ИстекТаймаут()).Равно(Ложь);
    Ожидаем.Что(Результат.Описание()).Равно(ТестовоеСообщение);
    Ожидаем.Что(Результат.ОшибкаОписание).Равно(ТестовоеСообщение);

КонецПроцедуры

&Тест
Процедура Тест_ИзТаймаута() Экспорт

    // Дано
    Результат = ОтелРезультатыЗакрытия.Таймаут();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Ожидаем.Что(Результат.ИстекТаймаут()).Равно(Истина);
    Ожидаем.Что(Результат.Истекло).Равно(Истина);

КонецПроцедуры

&Тест
Процедура Тест_КонструкторПоУмолчанию() Экспорт

    // Дано
    Результат = Новый ОтелРезультатЗакрытия();

    // Тогда - по умолчанию успешный
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    Ожидаем.Что(Результат.ИстекТаймаут()).Равно(Ложь);

КонецПроцедуры
