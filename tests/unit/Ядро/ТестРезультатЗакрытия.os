&Тест
Процедура Тест_УспешноеЗакрытие() Экспорт

    // Дано
    Результат = ОтелРезультатыЗакрытия.Успешно();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    Ожидаем.Что(Результат.ИстёкТаймаут()).Равно(Ложь);
    Ожидаем.Что(Результат.Описание()).Равно("");
    Ожидаем.Что(Результат.Успех).Равно(Истина);

КонецПроцедуры

&Тест
Процедура Тест_СОшибкой() Экспорт

    // Дано
    Результат = ОтелРезультатыЗакрытия.СОшибкой("что-то пошло не так");

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Ожидаем.Что(Результат.ИстёкТаймаут()).Равно(Ложь);
    Ожидаем.Что(Результат.Описание()).Равно("что-то пошло не так");
    Ожидаем.Что(Результат.ОшибкаОписание).Равно("что-то пошло не так");

КонецПроцедуры

&Тест
Процедура Тест_ИзТаймаута() Экспорт

    // Дано
    Результат = ОтелРезультатыЗакрытия.ИзТаймаута();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Ожидаем.Что(Результат.ИстёкТаймаут()).Равно(Истина);
    Ожидаем.Что(Результат.Истекло).Равно(Истина);

КонецПроцедуры

&Тест
Процедура Тест_КонструкторПоУмолчанию() Экспорт

    // Дано
    Результат = Новый ОтелРезультатЗакрытия();

    // Тогда - по умолчанию успешный
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    Ожидаем.Что(Результат.ИстёкТаймаут()).Равно(Ложь);

КонецПроцедуры
