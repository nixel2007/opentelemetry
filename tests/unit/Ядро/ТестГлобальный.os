#Использовать moskito

&ПослеКаждого
Процедура Очистка() Экспорт
    ОтелГлобальный.Сбросить();
КонецПроцедуры

&Тест
Процедура ИзначальноПуст() Экспорт

    // Дано / Когда / Тогда
    Ожидаем.Что(ОтелГлобальный.Получить()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура УстановкаИПолучение() Экспорт

    // Дано
    МокСдк = Новый Структура("Тип", "SDK");

    // Когда
    ОтелГлобальный.Установить(МокСдк);

    // Тогда
    Ожидаем.Что(ОтелГлобальный.Получить()).Равно(МокСдк);

КонецПроцедуры

&Тест
Процедура ПовторнаяУстановкаВызываетИсключение() Экспорт

    // Дано
    МокСдк1 = Новый Структура("Тип", "SDK1");
    МокСдк2 = Новый Структура("Тип", "SDK2");
    ОтелГлобальный.Установить(МокСдк1);

    // Когда
    ИсключениеВызвано = Ложь;
    Попытка
        ОтелГлобальный.Установить(МокСдк2);
    Исключение
        ИсключениеВызвано = Истина;
    КонецПопытки;

    // Тогда
    Ожидаем.Что(ИсключениеВызвано).Равно(Истина);

КонецПроцедуры

&Тест
Процедура Сбросить() Экспорт

    // Дано
    МокСдк = Новый Структура("Тип", "SDK");
    ОтелГлобальный.Установить(МокСдк);

    // Когда
    ОтелГлобальный.Сбросить();

    // Тогда
    Ожидаем.Что(ОтелГлобальный.Получить()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ПовторнаяУстановкаПослеСброса() Экспорт

    // Дано
    МокСдк1 = Новый Структура("Тип", "SDK1");
    МокСдк2 = Новый Структура("Тип", "SDK2");

    ОтелГлобальный.Установить(МокСдк1);
    ОтелГлобальный.Сбросить();

    // Когда
    ИсключениеВызвано = Ложь;
    Попытка
        ОтелГлобальный.Установить(МокСдк2);
    Исключение
        ИсключениеВызвано = Истина;
    КонецПопытки;

    // Тогда
    Ожидаем.Что(ИсключениеВызвано).Равно(Ложь);
    Ожидаем.Что(ОтелГлобальный.Получить()).Равно(МокСдк2);

КонецПроцедуры

&Тест
Процедура БезИнициализацииВозвращаетНоопТрассировщик() Экспорт

    // Дано / Когда - per spec: MUST return no-op when SDK not configured
    Результат = ОтелГлобальный.ПолучитьТрассировщик("тест");

    // Тогда
    Ожидаем.Что(Результат).Не_().ЭтоНеопределено();

КонецПроцедуры

&ПараметризованныйТест
&ИсточникЗначение("ПолучитьЛоггер")
&ИсточникЗначение("ПолучитьМетр")
Процедура БезИнициализацииВозвращаетНоопОбъект(ИмяМетода) Экспорт

    // Дано / Когда - per spec: MUST return no-op when SDK not configured
    Результат = Неопределено;
    // BSLLS:IfElseIfEndsWithElse-off
    Если ИмяМетода = "ПолучитьЛоггер" Тогда
        Результат = ОтелГлобальный.ПолучитьЛоггер("тест");
    ИначеЕсли ИмяМетода = "ПолучитьМетр" Тогда
        Результат = ОтелГлобальный.ПолучитьМетр("тест");
    КонецЕсли;

    // Тогда
    Ожидаем.Что(Результат).Не_().ЭтоНеопределено();

КонецПроцедуры

&Тест
Процедура ПолучитьТрассировщикShortcut() Экспорт

    // Дано
    МокПров = Мок.Получить(Тип("ОтелПровайдерТрассировки"));
    МокТрассировщик = Новый Структура("Имя", "глобальный");
    МокПров.Когда().ПолучитьТрассировщик(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(МокТрассировщик);
    Сдк = Новый ОтелSdk(МокПров);
    ОтелГлобальный.Установить(Сдк);

    // Когда
    Результат = ОтелГлобальный.ПолучитьТрассировщик("mylib");

    // Тогда
    Ожидаем.Что(Результат).Равно(МокТрассировщик);

КонецПроцедуры

&Тест
Процедура ПолучитьЛоггерShortcut() Экспорт

    // Дано
    МокПров = Мок.Получить(Тип("ОтелПровайдерЛогирования"));
    МокЛоггер = Новый Структура("Имя", "логгер");
    МокПров.Когда().ПолучитьЛоггер(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(МокЛоггер);
    Сдк = Новый ОтелSdk(Неопределено, МокПров);
    ОтелГлобальный.Установить(Сдк);

    // Когда
    Результат = ОтелГлобальный.ПолучитьЛоггер("mylib");

    // Тогда
    Ожидаем.Что(Результат).Равно(МокЛоггер);

КонецПроцедуры

&Тест
Процедура ПолучитьМетрShortcut() Экспорт

    // Дано
    МокПров = Мок.Получить(Тип("ОтелПровайдерМетрик"));
    МокМетр = Новый Структура("Имя", "метр");
    МокПров.Когда().ПолучитьМетр(
        Матчеры.ЛюбоеЗначение(),
        Матчеры.ЛюбоеЗначение()
    ).ТогдаВозвращает(МокМетр);
    Сдк = Новый ОтелSdk(Неопределено, Неопределено, МокПров);
    ОтелГлобальный.Установить(Сдк);

    // Когда
    Результат = ОтелГлобальный.ПолучитьМетр("mylib");

    // Тогда
    Ожидаем.Что(Результат).Равно(МокМетр);

КонецПроцедуры

&Тест
Процедура ПолучитьПропагаторыShortcut() Экспорт

    // Дано
    МокПропагатор = Новый Структура("Имя", "пропагатор");
    Сдк = Новый ОтелSdk(Неопределено, Неопределено, Неопределено, МокПропагатор);
    ОтелГлобальный.Установить(Сдк);

    // Когда
    Результат = ОтелГлобальный.ПолучитьПропагаторы();

    // Тогда
    Ожидаем.Что(Результат).Равно(МокПропагатор);

КонецПроцедуры

&Тест
Процедура ПолучитьПропагаторыБезИнициализацииВозвращаетНеопределено() Экспорт

    // Дано / Когда - noop SDK не содержит пропагаторов
    Результат = ОтелГлобальный.ПолучитьПропагаторы();

    // Тогда
    Ожидаем.Что(Результат).Равно(Неопределено);

КонецПроцедуры
