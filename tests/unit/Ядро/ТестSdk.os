&ПослеКаждого
Процедура Очистка() Экспорт
    ОтелГлобальный.Сбросить();
КонецПроцедуры

&Тест
Процедура ПостроениеSdk() Экспорт

    // Дано
    МокПровТрасс = Новый Структура("Тип", "Трассировка");
    МокПровЛог = Новый Структура("Тип", "Логирование");
    МокПровМетр = Новый Структура("Тип", "Метрики");

    // Когда
    Сдк = Новый ОтелSdk(МокПровТрасс, МокПровЛог, МокПровМетр);

    // Тогда
    Ожидаем.Что(Сдк.ПровайдерТрассировки()).Равно(МокПровТрасс);
    Ожидаем.Что(Сдк.ПровайдерЛогирования()).Равно(МокПровЛог);
    Ожидаем.Что(Сдк.ПровайдерМетрик()).Равно(МокПровМетр);

КонецПроцедуры

&Тест
Процедура ПостроительFluent() Экспорт

    // Дано
    МокПровТрасс = Новый Структура("Тип", "Трассировка");
    МокПровЛог = Новый Структура("Тип", "Логирование");
    МокПровМетр = Новый Структура("Тип", "Метрики");

    // Когда
    Сдк = Новый ОтелПостроительSdk()
        .УстановитьПровайдерТрассировки(МокПровТрасс)
        .УстановитьПровайдерЛогирования(МокПровЛог)
        .УстановитьПровайдерМетрик(МокПровМетр)
        .Построить();

    // Тогда
    Ожидаем.Что(Сдк.ПровайдерТрассировки()).Равно(МокПровТрасс);
    Ожидаем.Что(Сдк.ПровайдерЛогирования()).Равно(МокПровЛог);
    Ожидаем.Что(Сдк.ПровайдерМетрик()).Равно(МокПровМетр);

КонецПроцедуры

&Тест
Процедура ПостроитьИЗарегистрироватьГлобально() Экспорт

    // Дано
    МокПров = Новый Структура("Тип", "Трассировка");

    // Когда
    Сдк = Новый ОтелПостроительSdk()
        .УстановитьПровайдерТрассировки(МокПров)
        .ПостроитьИЗарегистрироватьГлобально();

    // Тогда
    Ожидаем.Что(ОтелГлобальный.Получить()).Равно(Сдк);

КонецПроцедуры

&Тест
Процедура СброситьБуфер() Экспорт

    // Дано
    ТекстПровайдера = "
    |Перем ВызванСброситьБуфер Экспорт;
    |Процедура СброситьБуфер(ТаймаутМс = 0) Экспорт
    |    ВызванСброситьБуфер = Истина;
    |КонецПроцедуры
    |Процедура Закрыть() Экспорт
    |КонецПроцедуры
    |ВызванСброситьБуфер = Ложь;";
    МокПров1 = ЗагрузитьСценарийИзСтроки(ТекстПровайдера);
    МокПров2 = ЗагрузитьСценарийИзСтроки(ТекстПровайдера);
    МокПров3 = ЗагрузитьСценарийИзСтроки(ТекстПровайдера);

    Сдк = Новый ОтелSdk(МокПров1, МокПров2, МокПров3);

    // Когда
    Сдк.СброситьБуфер();

    // Тогда
    Ожидаем.Что(МокПров1.ВызванСброситьБуфер).Равно(Истина);
    Ожидаем.Что(МокПров2.ВызванСброситьБуфер).Равно(Истина);
    Ожидаем.Что(МокПров3.ВызванСброситьБуфер).Равно(Истина);

КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт

    // Дано
    ТекстПровайдера = "
    |Перем ВызванЗакрыть Экспорт;
    |Процедура СброситьБуфер(ТаймаутМс = 0) Экспорт
    |КонецПроцедуры
    |Процедура Закрыть() Экспорт
    |    ВызванЗакрыть = Истина;
    |КонецПроцедуры
    |ВызванЗакрыть = Ложь;";
    МокПров1 = ЗагрузитьСценарийИзСтроки(ТекстПровайдера);
    МокПров2 = ЗагрузитьСценарийИзСтроки(ТекстПровайдера);
    МокПров3 = ЗагрузитьСценарийИзСтроки(ТекстПровайдера);

    Сдк = Новый ОтелSdk(МокПров1, МокПров2, МокПров3);

    // Когда
    Сдк.Закрыть();

    // Тогда
    Ожидаем.Что(МокПров1.ВызванЗакрыть).Равно(Истина);
    Ожидаем.Что(МокПров2.ВызванЗакрыть).Равно(Истина);
    Ожидаем.Что(МокПров3.ВызванЗакрыть).Равно(Истина);

КонецПроцедуры

&Тест
Процедура SdkБезПровайдеров() Экспорт

    // Дано / Когда
    Сдк = Новый ОтелSdk();

    // Тогда
    Ожидаем.Что(Сдк.ПровайдерТрассировки()).Равно(Неопределено);
    Ожидаем.Что(Сдк.ПровайдерЛогирования()).Равно(Неопределено);
    Ожидаем.Что(Сдк.ПровайдерМетрик()).Равно(Неопределено);

    // СброситьБуфер и Закрыть не должны вызывать ошибку
    Сдк.СброситьБуфер();
    Сдк.Закрыть();

КонецПроцедуры
