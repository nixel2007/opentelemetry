&ПослеКаждого
Процедура ОчисткаКонтекста() Экспорт
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НоваяОбластьНеЗакрыта() Экспорт

    // Дано / Когда
    Область = Новый ОтелОбласть();

    // Тогда
    Ожидаем.Что(Область.Закрыта()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЗакрытиеОбласти() Экспорт

    // Дано
    Область = ОтелКонтекст.УстановитьЗначение("test-key", "test-value");

    // Когда
    Область.Закрыть();

    // Тогда
    Ожидаем.Что(Область.Закрыта()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ИдемпотентностьЗакрытия() Экспорт

    // Дано
    Область = ОтелКонтекст.УстановитьЗначение("test-key", "test-value");

    // Когда
    Область.Закрыть();
    Область.Закрыть();

    // Тогда
    Ожидаем.Что(Область.Закрыта()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ВосстановлениеКонтекста() Экспорт

    // Дано
    ОбластьВнешняя = ОтелКонтекст.УстановитьЗначение("key", "outer");
    Ожидаем.Что(ОтелКонтекст.Получить("key")).Равно("outer");

    ОбластьВнутренняя = ОтелКонтекст.УстановитьЗначение("key", "inner");
    Ожидаем.Что(ОтелКонтекст.Получить("key")).Равно("inner");

    // Когда
    ОбластьВнутренняя.Закрыть();

    // Тогда
    Ожидаем.Что(ОтелКонтекст.Получить("key")).Равно("outer");

    ОбластьВнешняя.Закрыть();
    Ожидаем.Что(ОтелКонтекст.Получить("key")).Равно(Неопределено);

КонецПроцедуры
