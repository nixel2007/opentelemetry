&ПослеКаждого
Процедура ОчисткаКонтекста() Экспорт
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура НовыйТокенНеОтсоединён() Экспорт

    // Дано / Когда
    Токен = Новый ОтелТокенКонтекста();

    // Тогда
    Ожидаем.Что(Токен.Отсоединён()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ЗакрытиеТокена() Экспорт

    // Дано
    Ключ = ОтелКонтекст.СоздатьКлюч("test-key");
    Токен = ОтелКонтекст.УстановитьЗначение(Ключ, "test-value");

    // Когда
    Токен.Закрыть();

    // Тогда
    Ожидаем.Что(Токен.Отсоединён()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ИдемпотентностьЗакрытия() Экспорт

    // Дано
    Ключ = ОтелКонтекст.СоздатьКлюч("test-key");
    Токен = ОтелКонтекст.УстановитьЗначение(Ключ, "test-value");

    // Когда
    Токен.Закрыть();
    Токен.Закрыть();

    // Тогда
    Ожидаем.Что(Токен.Отсоединён()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ВосстановлениеКонтекста() Экспорт

    // Дано
    Ключ = ОтелКонтекст.СоздатьКлюч("key");
    ТокенВнешний = ОтелКонтекст.УстановитьЗначение(Ключ, "outer");
    Ожидаем.Что(ОтелКонтекст.Получить(Ключ)).Равно("outer");

    ТокенВнутренний = ОтелКонтекст.УстановитьЗначение(Ключ, "inner");
    Ожидаем.Что(ОтелКонтекст.Получить(Ключ)).Равно("inner");

    // Когда
    ТокенВнутренний.Закрыть();

    // Тогда
    Ожидаем.Что(ОтелКонтекст.Получить(Ключ)).Равно("outer");

    ТокенВнешний.Закрыть();
    Ожидаем.Что(ОтелКонтекст.Получить(Ключ)).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ТокенСодержитГлубинуИИдПотока() Экспорт

    // Дано
    Ключ = ОтелКонтекст.СоздатьКлюч("k");

    // Когда: первый Attach в чистом стеке
    Токен = ОтелКонтекст.УстановитьЗначение(Ключ, "v");

    // Тогда: глубина = 0 (стек был пуст до push), ИдПотока зафиксирован
    Ожидаем.Что(Токен.Глубина).Равно(0);
    Ожидаем.Что(ТипЗнч(Токен.ИдПотока)).Равно(Тип("Строка"));

    Токен.Закрыть();

КонецПроцедуры
