&Тест
Процедура УстановкаАтрибута() Экспорт

    // Дано / Когда
    Ресурс = Новый ОтелПостроительРесурса()
        .Установить("service.name", "test")
        .Построить();

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("test");

КонецПроцедуры

&Тест
Процедура УстановитьВсе() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("k1", "v1");
    Атрибуты.Установить("k2", "v2");

    // Когда
    Ресурс = Новый ОтелПостроительРесурса()
        .УстановитьВсе(Атрибуты)
        .Построить();

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("k1")).Равно("v1");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("k2")).Равно("v2");

КонецПроцедуры

&Тест
Процедура СлитьС() Экспорт

    // Дано
    ИсходныйРесурс = Новый ОтелРесурс(Истина);
    ИсходныйРесурс.Атрибуты().Установить("from.resource", "yes");

    // Когда
    Ресурс = Новый ОтелПостроительРесурса()
        .Установить("from.builder", "yes")
        .СлитьС(ИсходныйРесурс)
        .Построить();

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("from.builder")).Равно("yes");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("from.resource")).Равно("yes");

КонецПроцедуры

&Тест
Процедура ЦепочкаFluent() Экспорт

    // Дано / Когда
    Ресурс = Новый ОтелПостроительРесурса()
        .Установить("service.name", "my-service")
        .Установить("service.version", "1.0.0")
        .Установить("deployment.environment", "production")
        .Построить();

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("my-service");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.version")).Равно("1.0.0");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("deployment.environment")).Равно("production");

КонецПроцедуры
