&Тест
Процедура СозданиеСМинимальнымиПараметрами() Экспорт

    // Дано / Когда
    Скоуп = Новый ОтелСкоупИнструментирования("моя-библиотека");

    // Тогда
    Ожидаем.Что(Скоуп.Имя()).Равно("моя-библиотека");
    Ожидаем.Что(Скоуп.Версия()).Равно("");
    Ожидаем.Что(Скоуп.SchemaUrl()).Равно("");
    Ожидаем.Что(Скоуп.Атрибуты()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура СозданиеСоВсемиПараметрами() Экспорт

    // Дано
    Атр = Новый ОтелАтрибуты();
    Атр.Установить("scope.key", "scope.val");

    // Когда
    Скоуп = Новый ОтелСкоупИнструментирования("моя-библ", "1.2.3", Атр, "https://schema.example.com");

    // Тогда
    Ожидаем.Что(Скоуп.Имя()).Равно("моя-библ");
    Ожидаем.Что(Скоуп.Версия()).Равно("1.2.3");
    Ожидаем.Что(Скоуп.SchemaUrl()).Равно("https://schema.example.com");
    Ожидаем.Что(Скоуп.Атрибуты().Получить("scope.key")).Равно("scope.val");

КонецПроцедуры

&Тест
Процедура Ключ() Экспорт

    // Дано
    Скоуп1 = Новый ОтелСкоупИнструментирования("библ1", "1.0");
    Скоуп2 = Новый ОтелСкоупИнструментирования("библ1", "1.0");
    Скоуп3 = Новый ОтелСкоупИнструментирования("библ1", "2.0");

    // Тогда
    Ожидаем.Что(Скоуп1.Ключ()).Равно(Скоуп2.Ключ());
    Ожидаем.Что(Скоуп1.Ключ() <> Скоуп3.Ключ()).Равно(Истина);

КонецПроцедуры
