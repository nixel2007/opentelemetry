&ПослеКаждого
Процедура ОчисткаКонтекста() Экспорт
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура ПустойКонтекст() Экспорт

    // Дано / Когда
    Контекст = ОтелКонтекст.Текущий();

    // Тогда
    Ожидаем.Что(Контекст).ИмеетТип("ФиксированноеСоответствие");
    Ожидаем.Что(Контекст.Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура УстановкаЗначения() Экспорт

    // Дано / Когда
    Область = ОтелКонтекст.УстановитьЗначение("key", "val");

    // Тогда
    Ожидаем.Что(ОтелКонтекст.Получить("key")).Равно("val");

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ВложенныеКонтексты() Экспорт

    // Дано
    Область1 = ОтелКонтекст.УстановитьЗначение("key", "val1");
    Ожидаем.Что(ОтелКонтекст.Получить("key")).Равно("val1");

    // Когда
    Область2 = ОтелКонтекст.УстановитьЗначение("key", "val2");

    // Тогда
    Ожидаем.Что(ОтелКонтекст.Получить("key")).Равно("val2");

    Область2.Закрыть();
    Ожидаем.Что(ОтелКонтекст.Получить("key")).Равно("val1");

    Область1.Закрыть();

КонецПроцедуры

&Тест
Процедура ТекущийСпан() Экспорт

    // Дано
    МокСпан = Новый Структура("Имя", "тестовый-спан");

    // Когда
    Область = ОтелКонтекст.СделатьСпанТекущим(МокСпан);

    // Тогда
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(МокСпан);

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ТекущийBaggage() Экспорт

    // Дано
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("key", "val")
        .Построить();

    // Когда
    Область = ОтелКонтекст.СделатьBaggageТекущим(Багаж);

    // Тогда
    ТекущийБагаж = ОтелКонтекст.ТекущийBaggage();
    Ожидаем.Что(ТекущийБагаж.Получить("key")).Равно("val");

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура НезависимостьСпанаИBaggage() Экспорт

    // Дано
    МокСпан = Новый Структура("Имя", "тестовый-спан");
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("key", "val")
        .Построить();

    // Когда
    ОбластьСпана = ОтелКонтекст.СделатьСпанТекущим(МокСпан);
    ОбластьБагажа = ОтелКонтекст.СделатьBaggageТекущим(Багаж);

    // Тогда
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан()).Равно(МокСпан);
    Ожидаем.Что(ОтелКонтекст.ТекущийBaggage().Получить("key")).Равно("val");

    ОбластьБагажа.Закрыть();
    ОбластьСпана.Закрыть();

КонецПроцедуры

&Тест
Процедура Очистить() Экспорт

    // Дано
    ОтелКонтекст.УстановитьЗначение("key1", "val1");
    ОтелКонтекст.УстановитьЗначение("key2", "val2");
    Ожидаем.Что(ОтелКонтекст.Текущий().Количество() > 0).Равно(Истина);

    // Когда
    ОтелКонтекст.Очистить();

    // Тогда
    Ожидаем.Что(ОтелКонтекст.Текущий().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура ОтсоединитьКонтекстЧерезТокен() Экспорт

    // Дано
    МокСпан1 = Новый Структура("Имя", "спан1");
    МокСпан2 = Новый Структура("Имя", "спан2");
    Токен1 = ОтелКонтекст.СделатьСпанТекущим(МокСпан1);
    Токен2 = ОтелКонтекст.СделатьСпанТекущим(МокСпан2);
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан().Имя).Равно("спан2");

    // Когда
    Результат = ОтелКонтекст.ОтсоединитьКонтекст(Токен2);

    // Тогда
    Ожидаем.Что(Результат).Равно(Истина);
    Ожидаем.Что(ОтелКонтекст.ТекущийСпан().Имя).Равно("спан1");

    // И - повторное отсоединение того же токена идемпотентно
    Ожидаем.Что(ОтелКонтекст.ОтсоединитьКонтекст(Токен2)).Равно(Истина);

    // Чистим стек
    ОтелКонтекст.ОтсоединитьКонтекст(Токен1);

КонецПроцедуры

&Тест
Процедура ОтсоединениеТокенаВНарушенномПорядкеЗаписываетПредупреждение() Экспорт

    // Дано: два присоединения, но отсоединяем сначала «нижний» токен
    МокСпан1 = Новый Структура("Имя", "спан1");
    МокСпан2 = Новый Структура("Имя", "спан2");
    Токен1 = ОтелКонтекст.СделатьСпанТекущим(МокСпан1);
    Токен2 = ОтелКонтекст.СделатьСпанТекущим(МокСпан2);

    // Когда: отсоединяем нижний токен (нарушение порядка)
    Результат = ОтелКонтекст.ОтсоединитьКонтекст(Токен1);

    // Тогда: API сообщает о нарушении, но восстанавливает стек до глубины токена
    Ожидаем.Что(Результат).Равно(Ложь);
    Ожидаем.Что(ОтелКонтекст.Текущий().Количество()).Равно(0);

    // И - явный Detach Токен2 после нарушения порядка возвращает Ложь (стек уже пуст)
    Ожидаем.Что(ОтелКонтекст.ОтсоединитьКонтекст(Токен2)).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ОтсоединитьКонтекстСПустымТокеном() Экспорт

    // Когда / Тогда: вызов с Неопределено возвращает Ложь и не падает
    Ожидаем.Что(ОтелКонтекст.ОтсоединитьКонтекст(Неопределено)).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура КоличествоОтслеживаемыхПотоков() Экспорт

    // Дано - после Очистить() запись потока остается
    Ожидаем.Что(ОтелКонтекст.КоличествоОтслеживаемыхПотоков() >= 0).Равно(Истина);

    // Когда - создаем контекст в текущем потоке
    Область = ОтелКонтекст.УстановитьЗначение("test-key", "test-val");

    // Тогда - как минимум один поток отслеживается
    Ожидаем.Что(ОтелКонтекст.КоличествоОтслеживаемыхПотоков() >= 1).Равно(Истина);

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ОчисткаНеУдаляетТекущийПоток() Экспорт

    // Дано
    ОтелКонтекст.ОчиститьМертвыеПотоки();
    Область = ОтелКонтекст.УстановитьЗначение("key", "val");
    КоличествоДо = ОтелКонтекст.КоличествоОтслеживаемыхПотоков();

    // Когда
    ОтелКонтекст.ОчиститьМертвыеПотоки();

    // Тогда - текущий поток на месте, контекст цел
    Ожидаем.Что(ОтелКонтекст.КоличествоОтслеживаемыхПотоков()).Равно(КоличествоДо);
    Ожидаем.Что(ОтелКонтекст.Получить("key")).Равно("val");

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ОчисткаУдаляетМертвыеПотоки() Экспорт

    // Дано - чистим стартовое состояние от мертвых потоков предыдущих тестов
    ОтелКонтекст.ОчиститьМертвыеПотоки();
    Область = ОтелКонтекст.УстановитьЗначение("main-key", "main-val");
    КоличествоДо = ОтелКонтекст.КоличествоОтслеживаемыхПотоков();

    // Запускаем фоновое задание, которое создаст контекст и завершится
    Задание = ФоновыеЗадания.Выполнить(ЭтотОбъект, "СоздатьКонтекстВФоне");
    Задание.ОжидатьЗавершения();

    // Мертвый поток добавил запись
    Ожидаем.Что(ОтелКонтекст.КоличествоОтслеживаемыхПотоков()).Равно(КоличествоДо + 1);

    // Когда
    ОтелКонтекст.ОчиститьМертвыеПотоки();

    // Тогда - мертвый поток удален, текущий цел
    Ожидаем.Что(ОтелКонтекст.КоличествоОтслеживаемыхПотоков()).Равно(КоличествоДо);
    Ожидаем.Что(ОтелКонтекст.Получить("main-key")).Равно("main-val");

    Область.Закрыть();

КонецПроцедуры

// Вспомогательный метод для фонового задания.
// Создает контекст в потоке фонового задания и не закрывает область (имитация утечки).
//
Процедура СоздатьКонтекстВФоне() Экспорт
    ОтелКонтекст.УстановитьЗначение("bg-key", "bg-val");
КонецПроцедуры
