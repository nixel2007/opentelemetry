&ПослеКаждого
Процедура ОчисткаКонтекста() Экспорт
    ОтелКонтекст.Очистить();
КонецПроцедуры

&Тест
Процедура СозданиеЧерезПостроитель() Экспорт

    // Дано / Когда
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("userId", "123")
        .Установить("tenantId", "abc")
        .Построить();

    // Тогда
    Ожидаем.Что(Багаж.Получить("userId")).Равно("123");
    Ожидаем.Что(Багаж.Получить("tenantId")).Равно("abc");
    Ожидаем.Что(Багаж.Количество()).Равно(2);

КонецПроцедуры

&Тест
Процедура Иммутабельность() Экспорт

    // Дано
    Оригинал = Новый ОтелПостроительBaggage()
        .Установить("key1", "val1")
        .Построить();

    // Когда
    Новый_ = Оригинал.Установить("key2", "val2");

    // Тогда
    Ожидаем.Что(Оригинал.Количество()).Равно(1);
    Ожидаем.Что(Новый_.Количество()).Равно(2);
    Ожидаем.Что(Оригинал.Получить("key2")).Равно(Неопределено);
    Ожидаем.Что(Новый_.Получить("key2")).Равно("val2");

КонецПроцедуры

&Тест
Процедура УдалениеКлюча() Экспорт

    // Дано
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("key1", "val1")
        .Установить("key2", "val2")
        .Построить();

    // Когда
    НовыйБагаж = Багаж.Удалить("key1");

    // Тогда
    Ожидаем.Что(НовыйБагаж.Количество()).Равно(1);
    Ожидаем.Что(НовыйБагаж.Получить("key1")).Равно(Неопределено);
    Ожидаем.Что(НовыйБагаж.Получить("key2")).Равно("val2");
    // Оригинал не изменился
    Ожидаем.Что(Багаж.Количество()).Равно(2);

КонецПроцедуры

&Тест
Процедура ТоПостроитель() Экспорт

    // Дано
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("key1", "val1")
        .Построить();

    // Когда
    НовыйБагаж = Багаж.ТоПостроитель()
        .Установить("key2", "val2")
        .Построить();

    // Тогда
    Ожидаем.Что(НовыйБагаж.Получить("key1")).Равно("val1");
    Ожидаем.Что(НовыйБагаж.Получить("key2")).Равно("val2");
    Ожидаем.Что(НовыйБагаж.Количество()).Равно(2);

КонецПроцедуры

&Тест
Процедура ТекущийИСделатьТекущим() Экспорт

    // Дано
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("key", "val")
        .Построить();

    // Когда
    Область = Багаж.СделатьТекущим();

    // Тогда
    ТекущийБагаж = ОтелКонтекст.ТекущийBaggage();
    Ожидаем.Что(ТекущийБагаж.Получить("key")).Равно("val");

    // Восстанавливаем контекст
    Область.Закрыть();
    Ожидаем.Что(ОтелКонтекст.ТекущийBaggage()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ПустойBaggage() Экспорт

    // Дано / Когда
    Багаж = Новый ОтелBaggage();

    // Тогда
    Ожидаем.Что(Багаж.Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура СтатическийМетодТекущий() Экспорт

    // Дано
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("skey", "sval")
        .Построить();
    Область = Багаж.СделатьТекущим();

    // Когда - используем контекстный метод ТекущийBaggage
    ТекущийБагаж = ОтелКонтекст.ТекущийBaggage();

    // Тогда
    Ожидаем.Что(ТекущийБагаж.Получить("skey")).Равно("sval");

    Область.Закрыть();

КонецПроцедуры

&Тест
Процедура ПолучитьВсе() Экспорт

    // Дано
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("a", "1")
        .Установить("b", "2")
        .Построить();

    // Когда
    Все = Багаж.ПолучитьВсе();

    // Тогда
    Ожидаем.Что(Все.Количество()).Равно(2);
    Ожидаем.Что(Все.Получить("a")).Равно("1");

КонецПроцедуры

&Тест
Процедура МетодТекущийЧерезЭкземпляр() Экспорт

    // Дано
    Багаж = Новый ОтелПостроительBaggage()
        .Установить("skey", "sval")
        .Построить();
    Область = Багаж.СделатьТекущим();

    // Когда - вызываем Текущий() через экземпляр
    ТекущийБагаж = Багаж.Текущий();

    // Тогда
    Ожидаем.Что(ТекущийБагаж.Получить("skey")).Равно("sval");

    Область.Закрыть();

КонецПроцедуры
