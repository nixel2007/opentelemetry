// BSLLS:DuplicatedInsertionIntoCollection-off

&Тест
Процедура Тест_Успех() Экспорт

    // Дано
    Результат = ОтелРезультатыЭкспорта.Успех();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);
    Ожидаем.Что(Результат.Статус()).Равно(0);

КонецПроцедуры

&Тест
Процедура Тест_Ошибка() Экспорт

    // Дано
    Результат = ОтелРезультатыЭкспорта.Ошибка();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Ожидаем.Что(Результат.Статус()).Равно(1);

КонецПроцедуры

&Тест
Процедура Тест_ВПроцессе() Экспорт

    // Дано
    Результат = Новый ОтелРезультатЭкспорта();

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);
    Ожидаем.Что(Результат.Статус()).Равно(-1);

КонецПроцедуры

&Тест
Процедура Тест_ОжидатьВозвращаетСебя() Экспорт

    // Дано
    Результат = ОтелРезультатыЭкспорта.Успех();

    // Когда
    ВозвращенныйОбъект = Результат.Ожидать();

    // Тогда
    Ожидаем.Что(ВозвращенныйОбъект).Равно(Результат);

КонецПроцедуры

&Тест
Процедура Тест_ОжидатьВсеУспех() Экспорт

    // Дано
    Массив = Новый Массив();
    Массив.Добавить(ОтелРезультатыЭкспорта.Успех());
    Массив.Добавить(ОтелРезультатыЭкспорта.Успех());
    Массив.Добавить(ОтелРезультатыЭкспорта.Успех());

    // Когда
    Результат = ОтелРезультатыЭкспорта.ОжидатьВсе(Массив);

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура Тест_ОжидатьВсеОшибка() Экспорт

    // Дано
    Массив = Новый Массив();
    Массив.Добавить(ОтелРезультатыЭкспорта.Успех());
    Массив.Добавить(ОтелРезультатыЭкспорта.Ошибка());
    Массив.Добавить(ОтелРезультатыЭкспорта.Успех());

    // Когда
    Результат = ОтелРезультатыЭкспорта.ОжидатьВсе(Массив);

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура Тест_ОжидатьВсеПустойМассив() Экспорт

    // Дано
    Массив = Новый Массив();

    // Когда
    Результат = ОтелРезультатыЭкспорта.ОжидатьВсе(Массив);

    // Тогда
    Ожидаем.Что(Результат.Успешно()).Равно(Истина);

КонецПроцедуры

&Тест
Процедура Тест_СОбещаниемБезОбещания() Экспорт

    // Дано - результат "в процессе" без обещания
    Результат = Новый ОтелРезультатЭкспорта();

    // Когда - ожидание не вызывает ошибку
    ВозвращенныйОбъект = Результат.Ожидать();

    // Тогда
    Ожидаем.Что(ВозвращенныйОбъект).Равно(Результат);

КонецПроцедуры
