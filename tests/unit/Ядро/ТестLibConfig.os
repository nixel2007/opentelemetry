// BSLLS:MagicNumber-off
// BSLLS:MissingVariablesDescription-off
// BSLLS:PublicMethodsDescription-off
// BSLLS:MissingParameterDescription-off
// BSLLS:MissingReturnedValueDescription-off
#Использовать "../../.."
#Использовать asserts

#Область Тесты

&Тест
Процедура ВсеФайлыSrcЗарегистрированыВLibConfig() Экспорт
    КаталогПроекта = Новый Файл(ОбъединитьПути(ТекущийСценарий().Каталог, "..", "..", "..")).ПолноеИмя;
    ПутьLibConfig = ОбъединитьПути(КаталогПроекта, "lib.config");
    КаталогSrc = ОбъединитьПути(КаталогПроекта, "src");

    // Читаем lib.config и собираем все пути из атрибута file=
    ПутиВLibConfig = Новый Соответствие;
    ЧтениеXML = Новый ЧтениеXML;
    ЧтениеXML.ОткрытьФайл(ПутьLibConfig);
    Пока ЧтениеXML.Прочитать() Цикл
        Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
            ЗначениеФайла = ЧтениеXML.ПолучитьАтрибут("file");
            Если ЗначениеФайла <> Неопределено И ЗначениеФайла <> "" Тогда
                ПутиВLibConfig.Вставить(ЗначениеФайла, Истина);
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
    ЧтениеXML.Закрыть();

    // Проверяем что каждый path из lib.config существует на диске
    НесуществующиеФайлы = Новый Массив;
    Для Каждого КП Из ПутиВLibConfig Цикл
        ПолныйПуть = ОбъединитьПути(КаталогПроекта, КП.Ключ);
        ФайлОбъект = Новый Файл(ПолныйПуть);
        Если НЕ ФайлОбъект.Существует() Тогда
            НесуществующиеФайлы.Добавить(КП.Ключ);
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НесуществующиеФайлы).ИмеетДлину(0);

    // Собираем все .os файлы из src/ (кроме fake-entrypoint.os)
    ФайлыSrc = НайтиФайлы(КаталогSrc, "*.os", Истина);
    НезарегистрированныеФайлы = Новый Массив;
    Для Каждого Файл Из ФайлыSrc Цикл
        Если Файл.Имя = "fake-entrypoint.os" Тогда
            Продолжить;
        КонецЕсли;
        ОтносительныйПуть = СтрЗаменить(Файл.ПолноеИмя, КаталогПроекта + ПолучитьРазделительПути(), "");
        ОтносительныйПутьСлэш = СтрЗаменить(ОтносительныйПуть, "\", "/");
        Если ПутиВLibConfig.Получить(ОтносительныйПутьСлэш) = Неопределено Тогда
            НезарегистрированныеФайлы.Добавить(ОтносительныйПутьСлэш);
        КонецЕсли;
    КонецЦикла;
    Ожидаем.Что(НезарегистрированныеФайлы).ИмеетДлину(0);
КонецПроцедуры

#КонецОбласти
