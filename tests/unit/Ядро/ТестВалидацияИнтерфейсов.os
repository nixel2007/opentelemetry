    МокЭкспортер = Мок.Получить(Тип("ОтелЭкспортерСпанов"));
    Базовый = Новый ОтелБазовыйПакетныйПроцессор(МокЭкспортер, "тест", 2048, 512);
    Объект = Новый ПостроительНаследника(Новый ОтелПакетныйПроцессорСпанов(), Базовый).Построить();
    Валидатор.ИнтерфейсыРеализованыКорректно(Объект);
КонецПроцедуры

