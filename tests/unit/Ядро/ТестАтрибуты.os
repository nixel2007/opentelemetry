КонецПроцедуры

&Тест
Процедура ВМассивOtlpМассивСтрок() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    МассивЗначений = Новый Массив();
    МассивЗначений.Добавить("a");
    МассивЗначений.Добавить("b");
    МассивЗначений.Добавить("c");
    Атрибуты.Установить("tags", МассивЗначений);

    // Когда
    Массив = Атрибуты.ВМассивOtlp();

    // Тогда
    Элемент = Массив[0];
    Ожидаем.Что(Элемент["key"]).Равно("tags");
    ЗначениеМассива = Элемент["value"]["arrayValue"];
    Ожидаем.Что(ЗначениеМассива).ИмеетТип("Соответствие");
    Значения = ЗначениеМассива["values"];
    Ожидаем.Что(Значения).ИмеетДлину(3);
    Ожидаем.Что(Значения[0]["stringValue"]).Равно("a");
    Ожидаем.Что(Значения[1]["stringValue"]).Равно("b");
    Ожидаем.Что(Значения[2]["stringValue"]).Равно("c");

КонецПроцедуры

&Тест
Процедура ВМассивOtlpМассивЧисел() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    МассивЗначений = Новый Массив();
    МассивЗначений.Добавить(1);
    МассивЗначений.Добавить(2);
    МассивЗначений.Добавить(3);
    Атрибуты.Установить("ids", МассивЗначений);

    // Когда
    Массив = Атрибуты.ВМассивOtlp();

    // Тогда
    Элемент = Массив[0];
    Значения = Элемент["value"]["arrayValue"]["values"];
    Ожидаем.Что(Значения).ИмеетДлину(3);
    Ожидаем.Что(Значения[0]["intValue"]).Равно("1");
    Ожидаем.Что(Значения[1]["intValue"]).Равно("2");
    Ожидаем.Что(Значения[2]["intValue"]).Равно("3");

КонецПроцедуры

&Тест
Процедура ВМассивOtlpМассивБулевых() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    МассивЗначений = Новый Массив();
    МассивЗначений.Добавить(Истина);
    МассивЗначений.Добавить(Ложь);
    Атрибуты.Установить("flags", МассивЗначений);

    // Когда
    Массив = Атрибуты.ВМассивOtlp();

    // Тогда
    Элемент = Массив[0];
    Значения = Элемент["value"]["arrayValue"]["values"];
    Ожидаем.Что(Значения).ИмеетДлину(2);
    Ожидаем.Что(Значения[0]["boolValue"]).Равно(Истина);
    Ожидаем.Что(Значения[1]["boolValue"]).Равно(Ложь);

КонецПроцедуры

&Тест
Процедура ВМассивOtlpМассивДробных() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    МассивЗначений = Новый Массив();
