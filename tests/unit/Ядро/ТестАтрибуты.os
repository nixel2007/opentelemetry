&Тест
Процедура УстановкаИПолучениеАтрибута() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();

    // Когда
    Атрибуты.Установить("key1", "value1");

    // Тогда
    Ожидаем.Что(Атрибуты.Получить("key1")).Равно("value1");

КонецПроцедуры

&Тест
Процедура ЦепочкаВызовов() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();

    // Когда
    Результат = Атрибуты.Установить("a", "1").Установить("b", "2");

    // Тогда
    Ожидаем.Что(Атрибуты.Получить("a")).Равно("1");
    Ожидаем.Что(Атрибуты.Получить("b")).Равно("2");
    Ожидаем.Что(Результат).Равно(Атрибуты);

КонецПроцедуры

&Тест
Процедура УдалениеАтрибута() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("key1", "value1");

    // Когда
    Атрибуты.Удалить("key1");

    // Тогда
    Ожидаем.Что(Атрибуты.Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура Количество() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();

    // Когда
    Атрибуты.Установить("k1", "v1");
    Атрибуты.Установить("k2", "v2");
    Атрибуты.Установить("k3", "v3");

    // Тогда
    Ожидаем.Что(Атрибуты.Количество()).Равно(3);

КонецПроцедуры

&Тест
Процедура ВСоответствие() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("key", "value");

    // Когда
    Результат = Атрибуты.ВСоответствие();

    // Тогда
    Ожидаем.Что(Результат).ИмеетТип("Соответствие");
    Ожидаем.Что(Результат["key"]).Равно("value");

КонецПроцедуры

&Тест
Процедура ВМассивOtlpСтрока() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("k", "v");

    // Когда
    Массив = Атрибуты.ВМассивOtlp();

    // Тогда
    Ожидаем.Что(Массив).ИмеетДлину(1);
    Элемент = Массив[0];
    Ожидаем.Что(Элемент["key"]).Равно("k");
    Ожидаем.Что(Элемент["value"]["stringValue"]).Равно("v");

КонецПроцедуры

&Тест
Процедура ВМассивOtlpЧисло() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("count", 42);

    // Когда
    Массив = Атрибуты.ВМассивOtlp();

    // Тогда
    Элемент = Массив[0];
    Ожидаем.Что(Элемент["key"]).Равно("count");
    Ожидаем.Что(Элемент["value"]["intValue"]).Равно("42");

КонецПроцедуры

&Тест
Процедура ВМассивOtlpДробное() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
