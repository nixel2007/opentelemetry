&Тест
Процедура ВМассивOtlpБулево() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("enabled", Истина);

    // Когда
    Массив = Атрибуты.ВМассивOtlp();

    // Тогда
    Элемент = Массив[0];
    Ожидаем.Что(Элемент["key"]).Равно("enabled");
