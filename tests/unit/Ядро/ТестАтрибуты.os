    // Тогда
    Элемент = Массив[0];
    Ожидаем.Что(Элемент["key"]).Равно("ratio");
    Ожидаем.Что(Элемент["value"]["doubleValue"]).Равно(1.5);

КонецПроцедуры

&Тест
Процедура ВМассивOtlpБулево() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("enabled", Истина);

    // Когда
    Массив = Атрибуты.ВМассивOtlp();

    // Тогда
    Элемент = Массив[0];
    Ожидаем.Что(Элемент["key"]).Равно("enabled");
    Ожидаем.Что(Элемент["value"]["boolValue"]).Равно(Истина);

КонецПроцедуры
