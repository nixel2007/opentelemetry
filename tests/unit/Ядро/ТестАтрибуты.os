    Ожидаем.Что(Значения).ИмеетДлину(2);
    Ожидаем.Что(Значения[0]["doubleValue"]).Равно(1.5);
    Ожидаем.Что(Значения[1]["doubleValue"]).Равно(2.7);

КонецПроцедуры

&Тест
Процедура ВМассивOtlpПустойМассив() Экспорт

    // Дано
    Атрибуты = Новый ОтелАтрибуты();
    Атрибуты.Установить("empty", Новый Массив());

    // Когда
    Массив = Атрибуты.ВМассивOtlp();

    // Тогда
    Элемент = Массив[0];
    Значения = Элемент["value"]["arrayValue"]["values"];
