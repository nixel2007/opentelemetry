&Тест
Процедура СозданиеСДефолтами() Экспорт

    // Дано / Когда
    Ресурс = Новый ОтелРесурс();

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("unknown_service:oscript");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("telemetry.sdk.name")).Равно("opentelemetry");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("telemetry.sdk.version")).Равно("0.1.0");
    Ожидаем.Что(Ресурс.Атрибуты().Получить("telemetry.sdk.language")).Равно("oscript");

КонецПроцедуры

&Тест
Процедура СозданиеБезДефолтов() Экспорт

    // Дано / Когда
    Ресурс = Новый ОтелРесурс(Истина);

    // Тогда
    Ожидаем.Что(Ресурс.Атрибуты().Количество()).Равно(0);

КонецПроцедуры

&Тест
Процедура СозданиеСДефолтамиСливаетАтрибутыИзОкружения() Экспорт

    // Дано: env-переменные OTEL_RESOURCE_ATTRIBUTES и OTEL_SERVICE_NAME
    // Per spec (Resource SDK): MUST extract OTEL_RESOURCE_ATTRIBUTES и merge as secondary.
    УстановитьПеременнуюСреды("OTEL_RESOURCE_ATTRIBUTES", "deployment.environment=prod,team=core");
    УстановитьПеременнуюСреды("OTEL_SERVICE_NAME", "my-service");

    // Когда: создание ресурса с дефолтами напрямую (без автоконфигурации)
    Попытка
        Ресурс = Новый ОтелРесурс();

        // Тогда
        Ожидаем.Что(Ресурс.Атрибуты().Получить("deployment.environment")).Равно("prod");
        Ожидаем.Что(Ресурс.Атрибуты().Получить("team")).Равно("core");
        Ожидаем.Что(Ресурс.Атрибуты().Получить("service.name")).Равно("my-service");
    Исключение
        УстановитьПеременнуюСреды("OTEL_RESOURCE_ATTRIBUTES", "");
        УстановитьПеременнуюСреды("OTEL_SERVICE_NAME", "");
        ВызватьИсключение;
    КонецПопытки;
    УстановитьПеременнуюСреды("OTEL_RESOURCE_ATTRIBUTES", "");
    УстановитьПеременнуюСреды("OTEL_SERVICE_NAME", "");

КонецПроцедуры

&Тест
Процедура СозданиеСДефолтамиДекодируетПроцентыВАтрибутахИзОкружения() Экспорт

    // Дано: значение со спецсимволами (percent-encoded) по спеке Resource SDK
    УстановитьПеременнуюСреды("OTEL_RESOURCE_ATTRIBUTES", "label=hello%20world%2Cfoo");

    // Когда
    Попытка
        Ресурс = Новый ОтелРесурс();

        // Тогда: запятая в значении корректно декодирована, разделителем не считается
        Ожидаем.Что(Ресурс.Атрибуты().Получить("label")).Равно("hello world,foo");
    Исключение
        УстановитьПеременнуюСреды("OTEL_RESOURCE_ATTRIBUTES", "");
        ВызватьИсключение;
    КонецПопытки;
    УстановитьПеременнуюСреды("OTEL_RESOURCE_ATTRIBUTES", "");

КонецПроцедуры

&Тест
Процедура СлияниеРесурсов() Экспорт

    // Дано
    Ресурс1 = Новый ОтелРесурс(Истина);
    Ресурс1.Атрибуты().Установить("key1", "value1");
    Ресурс1.Атрибуты().Установить("shared", "from1");

    Ресурс2 = Новый ОтелРесурс(Истина);
    Ресурс2.Атрибуты().Установить("key2", "value2");
    Ресурс2.Атрибуты().Установить("shared", "from2");

    // Когда
    Результат = Ресурс1.Слить(Ресурс2);

    // Тогда
    Ожидаем.Что(Результат.Атрибуты().Получить("key1")).Равно("value1");
    Ожидаем.Что(Результат.Атрибуты().Получить("key2")).Равно("value2");
    Ожидаем.Что(Результат.Атрибуты().Получить("shared")).Равно("from2");

КонецПроцедуры

&Тест
Процедура ВСоответствиеOtlp() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Ресурс.Атрибуты().Установить("service.name", "test");

    // Когда
    Результат = Ресурс.ВСоответствиеOtlp();

    // Тогда
    Ожидаем.Что(Результат).ИмеетТип("Соответствие");
    МассивАтрибутов = Результат["attributes"];
    Ожидаем.Что(МассивАтрибутов).ИмеетТип("Массив");
    Ожидаем.Что(МассивАтрибутов).ИмеетДлину(1);
    Ожидаем.Что(МассивАтрибутов[0]["key"]).Равно("service.name");

КонецПроцедуры

&Тест
Процедура ТестСлитьДваРесурса() Экспорт

    // Дано
    Ресурс1 = Новый ОтелРесурс(Истина);
    Ресурс1.Атрибуты().Установить("key1", "val1");
    Ресурс1.Атрибуты().Установить("shared", "from_first");

    Ресурс2 = Новый ОтелРесурс(Истина);
    Ресурс2.Атрибуты().Установить("key2", "val2");
    Ресурс2.Атрибуты().Установить("shared", "from_second");

    // Когда
    Результат = Ресурс1.Слить(Ресурс2);

    // Тогда - другой ресурс побеждает при конфликте
    Ожидаем.Что(Результат.Атрибуты().Получить("key1")).Равно("val1");
    Ожидаем.Что(Результат.Атрибуты().Получить("key2")).Равно("val2");
    Ожидаем.Что(Результат.Атрибуты().Получить("shared")).Равно("from_second");

КонецПроцедуры

&Тест
Процедура ТестСлитьАдресСхемы() Экспорт

    // Если первый пустой - берем от второго
    Ресурс1 = Новый ОтелРесурс(Истина);
    Ресурс2 = Новый ОтелРесурс(Истина, "https://schema.example.com");

    Результат = Ресурс1.Слить(Ресурс2);
    Ожидаем.Что(Результат.АдресСхемы()).Равно("https://schema.example.com");

КонецПроцедуры

&Тест
Процедура ТестСлитьНеМутируетОригинал() Экспорт

    // Дано
    Ресурс1 = Новый ОтелРесурс(Истина);
    Ресурс1.Атрибуты().Установить("key1", "val1");

    Ресурс2 = Новый ОтелРесурс(Истина);
    Ресурс2.Атрибуты().Установить("key2", "val2");

    // Когда
    Результат = Ресурс1.Слить(Ресурс2);

    // Тогда - оригинал не изменен
    Ожидаем.Что(Ресурс1.Атрибуты().Получить("key2")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ТестOtlpDroppedAttributesCount() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс(Истина);
    Ресурс.Атрибуты().Установить("key", "value");

    // Когда
    Результат = Ресурс.ВСоответствиеOtlp();

    // Тогда - droppedAttributesCount всегда 0 (Resource не имеет лимитов)
    Ожидаем.Что(Результат.Получить("droppedAttributesCount")).Равно(0);
    Ожидаем.Что(Результат.Получить("attributes") <> Неопределено).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ТестСлитьКонфликтАдресСхемы() Экспорт

    // Дано - два ресурса с РАЗНЫМИ непустыми schemaUrl
    Ресурс1 = Новый ОтелРесурс(Истина, "https://schema1.example.com");
    Ресурс1.Атрибуты().Установить("k1", "v1");
    Ресурс2 = Новый ОтелРесурс(Истина, "https://schema2.example.com");
    Ресурс2.Атрибуты().Установить("k2", "v2");

    // Когда - per spec: если schemaUrl различаются, результат - пустой ресурс
    Результат = Ресурс1.Слить(Ресурс2);

    // Тогда
    Ожидаем.Что(Результат.Атрибуты().Количество()).Равно(0);
    Ожидаем.Что(Результат.АдресСхемы()).Равно("");

КонецПроцедуры

&Тест
Процедура ТестСлитьОдинаковыеАдресСхемы() Экспорт

    // Дано - два ресурса с ОДИНАКОВЫМИ schemaUrl
    Ресурс1 = Новый ОтелРесурс(Истина, "https://schema.example.com");
    Ресурс1.Атрибуты().Установить("k1", "v1");
    Ресурс2 = Новый ОтелРесурс(Истина, "https://schema.example.com");
    Ресурс2.Атрибуты().Установить("k2", "v2");

    // Когда - одинаковые schemaUrl: слияние нормальное
    Результат = Ресурс1.Слить(Ресурс2);

    // Тогда
    Ожидаем.Что(Результат.АдресСхемы()).Равно("https://schema.example.com");
    Ожидаем.Что(Результат.Атрибуты().Получить("k1")).Равно("v1");
    Ожидаем.Что(Результат.Атрибуты().Получить("k2")).Равно("v2");

КонецПроцедуры
