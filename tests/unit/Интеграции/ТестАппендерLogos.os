#Использовать "../../.."
#Использовать asserts
#Использовать moskito
#Использовать logos

&Тест
Процедура СозданиеАппендера() Экспорт

    // Когда
    Аппендер = Новый ОтелАппендерLogos();

    // Тогда - аппендер создан без логгера
    Ожидаем.Что(Аппендер.Логгер()).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура УстановкаЛоггера() Экспорт

    // Дано
    МокЛоггер = Мок.Получить(Тип("Структура"));
    Аппендер = Новый ОтелАппендерLogos();

    // Когда
    Аппендер.УстановитьЛоггер(МокЛоггер);

    // Тогда
    Ожидаем.Что(Аппендер.Логгер()).Не_().Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура Закрыть() Экспорт

    // Дано
    Аппендер = Новый ОтелАппендерLogos();

    // Когда / Тогда - закрытие не вызывает ошибку
    Аппендер.Закрыть();

КонецПроцедуры

&Тест
Процедура ВыводСобытияБезЛоггера() Экспорт

    // Дано - аппендер без логгера
    Аппендер = Новый ОтелАппендерLogos();
    Событие = Новый СобытиеЛога("test.logger", "Информация", "тестовое сообщение");

    // Когда / Тогда - не падает
    Аппендер.ВывестиСобытие(Событие);

КонецПроцедуры

&Тест
Процедура ВыводСобытияИспользуетЧистоеСообщение() Экспорт

    // Дано
    Ресурс = Новый ОтелРесурс();
    Процессор = Новый ОтелПростойПроцессорЛогов(Мок.Получить(Тип("ОтелЭкспортерЛогов")));
    Логгер = Новый ОтелЛоггер("test", "", Ресурс, Процессор);

    Аппендер = Новый ОтелАппендерLogos(Логгер);

    ВремяМс = ТекущаяУниверсальнаяДатаВМиллисекундах();
    Событие = Новый СобытиеЛога("test.logger", "Информация", "чистое сообщение", ВремяМс, УровниЛога.Информация);
    Событие.УстановитьФорматированноеСообщение("2026-03-12 20:00:00 INFO test.logger - чистое сообщение");

    // Когда
    Аппендер.ВывестиСобытие(Событие);

    // Тогда - проверяем через создание реальной записи
    // Главное - не падает и использует чистое сообщение (без дублирования уровня/имени)

КонецПроцедуры
