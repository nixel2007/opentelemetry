#Использовать cpuinfo
#Использовать logos

#Область ОписаниеПеременных

// ОтелАтрибуты - атрибуты ресурса
Перем Атрибуты;
// Строка - URL схемы ресурса
Перем АдресСхемы;
// Логгер logos - логгер для диагностических сообщений
Перем Лог;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Возвращает атрибуты ресурса.
//
// Возвращаемое значение:
//   ОтелАтрибуты - атрибуты ресурса
//
Функция Атрибуты() Экспорт
    Возврат Атрибуты;
КонецФункции

// Возвращает URL схемы ресурса.
//
// Возвращаемое значение:
//   Строка - URL схемы или пустая строка
//
Функция АдресСхемы() Экспорт
    Возврат АдресСхемы;
КонецФункции

// Создает новый ресурс как результат слияния текущего с другим.
// Атрибуты другого ресурса имеют приоритет.
//
// Параметры:
//   ДругойРесурс - ОтелРесурс - ресурс для слияния
//
// Возвращаемое значение:
//   ОтелРесурс - новый ресурс
//
Функция Слить(ДругойРесурс) Экспорт
    // Per spec: если оба schemaUrl не пусты и различаются, результат - пустой ресурс
    Если НЕ ПустаяСтрока(АдресСхемы) И НЕ ПустаяСтрока(ДругойРесурс.АдресСхемы())
        И АдресСхемы <> ДругойРесурс.АдресСхемы() Тогда
        Возврат Новый ОтелРесурс(Истина);
    КонецЕсли;

    // АдресСхемы: берем непустой
    НовыйАдресСхемы = АдресСхемы;
    Если ПустаяСтрока(АдресСхемы) И НЕ ПустаяСтрока(ДругойРесурс.АдресСхемы()) Тогда
        НовыйАдресСхемы = ДругойРесурс.АдресСхемы();
    КонецЕсли;

    НовыйРесурс = Новый ОтелРесурс(Истина, НовыйАдресСхемы);
    Для Каждого КлючИЗначение Из Атрибуты.ВСоответствие() Цикл
        НовыйРесурс.Атрибуты().Установить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
    КонецЦикла;
    Для Каждого КлючИЗначение Из ДругойРесурс.Атрибуты().ВСоответствие() Цикл
        НовыйРесурс.Атрибуты().Установить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
    КонецЦикла;
    Возврат НовыйРесурс;
КонецФункции

// Преобразует ресурс в соответствие формата OTLP JSON.
//
// Возвращаемое значение:
//   Соответствие - {"attributes": [...]}
//
Функция ВСоответствиеOtlp() Экспорт
    Результат = Новый Соответствие();
    Результат.Вставить("attributes", Атрибуты.ВМассивOtlp());
    Результат.Вставить("droppedAttributesCount", 0);
    Возврат Результат;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Класс описания ресурса (Resource) по спецификации OpenTelemetry.
//
// Ресурс описывает сущность, производящую телеметрию:
// сервис, хост, процесс и т.д.
//
// Конструктор ресурса.
// По умолчанию добавляет обязательные атрибуты: service.name, telemetry.sdk.*.
//
// Параметры:
//   БезУмолчаний - Булево - если Истина, не добавлять дефолтные атрибуты (по умолчанию Ложь)
//   НовыйАдресСхемы - Строка - URL схемы ресурса (по умолчанию "")
//
Процедура ПриСозданииОбъекта(БезУмолчаний = Ложь, НовыйАдресСхемы = "")
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.resource");
    Атрибуты = Новый ОтелАтрибуты();
    АдресСхемы = НовыйАдресСхемы;
    Если НЕ БезУмолчаний Тогда
        ЗаполнитьАтрибутыПоУмолчанию();
    КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьАтрибутыПоУмолчанию()
    Атрибуты.Установить("service.name", "unknown_service:oscript");
    Атрибуты.Установить("telemetry.sdk.name", "opentelemetry");
    Атрибуты.Установить("telemetry.sdk.version", "0.1.0");
    Атрибуты.Установить("telemetry.sdk.language", "oscript");

    ЗаполнитьИнформациюОХосте();
    ЗаполнитьИнформациюОПроцессе();
    ЗаполнитьИнформациюОПроцессоре();
КонецПроцедуры

Процедура ЗаполнитьИнформациюОХосте()
    Попытка
        СисИнфо = Новый СистемнаяИнформация();
        Атрибуты.Установить("host.name", СисИнфо.ИмяКомпьютера);
        Атрибуты.Установить("os.type", ОпределитьТипОС(НРег(Строка(СисИнфо.ТипПлатформы))));
    Исключение
        Лог.Отладка("Нет доступа к системной информации: " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры

Функция ОпределитьТипОС(ЗначениеТипаПлатформы)
    // BSLLS:IfElseIfEndsWithElse-off
    Если СтрНайти(ЗначениеТипаПлатформы, "linux") > 0 Тогда
        Возврат "linux";
    ИначеЕсли СтрНайти(ЗначениеТипаПлатформы, "windows") > 0 Тогда
        Возврат "windows";
    ИначеЕсли СтрНайти(ЗначениеТипаПлатформы, "macos") > 0 ИЛИ СтрНайти(ЗначениеТипаПлатформы, "osx") > 0 Тогда
        Возврат "darwin";
    КонецЕсли;

    Возврат ЗначениеТипаПлатформы;
КонецФункции

Процедура ЗаполнитьИнформациюОПроцессе()
    Попытка
        Атрибуты.Установить("process.pid", ТекущийПроцесс().Идентификатор);
    Исключение
        Лог.Отладка("Нет доступа к PID: " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры

Процедура ЗаполнитьИнформациюОПроцессоре()
    Попытка
        ИнфоЦПУ = Новый ИнформацияОПроцессоре();
        Атрибуты.Установить("host.cpu.model.name", ИнфоЦПУ.ИмяПроцессора);
        Атрибуты.Установить("host.cpu.count", ИнфоЦПУ.КоличествоЛогическихПроцессоров);
        Атрибуты.Установить("host.arch", ОпределитьАрхитектуру(ВРег(Строка(ИнфоЦПУ.Архитектура))));
    Исключение
        Лог.Отладка("cpuinfo недоступен: " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры

Функция ОпределитьАрхитектуру(ЗначениеАрхитектуры)
    // BSLLS:IfElseIfEndsWithElse-off
    Если ЗначениеАрхитектуры = "X64" Тогда
        Возврат "amd64";
    ИначеЕсли ЗначениеАрхитектуры = "X86" Тогда
        Возврат "x86";
    ИначеЕсли ЗначениеАрхитектуры = "ARM64" Тогда
        Возврат "arm64";
    ИначеЕсли ЗначениеАрхитектуры = "ARM" Тогда
        Возврат "arm32";
    КонецЕсли;

    Возврат НРег(ЗначениеАрхитектуры);
КонецФункции

#КонецОбласти
