#Область ОписаниеПеременных

// Число - глубина стека контекстов на момент присоединения (длина стека ДО push).
// Используется для валидации порядка отсоединения (Detach).
Перем Глубина Экспорт;

// Строка - идентификатор потока, в котором был выдан токен.
// Используется для валидации, что отсоединение происходит в том же потоке.
Перем ИдПотока Экспорт;

// Булево - признак того, что токен уже отсоединён.
Перем Отсоединён;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Возвращает признак того, что токен уже отсоединён (Detach был вызван).
//
// Возвращаемое значение:
//   Булево - Истина, если токен отсоединён
//
Функция Отсоединён() Экспорт
    Возврат Отсоединён;
КонецФункции

// Помечает токен как отсоединённый.
// Внутренний метод, вызывается из ОтелКонтекст.ОтсоединитьКонтекст().
//
Процедура ПометитьОтсоединённым() Экспорт
    Отсоединён = Истина;
КонецПроцедуры

// Отсоединяет контекст, восстанавливая предыдущий (сахар над ОтелКонтекст.ОтсоединитьКонтекст).
// Эквивалентно RAII-паттерну: повторный вызов идемпотентен.
//
// По спецификации OpenTelemetry: Detach Context API MUST accept a Token returned by Attach.
//
Процедура Закрыть() Экспорт
    Если НЕ Отсоединён Тогда
        ОтелКонтекст.ОтсоединитьКонтекст(ЭтотОбъект);
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Токен (Token) контекста по спецификации OpenTelemetry Context API.
// Аналог: Java Scope, Python opentelemetry.context.Token, Go detach token.
//
// Возвращается из ОтелКонтекст.ПрисоединитьКонтекст() и должен быть передан
// в ОтелКонтекст.ОтсоединитьКонтекст() для восстановления предыдущего контекста.
//
// Поддерживает RAII-паттерн через метод Закрыть().
//
// Пример (RAII):
//   Токен = Спан.СделатьТекущим();
//   Попытка
//       // ... работа в контексте спана ...
//   Исключение
//       Спан.ЗаписатьИсключение(ИнформацияОбОшибке());
//   КонецПопытки;
//   Токен.Закрыть();
//   Спан.Завершить();
//
// Пример (явный Detach):
//   Токен = ОтелКонтекст.ПрисоединитьКонтекст(Контекст);
//   // ... работа ...
//   ОтелКонтекст.ОтсоединитьКонтекст(Токен);
//
// Параметры:
//   ПараметрГлубина - Число - глубина стека на момент присоединения
//   ПараметрИдПотока - Строка - идентификатор потока
//
Процедура ПриСозданииОбъекта(ПараметрГлубина = 0, ПараметрИдПотока = "")
    Глубина = ПараметрГлубина;
    ИдПотока = ПараметрИдПотока;
    Отсоединён = Ложь;
КонецПроцедуры

#КонецОбласти
