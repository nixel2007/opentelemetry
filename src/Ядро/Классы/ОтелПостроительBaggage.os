#Область ОписаниеПеременных

// Соответствие - накопленные пары ключ-значение baggage
Перем мЗначения;
// Соответствие - метаданные для каждого ключа
Перем мМетаданные;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Устанавливает пару ключ-значение с опциональными метаданными.
// Per spec: Baggage.set(key, value, metadata)
//
// Параметры:
//   Ключ - Строка - ключ элемента
//   Значение - Строка - значение элемента
//   Метаданные - Строка - метаданные элемента (необязательный, по умолчанию "")
//
// Возвращаемое значение:
//   ОтелПостроительBaggage - ЭтотОбъект для fluent API
//
Функция Установить(Ключ, Значение, Метаданные = "") Экспорт
    мЗначения.Вставить(Ключ, Значение);
    мМетаданные.Вставить(Ключ, Метаданные);
    Возврат ЭтотОбъект;
КонецФункции

// Удаляет ключ.
//
// Параметры:
//   Ключ - Строка - ключ элемента для удаления
//
// Возвращаемое значение:
//   ОтелПостроительBaggage - ЭтотОбъект для fluent API
//
Функция Удалить(Ключ) Экспорт
    мЗначения.Удалить(Ключ);
    мМетаданные.Удалить(Ключ);
    Возврат ЭтотОбъект;
КонецФункции

// Создаёт иммутабельный экземпляр Baggage.
//
// Возвращаемое значение:
//   ОтелBaggage - созданный Baggage
//
Функция Построить() Экспорт
    Возврат Новый ОтелBaggage(мЗначения, мМетаданные);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Построитель Baggage (BaggageBuilder) по спецификации OpenTelemetry.
// Аналог Java SDK: Baggage.builder()
//
// Конструктор.
//
// Параметры:
//   НачальныеЗначения - Соответствие - начальные значения (необязательный, для toBuilder)
//   НачальныеМетаданные - Соответствие - начальные метаданные (необязательный, для toBuilder)
//
// Пример:
//   Baggage = Новый ОтелПостроительBaggage()
//       .Установить("userId", "12345")
//       .Установить("tenantId", "abc")
//       .Построить();
//
Процедура ПриСозданииОбъекта(НачальныеЗначения = Неопределено, НачальныеМетаданные = Неопределено)
    мЗначения = Новый Соответствие();
    мМетаданные = Новый Соответствие();
    Если НачальныеЗначения <> Неопределено Тогда
        Для Каждого Элемент Из НачальныеЗначения Цикл
            мЗначения.Вставить(Элемент.Ключ, Элемент.Значение);
        КонецЦикла;
    КонецЕсли;
    Если НачальныеМетаданные <> Неопределено Тогда
        Для Каждого Элемент Из НачальныеМетаданные Цикл
            мМетаданные.Вставить(Элемент.Ключ, Элемент.Значение);
        КонецЦикла;
    КонецЕсли;
КонецПроцедуры

#КонецОбласти
