Функция ПостроительМетра(ИмяБиблиотеки) Экспорт
    Возврат ПровайдерМетрик.ПостроительМетра(ИмяБиблиотеки);
КонецФункции

// Принудительно отправляет все накопленные данные из всех провайдеров.
//
// Параметры:
//   ТаймаутМс - Число - таймаут в миллисекундах (0 - без ограничения)
//
// Возвращаемое значение:
//   ОтелРезультатЭкспорта - агрегированный результат сброса всех провайдеров
//
Функция СброситьБуфер(ТаймаутМс = 0) Экспорт
    Результаты = Новый Массив();
    Если ПровайдерТрассировки <> Неопределено Тогда
        Результаты.Добавить(ПровайдерТрассировки.СброситьБуфер(ТаймаутМс));
    КонецЕсли;
    Если ПровайдерЛогирования <> Неопределено Тогда
        Результаты.Добавить(ПровайдерЛогирования.СброситьБуфер(ТаймаутМс));
    КонецЕсли;
    Если ПровайдерМетрик <> Неопределено Тогда
        Результаты.Добавить(ПровайдерМетрик.СброситьБуфер(ТаймаутМс));
    КонецЕсли;
    Возврат ОтелРезультатыЭкспорта.ОжидатьВсе(Результаты, ТаймаутМс);
КонецФункции

// Завершает работу всех провайдеров.
//
// Параметры:
//   ТаймаутМс - Число - таймаут завершения в миллисекундах (необязательный, по умолчанию 30000).
//       Переопределяется переменной окружения OTEL_SDK_SHUTDOWN_TIMEOUT, если она задана и > 0.
//
// Возвращаемое значение:
//   ОтелРезультатЗакрытия - первый неуспешный результат или успешный результат
//
Функция Закрыть(ТаймаутМс = 30000) Экспорт
    ТаймаутМс = ОпределитьТаймаутЗакрытия(ТаймаутМс);

    Результаты = Новый Массив;
    Если ПровайдерТрассировки <> Неопределено Тогда
        Попытка
            Результаты.Добавить(ПровайдерТрассировки.Закрыть(ТаймаутМс));
        Исключение
            Лог.Предупреждение("Ошибка закрытия провайдера трассировки: %1", ОписаниеОшибки());
            Результаты.Добавить(ОтелРезультатыЗакрытия.Ошибка(ОписаниеОшибки()));
        КонецПопытки;
    КонецЕсли;
    Если ПровайдерЛогирования <> Неопределено Тогда
        Попытка
            Результаты.Добавить(ПровайдерЛогирования.Закрыть(ТаймаутМс));
        Исключение
            Лог.Предупреждение("Ошибка закрытия провайдера логирования: %1", ОписаниеОшибки());
            Результаты.Добавить(ОтелРезультатыЗакрытия.Ошибка(ОписаниеОшибки()));
        КонецПопытки;
    КонецЕсли;
    Если ПровайдерМетрик <> Неопределено Тогда
        Попытка
            Результаты.Добавить(ПровайдерМетрик.Закрыть(ТаймаутМс));
        Исключение
            Лог.Предупреждение("Ошибка закрытия провайдера метрик: %1", ОписаниеОшибки());
            Результаты.Добавить(ОтелРезультатыЗакрытия.Ошибка(ОписаниеОшибки()));
        КонецПопытки;
    КонецЕсли;
    ОтелКонтекст.ОчиститьМертвыеПотоки();

    Для Каждого Результат Из Результаты Цикл
        Если НЕ Результат.Успех Тогда
            Возврат Результат;
        КонецЕсли;
    КонецЦикла;
    Возврат ОтелРезультатыЗакрытия.Успех();
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура УстановитьПровайдерЛогирования(Значение)
    ПровайдерЛогирования = Значение;
КонецПроцедуры

// Возвращает таймаут закрытия, применяя переопределение из переменной окружения.
//
// Параметры:
//   ТаймаутПоУмолчанию - Число - таймаут по умолчанию в мс
//
// Возвращаемое значение:
//   Число - итоговый таймаут в мс
//
Функция ОпределитьТаймаутЗакрытия(ТаймаутПоУмолчанию)
    ЗначениеEnv = ПолучитьПеременнуюСреды("OTEL_SDK_SHUTDOWN_TIMEOUT");
    Если ЗначениеEnv <> Неопределено И ЗначениеEnv <> "" Тогда
        ТаймаутИзEnv = Новый ОписаниеТипов("Число").ПривестиЗначение(ЗначениеEnv);
        Если ТаймаутИзEnv > 0 Тогда
            Возврат ТаймаутИзEnv;
        КонецЕсли;
    КонецЕсли;
    Возврат ТаймаутПоУмолчанию;
КонецФункции

Процедура УстановитьПровайдерМетрик(Значение)
    ПровайдерМетрик = Значение;
КонецПроцедуры

Процедура УстановитьПровайдерТрассировки(Значение)
    ПровайдерТрассировки = Значение;
КонецПроцедуры

Процедура УстановитьПропагаторы(Значение)
    Пропагаторы = Значение;
КонецПроцедуры

// Класс OpenTelemetry SDK - единая точка входа в телеметрию.
// Аналог Java SDK: OpenTelemetrySdk
//
// Агрегирует TracerProvider, LoggerProvider, MeterProvider и ContextPropagators.
// Предоставляет shortcut-методы для получения Tracer/Logger/Meter.
//
// Конструктор SDK. Вызывается из ОтелПостроительSdk.Построить().
//
// Параметры:
//   ПровайдерТрассировки - ОтелПровайдерТрассировки - провайдер трассировки (необязательный)
//   ПровайдерЛогирования - ОтелПровайдерЛогирования - провайдер логирования (необязательный)
//   ПровайдерМетрик - ОтелПровайдерМетрик - провайдер метрик (необязательный)
//   Пропагаторы - ОтелКомпозитныйПропагатор - пропагаторы контекста (необязательный)
//
// Пример:
//   Сдк = Новый ОтелПостроительSdk()
//       .УстановитьПровайдерТрассировки(ПровайдерТрассировки)
//       .УстановитьПровайдерМетрик(ПровайдерМетрик)
//       .Построить();
//
//   Трассировщик = Сдк.ПолучитьТрассировщик("мой-сервис");
//
// BSLLS:NumberOfOptionalParams-off
Процедура ПриСозданииОбъекта(
        ПровайдерТрассировки = Неопределено,
        ПровайдерЛогирования = Неопределено,
        ПровайдерМетрик = Неопределено,
        Пропагаторы = Неопределено)
    УстановитьПровайдерТрассировки(ПровайдерТрассировки);
    УстановитьПровайдерЛогирования(ПровайдерЛогирования);
    УстановитьПровайдерМетрик(ПровайдерМетрик);
    УстановитьПропагаторы(Пропагаторы);
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.sdk");
КонецПроцедуры

#КонецОбласти
