// Модуль результатов экспорта по спецификации OpenTelemetry.
//
// Определяет коды возврата экспортеров для обработки ошибок в процессорах.

// Экспорт выполнен успешно.
Функция Успех() Экспорт
    Возврат 0;
КонецФункции

// Экспорт завершился с ошибкой.
Функция Ошибка() Экспорт
    Возврат 1;
КонецФункции
