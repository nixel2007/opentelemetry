// BSLLS:DuplicatedInsertionIntoCollection-off
// Модуль вспомогательных функций OpenTelemetry SDK.
//
// Предоставляет утилиты для генерации идентификаторов и работы с временными метками.
// Поддерживает подключаемые реализации Clock и IdGenerator для тестируемости.

#Область ОписаниеПеременных

// Произвольный - пользовательские часы или Неопределено для системных
Перем Часы;
// Произвольный - пользовательский генератор идентификаторов или Неопределено
Перем ГенераторИд;
// Число - смещение в миллисекундах от 0001-01-01 до 1970-01-01
Перем СмещениеUnixМс;
// Соответствие - таблица транслитерации кириллицы в латиницу
Перем ТаблицаТранслитерации;
// Число - длина hex-строки идентификатора спана (16 символов)
//
Перем ДлинаИдСпана;
// Число - основание шестнадцатеричной системы счисления (16)
//
Перем ОснованиеШестнадцатеричной;
// Число - количество миллисекунд в одной секунде (1000)
//
Перем МиллисекундВСекунде;
// Число - максимальный код ASCII-символа (127)
//
Перем МаксКодASCII;
// Число - год начала эпохи Unix (1970)
//
Перем ЭпохаЮникс;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Устанавливает пользовательские часы.
// Аналог Java SDK: SdkTracerProviderBuilder.setClock(clock)
// Часы должны реализовывать метод ТекущееВремяВНаносекундах() -> Строка.
//
// Параметры:
//   НовыеЧасы - Произвольный - объект с методом ТекущееВремяВНаносекундах()
//
Процедура УстановитьЧасы(НовыеЧасы) Экспорт
    Часы = НовыеЧасы;
КонецПроцедуры

// Сбрасывает часы к системной реализации по умолчанию.
//
Процедура СброситьЧасы() Экспорт
    Часы = Неопределено;
КонецПроцедуры

// Устанавливает пользовательский генератор идентификаторов.
// Аналог Java SDK: SdkTracerProviderBuilder.setIdGenerator(idGenerator)
// Генератор должен реализовывать методы:
//   СгенерироватьИдТрассировки() -> Строка (32 hex)
//   СгенерироватьИдСпана() -> Строка (16 hex)
//
// Параметры:
//   Генератор - Произвольный - объект с методами СгенерироватьИдТрассировки() и СгенерироватьИдСпана()
//
Процедура УстановитьГенераторИд(Генератор) Экспорт
    ГенераторИд = Генератор;
КонецПроцедуры

// Сбрасывает генератор идентификаторов к реализации по умолчанию (UUID).
//
Процедура СброситьГенераторИд() Экспорт
    ГенераторИд = Неопределено;
КонецПроцедуры

// Генерирует идентификатор трассировки (trace ID) - 32 шестнадцатеричных символа.
//
// Возвращаемое значение:
//   Строка - 32-символьная hex-строка
//
Функция СгенерироватьИдТрассировки() Экспорт
    Если ГенераторИд <> Неопределено Тогда
        Возврат ГенераторИд.СгенерироватьИдТрассировки();
    КонецЕсли;
    // Per spec: trace-id MUST be non-zero
    МаксПопыток = 3;
    Для НомерПопытки = 1 По МаксПопыток Цикл // BSLLS:UnusedLocalVariable-off
        ГУИД = Строка(Новый УникальныйИдентификатор());
        Результат = СтрЗаменить(ГУИД, "-", "");
        Если Результат <> "00000000000000000000000000000000" Тогда
            Возврат Результат;
        КонецЕсли;
    КонецЦикла;
    Возврат СтрЗаменить(ГУИД, "-", "");
КонецФункции

// Генерирует идентификатор спана (span ID) - 16 шестнадцатеричных символов.
//
// Возвращаемое значение:
//   Строка - 16-символьная hex-строка
//
Функция СгенерироватьИдСпана() Экспорт
    Если ГенераторИд <> Неопределено Тогда
        Возврат ГенераторИд.СгенерироватьИдСпана();
    КонецЕсли;
    // Per spec: span-id MUST be non-zero
    МаксПопыток = 3;
    Для НомерПопытки = 1 По МаксПопыток Цикл // BSLLS:UnusedLocalVariable-off
        ГУИД = Строка(Новый УникальныйИдентификатор());
        БезДефисов = СтрЗаменить(ГУИД, "-", "");
        Результат = Лев(БезДефисов, ДлинаИдСпана);
        Если Результат <> "0000000000000000" Тогда
            Возврат Результат;
        КонецЕсли;
    КонецЦикла;
    Возврат Лев(СтрЗаменить(ГУИД, "-", ""), ДлинаИдСпана);
КонецФункции

// Возвращает текущее время в наносекундах с начала эпохи Unix (UTC).
//
// Возвращаемое значение:
//   Строка - строковое представление наносекунд
//
Функция ТекущееВремяВНаносекундах() Экспорт
    Если Часы <> Неопределено Тогда
        Возврат Часы.ТекущееВремяВНаносекундах();
    КонецЕсли;
    UnixМс = ТекущаяУниверсальнаяДатаВМиллисекундах() - СмещениеUnixМс;
    Возврат Формат(UnixМс, "ЧГ=") + "000000";
КонецФункции

// Конвертирует миллисекунды от эпохи 0001-01-01 (формат logos) в наносекунды Unix epoch.
//
// Параметры:
//   МиллисекундыОт0001 - Число - миллисекунды от 0001-01-01 (ТекущаяУниверсальнаяДатаВМиллисекундах())
//
// Возвращаемое значение:
//   Строка - наносекунды Unix epoch
//
Функция МиллисекундыВНаносекунды(МиллисекундыОт0001) Экспорт
    UnixМс = МиллисекундыОт0001 - СмещениеUnixМс;
    Возврат Формат(UnixМс, "ЧГ=") + "000000";
КонецФункции

// Приостанавливает выполнение на указанное количество секунд.
//
// Параметры:
//   Секунды - Число - время ожидания в секундах
//
Процедура Пауза(Секунды) Экспорт
    Приостановить(Секунды * МиллисекундВСекунде);
КонецПроцедуры

// Преобразует число в шестнадцатеричную строку.
//
// Параметры:
//   Значение - Число - значение для преобразования
//
// Возвращаемое значение:
//   Строка - шестнадцатеричное представление
//
Функция ВШестнадцатеричнуюСтроку(Знач Значение) Экспорт
    Если Значение = 0 Тогда
        Возврат "0";
    КонецЕсли;

    ШестнадцатеричныеСимволы = "0123456789abcdef";
    Результат = "";

    Пока Значение > 0 Цикл
        Остаток = Значение % ОснованиеШестнадцатеричной;
        Результат = Сред(ШестнадцатеричныеСимволы, Остаток + 1, 1) + Результат;
        Значение = Цел(Значение / ОснованиеШестнадцатеричной);
    КонецЦикла;

    Возврат Результат;
КонецФункции

// Преобразует шестнадцатеричную строку в число.
//
// Параметры:
//   ШестнадцатеричнаяСтрока - Строка - шестнадцатеричное представление
//
// Возвращаемое значение:
//   Число - десятичное значение
//
Функция ИзШестнадцатеричнойСтроки(Знач ШестнадцатеричнаяСтрока) Экспорт
    ШестнадцатеричныеСимволы = "0123456789abcdef";
    ШестнадцатеричнаяСтрока = НРег(ШестнадцатеричнаяСтрока);
    Результат = 0;

    Для Индекс = 1 По СтрДлина(ШестнадцатеричнаяСтрока) Цикл
        Символ = Сред(ШестнадцатеричнаяСтрока, Индекс, 1);
        ПозицияСимвола = СтрНайти(ШестнадцатеричныеСимволы, Символ) - 1;
        Если ПозицияСимвола < 0 Тогда
            Возврат 0;
        КонецЕсли;
        Результат = Результат * ОснованиеШестнадцатеричной + ПозицияСимвола;
    КонецЦикла;

    Возврат Результат;
КонецФункции

// Преобразует значение атрибута в формат OTLP JSON.
//
// Параметры:
//   Значение - Произвольный - значение атрибута
//
// Возвращаемое значение:
//   Соответствие - объект значения в формате OTLP {"stringValue": "..."} и т.д.
//
Функция ЗначениеАтрибутаВФорматОтел(Знач Значение) Экспорт
    Результат = Новый Соответствие();
    ТипЗначения = ТипЗнч(Значение);

    Если ТипЗначения = Тип("Строка") Тогда
        Результат.Вставить("stringValue", Значение);
    ИначеЕсли ТипЗначения = Тип("Число") Тогда
        ЕстьДробнаяЧасть = (Цел(Значение) <> Значение);
        Если ЕстьДробнаяЧасть Тогда
            Результат.Вставить("doubleValue", Значение);
        Иначе
            Результат.Вставить("intValue", Формат(Значение, "ЧГ=; ЧН=0; ЧДЦ=0"));
        КонецЕсли;
    ИначеЕсли ТипЗначения = Тип("Булево") Тогда
        Результат.Вставить("boolValue", Значение);
    ИначеЕсли ТипЗначения = Тип("Массив") Тогда
        ЭлементыМассива = Новый Массив();
        Для Каждого Элемент Из Значение Цикл
            ЭлементыМассива.Добавить(ЗначениеАтрибутаВФорматОтел(Элемент));
        КонецЦикла;
        ЗначениеМассива = Новый Соответствие();
        ЗначениеМассива.Вставить("values", ЭлементыМассива);
        Результат.Вставить("arrayValue", ЗначениеМассива);
    Иначе
        Результат.Вставить("stringValue", Строка(Значение));
    КонецЕсли;

    Возврат Результат;
КонецФункции

// Транслитерирует кириллицу в ASCII и приводит к нижнему регистру.
// Символы, не имеющие замены (латиница, цифры, точки, подчеркивания), остаются как есть.
//
// Параметры:
//   Значение - Строка - исходная строка
//
// Возвращаемое значение:
//   Строка - транслитерированная строка в нижнем регистре
//
Функция Транслитерировать(Знач Значение) Экспорт
    Результат = "";
    ПредыдущийБылСтрочным = Ложь;
    Для Позиция = 1 По СтрДлина(Значение) Цикл
        Символ = Сред(Значение, Позиция, 1);
        ЭтоЗаглавная = (Символ <> НРег(Символ)) И (Символ = ВРег(Символ));
        Если ЭтоЗаглавная И ПредыдущийБылСтрочным И Результат <> "" Тогда
            Результат = Результат + "_";
        КонецЕсли;
        Замена = ТаблицаТранслитерации.Получить(Символ);
        Если Замена <> Неопределено Тогда
            Результат = Результат + Замена;
        Иначе
            Результат = Результат + Символ;
        КонецЕсли;
        ПредыдущийБылСтрочным = (Символ = НРег(Символ)) И (Символ <> ВРег(Символ));
    КонецЦикла;
    Возврат НРег(Результат);
КонецФункции

// Проверяет, что имя метрики содержит только допустимые ASCII-символы.
// Допустимые символы: a-z, A-Z, 0-9, '.', '_', '-'.
// Выбрасывает исключение, если имя содержит не-ASCII символы.
//
// Параметры:
//   ИмяМетрики - Строка - имя метрики для проверки
//
Процедура ПроверитьИмяМетрики(Знач ИмяМетрики) Экспорт
    Для Позиция = 1 По СтрДлина(ИмяМетрики) Цикл
        КодСимвола = КодСимвола(ИмяМетрики, Позиция);
        Если КодСимвола > МаксКодASCII Тогда
            ВызватьИсключение "Имя метрики '" + ИмяМетрики + "' содержит не-ASCII символы (позиция " + Позиция + "). "
                + "Имена метрик OpenTelemetry должны содержать только ASCII-символы (a-z, A-Z, 0-9, '.', '_', '-'). "
                + "Укажите ASCII-имя явно в параметре аннотации.";
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ИнициализироватьТаблицуТранслитерации()
    ТаблицаТранслитерации = Новый Соответствие();
    ТаблицаТранслитерации.Вставить("а", "a");
    ТаблицаТранслитерации.Вставить("б", "b");
    ТаблицаТранслитерации.Вставить("в", "v");
    ТаблицаТранслитерации.Вставить("г", "g");
    ТаблицаТранслитерации.Вставить("д", "d");
    ТаблицаТранслитерации.Вставить("е", "e");
    ТаблицаТранслитерации.Вставить("ё", "yo");
    ТаблицаТранслитерации.Вставить("ж", "zh");
    ТаблицаТранслитерации.Вставить("з", "z");
    ТаблицаТранслитерации.Вставить("и", "i");
    ТаблицаТранслитерации.Вставить("й", "y");
    ТаблицаТранслитерации.Вставить("к", "k");
    ТаблицаТранслитерации.Вставить("л", "l");
    ТаблицаТранслитерации.Вставить("м", "m");
    ТаблицаТранслитерации.Вставить("н", "n");
    ТаблицаТранслитерации.Вставить("о", "o");
    ТаблицаТранслитерации.Вставить("п", "p");
    ТаблицаТранслитерации.Вставить("р", "r");
    ТаблицаТранслитерации.Вставить("с", "s");
    ТаблицаТранслитерации.Вставить("т", "t");
    ТаблицаТранслитерации.Вставить("у", "u");
    ТаблицаТранслитерации.Вставить("ф", "f");
    ТаблицаТранслитерации.Вставить("х", "kh");
    ТаблицаТранслитерации.Вставить("ц", "ts");
    ТаблицаТранслитерации.Вставить("ч", "ch");
    ТаблицаТранслитерации.Вставить("ш", "sh");
    ТаблицаТранслитерации.Вставить("щ", "shch");
    ТаблицаТранслитерации.Вставить("ъ", "");
    ТаблицаТранслитерации.Вставить("ы", "y");
    ТаблицаТранслитерации.Вставить("ь", "");
    ТаблицаТранслитерации.Вставить("э", "e");
    ТаблицаТранслитерации.Вставить("ю", "yu");
    ТаблицаТранслитерации.Вставить("я", "ya");
    ТаблицаТранслитерации.Вставить("А", "A");
    ТаблицаТранслитерации.Вставить("Б", "B");
    ТаблицаТранслитерации.Вставить("В", "V");
    ТаблицаТранслитерации.Вставить("Г", "G");
    ТаблицаТранслитерации.Вставить("Д", "D");
    ТаблицаТранслитерации.Вставить("Е", "E");
    ТаблицаТранслитерации.Вставить("Ё", "Yo");
    ТаблицаТранслитерации.Вставить("Ж", "Zh");
    ТаблицаТранслитерации.Вставить("З", "Z");
    ТаблицаТранслитерации.Вставить("И", "I");
    ТаблицаТранслитерации.Вставить("Й", "Y");
    ТаблицаТранслитерации.Вставить("К", "K");
    ТаблицаТранслитерации.Вставить("Л", "L");
    ТаблицаТранслитерации.Вставить("М", "M");
    ТаблицаТранслитерации.Вставить("Н", "N");
    ТаблицаТранслитерации.Вставить("О", "O");
    ТаблицаТранслитерации.Вставить("П", "P");
    ТаблицаТранслитерации.Вставить("Р", "R");
    ТаблицаТранслитерации.Вставить("С", "S");
