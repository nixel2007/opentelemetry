    ТаблицаТранслитерации.Вставить("Я", "Ya");
КонецПроцедуры

#КонецОбласти

#Область Инициализация

ДлинаИдСпана = 16;
ОснованиеШестнадцатеричной = 16;
МиллисекундВСекунде = 1000;
МаксКодASCII = 127;
ЭпохаЮникс = 1970;
СмещениеUnixМс = Цел((Дата(ЭпохаЮникс, 1, 1) - Дата(1, 1, 1)) * МиллисекундВСекунде);
ИнициализироватьТаблицуТранслитерации();

#КонецОбласти
