#Область ОписаниеПеременных

// ОтелОбластьИнструментирования - область инструментирования
Перем мОбластьИнструментирования;
// ОтелРесурс - Ресурс, описывающий источник телеметрии
Перем мРесурс;
// Произвольный - Процессор записей логов
Перем мПроцессор;
// ОтелЛимитыЗаписейЛога - Лимиты записей лога
Перем мЛимитыЗаписейЛога;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Создает новую запись лога.
//
// Возвращаемое значение:
//   ОтелЗаписьЛога
//
Функция СоздатьЗаписьЛога() Экспорт
    Возврат Новый ОтелЗаписьЛога(мЛимитыЗаписейЛога);
КонецФункции

// Проверяет, включен ли логгер.
// Per spec: Logger.Enabled() позволяет пропустить создание LogRecord,
// если логгер заведомо ничего не сделает (нет процессора).
//
// Возвращаемое значение:
//   Булево - Истина если логгер может обрабатывать записи
//
Функция Включен() Экспорт
    Возврат мПроцессор <> Неопределено;
КонецФункции

// Отправляет запись лога.
// По спеке Logger.emit() устанавливает scope и resource на записи,
// затем передает запись процессору.
//
// Параметры:
//   ЗаписьЛога - ОтелЗаписьЛога - запись лога для отправки
//
Процедура Записать(ЗаписьЛога) Экспорт
    ЗаписьЛога.УстановитьОбластьИнструментирования(мОбластьИнструментирования);
    ЗаписьЛога.УстановитьРесурс(мРесурс);

    // Per spec: SDK SHOULD set ObservedTimestamp to current time if not set
    Если ПустаяСтрока(ЗаписьЛога.ВремяНаблюдения()) Тогда
        ЗаписьЛога.УстановитьВремяНаблюдения(ОтелУтилиты.ТекущееВремяВНаносекундах());
    КонецЕсли;

    Если мПроцессор <> Неопределено Тогда
        мПроцессор.Обработать(ЗаписьЛога);
    КонецЕсли;

    // Per spec: LogRecord SHOULD be read-only after emit
    ЗаписьЛога.Зафиксировать();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Класс логгера (Logger) по спецификации OpenTelemetry.
//
// Создает и отправляет записи логов.
// Получается из ОтелПровайдерЛогирования.
//
// Конструктор логгера.
//
// Параметры:
//   ОбластьИнструментирования - ОтелОбластьИнструментирования - область инструментирования
//   Ресурс - ОтелРесурс - ресурс
//   Процессор - Произвольный - процессор записей логов (необязательный)
//   ЛимитыЗаписейЛога - ОтелЛимитыЗаписейЛога - лимиты записей лога (необязательный)
//
Процедура ПриСозданииОбъекта(ОбластьИнструментирования,
        Ресурс,
        Процессор = Неопределено,
        ЛимитыЗаписейЛога = Неопределено)
    мОбластьИнструментирования = ОбластьИнструментирования;
    мРесурс = Ресурс;
    мПроцессор = Процессор;
    мЛимитыЗаписейЛога = ЛимитыЗаписейЛога;
КонецПроцедуры

#КонецОбласти
