#Область ОписаниеПеременных

// Массив - Список процессоров спанов в цепочке
Перем Процессоры;
// Лог
Перем Лог;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Вызывается при создании спана - делегирует всем процессорам в цепочке.
//
// Параметры:
//   Спан - ОтелСпан - начатый спан
//   РодительскийКонтекст - Соответствие - родительский контекст (по спецификации)
//
Процедура ПриНачале(Спан, РодительскийКонтекст = Неопределено) Экспорт
    Для Каждого Процессор Из Процессоры Цикл
        Попытка
            Процессор.ПриНачале(Спан, РодительскийКонтекст);
        Исключение
            Лог.Предупреждение("Ошибка процессора спанов при ПриНачале: " + ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры

// Обрабатывает завершенный спан - делегирует всем процессорам в цепочке.
//
// Параметры:
//   Спан - ОтелСпан - завершенный спан
//
Процедура Обработать(Спан) Экспорт
    Для Каждого Процессор Из Процессоры Цикл
        Попытка
            Процессор.Обработать(Спан);
        Исключение
            Лог.Предупреждение("Ошибка процессора спанов при Обработать: " + ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры

// Проверяет наличие хотя бы одного процессора.
//
// Возвращаемое значение:
//   Булево - Истина если есть процессоры
//
Функция ЕстьПроцессоры() Экспорт
    Возврат Процессоры.Количество() > 0;
КонецФункции

// Принудительно сбрасывает буферы всех процессоров в цепочке.
//
Процедура СброситьБуфер() Экспорт
    Для Каждого Процессор Из Процессоры Цикл
        Попытка
            Процессор.СброситьБуфер();
        Исключение
            Лог.Предупреждение("Ошибка процессора спанов при СброситьБуфер: " + ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры

// Завершает работу всех процессоров в цепочке.
//
Процедура Закрыть() Экспорт
    Для Каждого Процессор Из Процессоры Цикл
        Попытка
            Процессор.Закрыть();
        Исключение
            Лог.Предупреждение("Ошибка процессора спанов при Закрыть: " + ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Композитный процессор спанов - делегирует вызовы цепочке процессоров.
//
// Конструктор.
//
// Параметры:
//   НовыеПроцессоры - Массив - массив процессоров спанов
//
Процедура ПриСозданииОбъекта(НовыеПроцессоры)
    Процессоры = НовыеПроцессоры;
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.traces");
КонецПроцедуры

#КонецОбласти
