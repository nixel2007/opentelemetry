// Модуль констант кодов статуса спана (StatusCode) по спецификации OpenTelemetry.
//
// Описывает статус завершения спана.
// Значения соответствуют OTLP StatusCode enum.

#Область ПрограммныйИнтерфейс

Функция НеУстановлен() Экспорт
    Возврат 0;
КонецФункции

Функция Ок() Экспорт
    Возврат 1;
КонецФункции

Функция Ошибка() Экспорт
    Возврат 2;
КонецФункции

#КонецОбласти
