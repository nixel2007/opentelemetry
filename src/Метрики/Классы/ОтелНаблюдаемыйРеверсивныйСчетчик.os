#Использовать lambdas

// Класс наблюдаемого реверсивного счетчика (ObservableUpDownCounter) по спецификации OpenTelemetry.
//
// Асинхронный инструмент, вызывающий callback для получения значения.
// В отличие от ObservableCounter, допускает убывание значения.

Перем мИмя;
Перем мОписание;
Перем мЕдиницаИзмерения;
Перем мТипЗначения; // "int" или "double"
Перем мДействие;

Функция Имя() Экспорт
    Возврат мИмя;
КонецФункции

Функция Описание() Экспорт
    Возврат мОписание;
КонецФункции

Функция ЕдиницаИзмерения() Экспорт
    Возврат мЕдиницаИзмерения;
КонецФункции

// Возвращает тип значения: "int" или "double".
// По умолчанию для наблюдаемого реверсивного счетчика - "int".
Функция ТипЗначения() Экспорт
    Возврат мТипЗначения;
КонецФункции

Функция ТипМетрики() Экспорт
    Возврат "sum";
КонецФункции

Функция Монотонный() Экспорт
    Возврат Ложь;
КонецФункции

Функция ТочкиДанных() Экспорт
    Результат = Новый Массив();
    Если мДействие = Неопределено Тогда
        Возврат Результат;
    КонецЕсли;

    Попытка
        Значение = мДействие.Выполнить();
        Если Значение <> Неопределено Тогда
            ТочкаДанных = Новый Соответствие();
            ТочкаДанных.Вставить("value", Значение);
            ТочкаДанных.Вставить("startTimeUnixNano", ОтелУтилиты.ТекущееВремяВНаносекундах());
            ТочкаДанных.Вставить("timeUnixNano", ОтелУтилиты.ТекущееВремяВНаносекундах());
            ТочкаДанных.Вставить("attributes", Новый Массив());
            Результат.Добавить(ТочкаДанных);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат Результат;
КонецФункции

Процедура ОчиститьТочкиДанных() Экспорт
КонецПроцедуры

Процедура ПриСозданииОбъекта(Имя, Callback, Описание = "", ЕдиницаИзмерения = "", ТипЗначения = "int")
    мИмя = Имя;
    мОписание = Описание;
    мЕдиницаИзмерения = ЕдиницаИзмерения;
    мТипЗначения = ТипЗначения;
    мДействие = Callback;
КонецПроцедуры
