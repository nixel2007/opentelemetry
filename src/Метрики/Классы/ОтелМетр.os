#Использовать logos

#Область ОписаниеПеременных

// Строка - Имя инструментирующей библиотеки
Перем мИмяБиблиотеки;
// Строка - Версия инструментирующей библиотеки
Перем мВерсияБиблиотеки;
// ОтелРесурс - Ресурс, описывающий источник телеметрии
Перем мРесурс;
// Массив - Массив зарегистрированных инструментов
Перем мИнструменты;
// Соответствие - Кэш инструментов по нормализованному имени (lowercase)
Перем мИнструментыПоИмени;
// Соответствие - Дескрипторы инструментов по нормализованному имени
Перем мДескрипторыИнструментов;
// ОтелАтрибуты - Атрибуты InstrumentationScope
Перем мАтрибутыСкоупа;
// Строка - URL схемы телеметрии
Перем мSchemaUrl;
// Число - Фильтр exemplars из ОтелФильтрЭкземпляров
Перем мФильтрЭкземпляров; // Число из ОтелФильтрЭкземпляров
// Число - Лимит мощности (cardinality limit) для инструментов
Перем мЛимитМощности; // Лимит мощности (cardinality limit) для инструментов
// Объект - Логгер библиотеки logos
Перем мЛог;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Создает новый счетчик.
//
// Параметры:
//   Имя - Строка - имя счетчика
//   Описание - Строка - описание счетчика (по умолчанию "")
//   ЕдиницаИзмерения - Строка - единица измерения (по умолчанию "")
//
// Возвращаемое значение:
//   ОтелСчетчик
//
Функция СоздатьСчетчик(Имя, Описание = "", ЕдиницаИзмерения = "") Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "Counter", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Счетчик = Новый ОтелСчетчик(Имя, Описание, ЕдиницаИзмерения);
    Счетчик.УстановитьЛимитМощности(мЛимитМощности);
    мИнструменты.Добавить(Счетчик);
    мИнструментыПоИмени.Вставить(НормИмя, Счетчик);
    ЗарегистрироватьДескриптор(НормИмя, "Counter", ЕдиницаИзмерения, Описание);
    Возврат Счетчик;
КонецФункции

// Создает новую гистограмму.
//
// Параметры:
//   Имя - Строка - имя гистограммы
//   Описание - Строка - описание гистограммы (по умолчанию "")
//   ЕдиницаИзмерения - Строка - единица измерения (по умолчанию "")
//
// Возвращаемое значение:
//   ОтелГистограмма
//
Функция СоздатьГистограмму(Имя, Описание = "", ЕдиницаИзмерения = "") Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "Histogram", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Гистограмма = Новый ОтелГистограмма(Имя, Описание, ЕдиницаИзмерения);
    Гистограмма.УстановитьФильтрЭкземпляров(мФильтрЭкземпляров);
    Гистограмма.УстановитьЛимитМощности(мЛимитМощности);
    мИнструменты.Добавить(Гистограмма);
    мИнструментыПоИмени.Вставить(НормИмя, Гистограмма);
    ЗарегистрироватьДескриптор(НормИмя, "Histogram", ЕдиницаИзмерения, Описание);
    Возврат Гистограмма;
КонецФункции

// Создает новую экспоненциальную гистограмму.
//
// Параметры:
//   Имя - Строка - имя гистограммы
//   Описание - Строка - описание (по умолчанию "")
//   ЕдиницаИзмерения - Строка - единица измерения (по умолчанию "")
//   МаксБакетов - Число - максимальное количество бакетов (по умолчанию 160)
//
// Возвращаемое значение:
//   ОтелЭкспоненциальнаяГистограмма
//
Функция СоздатьЭкспоненциальнуюГистограмму(Имя, Описание = "", ЕдиницаИзмерения = "", МаксБакетов = 160) Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "ExponentialHistogram", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма(Имя, Описание, ЕдиницаИзмерения, МаксБакетов);
    Гистограмма.УстановитьФильтрЭкземпляров(мФильтрЭкземпляров);
    Гистограмма.УстановитьЛимитМощности(мЛимитМощности);
    мИнструменты.Добавить(Гистограмма);
    мИнструментыПоИмени.Вставить(НормИмя, Гистограмма);
    ЗарегистрироватьДескриптор(НормИмя, "ExponentialHistogram", ЕдиницаИзмерения, Описание);
    Возврат Гистограмма;
КонецФункции

