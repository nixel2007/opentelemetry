    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "ObservableUpDownCounter", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Счетчик = Новый ОтелНаблюдаемыйРеверсивныйСчетчик(Имя, Callback, Описание, ЕдиницаИзмерения);
    мИнструменты.Добавить(Счетчик);
    мИнструментыПоИмени.Вставить(НормИмя, Счетчик);
    ЗарегистрироватьДескриптор(НормИмя, "ObservableUpDownCounter", ЕдиницаИзмерения, Описание);
    Возврат Счетчик;
КонецФункции

// Создает наблюдаемый датчик (ObservableGauge).
//
// Параметры:
//   Имя - Строка - имя инструмента
//   Callback - Действие - callback без параметров, возвращает число
//   Описание - Строка - описание (необязательный)
//   ЕдиницаИзмерения - Строка - единица измерения (необязательный)
//
// Возвращаемое значение:
//   ОтелНаблюдаемыйДатчик
//
Функция СоздатьНаблюдаемыйДатчик(Имя, Callback, Описание = "", ЕдиницаИзмерения = "") Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "ObservableGauge", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Датчик = Новый ОтелНаблюдаемыйДатчик(Имя, Callback, Описание, ЕдиницаИзмерения);
    мИнструменты.Добавить(Датчик);
    мИнструментыПоИмени.Вставить(НормИмя, Датчик);
    ЗарегистрироватьДескриптор(НормИмя, "ObservableGauge", ЕдиницаИзмерения, Описание);
    Возврат Датчик;
КонецФункции

// Устанавливает зарегистрированные представления (Views) для метра.
// Вызывается из ОтелПровайдерМетрик при создании метра.
//
// Параметры:
//   Представления - Массив - массив пар {Селектор, Представление}
//
Процедура УстановитьПредставления(Представления) Экспорт
    мПредставления = Представления;
КонецПроцедуры

// Возвращает зарегистрированные представления (Views).
//
// Возвращаемое значение:
//   Массив из Соответствие - пары {Селектор, Представление}
//
Функция ПолучитьПредставления() Экспорт
    Возврат мПредставления;
КонецФункции

// Возвращает все зарегистрированные инструменты.
//
// Возвращаемое значение:
//   Массив
//
Функция Инструменты() Экспорт
    Возврат мИнструменты;
КонецФункции

// Возвращает ресурс, ассоциированный с метрикой.
//
// Возвращаемое значение:
//   ОтелРесурс
//
Функция Ресурс() Экспорт
    Возврат мРесурс;
КонецФункции

// Возвращает область инструментирования (InstrumentationScope).
//
// Возвращаемое значение:
//   ОтелОбластьИнструментирования
//
Функция ОбластьИнструментирования() Экспорт
    Возврат мОбластьИнструментирования;
КонецФункции

// Устанавливает лимит мощности (cardinality limit) для новых инструментов.
//
// Параметры:
//   Лимит - Число - максимальное количество уникальных серий атрибутов
//
Процедура УстановитьЛимитМощности(Лимит) Экспорт
    мЛимитМощности = Лимит;
КонецПроцедуры

// Регистрирует обратный вызов для наблюдения нескольких инструментов.
// Callback получает Соответствие: ключ = имя инструмента, значение = ОтелНаблюдениеМетрики.
//
// Параметры:
//   Callback - Действие - обратный вызов
//   Инструменты - Массив - массив наблюдаемых инструментов
//
Процедура ЗарегистрироватьОбратныйВызов(Callback, Инструменты) Экспорт
    Регистрация = Новый Структура("Callback, Инструменты", Callback, Инструменты);
    мМультиОбратныеВызовы.Добавить(Регистрация);
КонецПроцедуры

// Вызывает все зарегистрированные мульти-callback.
// Создает ОтелНаблюдениеМетрики для каждого инструмента, передает в callback,
// затем добавляет результаты как внешние наблюдения в инструменты.
//
Процедура ВызватьМультиОбратныеВызовы() Экспорт
    Для Каждого Регистрация Из мМультиОбратныеВызовы Цикл
        Попытка
            Наблюдения = Новый Соответствие();
            Для Каждого Инструмент Из Регистрация.Инструменты Цикл
                Наблюдения.Вставить(Инструмент.Имя(), Новый ОтелНаблюдениеМетрики());
            КонецЦикла;

            Регистрация.Callback.Выполнить(Наблюдения);

            Для Каждого Инструмент Из Регистрация.Инструменты Цикл
                Наблюдение = Наблюдения.Получить(Инструмент.Имя());
                Если Наблюдение <> Неопределено И Наблюдение.Количество() > 0 Тогда
                    Инструмент.ДобавитьВнешниеНаблюдения(Наблюдение);
                КонецЕсли;
            КонецЦикла;
        Исключение
            мЛог.Предупреждение("Ошибка мульти-callback: " + ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры

// Отключает все инструменты метра.
// Вызывается при закрытии провайдера.
//
Процедура ОтключитьИнструменты() Экспорт
    Для Каждого Инструмент Из мИнструменты Цикл
        Попытка
            Инструмент.Отключить();
        Исключение // BSLLS:MissingCodeTryCatchEx-off
            // Наблюдаемые инструменты не имеют метода Отключить - пропускаем
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Класс метрики (Meter) по спецификации OpenTelemetry.
//
// Создает инструменты измерения: счетчики, гистограммы.
// Получается из ОтелПровайдерМетрик.
//
// Конструктор метрики.
//
// Параметры:
//   ОбластьИнструментирования - ОтелОбластьИнструментирования - область инструментирования
//   Ресурс - ОтелРесурс - ресурс
//   ФильтрЭкземпляров - Число - фильтр экземпляров из ОтелФильтрЭкземпляров (необязательный)
//
Процедура ПриСозданииОбъекта(ОбластьИнструментирования,
        Ресурс,
        ФильтрЭкземпляров = Неопределено)
    мОбластьИнструментирования = ОбластьИнструментирования;
    мРесурс = Ресурс;
    мИнструменты = Новый Массив();
    мИнструментыПоИмени = Новый СинхронизированнаяКарта(Новый КартаСоответствие());
    мДескрипторыИнструментов = Новый СинхронизированнаяКарта(Новый КартаСоответствие());
    Если ФильтрЭкземпляров = Неопределено Тогда
        мФильтрЭкземпляров = ОтелФильтрЭкземпляров.ПоТрассировке();
    Иначе
        мФильтрЭкземпляров = ФильтрЭкземпляров;
    КонецЕсли;
    мЛимитМощности = 2000;
    мМультиОбратныеВызовы = Новый Массив();
    мПредставления = Новый Массив();
    мЛог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.metrics");
КонецПроцедуры

Процедура ЗарегистрироватьДескриптор(НормИмя, Вид, ЕдиницаИзмерения, Описание)
    Дескриптор = Новый Структура("Вид, ЕдиницаИзмерения, Описание", Вид, ЕдиницаИзмерения, Описание);
    мДескрипторыИнструментов.Вставить(НормИмя, Дескриптор);
КонецПроцедуры

Процедура ПроверитьКонфликтДескриптора(НормИмя, Вид, ЕдиницаИзмерения, Описание)
    Существующий = мДескрипторыИнструментов.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Если Существующий.Вид <> Вид ИЛИ Существующий.ЕдиницаИзмерения <> ЕдиницаИзмерения
        ИЛИ Существующий.Описание <> Описание Тогда
        мЛог.Предупреждение("Инструмент с именем '" + НормИмя
            + "' уже зарегистрирован с другими параметрами ("
            + Существующий.Вид + "/" + Существующий.ЕдиницаИзмерения
            + "). Запрошен: " + Вид + "/" + ЕдиницаИзмерения
            + ". Возвращен ранее зарегистрированный инструмент.");
    КонецЕсли;
КонецПроцедуры

// Находит первое подходящее представление (View) для инструмента.
//
// Параметры:
//   ИмяИнструмента - Строка - имя инструмента
//   ТипМетрики - Строка - тип метрики ("sum", "histogram", "gauge")
//
// Возвращаемое значение:
//   ОтелПредставление, Неопределено
//
Функция НайтиПредставление(ИмяИнструмента, ТипМетрики)
    Для Каждого Пара Из мПредставления Цикл
        Селектор = Пара.Получить("Селектор");
        Если Селектор.Совпадает(ИмяИнструмента, ТипМетрики, мОбластьИнструментирования.Имя()) Тогда
            Возврат Пара.Получить("Представление");
        КонецЕсли;
    КонецЦикла;
    Возврат Неопределено;
КонецФункции

// Применяет представление (View) к счетчику.
//
// Параметры:
//   Счетчик - ОтелСчетчик, ОтелРеверсивныйСчетчик - инструмент-счетчик
//   ИмяИнструмента - Строка - оригинальное имя инструмента
//   ТипМетрики - Строка - тип метрики
//
Процедура ПрименитьПредставлениеСчетчик(Счетчик, ИмяИнструмента, ТипМетрики)
    Представление = НайтиПредставление(ИмяИнструмента, ТипМетрики);
    Если Представление = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Если Представление.РазрешенныеКлючиАтрибутов() <> Неопределено Тогда
        Счетчик.УстановитьРазрешенныеКлючиАтрибутов(Представление.РазрешенныеКлючиАтрибутов());
    КонецЕсли;
КонецПроцедуры

#КонецОбласти
