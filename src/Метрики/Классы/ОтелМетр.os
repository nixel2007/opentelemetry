#Использовать logos

#Область ОписаниеПеременных

// ОтелОбластьИнструментирования - область инструментирования
Перем мОбластьИнструментирования;
// ОтелРесурс - Ресурс, описывающий источник телеметрии
Перем мРесурс;
// Массив - Массив зарегистрированных инструментов
Перем мИнструменты;
// Соответствие - Кэш инструментов по нормализованному имени (lowercase)
Перем мИнструментыПоИмени;
// Соответствие - Дескрипторы инструментов по нормализованному имени
Перем мДескрипторыИнструментов;
// Число - Фильтр exemplars из ОтелФильтрЭкземпляров
Перем мФильтрЭкземпляров; // Число из ОтелФильтрЭкземпляров
// Число - Лимит мощности (cardinality limit) для инструментов
Перем мЛимитМощности; // Лимит мощности (cardinality limit) для инструментов
// Массив - Мульти-callback регистрации {Callback, Инструменты}
Перем мМультиОбратныеВызовы;
// Объект - Логгер библиотеки logos
Перем мЛог;
// Массив - Зарегистрированные представления (Views) с селекторами
Перем мПредставления; // Массив из Соответствие {Селектор, Представление}

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Создает новый счетчик.
//
// Параметры:
//   Имя - Строка - имя счетчика
//   Описание - Строка - описание счетчика (по умолчанию "")
//   ЕдиницаИзмерения - Строка - единица измерения (по умолчанию "")
//
// Возвращаемое значение:
//   ОтелСчетчик
//
Функция СоздатьСчетчик(Имя, Описание = "", ЕдиницаИзмерения = "") Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "Counter", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Счетчик = Новый ОтелСчетчик(Имя, Описание, ЕдиницаИзмерения);
    Счетчик.УстановитьЛимитМощности(мЛимитМощности);
    ПрименитьПредставлениеСчетчик(Счетчик, Имя, "sum");
    мИнструменты.Добавить(Счетчик);
    мИнструментыПоИмени.Вставить(НормИмя, Счетчик);
    ЗарегистрироватьДескриптор(НормИмя, "Counter", ЕдиницаИзмерения, Описание);
    Возврат Счетчик;
КонецФункции

// Создает новую гистограмму.
//
// Параметры:
//   Имя - Строка - имя гистограммы
//   Описание - Строка - описание гистограммы (по умолчанию "")
//   ЕдиницаИзмерения - Строка - единица измерения (по умолчанию "")
//
// Возвращаемое значение:
//   ОтелГистограмма
//
Функция СоздатьГистограмму(Имя, Описание = "", ЕдиницаИзмерения = "") Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "Histogram", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Гистограмма = Новый ОтелГистограмма(Имя, Описание, ЕдиницаИзмерения);
    Гистограмма.УстановитьФильтрЭкземпляров(мФильтрЭкземпляров);
    Гистограмма.УстановитьЛимитМощности(мЛимитМощности);
    мИнструменты.Добавить(Гистограмма);
    мИнструментыПоИмени.Вставить(НормИмя, Гистограмма);
    ЗарегистрироватьДескриптор(НормИмя, "Histogram", ЕдиницаИзмерения, Описание);
    Возврат Гистограмма;
КонецФункции

// Создает новую экспоненциальную гистограмму.
//
// Параметры:
//   Имя - Строка - имя гистограммы
//   Описание - Строка - описание (по умолчанию "")
//   ЕдиницаИзмерения - Строка - единица измерения (по умолчанию "")
//   МаксБакетов - Число - максимальное количество бакетов (по умолчанию 160)
//
// Возвращаемое значение:
//   ОтелЭкспоненциальнаяГистограмма
//
Функция СоздатьЭкспоненциальнуюГистограмму(Имя, Описание = "", ЕдиницаИзмерения = "", МаксБакетов = 160) Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "ExponentialHistogram", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Гистограмма = Новый ОтелЭкспоненциальнаяГистограмма(Имя, Описание, ЕдиницаИзмерения, МаксБакетов);
    Гистограмма.УстановитьФильтрЭкземпляров(мФильтрЭкземпляров);
    Гистограмма.УстановитьЛимитМощности(мЛимитМощности);
    мИнструменты.Добавить(Гистограмма);
    мИнструментыПоИмени.Вставить(НормИмя, Гистограмма);
    ЗарегистрироватьДескриптор(НормИмя, "ExponentialHistogram", ЕдиницаИзмерения, Описание);
    Возврат Гистограмма;
КонецФункции

// Создает новый реверсивный счетчик (UpDownCounter).
//
// Параметры:
//   Имя - Строка - имя счетчика
//   Описание - Строка - описание счетчика (по умолчанию "")
//   ЕдиницаИзмерения - Строка - единица измерения (по умолчанию "")
//
// Возвращаемое значение:
//   ОтелРеверсивныйСчетчик
//
Функция СоздатьРеверсивныйСчетчик(Имя, Описание = "", ЕдиницаИзмерения = "") Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "UpDownCounter", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Счетчик = Новый ОтелРеверсивныйСчетчик(Имя, Описание, ЕдиницаИзмерения);
    Счетчик.УстановитьЛимитМощности(мЛимитМощности);
    мИнструменты.Добавить(Счетчик);
    мИнструментыПоИмени.Вставить(НормИмя, Счетчик);
    ЗарегистрироватьДескриптор(НормИмя, "UpDownCounter", ЕдиницаИзмерения, Описание);
    Возврат Счетчик;
КонецФункции

// Создает новый датчик (Gauge).
//
// Параметры:
//   Имя - Строка - имя датчика
//   Описание - Строка - описание датчика (по умолчанию "")
//   ЕдиницаИзмерения - Строка - единица измерения (по умолчанию "")
//
// Возвращаемое значение:
//   ОтелДатчик
//
Функция СоздатьДатчик(Имя, Описание = "", ЕдиницаИзмерения = "") Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "Gauge", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Датчик = Новый ОтелДатчик(Имя, Описание, ЕдиницаИзмерения);
    Датчик.УстановитьЛимитМощности(мЛимитМощности);
    мИнструменты.Добавить(Датчик);
    мИнструментыПоИмени.Вставить(НормИмя, Датчик);
    ЗарегистрироватьДескриптор(НормИмя, "Gauge", ЕдиницаИзмерения, Описание);
    Возврат Датчик;
КонецФункции

// Создает наблюдаемый счетчик (ObservableCounter).
// Значение собирается через callback при запросе метрик.
//
// Параметры:
//   Имя - Строка - имя инструмента
//   Callback - Действие - callback без параметров, возвращает число
//   Описание - Строка - описание (необязательный)
//   ЕдиницаИзмерения - Строка - единица измерения (необязательный)
//
// Возвращаемое значение:
//   ОтелНаблюдаемыйСчетчик
//
Функция СоздатьНаблюдаемыйСчетчик(Имя, Callback, Описание = "", ЕдиницаИзмерения = "") Экспорт
    НормИмя = НРег(Имя);
    Существующий = мИнструментыПоИмени.ПолучитьИлиУмолчание(НормИмя, Неопределено);
    Если Существующий <> Неопределено Тогда
        ПроверитьКонфликтДескриптора(НормИмя, "ObservableCounter", ЕдиницаИзмерения, Описание);
        Возврат Существующий;
    КонецЕсли;
    Счетчик = Новый ОтелНаблюдаемыйСчетчик(Имя, Callback, Описание, ЕдиницаИзмерения);
    мИнструменты.Добавить(Счетчик);
    мИнструментыПоИмени.Вставить(НормИмя, Счетчик);
    ЗарегистрироватьДескриптор(НормИмя, "ObservableCounter", ЕдиницаИзмерения, Описание);
    Возврат Счетчик;
КонецФункции

// Создает наблюдаемый реверсивный счетчик (ObservableUpDownCounter).
//
// Параметры:
//   Имя - Строка - имя инструмента
//   Callback - Действие - callback без параметров, возвращает число
//   Описание - Строка - описание (необязательный)
//   ЕдиницаИзмерения - Строка - единица измерения (необязательный)
//
// Возвращаемое значение:
//   ОтелНаблюдаемыйРеверсивныйСчетчик
//
Функция СоздатьНаблюдаемыйРеверсивныйСчетчик(Имя, Callback, Описание = "", ЕдиницаИзмерения = "") Экспорт
    НормИмя = НРег(Имя);
