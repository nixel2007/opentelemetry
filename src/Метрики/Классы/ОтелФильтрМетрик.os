// Фильтр метрик (MetricFilter) по спецификации OpenTelemetry.
//
// Позволяет MetricReader фильтровать агрегированные точки данных
// на этапе сбора (Produce). Поддерживает фильтрацию по метрике целиком
// и по отдельным наборам атрибутов.

#Область ОписаниеПеременных

// Действие - делегат для проверки метрики (4 параметра)
Перем ДелегатТестМетрики;
// Действие - делегат для проверки атрибутов (5 параметров)
Перем ДелегатТестАтрибутов;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Проверяет, нужно ли собирать метрику.
//
// Параметры:
//   ОбластьИнструментирования - ОтелОбластьИнструментирования - область метрики
//   Имя - Строка - имя метрики
//   Вид - Строка - вид метрики (sum, gauge, histogram и т.д.)
//   ЕдиницаИзмерения - Строка - единица измерения
//
// Возвращаемое значение:
//   Число - значение из ОтелРезультатФильтраМетрик (Принять/Отбросить/ЧастичноеПринятие)
//
Функция ТестМетрики(ОбластьИнструментирования, Имя, Вид, ЕдиницаИзмерения) Экспорт
    Если ДелегатТестМетрики = Неопределено Тогда
        Возврат ОтелРезультатФильтраМетрик.Принять();
    КонецЕсли;

    Параметры = Новый Массив;
    Параметры.Добавить(ОбластьИнструментирования);
    Параметры.Добавить(Имя);
    Параметры.Добавить(Вид);
    Параметры.Добавить(ЕдиницаИзмерения);

    Возврат ДелегатТестМетрики.Выполнить(Параметры);
КонецФункции

// Проверяет, нужно ли собирать точку данных с указанными атрибутами.
// Вызывается только если ТестМетрики вернул ЧастичноеПринятие.
//
// Параметры:
//   ОбластьИнструментирования - ОтелОбластьИнструментирования - область метрики
//   Имя - Строка - имя метрики
//   Вид - Строка - вид метрики
//   ЕдиницаИзмерения - Строка - единица измерения
//   Атрибуты - Соответствие - набор атрибутов точки данных
//
// Возвращаемое значение:
//   Число - значение из ОтелРезультатФильтраАтрибутов (Принять/Отбросить)
//
Функция ТестАтрибутов(ОбластьИнструментирования, Имя, Вид, ЕдиницаИзмерения, Атрибуты) Экспорт
    Если ДелегатТестАтрибутов = Неопределено Тогда
        Возврат ОтелРезультатФильтраАтрибутов.Принять();
    КонецЕсли;

    Параметры = Новый Массив;
    Параметры.Добавить(ОбластьИнструментирования);
    Параметры.Добавить(Имя);
    Параметры.Добавить(Вид);
    Параметры.Добавить(ЕдиницаИзмерения);
    Параметры.Добавить(Атрибуты);

    Возврат ДелегатТестАтрибутов.Выполнить(Параметры);
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытий

// Конструктор.
//
// Параметры:
//   ДелегатТестМетрики - Действие - функция фильтрации метрики (4 параметра),
//       возвращает ОтелРезультатФильтраМетрик. Неопределено - принимать все.
//   ДелегатТестАтрибутов - Действие - функция фильтрации атрибутов (5 параметров),
//       возвращает ОтелРезультатФильтраАтрибутов. Неопределено - принимать все.
//
Процедура ПриСозданииОбъекта(ДелегатТестМетрики = Неопределено, ДелегатТестАтрибутов = Неопределено)
    УстановитьДелегатТестМетрики(ДелегатТестМетрики);
    УстановитьДелегатТестАтрибутов(ДелегатТестАтрибутов);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура УстановитьДелегатТестМетрики(Значение)
    ДелегатТестМетрики = Значение;
КонецПроцедуры

Процедура УстановитьДелегатТестАтрибутов(Значение)
    ДелегатТестАтрибутов = Значение;
КонецПроцедуры

#КонецОбласти
