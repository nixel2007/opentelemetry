// BSLLS:UnusedLocalVariable-off
// BSLLS:ExportVariables-off
// Конфигурация лимитов атрибутов (AttributeLimits).
//
// Используется на верхнем уровне и в logger_provider.limits.

#Область ОписаниеПеременных

// attribute_value_length_limit - Число/Неопределено - максимальная длина значения атрибута
// Неопределено означает отсутствие ограничения
Перем МаксДлинаЗначенияАтрибута Экспорт;

// attribute_count_limit - Число - максимальное количество атрибутов
Перем МаксКоличествоАтрибутов Экспорт;

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПриСозданииОбъекта()
	МаксДлинаЗначенияАтрибута = Неопределено;
	МаксКоличествоАтрибутов = 128;
КонецПроцедуры

#КонецОбласти
