#Использовать logos

#Область ОписаниеПеременных

Перем БуферКласса;
Перем Лог;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Возвращает сериализованные двоичные данные.
Функция ПолучитьДвоичныеДанные() Экспорт
    БуферДанных = Новый БуферДвоичныхДанных(БуферКласса.Количество());
    Для сч = 0 По БуферКласса.Количество() - 1 Цикл
        БуферДанных.Установить(сч, БуферКласса[сч]);
    КонецЦикла;
    ПотокВПамяти = Новый ПотокВПамяти(БуферДанных);
    Возврат ПотокВПамяти.ЗакрытьИПолучитьДвоичныеДанные();
КонецФункции

// Записывает тег protobuf (field_number << 3 | wire_type).
Функция ЗаписатьТег(НомерПоля, ВидWire) Экспорт
    Тег = (НомерПоля * 8) + ВидWire;
    ЗаписатьUInt64Varint(Тег);
    Возврат ЭтотОбъект;
КонецФункции

// Записывает unsigned varint (0..2^64-1).
Функция ЗаписатьUInt64Varint(Значение) Экспорт
    Х = Значение;
    Пока Х >= 128 Цикл
        Байт = (Х % 128) + 128;
        БуферКласса.Добавить(Байт);
        Х = Цел(Х / 128);
    КонецЦикла;
    БуферКласса.Добавить(Х % 256);
    Возврат ЭтотОбъект;
КонецФункции

// Записывает signed int64 varint через two's complement для отрицательных.
Функция ЗаписатьInt64Varint(Значение) Экспорт
    Если Значение < 0 Тогда
        БеззнаковоеЗначение = Значение + 18446744073709551616;
    Иначе
        БеззнаковоеЗначение = Значение;
    КонецЕсли;
    ЗаписатьUInt64Varint(БеззнаковоеЗначение);
    Возврат ЭтотОбъект;
КонецФункции

// Записывает fixed32 (4 байта, little-endian).
Функция ЗаписатьFixed32(Значение) Экспорт
    Х = Значение;
    Для сч = 0 По 3 Цикл
        БуферКласса.Добавить(Х % 256);
        Х = Цел(Х / 256);
    КонецЦикла;
    Возврат ЭтотОбъект;
КонецФункции

// Записывает fixed64 (8 байт, little-endian).
Функция ЗаписатьFixed64(Значение) Экспорт
    Х = Значение;
    Для сч = 0 По 7 Цикл
        БуферКласса.Добавить(Х % 256);
        Х = Цел(Х / 256);
    КонецЦикла;
    Возврат ЭтотОбъект;
КонецФункции

// Записывает sfixed64 - знаковое 64-битное целое (8 байт, little-endian, two's complement).
// Используется для полей protobuf типа sfixed64 (например, as_int в NumberDataPoint).
//
// Параметры:
//   Значение - Число - знаковое 64-битное целое
//
// Возвращаемое значение:
//   ОтелПротоПисатель - этот объект для chaining
//
Функция ЗаписатьSFixed64(Значение) Экспорт
    Если Значение < 0 Тогда
        БеззнаковоеЗначение = Значение + 18446744073709551616;
    Иначе
        БеззнаковоеЗначение = Значение;
    КонецЕсли;
    ЗаписатьFixed64(БеззнаковоеЗначение);
    Возврат ЭтотОбъект;
КонецФункции

// Записывает double (IEEE754 little-endian, 8 байт).
// Для нуля записывает 8 нулевых байт.
// Для нормальных чисел использует Log/Pow для вычисления показателя степени и мантиссы.
// Примечание: результат для чисел, не имеющих точного представления в float64 (например 0.1),
// может отличаться от C# (double)0.1 на 1 ULP из-за более точного Decimal в OneScript.
//
// Параметры:
//   ЗначениеЗнач - Число - значение double
//
// Возвращаемое значение:
//   ОтелПротоПисатель - этот объект для chaining
//
Функция ЗаписатьDouble(ЗначениеЗнач) Экспорт
    // Ноль - все байты нулевые
    Если ЗначениеЗнач = 0 Тогда
        Для Счетчик = 0 По 7 Цикл
            БуферКласса.Добавить(0);
        КонецЦикла;
        Возврат ЭтотОбъект;
    КонецЕсли;

    // Знак
    Знак = 0;
    АбсЗначение = ЗначениеЗнач;
    Если ЗначениеЗнач < 0 Тогда
        Знак = 1;
        АбсЗначение = -ЗначениеЗнач;
    КонецЕсли;

    // Вычисляем показатель степени как floor(log2(x)).
    // Цел() усекает к нулю, поэтому для отрицательных дробных log2
    // нужна дополнительная проверка (например, log2(0.1) = -3.32, Цел = -3, нужен -4).
    ЛогДва = Log(2);
    ПоказательСтепени = Цел(Log(АбсЗначение) / ЛогДва);
    Если АбсЗначение < Pow(2, ПоказательСтепени) Тогда
        ПоказательСтепени = ПоказательСтепени - 1;
    КонецЕсли;

    // Мантисса: нормализованная дробная часть в [0, 1)
    МантиссаДробная = АбсЗначение / Pow(2, ПоказательСтепени) - 1;
    // Защита от ошибок округления Log/Pow
    Если МантиссаДробная < 0 Тогда
        МантиссаДробная = 0;
    КонецЕсли;
    Если МантиссаДробная >= 1 Тогда
        МантиссаДробная = 0;
        ПоказательСтепени = ПоказательСтепени + 1;
    КонецЕсли;

    // 52-битная целая мантисса (2^52 = 4503599627370496)
    МантиссаЦелая = Цел(МантиссаДробная * 4503599627370496);

    // Смещённый показатель (bias = 1023)
    СмещениеПоказателя = 1023;
    СмещенныйПоказатель = ПоказательСтепени + СмещениеПоказателя;

    // Ограничиваем диапазон: [1, 2046] для нормальных чисел
    // (0 - денормальные/ноль, 2047 - бесконечность/NaN)
    МаксПоказатель = 2046;
    Если СмещенныйПоказатель < 1 Тогда
        // Число слишком маленькое - кодируем как +0.0
        Лог.Предупреждение("ЗаписатьDouble: значение %1 вне диапазона IEEE754, записываем 0.0", ЗначениеЗнач);
        Для Счетчик = 0 По 7 Цикл
            БуферКласса.Добавить(0);
        КонецЦикла;
        Возврат ЭтотОбъект;
    ИначеЕсли СмещенныйПоказатель > МаксПоказатель Тогда
        // Число слишком большое - кодируем как ±∞
        Лог.Предупреждение("ЗаписатьDouble: значение %1 переполняет IEEE754 double, записываем ±Inf", ЗначениеЗнач);
        МантиссаЦелая = 0;
        СмещенныйПоказатель = 2047;
    КонецЕсли;

    // Собираем 64-битное значение: sign(1) | exp(11) | mantissa(52)
    // В little-endian: mantissa(52 бит) занимает байты 0-6 (с перекрытием), exp и sign в байте 7
    // Итого: ЦелоеЗначение = sign * 2^63 + exp * 2^52 + mantissa
    МаксUint63 = 9223372036854775808; // 2^63
    МаксUint52 = 4503599627370496;    // 2^52
    ЦелоеЗначение = Знак * МаксUint63 + СмещенныйПоказатель * МаксUint52 + МантиссаЦелая;

    // Записываем 8 байт little-endian
    Для Счетчик = 0 По 7 Цикл
        БуферКласса.Добавить(ЦелоеЗначение % 256);
        ЦелоеЗначение = Цел(ЦелоеЗначение / 256);
    КонецЦикла;

    Возврат ЭтотОбъект;
КонецФункции

// Записывает length-delimited поле (строка, bytes, вложенное сообщение).
// Первым пишется varint длины, затем данные.
Функция ЗаписатьLengthDelimited(Данные) Экспорт
    ДлинаДанных = Данные.Размер();
    ЗаписатьUInt64Varint(ДлинаДанных);
    
    БуферДлячтения = Новый БуферДвоичныхДанных(ДлинаДанных);
    Поток = Данные.ОткрытьПотокДляЧтения();
    Поток.Прочитать(БуферДлячтения, 0, ДлинаДанных);
    Поток.Закрыть();
    
    Для сч = 0 По ДлинаДанных - 1 Цикл
        БуферКласса.Добавить(БуферДлячтения.Получить(сч));
    КонецЦикла;
    Возврат ЭтотОбъект;
КонецФункции

// Записывает UTF-8 строку в виде length-delimited (varint + UTF-8 bytes).
Функция ЗаписатьСтроку(Строка_) Экспорт
    ДвоичныеДанные = ПолучитьДвоичныеДанныеИзСтроки(Строка_, "UTF-8");
    ЗаписатьLengthDelimited(ДвоичныеДанные);
    Возврат ЭтотОбъект;
КонецФункции

// Записывает hex-строку как bytes (без длины, сами байты).
Функция ЗаписатьБайтыИзHex(HexСтрока) Экспорт
    ДвоичныеДанные = ХексВДвоичныеДанные(HexСтрока);
    ЗаписатьLengthDelimited(ДвоичныеДанные);
    Возврат ЭтотОбъект;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПриСозданииОбъекта()
    БуферКласса = Новый Массив();
    Лог = Логирование.ПолучитьЛог("oscript.lib.opentelemetry.proto");
КонецПроцедуры

Функция ХексВДвоичныеДанные(HexСтрока)
    КоличествоБайт = СтрДлина(HexСтрока) / 2;
    БуферХекса = Новый БуферДвоичныхДанных(КоличествоБайт);
    
    ШестнадцатеричнаяТаблица = Новый Соответствие();
    Для сч = 0 По 15 Цикл
        Если сч < 10 Тогда
            ШестнадцатеричнаяТаблица.Вставить(Строка(сч), сч);
        Иначе
            ШестнадцатеричнаяТаблица.Вставить(НРег(Сред("ABCDEF", сч - 9, 1)), сч);
        КонецЕсли;
    КонецЦикла;
    
    Для сч = 0 По КоличествоБайт - 1 Цикл
        Позиция = сч * 2;
        Старший = ШестнадцатеричнаяТаблица.Получить(НРег(Сред(HexСтрока, Позиция + 1, 1)));
        Младший = ШестнадцатеричнаяТаблица.Получить(НРег(Сред(HexСтрока, Позиция + 2, 1)));
        БуферХекса.Установить(сч, Старший * 16 + Младший);
    КонецЦикла;
    
    Поток = Новый ПотокВПамяти(БуферХекса);
    Возврат Поток.ЗакрытьИПолучитьДвоичныеДанные();
КонецФункции

#КонецОбласти
