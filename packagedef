////////////////////////////////////////////////////////////
// Описание пакета для сборки и установки
// Полную документацию см. на hub.oscript.io/packaging
//

Описание.Имя("opentelemetry")
        .Версия("0.1.0")
        .Автор("Nikita Fedkin")
        .АдресАвтора("nixel2007@gmail.com")
        .АдресРепозитория("https://github.com/nixel2007/opentelemetry")
        .Описание("OpenTelemetry SDK для OneScript")
        .ВерсияСреды("2.0.0")
        .ВключитьФайл("src")
        .ВключитьФайл("tests")
        .ВключитьФайл("README.md")

        .ЗависитОт("logos", "1.7.1")
        .ЗависитОт("1connector", "2.2.1")

        .РазработкаЗависитОт("oneunit", "0.2.4")
        .РазработкаЗависитОт("asserts", "1.5.0")

        // Ядро
        .ОпределяетКласс("ОтелАтрибуты", "src/Классы/ОтелАтрибуты.os")
        .ОпределяетКласс("ОтелРесурс", "src/Классы/ОтелРесурс.os")
        .ОпределяетКласс("ОтелКонтекстСпана", "src/Классы/ОтелКонтекстСпана.os")
        .ОпределяетКласс("ОтелСобытиеСпана", "src/Классы/ОтелСобытиеСпана.os")

        // Трассировка
        .ОпределяетКласс("ОтелПровайдерТрассировки", "src/Классы/ОтелПровайдерТрассировки.os")
        .ОпределяетКласс("ОтелТрассировщик", "src/Классы/ОтелТрассировщик.os")
        .ОпределяетКласс("ОтелСпан", "src/Классы/ОтелСпан.os")
        .ОпределяетКласс("ОтелПростойПроцессорСпанов", "src/Классы/ОтелПростойПроцессорСпанов.os")

        // Логирование
        .ОпределяетКласс("ОтелПровайдерЛогирования", "src/Классы/ОтелПровайдерЛогирования.os")
        .ОпределяетКласс("ОтелЛоггер", "src/Классы/ОтелЛоггер.os")
        .ОпределяетКласс("ОтелЗаписьЛога", "src/Классы/ОтелЗаписьЛога.os")

        // Метрики
        .ОпределяетКласс("ОтелПровайдерМетрик", "src/Классы/ОтелПровайдерМетрик.os")
        .ОпределяетКласс("ОтелМетрика", "src/Классы/ОтелМетрика.os")
        .ОпределяетКласс("ОтелСчетчик", "src/Классы/ОтелСчетчик.os")
        .ОпределяетКласс("ОтелГистограмма", "src/Классы/ОтелГистограмма.os")

        // Экспортеры
        .ОпределяетКласс("ОтелHttpТранспорт", "src/Классы/ОтелHttpТранспорт.os")
        .ОпределяетКласс("ОтелHttpЭкспортерСпанов", "src/Классы/ОтелHttpЭкспортерСпанов.os")
        .ОпределяетКласс("ОтелHttpЭкспортерЛогов", "src/Классы/ОтелHttpЭкспортерЛогов.os")
        .ОпределяетКласс("ОтелHttpЭкспортерМетрик", "src/Классы/ОтелHttpЭкспортерМетрик.os")

        // Интеграция с logos
        .ОпределяетКласс("ОтелАппендерLogos", "src/Классы/ОтелАппендерLogos.os")
        ;
